<?php
/**
 * Accounting Manager Class
 * كلاس إدارة المحاسبة
 * 
 * @charset UTF-8
 * @version 1.0
 * @author Real Estate System
 */

include_once dirname(__DIR__) . "/schema_migrations.hnt";

class AccountingManager {
    private $db;
    private $userId;
    private $fiscalYear;
    private $schemaMigrationErrors = [];
    private $propertyMetadataCache = [];
    private $tenantNameCache = [];
    
    public function __construct($db, $userId) {
        if (!$db) {
            die("Database connection error: \$db is null. Please check connectdb.hnt is included properly.");
        }
        $this->db = $db;
        $this->userId = $userId;
        $migrationResult = runAccountingSchemaMigrations($this->db);
        if (!$migrationResult['success']) {
            $this->schemaMigrationErrors = $migrationResult['errors'] ?? [$migrationResult['message'] ?? 'Schema migration error'];
        }
        $this->fiscalYear = $this->getCurrentFiscalYear();
    }

    public function getSchemaMigrationErrors() {
        return $this->schemaMigrationErrors;
    }
    
    // ============================================
    // Chart of Accounts Methods
    // دليل الحسابات
    // ============================================
    
    /**
     * Create new account
     * إنشاء حساب جديد
     */
    public function createAccount($data) {
        if (empty($data['account_type'])) {
            return [
                'success' => false, 
                'error' => 'Account type is required',
                'message' => 'نوع الحساب مطلوب. يرجى اختيار نوع الحساب'
            ];
        }
        
        $accountLevel = 1;
        if (!empty($data['parent_account_id'])) {
            $parentStmt = $this->db->prepare("SELECT account_level, is_leaf FROM acc_chart_of_accounts WHERE account_id = ?");
            $parentStmt->bind_param("i", $data['parent_account_id']);
            $parentStmt->execute();
            $parent = $parentStmt->get_result()->fetch_assoc();
            
            if ($parent) {
                $accountLevel = $parent['account_level'] + 1;
                
                if ($parent['is_leaf'] == 1) {
                    $this->db->query("UPDATE acc_chart_of_accounts SET is_leaf = 0 WHERE account_id = {$data['parent_account_id']}");
                }
            }
        }
        
        $stmt = $this->db->prepare("
            INSERT INTO acc_chart_of_accounts 
            (account_code, account_name_ar, account_name_en, parent_account_id, 
             account_type, account_category, account_level, is_leaf, 
             opening_balance, is_active, vat_applicable, description, 
             created_by, formuid)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, UUID())
        ");
        
        $stmt->bind_param("sssississdiss",
            $data['account_code'],
            $data['account_name_ar'],
            $data['account_name_en'],
            $data['parent_account_id'],
            $data['account_type'],
            $data['account_category'],
            $accountLevel,
            $data['is_leaf'],
            $data['opening_balance'],
            $data['is_active'],
            $data['vat_applicable'],
            $data['description'],
            $this->userId
        );
        
        if ($stmt->execute()) {
            $accountId = $stmt->insert_id;
            $this->logAudit('create', 'account', $accountId, null, $data);
            return ['success' => true, 'account_id' => $accountId];
        }
        
        $error = $stmt->error;
        $errorMessage = 'فشل في إنشاء الحساب';
        
        if (strpos($error, 'Duplicate entry') !== false && strpos($error, 'idx_code') !== false) {
            preg_match("/Duplicate entry '([^']+)'/", $error, $matches);
            $duplicateCode = $matches[1] ?? $data['account_code'];
            $errorMessage = "رمز الحساب '{$duplicateCode}' موجود بالفعل. يرجى استخدام رمز مختلف";
        }
        
        return ['success' => false, 'error' => $error, 'message' => $errorMessage];
    }

    /**
     * Update account
     * تحديث حساب
     */
    public function updateAccount($accountId, $data) {
        $accountId = (int)$accountId;
        if ($accountId <= 0) {
            return ['success' => false, 'message' => 'رقم الحساب غير صالح'];
        }

        if (empty($data['account_type'])) {
            return [
                'success' => false,
                'error' => 'Account type is required',
                'message' => 'نوع الحساب مطلوب. يرجى اختيار نوع الحساب'
            ];
        }

        $currentAccount = $this->getAccount($accountId);
        if (!$currentAccount) {
            return ['success' => false, 'message' => 'الحساب غير موجود'];
        }

        $parentAccountId = !empty($data['parent_account_id']) ? (int)$data['parent_account_id'] : null;
        if ($parentAccountId === $accountId) {
            return ['success' => false, 'message' => 'لا يمكن اختيار نفس الحساب كحساب رئيسي'];
        }

        $accountLevel = 1;
        if ($parentAccountId) {
            $parentStmt = $this->db->prepare("SELECT account_level, is_leaf FROM acc_chart_of_accounts WHERE account_id = ?");
            $parentStmt->bind_param("i", $parentAccountId);
            $parentStmt->execute();
            $parent = $parentStmt->get_result()->fetch_assoc();

            if (!$parent) {
                return ['success' => false, 'message' => 'الحساب الرئيسي المحدد غير موجود'];
            }

            $accountLevel = (int)$parent['account_level'] + 1;

            if ((int)$parent['is_leaf'] === 1) {
                $updateParentStmt = $this->db->prepare("UPDATE acc_chart_of_accounts SET is_leaf = 0 WHERE account_id = ?");
                $updateParentStmt->bind_param("i", $parentAccountId);
                $updateParentStmt->execute();
            }
        }

        $childCountStmt = $this->db->prepare("SELECT COUNT(*) AS child_count FROM acc_chart_of_accounts WHERE parent_account_id = ?");
        $childCountStmt->bind_param("i", $accountId);
        $childCountStmt->execute();
        $childCount = (int)($childCountStmt->get_result()->fetch_assoc()['child_count'] ?? 0);
        $isLeaf = $childCount > 0 ? 0 : (int)($data['is_leaf'] ?? 1);

        $stmt = $this->db->prepare(" 
            UPDATE acc_chart_of_accounts
            SET account_code = ?,
                account_name_ar = ?,
                account_name_en = ?,
                parent_account_id = ?,
                account_type = ?,
                account_category = ?,
                account_level = ?,
                is_leaf = ?,
                opening_balance = ?,
                vat_applicable = ?,
                description = ?
            WHERE account_id = ?
        ");

        $stmt->bind_param(
            "sssissiidisi",
            $data['account_code'],
            $data['account_name_ar'],
            $data['account_name_en'],
            $parentAccountId,
            $data['account_type'],
            $data['account_category'],
            $accountLevel,
            $isLeaf,
            $data['opening_balance'],
            $data['vat_applicable'],
            $data['description'],
            $accountId
        );

        if ($stmt->execute()) {
            $oldParentAccountId = !empty($currentAccount['parent_account_id']) ? (int)$currentAccount['parent_account_id'] : null;
            if ($oldParentAccountId && $oldParentAccountId !== $parentAccountId) {
                $oldParentCountStmt = $this->db->prepare("SELECT COUNT(*) AS child_count FROM acc_chart_of_accounts WHERE parent_account_id = ?");
                $oldParentCountStmt->bind_param("i", $oldParentAccountId);
                $oldParentCountStmt->execute();
                $oldParentChildCount = (int)($oldParentCountStmt->get_result()->fetch_assoc()['child_count'] ?? 0);
                $oldParentIsLeaf = $oldParentChildCount > 0 ? 0 : 1;

                $oldParentUpdateStmt = $this->db->prepare("UPDATE acc_chart_of_accounts SET is_leaf = ? WHERE account_id = ?");
                $oldParentUpdateStmt->bind_param("ii", $oldParentIsLeaf, $oldParentAccountId);
                $oldParentUpdateStmt->execute();
            }

            $this->logAudit('update', 'account', $accountId, $currentAccount, $data);
            return ['success' => true, 'account_id' => $accountId];
        }

        $error = $stmt->error;
        $errorMessage = 'فشل في تحديث الحساب';

        if (strpos($error, 'Duplicate entry') !== false && strpos($error, 'idx_code') !== false) {
            preg_match("/Duplicate entry '([^']+)'/", $error, $matches);
            $duplicateCode = $matches[1] ?? $data['account_code'];
            $errorMessage = "رمز الحساب '{$duplicateCode}' موجود بالفعل. يرجى استخدام رمز مختلف";
        }

        return ['success' => false, 'error' => $error, 'message' => $errorMessage];
    }
    
    /**
     * Get account by ID
     * الحصول على حساب
     */
    public function getAccount($accountId) {
        $stmt = $this->db->prepare("SELECT * FROM acc_chart_of_accounts WHERE account_id = ?");
        $stmt->bind_param("i", $accountId);
        $stmt->execute();
        return $stmt->get_result()->fetch_assoc();
    }
    
    /**
     * Get all accounts with filters
     * الحصول على جميع الحسابات
     */
    public function getAllAccounts($filters = []) {
        $sql = "SELECT * FROM acc_chart_of_accounts WHERE 1=1";
        $params = [];
        $types = "";
        
        if (isset($filters['account_type'])) {
            $sql .= " AND account_type = ?";
            $params[] = $filters['account_type'];
            $types .= "s";
        }
        
        if (isset($filters['is_active'])) {
            $sql .= " AND is_active = ?";
            $params[] = $filters['is_active'];
            $types .= "i";
        }
        
        if (isset($filters['is_leaf'])) {
            $sql .= " AND is_leaf = ?";
            $params[] = $filters['is_leaf'];
            $types .= "i";
        }

        if (isset($filters['account_category'])) {
            $sql .= " AND account_category = ?";
            $params[] = $filters['account_category'];
            $types .= "s";
        }
        
        $sql .= " ORDER BY account_code";
        
        $stmt = $this->db->prepare($sql);
        if (!empty($params)) {
            $stmt->bind_param($types, ...$params);
        }
        $stmt->execute();
        
        $result = $stmt->get_result();
        $accounts = [];
        while ($row = $result->fetch_assoc()) {
            $accounts[] = $row;
        }
        
        return $accounts;
    }

    public function getActiveCustomers() {
        $customers = [];
        $result = $this->db->query("SELECT customer_id, customer_name, customer_code FROM acc_customers WHERE is_active = 1 ORDER BY customer_name ASC");
        if ($result) {
            while ($row = $result->fetch_assoc()) {
                $customers[] = $row;
            }
        }

        return $customers;
    }

    public function getCashBankAccounts() {
        return $this->getAllAccounts([
            'account_type' => 'asset',
            'is_active' => 1,
            'is_leaf' => 1,
            'account_category' => 'cash'
        ]);
    }
    
    /**
     * Get account balance
     * الحصول على رصيد الحساب
     */
    public function getAccountBalance($accountId, $date = null) {
        if (!$date) {
            $date = date('Y-m-d');
        }
        
        $sql = "SELECT 
                    COALESCE(SUM(debit_amount), 0) as total_debit,
                    COALESCE(SUM(credit_amount), 0) as total_credit
                FROM acc_journal_entry_lines jel
                JOIN acc_journal_entries je ON jel.entry_id = je.entry_id
                WHERE jel.account_id = ? 
                AND je.status = 'posted'
                AND je.entry_date <= ?";
        
        $stmt = $this->db->prepare($sql);
        $stmt->bind_param("is", $accountId, $date);
        $stmt->execute();
        $result = $stmt->get_result()->fetch_assoc();
        
        // Get account type to determine balance calculation
        $account = $this->getAccount($accountId);
        $balance = 0;
        
        if (in_array($account['account_type'], ['asset', 'expense'])) {
            // Debit balance accounts
            $balance = $result['total_debit'] - $result['total_credit'];
        } else {
            // Credit balance accounts (liability, equity, revenue)
            $balance = $result['total_credit'] - $result['total_debit'];
        }
        
        return $balance + $account['opening_balance'];
    }
    
    // ============================================
    // Journal Entry Methods
    // القيود اليومية
    // ============================================
    
    /**
     * Create journal entry
     * إنشاء قيد يومية
     */
    public function createJournalEntry($data, $lines) {
        // Validate totals
        $totalDebit = array_sum(array_column($lines, 'debit_amount'));
        $totalCredit = array_sum(array_column($lines, 'credit_amount'));
        
        if (abs($totalDebit - $totalCredit) > 0.01) {
            return ['success' => false, 'error' => 'القيد غير متوازن: المدين لا يساوي الدائن'];
        }
        
        // Generate entry number
        $entryNumber = $this->generateEntryNumber();

        $journalId = isset($data['journal_id']) && $data['journal_id'] !== '' ? (int)$data['journal_id'] : null;
        if ($journalId) {
            $journalCheck = $this->db->prepare("SELECT journal_id FROM acc_journals WHERE journal_id = ? AND is_active = 1 LIMIT 1");
            if (!$journalCheck) {
                return ['success' => false, 'error' => $this->db->error, 'message' => 'فشل في التحقق من دفتر اليومية'];
            }
            $journalCheck->bind_param("i", $journalId);
            $journalCheck->execute();
            $journalExists = $journalCheck->get_result()->fetch_assoc();
            $journalCheck->close();
            if (!$journalExists) {
                return ['success' => false, 'error' => 'Invalid journal', 'message' => 'دفتر اليومية المحدد غير موجود أو غير نشط'];
            }
        }

        $tenantId = isset($data['tenant_id']) && $data['tenant_id'] !== '' ? (int)$data['tenant_id'] : null;
        $ownerId = isset($data['owner_id']) && $data['owner_id'] !== '' ? (int)$data['owner_id'] : null;
        $aqarId = isset($data['aqar_id']) && $data['aqar_id'] !== '' ? (int)$data['aqar_id'] : null;
        $subaqarId = isset($data['subaqar_id']) && $data['subaqar_id'] !== '' ? (int)$data['subaqar_id'] : null;
        $egarId = isset($data['egar_id']) && $data['egar_id'] !== '' ? (int)$data['egar_id'] : null;
        $sanadId = isset($data['sanad_id']) && $data['sanad_id'] !== '' ? (int)$data['sanad_id'] : null;
        $masrofatId = isset($data['masrofat_id']) && $data['masrofat_id'] !== '' ? (int)$data['masrofat_id'] : null;
        $invoiceId = isset($data['invoice_id']) && $data['invoice_id'] !== '' ? (int)$data['invoice_id'] : null;
        
        // Insert entry header
        $requestedStatus = $data['status'] ?? 'draft';
        $status = $requestedStatus == 'posted' ? 'draft' : $requestedStatus;
        $stmt = $this->db->prepare("
            INSERT INTO acc_journal_entries 
            (entry_number, entry_date, entry_type, journal_id, tenant_id, owner_id,
             aqar_id, subaqar_id, egar_id, sanad_id, masrofat_id, invoice_id,
             reference_type, reference_id, description, total_debit, total_credit,
             fiscal_year, fiscal_period, status, created_by, formuid)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, UUID())
        ");

        if (!$stmt) {
            return ['success' => false, 'error' => $this->db->error, 'message' => 'فشل في تجهيز القيد المحاسبي'];
        }
        
        $fiscalPeriod = (int)date('m', strtotime($data['entry_date']));
        
        $stmt->bind_param("sssiiiiiiiiisisddiisi",
            $entryNumber,
            $data['entry_date'],
            $data['entry_type'],
            $journalId,
            $tenantId,
            $ownerId,
            $aqarId,
            $subaqarId,
            $egarId,
            $sanadId,
            $masrofatId,
            $invoiceId,
            $data['reference_type'],
            $data['reference_id'],
            $data['description'],
            $totalDebit,
            $totalCredit,
            $this->fiscalYear,
            $fiscalPeriod,
            $status,
            $this->userId
        );
        
        if (!$stmt->execute()) {
            return ['success' => false, 'error' => $stmt->error];
        }
        
        $entryId = $stmt->insert_id;
        
        // Insert entry lines
        foreach ($lines as $index => $line) {
            $stmt = $this->db->prepare("
                INSERT INTO acc_journal_entry_lines
                (entry_id, account_id, line_number, description,
                 debit_amount, credit_amount, cost_center_id, formuid)
                VALUES (?, ?, ?, ?, ?, ?, ?, UUID())
            ");

            if (!$stmt) {
                $this->db->query("DELETE FROM acc_journal_entries WHERE entry_id = $entryId");
                return ['success' => false, 'error' => $this->db->error, 'message' => 'فشل في تجهيز بنود القيد'];
            }
            
            $lineNumber = $index + 1;
            $costCenterId = isset($line['cost_center_id']) && $line['cost_center_id'] !== '' ? (int)$line['cost_center_id'] : null;
            $stmt->bind_param("iiisddi",
                $entryId,
                $line['account_id'],
                $lineNumber,
                $line['description'],
                $line['debit_amount'],
                $line['credit_amount'],
                $costCenterId
            );
            
            if (!$stmt->execute()) {
                // Rollback - delete entry
                $this->db->query("DELETE FROM acc_journal_entries WHERE entry_id = $entryId");
                return ['success' => false, 'error' => $stmt->error];
            }
        }
        
        // Auto-post if requested
        if ($requestedStatus == 'posted') {
            $postResult = $this->postJournalEntry($entryId);
            if (!$postResult['success']) {
                $this->db->query("DELETE FROM acc_journal_entry_lines WHERE entry_id = $entryId");
                $this->db->query("DELETE FROM acc_journal_entries WHERE entry_id = $entryId");
                return ['success' => false, 'error' => $postResult['error'] ?? 'لا يمكن ترحيل القيد'];
            }
        }
        
        $this->logAudit('create', 'journal_entry', $entryId, null, $data);
        
        return ['success' => true, 'entry_id' => $entryId, 'entry_number' => $entryNumber];
    }
    
    /**
     * Post journal entry
     * ترحيل قيد اليومية
     */
    public function postJournalEntry($entryId) {
        // Update entry status
        $stmt = $this->db->prepare("
            UPDATE acc_journal_entries 
            SET status = 'posted', posted_date = NOW(), posted_by = ?
            WHERE entry_id = ? AND status = 'draft'
        ");
        $stmt->bind_param("ii", $this->userId, $entryId);
        
        if ($stmt->execute() && $stmt->affected_rows > 0) {
            // Update account balances
            $this->updateAccountBalances($entryId);
            $this->logAudit('post', 'journal_entry', $entryId, ['status' => 'draft'], ['status' => 'posted']);
            return ['success' => true];
        }
        
        return ['success' => false, 'error' => 'لا يمكن ترحيل القيد'];
    }
    
    /**
     * Update account balances from journal entry
     * تحديث أرصدة الحسابات
     */
    private function updateAccountBalances($entryId) {
        $sql = "SELECT account_id, 
                       SUM(debit_amount) as debit, 
                       SUM(credit_amount) as credit
                FROM acc_journal_entry_lines
                WHERE entry_id = ?
                GROUP BY account_id";
        
        $stmt = $this->db->prepare($sql);
        $stmt->bind_param("i", $entryId);
        $stmt->execute();
        $result = $stmt->get_result();
        
        while ($row = $result->fetch_assoc()) {
            $account = $this->getAccount($row['account_id']);
            $change = 0;
            
            if (in_array($account['account_type'], ['asset', 'expense'])) {
                $change = $row['debit'] - $row['credit'];
            } else {
                $change = $row['credit'] - $row['debit'];
            }
            
            $this->db->query("
                UPDATE acc_chart_of_accounts 
                SET current_balance = current_balance + $change
                WHERE account_id = {$row['account_id']}
            ");
        }
    }
    
    /**
     * Generate entry number
     * توليد رقم القيد
     */
    private function generateEntryNumber() {
        $prefix = $this->getSetting('journal_prefix', 'JE');
        $year = date('Y');
        
        $result = $this->db->query("
            SELECT MAX(CAST(SUBSTRING(entry_number, LENGTH('$prefix-$year-') + 1) AS UNSIGNED)) as max_num
            FROM acc_journal_entries
            WHERE entry_number LIKE '$prefix-$year-%'
        ");
        
        $row = $result->fetch_assoc();
        $nextNum = ($row['max_num'] ?? 0) + 1;
        
        return sprintf("%s-%s-%05d", $prefix, $year, $nextNum);
    }

    public function getActiveJournals() {
        $journals = [];
        $result = $this->db->query("SELECT journal_id, journal_code, journal_name_ar, journal_name_en, journal_type FROM acc_journals WHERE is_active = 1 ORDER BY journal_code ASC");
        if ($result) {
            while ($row = $result->fetch_assoc()) {
                $journals[] = $row;
            }
        }

        return $journals;
    }

    public function getDefaultJournalIdByCode($journalCode) {
        $stmt = $this->db->prepare("SELECT journal_id FROM acc_journals WHERE journal_code = ? AND is_active = 1 LIMIT 1");
        if (!$stmt) {
            return null;
        }

        $stmt->bind_param("s", $journalCode);
        $stmt->execute();
        $result = $stmt->get_result()->fetch_assoc();
        $stmt->close();

        return $result['journal_id'] ?? null;
    }

    public function getActiveCostCenters() {
        $costCenters = [];
        $result = $this->db->query("SELECT cost_center_id, cost_center_code, cost_center_name_ar, cost_center_name_en, aqar_id, subaqar_id FROM acc_cost_centers WHERE is_active = 1 ORDER BY cost_center_code ASC");
        if ($result) {
            while ($row = $result->fetch_assoc()) {
                $costCenters[] = $row;
            }
        }

        return $costCenters;
    }

    public function getCostCenterByAqarId($aqarId) {
        $aqarId = (int)$aqarId;
        if ($aqarId <= 0) {
            return null;
        }

        $stmt = $this->db->prepare("SELECT * FROM acc_cost_centers WHERE aqar_id = ? ORDER BY cost_center_id ASC LIMIT 1");
        if (!$stmt) {
            return null;
        }

        $stmt->bind_param("i", $aqarId);
        $stmt->execute();
        $result = $stmt->get_result()->fetch_assoc();
        $stmt->close();

        return $result ?: null;
    }

    public function ensurePropertyCostCenter($aqarId, $propertyName, $subaqarId = null) {
        $aqarId = (int)$aqarId;
        $subaqarId = !empty($subaqarId) ? (int)$subaqarId : null;
        if ($aqarId <= 0) {
            return ['success' => false, 'message' => 'رقم العقار غير صالح'];
        }

        $existing = $this->getCostCenterByAqarId($aqarId);
        if ($existing) {
            return ['success' => true, 'cost_center' => $existing, 'created' => false];
        }

        $costCenterCode = 'AQR-' . str_pad((string)$aqarId, 5, '0', STR_PAD_LEFT);
        $costCenterName = trim((string)$propertyName) !== '' ? trim((string)$propertyName) : ('عقار رقم ' . $aqarId);

        $stmt = $this->db->prepare("INSERT INTO acc_cost_centers (cost_center_code, cost_center_name_ar, cost_center_name_en, parent_cost_center_id, aqar_id, subaqar_id, is_active, formuid) VALUES (?, ?, ?, NULL, ?, ?, 1, UUID())");
        if (!$stmt) {
            return ['success' => false, 'message' => 'فشل في تجهيز مركز التكلفة: ' . $this->db->error];
        }

        $costCenterNameEn = $costCenterName;
        $stmt->bind_param("sssii", $costCenterCode, $costCenterName, $costCenterNameEn, $aqarId, $subaqarId);

        if (!$stmt->execute()) {
            $error = $stmt->error;
            $stmt->close();

            if (strpos($error, 'Duplicate entry') !== false) {
                $existing = $this->getCostCenterByAqarId($aqarId);
                if ($existing) {
                    return ['success' => true, 'cost_center' => $existing, 'created' => false];
                }
            }

            return ['success' => false, 'message' => 'فشل في إنشاء مركز التكلفة: ' . $error];
        }

        $costCenterId = $stmt->insert_id;
        $stmt->close();

        return [
            'success' => true,
            'created' => true,
            'cost_center' => [
                'cost_center_id' => $costCenterId,
                'cost_center_code' => $costCenterCode,
                'cost_center_name_ar' => $costCenterName,
                'cost_center_name_en' => $costCenterNameEn,
                'aqar_id' => $aqarId,
                'subaqar_id' => $subaqarId
            ]
        ];
    }

    public function getJournals($activeOnly = false) {
        $journals = [];
        $sql = "SELECT * FROM acc_journals";
        if ($activeOnly) {
            $sql .= " WHERE is_active = 1";
        }
        $sql .= " ORDER BY journal_code ASC, journal_id ASC";

        $result = $this->db->query($sql);
        if ($result) {
            while ($row = $result->fetch_assoc()) {
                $journals[] = $row;
            }
        }

        return $journals;
    }

    public function getJournal($journalId) {
        $journalId = (int)$journalId;
        if ($journalId <= 0) {
            return null;
        }

        $stmt = $this->db->prepare("SELECT * FROM acc_journals WHERE journal_id = ? LIMIT 1");
        if (!$stmt) {
            return null;
        }

        $stmt->bind_param("i", $journalId);
        $stmt->execute();
        $result = $stmt->get_result()->fetch_assoc();
        $stmt->close();

        return $result ?: null;
    }

    public function saveJournal($data, $journalId = null) {
        $journalCode = trim((string)($data['journal_code'] ?? ''));
        $journalNameAr = trim((string)($data['journal_name_ar'] ?? ''));
        $journalNameEn = trim((string)($data['journal_name_en'] ?? ''));
        $journalType = trim((string)($data['journal_type'] ?? 'general'));
        $isActive = isset($data['is_active']) ? (int)$data['is_active'] : 1;

        if ($journalCode === '') {
            return ['success' => false, 'message' => 'رمز دفتر اليومية مطلوب'];
        }

        if ($journalNameAr === '') {
            return ['success' => false, 'message' => 'اسم دفتر اليومية بالعربية مطلوب'];
        }

        if ($journalId) {
            $stmt = $this->db->prepare("UPDATE acc_journals SET journal_code = ?, journal_name_ar = ?, journal_name_en = ?, journal_type = ?, is_active = ? WHERE journal_id = ?");
            if (!$stmt) {
                return ['success' => false, 'message' => 'فشل في تجهيز تحديث دفتر اليومية: ' . $this->db->error];
            }
            $journalId = (int)$journalId;
            $stmt->bind_param("ssssii", $journalCode, $journalNameAr, $journalNameEn, $journalType, $isActive, $journalId);
        } else {
            $stmt = $this->db->prepare("INSERT INTO acc_journals (journal_code, journal_name_ar, journal_name_en, journal_type, is_active, formuid) VALUES (?, ?, ?, ?, ?, UUID())");
            if (!$stmt) {
                return ['success' => false, 'message' => 'فشل في تجهيز إضافة دفتر اليومية: ' . $this->db->error];
            }
            $stmt->bind_param("ssssi", $journalCode, $journalNameAr, $journalNameEn, $journalType, $isActive);
        }

        if (!$stmt->execute()) {
            $error = $stmt->error;
            $stmt->close();
            if (strpos($error, 'Duplicate entry') !== false) {
                return ['success' => false, 'message' => 'رمز دفتر اليومية مستخدم بالفعل'];
            }
            return ['success' => false, 'message' => 'فشل في حفظ دفتر اليومية: ' . $error];
        }

        $savedId = $journalId ?: $stmt->insert_id;
        $stmt->close();

        return ['success' => true, 'journal_id' => $savedId];
    }

    public function toggleJournalStatus($journalId) {
        $journal = $this->getJournal($journalId);
        if (!$journal) {
            return ['success' => false, 'message' => 'دفتر اليومية غير موجود'];
        }

        $newStatus = $journal['is_active'] ? 0 : 1;
        $stmt = $this->db->prepare("UPDATE acc_journals SET is_active = ? WHERE journal_id = ?");
        if (!$stmt) {
            return ['success' => false, 'message' => 'فشل في تجهيز تحديث حالة دفتر اليومية: ' . $this->db->error];
        }

        $journalId = (int)$journalId;
        $stmt->bind_param("ii", $newStatus, $journalId);
        if (!$stmt->execute()) {
            $error = $stmt->error;
            $stmt->close();
            return ['success' => false, 'message' => 'فشل في تحديث حالة دفتر اليومية: ' . $error];
        }
        $stmt->close();

        return ['success' => true, 'is_active' => $newStatus];
    }

