        $newStatus = $costCenter['is_active'] ? 0 : 1;
        $stmt = $this->db->prepare("UPDATE acc_cost_centers SET is_active = ? WHERE cost_center_id = ?");
        if (!$stmt) {
            return ['success' => false, 'message' => 'فشل في تجهيز تحديث حالة مركز التكلفة: ' . $this->db->error];
        }

        $costCenterId = (int)$costCenterId;
        $stmt->bind_param("ii", $newStatus, $costCenterId);
        if (!$stmt->execute()) {
            $error = $stmt->error;
            $stmt->close();
            return ['success' => false, 'message' => 'فشل في تحديث حالة مركز التكلفة: ' . $error];
        }
        $stmt->close();

        return ['success' => true, 'is_active' => $newStatus];
    }

    private function getTenantDisplayName($tenantId) {
        $tenantId = (int)$tenantId;
        if ($tenantId <= 0) {
            return '';
        }

        if (isset($this->tenantNameCache[$tenantId])) {
            return $this->tenantNameCache[$tenantId];
        }

        $tenantName = '';
        $stmt = $this->db->prepare("SELECT mostagername FROM mostagereen WHERE mostagerid = ? LIMIT 1");
        if ($stmt) {
            $stmt->bind_param("i", $tenantId);
            $stmt->execute();
            $row = $stmt->get_result()->fetch_assoc();
            $tenantName = $row['mostagername'] ?? '';
            $stmt->close();
        }

        $this->tenantNameCache[$tenantId] = $tenantName;
        return $tenantName;
    }

    public function getPropertyMetadata($aqarId) {
        $aqarId = (int)$aqarId;
        if ($aqarId <= 0) {
            return [
                'property_id' => 0,
                'property_name' => 'غير محدد',
                'property_type' => 'other'
            ];
        }

        if (isset($this->propertyMetadataCache[$aqarId])) {
            return $this->propertyMetadataCache[$aqarId];
        }

        $propertyName = 'عقار #' . $aqarId;
        $propertyType = 'other';

        $amlakStmt = $this->db->prepare("SELECT aqarname FROM amlak WHERE idaqar = ? LIMIT 1");
        if ($amlakStmt) {
            $amlakStmt->bind_param("i", $aqarId);
            $amlakStmt->execute();
            $amlakRow = $amlakStmt->get_result()->fetch_assoc();
            if (!empty($amlakRow['aqarname'])) {
                $propertyName = $amlakRow['aqarname'];
            }
            $amlakStmt->close();
        }

        $stmt = $this->db->prepare("SELECT emararakam FROM emara WHERE emaraid = ? LIMIT 1");
        if ($stmt) {
            $stmt->bind_param("i", $aqarId);
            $stmt->execute();
            $row = $stmt->get_result()->fetch_assoc();
            if ($row) {
                $propertyType = 'building';
                if ($propertyName === 'عقار #' . $aqarId) {
                    $propertyName = 'عمارة رقم ' . $row['emararakam'];
                }
            }
            $stmt->close();
        }

        if ($propertyType === 'other') {
            $stmt = $this->db->prepare("SELECT ardy_rakam FROM arady WHERE ardyid = ? LIMIT 1");
            if ($stmt) {
                $stmt->bind_param("i", $aqarId);
                $stmt->execute();
                $row = $stmt->get_result()->fetch_assoc();
                if ($row) {
                    $propertyType = 'land';
                    if ($propertyName === 'عقار #' . $aqarId) {
                        $propertyName = 'أرض رقم ' . $row['ardy_rakam'];
                    }
                }
                $stmt->close();
            }
        }

        if ($propertyType === 'other') {
            $stmt = $this->db->prepare("SELECT vilarakam FROM vila WHERE vilaid = ? LIMIT 1");
            if ($stmt) {
                $stmt->bind_param("i", $aqarId);
                $stmt->execute();
                $row = $stmt->get_result()->fetch_assoc();
                if ($row) {
                    $propertyType = 'villa';
                    if ($propertyName === 'عقار #' . $aqarId) {
                        $propertyName = 'فيلا رقم ' . $row['vilarakam'];
                    }
                }
                $stmt->close();
            }
        }

        $metadata = [
            'property_id' => $aqarId,
            'property_name' => $propertyName,
            'property_type' => $propertyType
        ];

        $this->propertyMetadataCache[$aqarId] = $metadata;
        return $metadata;
    }

    private function getPropertyLedgerLines($dateFrom, $dateTo, $accountType, $costCenterId = null, $accountId = null) {
        $sql = "SELECT
                    je.entry_id,
                    je.entry_date,
                    je.description AS entry_description,
                    je.tenant_id,
                    je.owner_id,
                    je.aqar_id,
                    je.subaqar_id,
                    je.journal_id,
                    jel.line_number,
                    jel.description AS line_description,
                    jel.debit_amount,
                    jel.credit_amount,
                    jel.cost_center_id,
                    acc.account_id,
                    acc.account_code,
                    acc.account_name_ar,
                    COALESCE(je.aqar_id, cc.aqar_id) AS property_id,
                    COALESCE(jel.cost_center_id, cc.cost_center_id) AS resolved_cost_center_id,
                    cc.cost_center_code,
                    cc.cost_center_name_ar,
                    j.journal_code,
                    j.journal_name_ar
                FROM acc_journal_entry_lines jel
                INNER JOIN acc_journal_entries je ON jel.entry_id = je.entry_id
                INNER JOIN acc_chart_of_accounts acc ON jel.account_id = acc.account_id
                LEFT JOIN acc_cost_centers cc ON jel.cost_center_id = cc.cost_center_id
                LEFT JOIN acc_journals j ON je.journal_id = j.journal_id
                WHERE je.status = 'posted'
                  AND je.entry_date BETWEEN ? AND ?
                  AND acc.account_type = ?
                  AND COALESCE(je.aqar_id, cc.aqar_id) IS NOT NULL
                  AND COALESCE(je.aqar_id, cc.aqar_id) > 0";

        $types = 'sss';
        $params = [$dateFrom, $dateTo, $accountType];

        if (!empty($costCenterId)) {
            $sql .= " AND jel.cost_center_id = ?";
            $types .= 'i';
            $params[] = (int)$costCenterId;
        }

        if (!empty($accountId)) {
            $sql .= " AND acc.account_id = ?";
            $types .= 'i';
            $params[] = (int)$accountId;
        }

        $sql .= " ORDER BY COALESCE(je.aqar_id, cc.aqar_id), je.entry_date, je.entry_id, jel.line_number";

        $stmt = $this->db->prepare($sql);
        if (!$stmt) {
            return [];
        }

        $stmt->bind_param($types, ...$params);
        $stmt->execute();
        $result = $stmt->get_result()->fetch_all(MYSQLI_ASSOC);
        $stmt->close();

        return $result;
    }

    public function getPropertyRevenueReportData($dateFrom, $dateTo, $costCenterId = null) {
        $lines = $this->getPropertyLedgerLines($dateFrom, $dateTo, 'revenue', $costCenterId);
        $propertyData = [];
        $totals = [
            'rental' => 0,
            'service' => 0,
            'other' => 0,
            'total' => 0
        ];

        foreach ($lines as $line) {
            $amount = (float)$line['credit_amount'] - (float)$line['debit_amount'];
            if ($amount <= 0) {
                continue;
            }

            $propertyId = (int)$line['property_id'];
            $metadata = $this->getPropertyMetadata($propertyId);

            if (!isset($propertyData[$propertyId])) {
                $propertyData[$propertyId] = [
                    'property_id' => $propertyId,
                    'property_name' => $metadata['property_name'],
                    'property_type' => $metadata['property_type'],
                    'revenues' => [],
                    'rental' => 0,
                    'service' => 0,
                    'other' => 0,
                    'total' => 0,
                    'count' => 0
                ];
            }

            $bucket = 'other';
            $accountCode = (string)($line['account_code'] ?? '');
            $accountName = (string)($line['account_name_ar'] ?? '');
            $descriptionText = (string)($line['line_description'] ?: $line['entry_description']);
            $normalizedText = mb_strtolower($accountName . ' ' . $descriptionText);

            if (strpos($accountCode, '4') === 0 || mb_strpos($normalizedText, 'ايجار') !== false || mb_strpos($normalizedText, 'إيجار') !== false) {
                $bucket = 'rental';
            } elseif (mb_strpos($normalizedText, 'خدم') !== false || mb_strpos($normalizedText, 'ماء') !== false || mb_strpos($normalizedText, 'كهرب') !== false || mb_strpos($normalizedText, 'service') !== false) {
                $bucket = 'service';
            }

            $tenantName = $this->getTenantDisplayName($line['tenant_id'] ?? 0);
            $row = [
                'date' => $line['entry_date'],
                'tenant' => $tenantName,
                'description' => $descriptionText,
                'journal' => trim((string)(($line['journal_code'] ?? '') . ' - ' . ($line['journal_name_ar'] ?? '')), ' -'),
                'account_name' => $accountName,
                'cost_center' => trim((string)(($line['cost_center_code'] ?? '') . ' - ' . ($line['cost_center_name_ar'] ?? '')), ' -'),
                'bucket' => $bucket,
                'amount' => $amount
            ];

            $propertyData[$propertyId]['revenues'][] = $row;
            $propertyData[$propertyId][$bucket] += $amount;
            $propertyData[$propertyId]['total'] += $amount;
            $propertyData[$propertyId]['count']++;

            $totals[$bucket] += $amount;
            $totals['total'] += $amount;
        }

        uasort($propertyData, function ($a, $b) {
            return $b['total'] <=> $a['total'];
        });

        return [
            'property_data' => $propertyData,
            'totals' => $totals
        ];
    }

    public function getPropertyExpenseReportData($dateFrom, $dateTo, $costCenterId = null, $expenseAccountId = null) {
        $lines = $this->getPropertyLedgerLines($dateFrom, $dateTo, 'expense', $costCenterId, $expenseAccountId);
        $propertyData = [];
        $totals = ['total' => 0];
        $categoryTotals = [];

        foreach ($lines as $line) {
            $amount = (float)$line['debit_amount'] - (float)$line['credit_amount'];
            if ($amount <= 0) {
                continue;
            }

            $propertyId = (int)$line['property_id'];
            $metadata = $this->getPropertyMetadata($propertyId);
            $category = (string)($line['account_name_ar'] ?: 'غير محدد');

            if (!isset($propertyData[$propertyId])) {
                $propertyData[$propertyId] = [
                    'property_id' => $propertyId,
                    'property_name' => $metadata['property_name'],
                    'property_type' => $metadata['property_type'],
                    'expenses' => [],
                    'total' => 0,
                    'count' => 0,
                    'categories' => []
                ];
            }

            $propertyData[$propertyId]['expenses'][] = [
                'date' => $line['entry_date'],
                'category' => $category,
                'description' => (string)($line['line_description'] ?: $line['entry_description']),
                'paid_by' => trim((string)(($line['journal_code'] ?? '') . ' - ' . ($line['journal_name_ar'] ?? '')), ' -'),
                'cost_center' => trim((string)(($line['cost_center_code'] ?? '') . ' - ' . ($line['cost_center_name_ar'] ?? '')), ' -'),
                'amount' => $amount
            ];

            $propertyData[$propertyId]['total'] += $amount;
            $propertyData[$propertyId]['count']++;

            if (!isset($propertyData[$propertyId]['categories'][$category])) {
                $propertyData[$propertyId]['categories'][$category] = 0;
            }
            $propertyData[$propertyId]['categories'][$category] += $amount;

            if (!isset($categoryTotals[$category])) {
                $categoryTotals[$category] = 0;
            }
            $categoryTotals[$category] += $amount;

            $totals['total'] += $amount;
        }

        uasort($propertyData, function ($a, $b) {
            return $b['total'] <=> $a['total'];
        });
        arsort($categoryTotals);

        return [
            'property_data' => $propertyData,
            'totals' => $totals,
            'category_totals' => $categoryTotals
        ];
    }

    public function getPropertyProfitabilityReportData($dateFrom, $dateTo, $costCenterId = null) {
        $incomeReport = $this->getPropertyRevenueReportData($dateFrom, $dateTo, $costCenterId);
        $expenseReport = $this->getPropertyExpenseReportData($dateFrom, $dateTo, $costCenterId);

        $incomeByProperty = $incomeReport['property_data'];
        $expenseByProperty = $expenseReport['property_data'];
        $propertyIds = array_unique(array_merge(array_keys($incomeByProperty), array_keys($expenseByProperty)));

        $propertyData = [];
        $totals = [
            'income' => 0,
            'expenses' => 0,
            'profit' => 0
        ];

        foreach ($propertyIds as $propertyId) {
            $metadata = $this->getPropertyMetadata((int)$propertyId);
            $income = (float)($incomeByProperty[$propertyId]['total'] ?? 0);
            $expenses = (float)($expenseByProperty[$propertyId]['total'] ?? 0);
            $profit = $income - $expenses;
            $margin = $income > 0 ? ($profit / $income) * 100 : 0;

            $propertyData[$propertyId] = [
                'property_id' => (int)$propertyId,
                'property_name' => $metadata['property_name'],
                'property_type' => $metadata['property_type'],
                'income' => $income,
                'expenses' => $expenses,
                'profit' => $profit,
                'margin' => $margin
            ];

            $totals['income'] += $income;
            $totals['expenses'] += $expenses;
            $totals['profit'] += $profit;
        }

        return [
            'property_data' => $propertyData,
            'totals' => $totals,
            'overall_margin' => $totals['income'] > 0 ? ($totals['profit'] / $totals['income']) * 100 : 0
        ];
    }
    
    // ============================================
    // Invoice Methods
    // الفواتير
    // ============================================
    
    /**
     * Create invoice
     * إنشاء فاتورة
     */
    public function ensureInvoiceDimensionColumnsExist() {
        $dimensionColumns = [
            'journal_id' => "ALTER TABLE acc_invoices ADD COLUMN journal_id INT NULL AFTER due_date",
            'cost_center_id' => "ALTER TABLE acc_invoices ADD COLUMN cost_center_id INT NULL AFTER journal_id",
            'tenant_id' => "ALTER TABLE acc_invoices ADD COLUMN tenant_id INT NULL AFTER cost_center_id",
            'owner_id' => "ALTER TABLE acc_invoices ADD COLUMN owner_id INT NULL AFTER tenant_id",
            'aqar_id' => "ALTER TABLE acc_invoices ADD COLUMN aqar_id INT NULL AFTER owner_id",
            'subaqar_id' => "ALTER TABLE acc_invoices ADD COLUMN subaqar_id INT NULL AFTER aqar_id",
            'egar_id' => "ALTER TABLE acc_invoices ADD COLUMN egar_id INT NULL AFTER subaqar_id"
        ];

        foreach ($dimensionColumns as $columnName => $alterSql) {
            $columnCheck = $this->db->query("SHOW COLUMNS FROM acc_invoices LIKE '{$columnName}'");
            if (!$columnCheck) {
                return false;
            }

            if ($columnCheck->num_rows == 0 && !$this->db->query($alterSql)) {
                return false;
            }
        }

        return true;
    }

    public function createInvoice($data, $items) {
        // Calculate totals
        $subtotal = 0;
        $vatAmount = 0;
        
        foreach ($items as $item) {
            $itemSubtotal = $item['quantity'] * $item['unit_price'];
            $itemVat = $itemSubtotal * ($item['vat_rate'] / 100);
            $subtotal += $itemSubtotal;
            $vatAmount += $itemVat;
        }
        
        $totalAmount = $subtotal + $vatAmount;

        $receivableAccountId = (int)$this->getSetting('default_invoice_receivable_account_id', 0);
        $revenueAccountId = (int)$this->getSetting('default_invoice_revenue_account_id', 0);
        $vatAccountId = (int)$this->getSetting('default_invoice_vat_account_id', 0);

        if ($receivableAccountId <= 0 || $revenueAccountId <= 0 || ($vatAmount > 0 && $vatAccountId <= 0)) {
            return [
                'success' => false,
                'error' => 'Invoice posting accounts are not configured',
                'message' => 'يرجى تحديد الحسابات الافتراضية للفواتير من إعدادات المحاسبة قبل إنشاء الفاتورة'
            ];
        }
        
        // Generate invoice number
        $invoiceNumber = $this->generateInvoiceNumber($data['invoice_type'] ?? 'standard');

        // Ensure required columns exist in acc_invoices table
        $checkColumns = $this->db->query("SHOW COLUMNS FROM acc_invoices LIKE 'customer_address'");
        if ($checkColumns->num_rows == 0) {
            // Add missing columns
            $alterSQL = "ALTER TABLE acc_invoices
                ADD COLUMN customer_address TEXT NULL AFTER customer_vat_number,
                ADD COLUMN payment_method VARCHAR(50) NULL AFTER payment_status,
                ADD COLUMN notes TEXT NULL AFTER payment_method";

            if (!$this->db->query($alterSQL)) {
                return ['success' => false, 'error' => 'Failed to add required columns: ' . $this->db->error];
            }
        }

        $sellerColumns = [
            'seller_source' => "ALTER TABLE acc_invoices ADD COLUMN seller_source VARCHAR(20) NULL AFTER notes",
            'seller_supplier_id' => "ALTER TABLE acc_invoices ADD COLUMN seller_supplier_id INT NULL AFTER seller_source",
            'seller_name' => "ALTER TABLE acc_invoices ADD COLUMN seller_name VARCHAR(255) NULL AFTER seller_supplier_id",
            'seller_vat_number' => "ALTER TABLE acc_invoices ADD COLUMN seller_vat_number VARCHAR(50) NULL AFTER seller_name",
            'seller_address' => "ALTER TABLE acc_invoices ADD COLUMN seller_address TEXT NULL AFTER seller_vat_number"
        ];

        foreach ($sellerColumns as $columnName => $alterSql) {
            $columnCheck = $this->db->query("SHOW COLUMNS FROM acc_invoices LIKE '{$columnName}'");
            if ($columnCheck && $columnCheck->num_rows == 0) {
                if (!$this->db->query($alterSql)) {
                    return ['success' => false, 'error' => 'Failed to add seller columns: ' . $this->db->error];
                }
            }
        }

        if (!$this->ensureInvoiceDimensionColumnsExist()) {
            return ['success' => false, 'error' => 'Failed to add invoice dimension columns: ' . $this->db->error];
        }

        $this->db->begin_transaction();

        // Insert invoice
        $stmt = $this->db->prepare(" 
            INSERT INTO acc_invoices
            (invoice_number, invoice_type, invoice_date, due_date,
             journal_id, cost_center_id, tenant_id, owner_id, aqar_id, subaqar_id, egar_id,
             customer_type, customer_id, customer_name, customer_vat_number, customer_address,
             subtotal, vat_amount, total_amount, paid_amount,
             payment_status, payment_method, notes, seller_source, seller_supplier_id,
             seller_name, seller_vat_number, seller_address, created_by, formuid)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, 0, 'unpaid', ?, ?, ?, ?, ?, ?, ?, ?, UUID())
        ");

        if (!$stmt) {
            $this->db->rollback();
            return ['success' => false, 'error' => 'SQL Prepare Error: ' . $this->db->error];
        }

        $customerType = $data['customer_type'] ?? 'tenant';
        $customerId = $data['customer_id'] ?? 0;
        $customerAddress = $data['customer_address'] ?? '';
        $paymentMethod = $data['payment_method'] ?? '';
        $notes = $data['notes'] ?? '';

        $sellerSource = $data['seller_source'] ?? 'company';
        $sellerSupplierId = !empty($data['seller_supplier_id']) ? intval($data['seller_supplier_id']) : null;
        $sellerName = $data['seller_name'] ?? '';
        $sellerVatNumber = $data['seller_vat_number'] ?? '';
        $sellerAddress = $data['seller_address'] ?? '';

        $journalId = isset($data['journal_id']) && $data['journal_id'] !== '' ? (int)$data['journal_id'] : null;
        $costCenterId = isset($data['cost_center_id']) && $data['cost_center_id'] !== '' ? (int)$data['cost_center_id'] : null;
        $tenantId = isset($data['tenant_id']) && $data['tenant_id'] !== '' ? (int)$data['tenant_id'] : null;
        $ownerId = isset($data['owner_id']) && $data['owner_id'] !== '' ? (int)$data['owner_id'] : null;
        $aqarId = isset($data['aqar_id']) && $data['aqar_id'] !== '' ? (int)$data['aqar_id'] : null;
        $subaqarId = isset($data['subaqar_id']) && $data['subaqar_id'] !== '' ? (int)$data['subaqar_id'] : null;
        $egarId = isset($data['egar_id']) && $data['egar_id'] !== '' ? (int)$data['egar_id'] : null;

        $stmt->bind_param("ssssiiiiiiisisssdddsssisssi",
            $invoiceNumber,
            $data['invoice_type'],
            $data['invoice_date'],
            $data['due_date'],
            $journalId,
            $costCenterId,
            $tenantId,
            $ownerId,
            $aqarId,
            $subaqarId,
            $egarId,
            $customerType,
            $customerId,
            $data['customer_name'],
            $data['customer_vat_number'],
            $customerAddress,
            $subtotal,
            $vatAmount,
            $totalAmount,
            $paymentMethod,
            $notes,
            $sellerSource,
            $sellerSupplierId,
            $sellerName,
            $sellerVatNumber,
            $sellerAddress,
            $this->userId
        );
        
        if (!$stmt->execute()) {
            $this->db->rollback();
            return ['success' => false, 'error' => $stmt->error];
        }

        $invoiceId = $stmt->insert_id;

        // Ensure acc_invoice_items table exists
        $checkItemsTable = $this->db->query("SHOW TABLES LIKE 'acc_invoice_items'");
        if ($checkItemsTable->num_rows == 0) {
            $createItemsTable = "CREATE TABLE acc_invoice_items (
                item_id INT AUTO_INCREMENT PRIMARY KEY,
                invoice_id INT NOT NULL,
                item_description VARCHAR(255) NOT NULL,
                quantity DECIMAL(10,2) NOT NULL,
                unit_price DECIMAL(10,2) NOT NULL,
                vat_rate DECIMAL(5,2) DEFAULT 15.00,
                discount DECIMAL(10,2) DEFAULT 0,
                line_total DECIMAL(10,2) NOT NULL,
                created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                INDEX idx_invoice (invoice_id)
            ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4";

            if (!$this->db->query($createItemsTable)) {
                $this->db->rollback();
                return ['success' => false, 'error' => 'Failed to create invoice items table: ' . $this->db->error];
            }
        }

        // Insert invoice items
        $itemStmt = $this->db->prepare("
            INSERT INTO acc_invoice_items
            (invoice_id, item_description, quantity, unit_price, vat_rate, discount, line_total)
            VALUES (?, ?, ?, ?, ?, ?, ?)
        ");

        if (!$itemStmt) {
            $this->db->rollback();
            return ['success' => false, 'error' => 'Failed to prepare item statement: ' . $this->db->error];
        }

        foreach ($items as $item) {
            $lineTotal = ($item['quantity'] * $item['unit_price']) * (1 + ($item['vat_rate'] / 100));
            $discount = $item['discount'] ?? 0;

            $itemStmt->bind_param("isddddd",
                $invoiceId,
                $item['description'],
                $item['quantity'],
                $item['unit_price'],
                $item['vat_rate'],
                $discount,
                $lineTotal
            );

            if (!$itemStmt->execute()) {
                $this->db->rollback();
                return ['success' => false, 'error' => 'Failed to insert item: ' . $itemStmt->error];
            }
        }

        $defaultCostCenterId = !empty($data['cost_center_id']) ? (int)$data['cost_center_id'] : null;

        $entryData = [
            'entry_date' => $data['invoice_date'],
            'entry_type' => 'auto',
            'journal_id' => $data['journal_id'] ?? null,
            'tenant_id' => $data['tenant_id'] ?? null,
            'owner_id' => $data['owner_id'] ?? null,
            'aqar_id' => $data['aqar_id'] ?? null,
            'subaqar_id' => $data['subaqar_id'] ?? null,
            'egar_id' => $data['egar_id'] ?? null,
            'invoice_id' => $invoiceId,
            'reference_type' => 'invoice',
            'reference_id' => $invoiceId,
            'description' => "إثبات فاتورة {$invoiceNumber} - {$data['customer_name']}",
            'status' => 'posted'
        ];

        $lines = [
            [
                'account_id' => $receivableAccountId,
                'description' => "المدين - فاتورة {$invoiceNumber}",
                'debit_amount' => $totalAmount,
                'credit_amount' => 0,
                'cost_center_id' => $defaultCostCenterId
            ],
            [
                'account_id' => $revenueAccountId,
                'description' => "الإيراد - فاتورة {$invoiceNumber}",
                'debit_amount' => 0,
                'credit_amount' => $subtotal,
                'cost_center_id' => $defaultCostCenterId
            ]
        ];

        if ($vatAmount > 0) {
            $lines[] = [
                'account_id' => $vatAccountId,
                'description' => "ضريبة القيمة المضافة - فاتورة {$invoiceNumber}",
                'debit_amount' => 0,
                'credit_amount' => $vatAmount,
                'cost_center_id' => $defaultCostCenterId
            ];
        }

        $journalResult = $this->createJournalEntry($entryData, $lines);
        if (!$journalResult['success']) {
            $this->db->rollback();
            return [
                'success' => false,
                'error' => $journalResult['error'] ?? 'Failed to create journal entry',
                'message' => 'فشل في إنشاء القيد المحاسبي للفاتورة'
            ];
        }

        $this->db->commit();

        $this->logAudit('create', 'invoice', $invoiceId, null, $data);

        return ['success' => true, 'invoice_id' => $invoiceId, 'invoice_number' => $invoiceNumber];
    }
    
    /**
     * Generate invoice number
     * توليد رقم الفاتورة
     */
    private function generateInvoiceNumber($type) {
        $prefix = $this->getSetting('invoice_prefix', 'INV');
        $year = date('Y');
        
        $result = $this->db->query("
            SELECT MAX(CAST(SUBSTRING(invoice_number, LENGTH('$prefix-$year-') + 1) AS UNSIGNED)) as max_num
            FROM acc_invoices
            WHERE invoice_number LIKE '$prefix-$year-%'
        ");
        
        $row = $result->fetch_assoc();
        $nextNum = ($row['max_num'] ?? 0) + 1;
        
        return sprintf("%s-%s-%05d", $prefix, $year, $nextNum);
    }

    public function getReportDimensionOptions() {
        $properties = [];
        $tenants = [];
        $owners = [];
        $contracts = [];

        $propertiesResult = $this->db->query("SELECT idaqar AS property_id, aqarname AS property_name FROM amlak WHERE aqarname != '' ORDER BY aqarname ASC");
        if ($propertiesResult) {
            while ($row = $propertiesResult->fetch_assoc()) {
                $properties[] = $row;
            }
        }

        $tenantsResult = $this->db->query("SELECT mostagerid AS tenant_id, mostagername AS tenant_name FROM mostagereen WHERE mostagername != '' ORDER BY mostagername ASC");
        if ($tenantsResult) {
            while ($row = $tenantsResult->fetch_assoc()) {
                $tenants[] = $row;
            }
        }

        $ownersResult = $this->db->query("SELECT malekid AS owner_id, malekbayan1 AS owner_name FROM malek WHERE malekbayan1 != '' ORDER BY malekbayan1 ASC");
        if ($ownersResult) {
            while ($row = $ownersResult->fetch_assoc()) {
                $owners[] = $row;
            }
        }

        $contractsResult = $this->db->query("SELECT rakam3akdid AS egar_id, rakam3akd AS contract_number FROM egar ORDER BY rakam3akdid DESC");
        if ($contractsResult) {
            while ($row = $contractsResult->fetch_assoc()) {
                $contracts[] = $row;
            }
        }

        return [
            'journals' => $this->getActiveJournals(),
            'cost_centers' => $this->getActiveCostCenters(),
            'properties' => $properties,
            'tenants' => $tenants,
            'owners' => $owners,
            'contracts' => $contracts,
            'customers' => $this->getActiveCustomers(),
            'cash_bank_accounts' => $this->getCashBankAccounts()
        ];
    }

    private function buildDimensionFilterClause($filters, $entryAlias = 'je', $lineAlias = 'jel', $costCenterAlias = 'cc') {
        $conditions = [];
        $params = [];
        $types = '';

        if (!empty($filters['journal_id'])) {
            $conditions[] = "$entryAlias.journal_id = ?";
            $params[] = (int)$filters['journal_id'];
            $types .= 'i';
        }

        if (!empty($filters['cost_center_id'])) {
            $conditions[] = "$lineAlias.cost_center_id = ?";
            $params[] = (int)$filters['cost_center_id'];
            $types .= 'i';
        }

        if (!empty($filters['aqar_id'])) {
            $conditions[] = "COALESCE($entryAlias.aqar_id, $costCenterAlias.aqar_id) = ?";
            $params[] = (int)$filters['aqar_id'];
            $types .= 'i';
        }

        if (!empty($filters['tenant_id'])) {
            $conditions[] = "$entryAlias.tenant_id = ?";
            $params[] = (int)$filters['tenant_id'];
            $types .= 'i';
        }

        if (!empty($filters['owner_id'])) {
            $conditions[] = "$entryAlias.owner_id = ?";
            $params[] = (int)$filters['owner_id'];
            $types .= 'i';
        }

        if (!empty($filters['egar_id'])) {
            $conditions[] = "$entryAlias.egar_id = ?";
            $params[] = (int)$filters['egar_id'];
            $types .= 'i';
        }

        return [
            'sql' => !empty($conditions) ? (' AND ' . implode(' AND ', $conditions)) : '',
            'params' => $params,
            'types' => $types
        ];
    }

    private function buildInvoiceDimensionFilterClause($filters, $invoiceAlias = 'inv', $invoiceCostCenterAlias = 'inv_cc', $entryAlias = 'je', $lineAlias = 'jel', $entryCostCenterAlias = 'cc') {
        $conditions = [];
        $params = [];
        $types = '';

        if (!empty($filters['journal_id'])) {
            $conditions[] = "COALESCE($invoiceAlias.journal_id, $entryAlias.journal_id) = ?";
            $params[] = (int)$filters['journal_id'];
            $types .= 'i';
        }

        if (!empty($filters['cost_center_id'])) {
            $conditions[] = "COALESCE($invoiceAlias.cost_center_id, $lineAlias.cost_center_id) = ?";
            $params[] = (int)$filters['cost_center_id'];
            $types .= 'i';
        }

        if (!empty($filters['aqar_id'])) {
            $conditions[] = "COALESCE($invoiceAlias.aqar_id, $invoiceCostCenterAlias.aqar_id, $entryAlias.aqar_id, $entryCostCenterAlias.aqar_id) = ?";
            $params[] = (int)$filters['aqar_id'];
            $types .= 'i';
        }

        if (!empty($filters['tenant_id'])) {
            $conditions[] = "COALESCE($invoiceAlias.tenant_id, $entryAlias.tenant_id) = ?";
            $params[] = (int)$filters['tenant_id'];
            $types .= 'i';
        }

        if (!empty($filters['owner_id'])) {
            $conditions[] = "COALESCE($invoiceAlias.owner_id, $entryAlias.owner_id) = ?";
            $params[] = (int)$filters['owner_id'];
            $types .= 'i';
        }

        if (!empty($filters['egar_id'])) {
            $conditions[] = "COALESCE($invoiceAlias.egar_id, $entryAlias.egar_id) = ?";
            $params[] = (int)$filters['egar_id'];
            $types .= 'i';
        }

        return [
            'sql' => !empty($conditions) ? (' AND ' . implode(' AND ', $conditions)) : '',
            'params' => $params,
            'types' => $types
        ];
    }

    public function getInvoiceDimensionContext($invoiceId) {
        if (!$this->ensureInvoiceDimensionColumnsExist()) {
            return [
                'journal_id' => null,
                'cost_center_id' => null,
                'tenant_id' => null,
                'owner_id' => null,
                'aqar_id' => null,
                'subaqar_id' => null,
                'egar_id' => null
            ];
        }

        $invoiceId = (int)$invoiceId;
        if ($invoiceId <= 0) {
            return [
                'journal_id' => null,
                'cost_center_id' => null,
                'tenant_id' => null,
                'owner_id' => null,
                'aqar_id' => null,
                'subaqar_id' => null,
                'egar_id' => null
            ];
        }

        $stmt = $this->db->prepare("SELECT
                inv.journal_id,
                inv.cost_center_id,
                inv.tenant_id,
                inv.owner_id,
                inv.aqar_id,
                inv.subaqar_id,
                inv.egar_id,
                (
                    SELECT je.journal_id
                    FROM acc_journal_entries je
                    WHERE je.reference_type = 'invoice'
                      AND je.reference_id = inv.invoice_id
                      AND je.status = 'posted'
                      AND je.entry_type = 'auto'
                    ORDER BY je.entry_id DESC
                    LIMIT 1
                ) AS fallback_journal_id,
                (
                    SELECT MAX(jel.cost_center_id)
                    FROM acc_journal_entries je
                    LEFT JOIN acc_journal_entry_lines jel ON je.entry_id = jel.entry_id
                    WHERE je.reference_type = 'invoice'
                      AND je.reference_id = inv.invoice_id
                      AND je.status = 'posted'
                      AND je.entry_type = 'auto'
                ) AS fallback_cost_center_id,
                (
                    SELECT je.tenant_id
                    FROM acc_journal_entries je
                    WHERE je.reference_type = 'invoice'
                      AND je.reference_id = inv.invoice_id
                      AND je.status = 'posted'
                      AND je.entry_type = 'auto'
                    ORDER BY je.entry_id DESC
                    LIMIT 1
                ) AS fallback_tenant_id,
                (
                    SELECT je.owner_id
                    FROM acc_journal_entries je
                    WHERE je.reference_type = 'invoice'
                      AND je.reference_id = inv.invoice_id
                      AND je.status = 'posted'
                      AND je.entry_type = 'auto'
                    ORDER BY je.entry_id DESC
                    LIMIT 1
                ) AS fallback_owner_id,
                (
                    SELECT je.aqar_id
                    FROM acc_journal_entries je
                    WHERE je.reference_type = 'invoice'
                      AND je.reference_id = inv.invoice_id
                      AND je.status = 'posted'
                      AND je.entry_type = 'auto'
                    ORDER BY je.entry_id DESC
                    LIMIT 1
                ) AS fallback_aqar_id,
                (
                    SELECT je.subaqar_id
                    FROM acc_journal_entries je
                    WHERE je.reference_type = 'invoice'
                      AND je.reference_id = inv.invoice_id
                      AND je.status = 'posted'
                      AND je.entry_type = 'auto'
                    ORDER BY je.entry_id DESC
                    LIMIT 1
                ) AS fallback_subaqar_id,
                (
                    SELECT je.egar_id
                    FROM acc_journal_entries je
                    WHERE je.reference_type = 'invoice'
                      AND je.reference_id = inv.invoice_id
                      AND je.status = 'posted'
                      AND je.entry_type = 'auto'
                    ORDER BY je.entry_id DESC
                    LIMIT 1
                ) AS fallback_egar_id
            FROM acc_invoices inv
            WHERE inv.invoice_id = ?
            LIMIT 1");
        if (!$stmt) {
            return [
                'journal_id' => null,
                'cost_center_id' => null,
                'tenant_id' => null,
                'owner_id' => null,
                'aqar_id' => null,
                'subaqar_id' => null,
                'egar_id' => null
            ];
        }

        $stmt->bind_param('i', $invoiceId);
        $stmt->execute();
        $row = $stmt->get_result()->fetch_assoc();
        $stmt->close();

        if (!$row) {
            return [
                'journal_id' => null,
                'cost_center_id' => null,
                'tenant_id' => null,
                'owner_id' => null,
                'aqar_id' => null,
                'subaqar_id' => null,
                'egar_id' => null
            ];
        }

        return [
            'journal_id' => $row['journal_id'] ?? $row['fallback_journal_id'] ?? null,
            'cost_center_id' => $row['cost_center_id'] ?? $row['fallback_cost_center_id'] ?? null,
            'tenant_id' => $row['tenant_id'] ?? $row['fallback_tenant_id'] ?? null,
            'owner_id' => $row['owner_id'] ?? $row['fallback_owner_id'] ?? null,
            'aqar_id' => $row['aqar_id'] ?? $row['fallback_aqar_id'] ?? null,
            'subaqar_id' => $row['subaqar_id'] ?? $row['fallback_subaqar_id'] ?? null,
            'egar_id' => $row['egar_id'] ?? $row['fallback_egar_id'] ?? null
        ];
    }

    public function getIncomeStatementData($dateFrom, $dateTo, $filters = []) {
        $dimensionClause = $this->buildDimensionFilterClause($filters);

        $buildQuery = function ($accountType) use ($dateFrom, $dateTo, $dimensionClause) {
            $amountExpression = $accountType === 'revenue'
                ? 'jel.credit_amount - jel.debit_amount'
                : 'jel.debit_amount - jel.credit_amount';

            $sql = "SELECT
                        acc.account_id,
                        acc.account_code,
                        acc.account_name_ar,
                        COALESCE(SUM(CASE
                            WHEN je.status = 'posted'
                             AND je.entry_date BETWEEN ? AND ?" . $dimensionClause['sql'] . "
                            THEN $amountExpression
                            ELSE 0
                        END), 0) AS amount
                    FROM acc_chart_of_accounts acc
                    LEFT JOIN acc_journal_entry_lines jel ON acc.account_id = jel.account_id
                    LEFT JOIN acc_journal_entries je ON jel.entry_id = je.entry_id
                    LEFT JOIN acc_cost_centers cc ON jel.cost_center_id = cc.cost_center_id
                    WHERE acc.account_type = ? AND acc.is_active = 1
                    GROUP BY acc.account_id
                    HAVING amount != 0
                    ORDER BY acc.account_code";

            $params = array_merge([$dateFrom, $dateTo], $dimensionClause['params'], [$accountType]);
            $types = 'ss' . $dimensionClause['types'] . 's';

            $stmt = $this->db->prepare($sql);
            if (!$stmt) {
                return [];
            }

            $stmt->bind_param($types, ...$params);
            $stmt->execute();
            $rows = $stmt->get_result()->fetch_all(MYSQLI_ASSOC);
            $stmt->close();

            return $rows;
        };

        $revenueAccounts = $buildQuery('revenue');
        $expenseAccounts = $buildQuery('expense');

        return [
            'revenue_accounts' => $revenueAccounts,
            'expense_accounts' => $expenseAccounts,
            'total_revenue' => array_sum(array_column($revenueAccounts, 'amount')),
            'total_expenses' => array_sum(array_column($expenseAccounts, 'amount'))
        ];
    }

    public function getBalanceSheetData($asOfDate, $filters = []) {
        $dimensionClause = $this->buildDimensionFilterClause($filters);

        $fetchByType = function ($accountType) use ($asOfDate, $dimensionClause) {
            $movementExpression = in_array($accountType, ['asset', 'expense'], true)
                ? 'jel.debit_amount - jel.credit_amount'
                : 'jel.credit_amount - jel.debit_amount';

            $sql = "SELECT
                        acc.account_id,
                        acc.account_code,
                        acc.account_name_ar,
                        acc.account_category,
                        acc.opening_balance + COALESCE(SUM(CASE
                            WHEN je.status = 'posted'
                             AND je.entry_date <= ?" . $dimensionClause['sql'] . "
                            THEN $movementExpression
                            ELSE 0
                        END), 0) AS balance
                    FROM acc_chart_of_accounts acc
                    LEFT JOIN acc_journal_entry_lines jel ON acc.account_id = jel.account_id
                    LEFT JOIN acc_journal_entries je ON jel.entry_id = je.entry_id
                    LEFT JOIN acc_cost_centers cc ON jel.cost_center_id = cc.cost_center_id
                    WHERE acc.account_type = ? AND acc.is_active = 1
                    GROUP BY acc.account_id
                    HAVING balance != 0
                    ORDER BY acc.account_code";

            $params = array_merge([$asOfDate], $dimensionClause['params'], [$accountType]);
            $types = 's' . $dimensionClause['types'] . 's';

            $stmt = $this->db->prepare($sql);
            if (!$stmt) {
                return [];
            }

            $stmt->bind_param($types, ...$params);
            $stmt->execute();
            $rows = $stmt->get_result()->fetch_all(MYSQLI_ASSOC);
            $stmt->close();

            return $rows;
        };

        $assets = $fetchByType('asset');
        $liabilities = $fetchByType('liability');
        $equity = $fetchByType('equity');

        return [
            'assets' => $assets,
            'liabilities' => $liabilities,
            'equity' => $equity,
            'total_assets' => array_sum(array_column($assets, 'balance')),
            'total_liabilities' => array_sum(array_column($liabilities, 'balance')),
            'total_equity' => array_sum(array_column($equity, 'balance'))
        ];
    }

    public function getCustomerStatementData($customerId, $dateFrom, $dateTo, $filters = []) {
        $customerId = (int)$customerId;
        $result = [
            'customer_name' => '',
            'transactions' => [],
            'total_invoices' => 0,
            'total_payments' => 0,
            'balance' => 0,
            'opening_balance' => 0
        ];

        if ($customerId <= 0) {
            return $result;
        }

        $customerStmt = $this->db->prepare("SELECT customer_name FROM acc_customers WHERE customer_id = ? LIMIT 1");
        if ($customerStmt) {
            $customerStmt->bind_param('i', $customerId);
            $customerStmt->execute();
            $row = $customerStmt->get_result()->fetch_assoc();
            $result['customer_name'] = $row['customer_name'] ?? '';
            $customerStmt->close();
        }

        if ($result['customer_name'] === '') {
            return $result;
        }

        $dimensionClause = $this->buildDimensionFilterClause($filters);
        $this->ensureInvoiceDimensionColumnsExist();
        $invoiceDimensionClause = $this->buildInvoiceDimensionFilterClause($filters);

        $invoiceSql = "SELECT
                inv.invoice_id,
                inv.invoice_number,
                inv.invoice_date,
                inv.invoice_type,
                inv.total_amount,
                COALESCE(MAX(inv_j.journal_code), MAX(j.journal_code)) AS journal_code,
                COALESCE(MAX(inv_j.journal_name_ar), MAX(j.journal_name_ar)) AS journal_name_ar,
                COALESCE(MAX(inv_cc.cost_center_code), MAX(cc.cost_center_code)) AS cost_center_code,
                COALESCE(MAX(inv_cc.cost_center_name_ar), MAX(cc.cost_center_name_ar)) AS cost_center_name_ar
            FROM acc_invoices inv
            LEFT JOIN acc_journal_entries je ON je.reference_type = 'invoice' AND je.reference_id = inv.invoice_id AND je.status = 'posted' AND je.entry_type = 'auto'
            LEFT JOIN acc_journal_entry_lines jel ON je.entry_id = jel.entry_id
            LEFT JOIN acc_cost_centers inv_cc ON inv.cost_center_id = inv_cc.cost_center_id
            LEFT JOIN acc_cost_centers cc ON jel.cost_center_id = cc.cost_center_id
            LEFT JOIN acc_journals inv_j ON inv.journal_id = inv_j.journal_id
            LEFT JOIN acc_journals j ON je.journal_id = j.journal_id
            WHERE inv.customer_id = ?
              AND inv.invoice_date BETWEEN ? AND ?" . $invoiceDimensionClause['sql'] . "
            GROUP BY inv.invoice_id
            ORDER BY inv.invoice_date, inv.invoice_id";

        $invoiceStmt = $this->db->prepare($invoiceSql);
        $invoiceParams = array_merge([$customerId, $dateFrom, $dateTo], $invoiceDimensionClause['params']);
        $invoiceTypes = 'iss' . $invoiceDimensionClause['types'];
        $invoiceStmt->bind_param($invoiceTypes, ...$invoiceParams);
        $invoiceStmt->execute();
        $invoices = $invoiceStmt->get_result()->fetch_all(MYSQLI_ASSOC);
        $invoiceStmt->close();

        $openingInvoiceSql = "SELECT COALESCE(SUM(inv.total_amount), 0) AS total_amount
            FROM (
                SELECT inv.invoice_id, inv.total_amount
                FROM acc_invoices inv
                LEFT JOIN acc_journal_entries je ON je.reference_type = 'invoice' AND je.reference_id = inv.invoice_id AND je.status = 'posted' AND je.entry_type = 'auto'
                LEFT JOIN acc_journal_entry_lines jel ON je.entry_id = jel.entry_id
                LEFT JOIN acc_cost_centers inv_cc ON inv.cost_center_id = inv_cc.cost_center_id
                LEFT JOIN acc_cost_centers cc ON jel.cost_center_id = cc.cost_center_id
                WHERE inv.customer_id = ?
                  AND inv.invoice_date < ?" . $invoiceDimensionClause['sql'] . "
                GROUP BY inv.invoice_id
            ) inv";
        $openingInvoiceStmt = $this->db->prepare($openingInvoiceSql);
        $openingInvoiceParams = array_merge([$customerId, $dateFrom], $invoiceDimensionClause['params']);
        $openingInvoiceTypes = 'is' . $invoiceDimensionClause['types'];
        $openingInvoiceStmt->bind_param($openingInvoiceTypes, ...$openingInvoiceParams);
        $openingInvoiceStmt->execute();
        $openingInvoiceTotal = (float)($openingInvoiceStmt->get_result()->fetch_assoc()['total_amount'] ?? 0);
        $openingInvoiceStmt->close();

        $receivableCode = '1121';
        $paymentSql = "SELECT
                je.entry_id,
                je.entry_number,
                je.entry_date,
                je.description,
                SUM(jel.credit_amount - jel.debit_amount) AS amount,
                MAX(j.journal_code) AS journal_code,
                MAX(j.journal_name_ar) AS journal_name_ar,
                MAX(cc.cost_center_code) AS cost_center_code,
                MAX(cc.cost_center_name_ar) AS cost_center_name_ar
            FROM acc_journal_entries je
            INNER JOIN acc_invoices inv ON je.invoice_id = inv.invoice_id
            INNER JOIN acc_journal_entry_lines jel ON je.entry_id = jel.entry_id
            INNER JOIN acc_chart_of_accounts acc ON jel.account_id = acc.account_id
            LEFT JOIN acc_cost_centers cc ON jel.cost_center_id = cc.cost_center_id
            LEFT JOIN acc_journals j ON je.journal_id = j.journal_id
            WHERE je.status = 'posted'
              AND inv.customer_id = ?
              AND acc.account_code = ?
              AND (jel.credit_amount - jel.debit_amount) > 0
              AND je.entry_date BETWEEN ? AND ?" . $dimensionClause['sql'] . "
            GROUP BY je.entry_id
            ORDER BY je.entry_date, je.entry_id";
        $paymentStmt = $this->db->prepare($paymentSql);
        $paymentParams = array_merge([$customerId, $receivableCode, $dateFrom, $dateTo], $dimensionClause['params']);
        $paymentTypes = 'isss' . $dimensionClause['types'];
        $paymentStmt->bind_param($paymentTypes, ...$paymentParams);
        $paymentStmt->execute();
        $payments = $paymentStmt->get_result()->fetch_all(MYSQLI_ASSOC);
        $paymentStmt->close();

        $openingPaymentSql = "SELECT COALESCE(SUM(payment_rows.amount), 0) AS total_amount
            FROM (
                SELECT je.entry_id, SUM(jel.credit_amount - jel.debit_amount) AS amount
                FROM acc_journal_entries je
                INNER JOIN acc_invoices inv ON je.invoice_id = inv.invoice_id
                INNER JOIN acc_journal_entry_lines jel ON je.entry_id = jel.entry_id
                INNER JOIN acc_chart_of_accounts acc ON jel.account_id = acc.account_id
                LEFT JOIN acc_cost_centers cc ON jel.cost_center_id = cc.cost_center_id
                WHERE je.status = 'posted'
                  AND inv.customer_id = ?
                  AND acc.account_code = ?
                  AND (jel.credit_amount - jel.debit_amount) > 0
                  AND je.entry_date < ?" . $dimensionClause['sql'] . "
                GROUP BY je.entry_id
            ) payment_rows";
        $openingPaymentStmt = $this->db->prepare($openingPaymentSql);
        $openingPaymentParams = array_merge([$customerId, $receivableCode, $dateFrom], $dimensionClause['params']);
        $openingPaymentTypes = 'iss' . $dimensionClause['types'];
        $openingPaymentStmt->bind_param($openingPaymentTypes, ...$openingPaymentParams);
        $openingPaymentStmt->execute();
        $openingPaymentTotal = (float)($openingPaymentStmt->get_result()->fetch_assoc()['total_amount'] ?? 0);
        $openingPaymentStmt->close();

        $transactions = [];
        foreach ($invoices as $invoice) {
            $transactions[] = [
                'date' => $invoice['invoice_date'],
                'type' => 'invoice',
                'reference' => $invoice['invoice_number'],
                'description' => 'فاتورة ' . ($invoice['invoice_type'] ?: 'مبيعات'),
                'journal' => trim((string)(($invoice['journal_code'] ?? '') . ' - ' . ($invoice['journal_name_ar'] ?? '')), ' -'),
                'cost_center' => trim((string)(($invoice['cost_center_code'] ?? '') . ' - ' . ($invoice['cost_center_name_ar'] ?? '')), ' -'),
                'debit' => (float)$invoice['total_amount'],
                'credit' => 0,
                'balance' => 0
            ];
        }

        foreach ($payments as $payment) {
            $transactions[] = [
                'date' => $payment['entry_date'],
                'type' => 'payment',
                'reference' => $payment['entry_number'],
                'description' => $payment['description'],
                'journal' => trim((string)(($payment['journal_code'] ?? '') . ' - ' . ($payment['journal_name_ar'] ?? '')), ' -'),
                'cost_center' => trim((string)(($payment['cost_center_code'] ?? '') . ' - ' . ($payment['cost_center_name_ar'] ?? '')), ' -'),
                'debit' => 0,
                'credit' => (float)$payment['amount'],
                'balance' => 0
            ];
        }

        usort($transactions, function ($a, $b) {
            $comparison = strcmp($a['date'], $b['date']);
            if ($comparison !== 0) {
                return $comparison;
            }
            return strcmp($a['reference'], $b['reference']);
        });

        $openingBalance = $openingInvoiceTotal - $openingPaymentTotal;
        $runningBalance = $openingBalance;
        if (abs($openingBalance) > 0.0001) {
            $result['transactions'][] = [
                'date' => $dateFrom,
                'type' => 'opening',
                'reference' => '-',
                'description' => 'رصيد أول المدة',
                'journal' => '-',
                'cost_center' => '-',
                'debit' => $openingBalance > 0 ? $openingBalance : 0,
                'credit' => $openingBalance < 0 ? abs($openingBalance) : 0,
                'balance' => $openingBalance
            ];
        }

        foreach ($transactions as $transaction) {
            $runningBalance += $transaction['debit'] - $transaction['credit'];
            $transaction['balance'] = $runningBalance;
            $result['transactions'][] = $transaction;
            $result['total_invoices'] += (float)$transaction['debit'];
            $result['total_payments'] += (float)$transaction['credit'];
        }

        $result['opening_balance'] = $openingBalance;
        $result['balance'] = $runningBalance;

        return $result;
    }

    public function getAgedReceivablesData($asOfDate, $showZeroBalance = false, $filters = []) {
        $this->ensureInvoiceDimensionColumnsExist();
        $dimensionClause = $this->buildInvoiceDimensionFilterClause($filters);
        $sql = "SELECT
                inv.invoice_id,
                inv.customer_id,
                inv.customer_name,
                COALESCE(inv.remaining_amount, inv.total_amount - inv.paid_amount) AS outstanding,
                DATEDIFF(?, inv.invoice_date) AS days_old
            FROM acc_invoices inv
            LEFT JOIN acc_journal_entries je ON je.reference_type = 'invoice' AND je.reference_id = inv.invoice_id AND je.status = 'posted' AND je.entry_type = 'auto'
            LEFT JOIN acc_journal_entry_lines jel ON je.entry_id = jel.entry_id
            LEFT JOIN acc_cost_centers inv_cc ON inv.cost_center_id = inv_cc.cost_center_id
            LEFT JOIN acc_cost_centers cc ON jel.cost_center_id = cc.cost_center_id
            WHERE inv.invoice_date <= ?
              AND COALESCE(inv.remaining_amount, inv.total_amount - inv.paid_amount) >= 0" . $dimensionClause['sql'] . "
            GROUP BY inv.invoice_id
            ORDER BY inv.customer_name, inv.invoice_date";
        $stmt = $this->db->prepare($sql);
        $params = array_merge([$asOfDate, $asOfDate], $dimensionClause['params']);
        $types = 'ss' . $dimensionClause['types'];
        $stmt->bind_param($types, ...$params);
        $stmt->execute();
        $invoices = $stmt->get_result()->fetch_all(MYSQLI_ASSOC);
        $stmt->close();

        $customerData = [];
        if ($showZeroBalance) {
            foreach ($this->getActiveCustomers() as $customer) {
                $customerData[(int)$customer['customer_id']] = [
                    'customer_id' => (int)$customer['customer_id'],
                    'customer_name' => $customer['customer_name'],
                    'current' => 0,
                    '30' => 0,
                    '60' => 0,
                    '90_plus' => 0,
                    'total' => 0
                ];
            }
        }

        $totals = [
            'current' => 0,
            '30' => 0,
            '60' => 0,
            '90_plus' => 0,
            'total' => 0
        ];

        foreach ($invoices as $invoice) {
            $customerId = (int)$invoice['customer_id'];
            if (!isset($customerData[$customerId])) {
                $customerData[$customerId] = [
                    'customer_id' => $customerId,
                    'customer_name' => $invoice['customer_name'],
                    'current' => 0,
                    '30' => 0,
                    '60' => 0,
                    '90_plus' => 0,
                    'total' => 0
                ];
            }

            $outstanding = (float)$invoice['outstanding'];
            $daysOld = (int)$invoice['days_old'];

            if ($daysOld <= 30) {
                $bucket = 'current';
            } elseif ($daysOld <= 60) {
                $bucket = '30';
            } elseif ($daysOld <= 90) {
                $bucket = '60';
            } else {
                $bucket = '90_plus';
            }

            $customerData[$customerId][$bucket] += $outstanding;
            $customerData[$customerId]['total'] += $outstanding;
            $totals[$bucket] += $outstanding;
            $totals['total'] += $outstanding;
        }

        if (!$showZeroBalance) {
            $customerData = array_filter($customerData, function ($row) {
                return $row['total'] > 0;
            });
        }

        uasort($customerData, function ($a, $b) {
            return $b['total'] <=> $a['total'];
        });

        return [
            'customer_data' => $customerData,
            'totals' => $totals,
            'total_customers' => count($customerData),
            'total_outstanding' => $totals['total']
        ];
    }

    public function getGeneralLedgerDetailData($accountId, $dateFrom, $dateTo, $filters = []) {
        $accountId = (int)$accountId;
        $account = $this->getAccount($accountId);
        if (!$account) {
            return [
                'account' => null,
                'rows' => [],
                'opening_balance' => 0,
                'total_debit' => 0,
                'total_credit' => 0,
                'ending_balance' => 0
            ];
        }

        $dimensionClause = $this->buildDimensionFilterClause($filters);
        $openingSql = "SELECT COALESCE(SUM(jel.debit_amount), 0) AS total_debit, COALESCE(SUM(jel.credit_amount), 0) AS total_credit
            FROM acc_journal_entry_lines jel
            INNER JOIN acc_journal_entries je ON jel.entry_id = je.entry_id
            LEFT JOIN acc_cost_centers cc ON jel.cost_center_id = cc.cost_center_id
            WHERE jel.account_id = ?
              AND je.status = 'posted'
              AND je.entry_date < ?" . $dimensionClause['sql'];
        $openingStmt = $this->db->prepare($openingSql);
        $openingParams = array_merge([$accountId, $dateFrom], $dimensionClause['params']);
        $openingTypes = 'is' . $dimensionClause['types'];
        $openingStmt->bind_param($openingTypes, ...$openingParams);
        $openingStmt->execute();
        $openingRow = $openingStmt->get_result()->fetch_assoc();
        $openingStmt->close();

        $openingMovement = in_array($account['account_type'], ['asset', 'expense'], true)
            ? ((float)$openingRow['total_debit'] - (float)$openingRow['total_credit'])
            : ((float)$openingRow['total_credit'] - (float)$openingRow['total_debit']);
        $openingBalance = (float)$account['opening_balance'] + $openingMovement;

        $detailSql = "SELECT
                je.entry_id,
                je.entry_number,
                je.entry_date,
                je.description AS entry_description,
                je.tenant_id,
                je.owner_id,
                je.aqar_id,
                je.egar_id,
                jel.description AS line_description,
                jel.debit_amount,
                jel.credit_amount,
                cc.cost_center_code,
                cc.cost_center_name_ar,
                j.journal_code,
                j.journal_name_ar
            FROM acc_journal_entry_lines jel
            INNER JOIN acc_journal_entries je ON jel.entry_id = je.entry_id
            LEFT JOIN acc_cost_centers cc ON jel.cost_center_id = cc.cost_center_id
            LEFT JOIN acc_journals j ON je.journal_id = j.journal_id
            WHERE jel.account_id = ?
              AND je.status = 'posted'
              AND je.entry_date BETWEEN ? AND ?" . $dimensionClause['sql'] . "
            ORDER BY je.entry_date, je.entry_id, jel.line_number";
        $detailStmt = $this->db->prepare($detailSql);
        $detailParams = array_merge([$accountId, $dateFrom, $dateTo], $dimensionClause['params']);
        $detailTypes = 'iss' . $dimensionClause['types'];
        $detailStmt->bind_param($detailTypes, ...$detailParams);
        $detailStmt->execute();
        $rows = $detailStmt->get_result()->fetch_all(MYSQLI_ASSOC);
        $detailStmt->close();

        $runningBalance = $openingBalance;
        $totalDebit = 0;
        $totalCredit = 0;
        foreach ($rows as &$row) {
            $debit = (float)$row['debit_amount'];
            $credit = (float)$row['credit_amount'];
            $totalDebit += $debit;
            $totalCredit += $credit;
            if (in_array($account['account_type'], ['asset', 'expense'], true)) {
                $runningBalance += $debit - $credit;
            } else {
                $runningBalance += $credit - $debit;
            }
            $row['description'] = (string)($row['line_description'] ?: $row['entry_description']);
            $row['journal'] = trim((string)(($row['journal_code'] ?? '') . ' - ' . ($row['journal_name_ar'] ?? '')), ' -');
            $row['cost_center'] = trim((string)(($row['cost_center_code'] ?? '') . ' - ' . ($row['cost_center_name_ar'] ?? '')), ' -');
            $row['running_balance'] = $runningBalance;
        }
        unset($row);

        return [
            'account' => $account,
            'rows' => $rows,
            'opening_balance' => $openingBalance,
            'total_debit' => $totalDebit,
            'total_credit' => $totalCredit,
            'ending_balance' => $runningBalance
        ];
    }

    public function getCashBankMovementData($dateFrom, $dateTo, $accountId = null, $filters = []) {
        $cashBankAccounts = $this->getCashBankAccounts();
        $selectedAccountId = !empty($accountId) ? (int)$accountId : null;
        $eligibleAccountIds = [];
        foreach ($cashBankAccounts as $account) {
            $eligibleAccountIds[] = (int)$account['account_id'];
        }

        if ($selectedAccountId && !in_array($selectedAccountId, $eligibleAccountIds, true)) {
            return [
                'accounts' => $cashBankAccounts,
                'rows' => [],
                'opening_balance' => 0,
                'total_receipts' => 0,
                'total_payments' => 0,
                'ending_balance' => 0
            ];
        }

        if (empty($eligibleAccountIds)) {
            return [
                'accounts' => [],
                'rows' => [],
                'opening_balance' => 0,
                'total_receipts' => 0,
                'total_payments' => 0,
                'ending_balance' => 0
            ];
        }

        $dimensionClause = $this->buildDimensionFilterClause($filters);
        $accountPlaceholders = implode(',', array_fill(0, count($selectedAccountId ? [$selectedAccountId] : $eligibleAccountIds), '?'));
        $accountIds = $selectedAccountId ? [$selectedAccountId] : $eligibleAccountIds;
        $accountTypes = str_repeat('i', count($accountIds));

        $openingSql = "SELECT acc.account_id, acc.opening_balance,
                COALESCE(SUM(jel.debit_amount), 0) AS total_debit,
                COALESCE(SUM(jel.credit_amount), 0) AS total_credit
            FROM acc_chart_of_accounts acc
            LEFT JOIN acc_journal_entry_lines jel ON acc.account_id = jel.account_id
            LEFT JOIN acc_journal_entries je ON jel.entry_id = je.entry_id
            LEFT JOIN acc_cost_centers cc ON jel.cost_center_id = cc.cost_center_id
            WHERE acc.account_id IN ($accountPlaceholders)
              AND (je.entry_id IS NULL OR (je.status = 'posted' AND je.entry_date < ?" . $dimensionClause['sql'] . "))
            GROUP BY acc.account_id, acc.opening_balance";
        $openingStmt = $this->db->prepare($openingSql);
        $openingParams = array_merge($accountIds, [$dateFrom], $dimensionClause['params']);
        $openingTypes = $accountTypes . 's' . $dimensionClause['types'];
        $openingStmt->bind_param($openingTypes, ...$openingParams);
        $openingStmt->execute();
        $openingRows = $openingStmt->get_result()->fetch_all(MYSQLI_ASSOC);
        $openingStmt->close();

        $openingBalance = 0;
        foreach ($openingRows as $openingRow) {
            $openingBalance += (float)$openingRow['opening_balance'] + ((float)$openingRow['total_debit'] - (float)$openingRow['total_credit']);
        }

        $movementSql = "SELECT
                acc.account_code,
                acc.account_name_ar,
                je.entry_number,
                je.entry_date,
                je.description AS entry_description,
                jel.description AS line_description,
                jel.debit_amount,
                jel.credit_amount,
                cc.cost_center_code,
                cc.cost_center_name_ar,
                j.journal_code,
                j.journal_name_ar
            FROM acc_journal_entry_lines jel
            INNER JOIN acc_chart_of_accounts acc ON jel.account_id = acc.account_id
            INNER JOIN acc_journal_entries je ON jel.entry_id = je.entry_id
            LEFT JOIN acc_cost_centers cc ON jel.cost_center_id = cc.cost_center_id
            LEFT JOIN acc_journals j ON je.journal_id = j.journal_id
            WHERE jel.account_id IN ($accountPlaceholders)
              AND je.status = 'posted'
              AND je.entry_date BETWEEN ? AND ?" . $dimensionClause['sql'] . "
            ORDER BY je.entry_date, je.entry_id, jel.line_number";
        $movementStmt = $this->db->prepare($movementSql);
        $movementParams = array_merge($accountIds, [$dateFrom, $dateTo], $dimensionClause['params']);
        $movementTypes = $accountTypes . 'ss' . $dimensionClause['types'];
        $movementStmt->bind_param($movementTypes, ...$movementParams);
        $movementStmt->execute();
        $rows = $movementStmt->get_result()->fetch_all(MYSQLI_ASSOC);
        $movementStmt->close();

        $totalReceipts = 0;
        $totalPayments = 0;
        $runningBalance = $openingBalance;
        foreach ($rows as &$row) {
            $debit = (float)$row['debit_amount'];
            $credit = (float)$row['credit_amount'];
            $totalReceipts += $debit;
            $totalPayments += $credit;
            $runningBalance += $debit - $credit;
            $row['description'] = (string)($row['line_description'] ?: $row['entry_description']);
            $row['journal'] = trim((string)(($row['journal_code'] ?? '') . ' - ' . ($row['journal_name_ar'] ?? '')), ' -');
            $row['cost_center'] = trim((string)(($row['cost_center_code'] ?? '') . ' - ' . ($row['cost_center_name_ar'] ?? '')), ' -');
            $row['running_balance'] = $runningBalance;
        }
        unset($row);

        return [
            'accounts' => $cashBankAccounts,
            'rows' => $rows,
            'opening_balance' => $openingBalance,
            'total_receipts' => $totalReceipts,
            'total_payments' => $totalPayments,
            'ending_balance' => $runningBalance
        ];
    }
    
    // ============================================
    // Reports
    // التقارير
    // ============================================
    
    /**
     * Get trial balance
     * ميزان المراجعة
     */
    public function getTrialBalance($date = null, $filters = [], $dateFrom = null) {
        if (!$date) {
            $date = date('Y-m-d');
        }
        if (!$dateFrom) {
            $dateFrom = date('Y-01-01', strtotime($date));
        }

        $dimensionClause = $this->buildDimensionFilterClause($filters);
        $sql = "SELECT
                    acc.account_id,
                    acc.account_code,
                    acc.account_name_ar,
                    acc.account_type,
                    acc.opening_balance,
                    COALESCE(SUM(CASE
                        WHEN je.status = 'posted'
                         AND je.entry_date BETWEEN ? AND ?" . $dimensionClause['sql'] . "
                        THEN jel.debit_amount
                        ELSE 0
                    END), 0) AS total_debit,
                    COALESCE(SUM(CASE
                        WHEN je.status = 'posted'
                         AND je.entry_date BETWEEN ? AND ?" . $dimensionClause['sql'] . "
                        THEN jel.credit_amount
                        ELSE 0
                    END), 0) AS total_credit
                FROM acc_chart_of_accounts acc
                LEFT JOIN acc_journal_entry_lines jel ON acc.account_id = jel.account_id
                LEFT JOIN acc_journal_entries je ON jel.entry_id = je.entry_id
                LEFT JOIN acc_cost_centers cc ON jel.cost_center_id = cc.cost_center_id
                WHERE acc.is_leaf = 1 AND acc.is_active = 1
                GROUP BY acc.account_id
                ORDER BY acc.account_code";

        $params = array_merge(
            [$dateFrom, $date],
            $dimensionClause['params'],
            [$dateFrom, $date],
            $dimensionClause['params']
        );
        $types = 'ss' . $dimensionClause['types'] . 'ss' . $dimensionClause['types'];

        $stmt = $this->db->prepare($sql);
        $stmt->bind_param($types, ...$params);
        $stmt->execute();

        return $stmt->get_result()->fetch_all(MYSQLI_ASSOC);
    }
    
    // ============================================
    // Utilities
    // الأدوات المساعدة
    // ============================================
    
    /**
     * Get current fiscal year
     * الحصول على السنة المالية الحالية
     */
    private function getCurrentFiscalYear() {
        $result = $this->db->query("
            SELECT fiscal_year 
            FROM acc_fiscal_years 
            WHERE status = 'open' 
            ORDER BY fiscal_year DESC 
            LIMIT 1
        ");
        
        if ($result && $row = $result->fetch_assoc()) {
            return $row['fiscal_year'];
        }
        
        return date('Y');
    }
    
    /**
     * Get system setting
     * الحصول على إعداد النظام
     */
    public function getSetting($key, $default = null) {
        $stmt = $this->db->prepare("SELECT setting_value FROM acc_system_settings WHERE setting_key = ?");
        $stmt->bind_param("s", $key);
        $stmt->execute();
        $result = $stmt->get_result();
        
        if ($row = $result->fetch_assoc()) {
            return $row['setting_value'];
        }
        
        return $default;
    }
    
    /**
     * Log audit trail
     * تسجيل سجل التدقيق
     */
    private function logAudit($action, $entity, $entityId, $oldValues, $newValues) {
        // Check if audit log table exists, create if not
        $tableCheck = $this->db->query("SHOW TABLES LIKE 'acc_audit_log'");
        if ($tableCheck->num_rows == 0) {
            // Create audit log table
            $createTable = "CREATE TABLE acc_audit_log (
                id INT AUTO_INCREMENT PRIMARY KEY,
                user_id INT NOT NULL,
                username VARCHAR(100) NOT NULL,
                action_type VARCHAR(50) NOT NULL,
                entity_type VARCHAR(50) NOT NULL,
                entity_id INT NULL,
                old_values TEXT NULL,
                new_values TEXT NULL,
                ip_address VARCHAR(45) NULL,
                formuid VARCHAR(36) NULL,
                created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                INDEX idx_user (user_id),
                INDEX idx_entity (entity_type, entity_id),
                INDEX idx_created (created_at)
            ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4";

            if (!$this->db->query($createTable)) {
                error_log('Failed to create audit log table: ' . $this->db->error);
                return; // Skip logging if table creation fails
            }
        }

        $stmt = $this->db->prepare("
            INSERT INTO acc_audit_log
            (user_id, username, action_type, entity_type, entity_id,
             old_values, new_values, ip_address, formuid)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, UUID())
        ");

        if (!$stmt) {
            error_log('Failed to prepare audit log statement: ' . $this->db->error);
            return; // Skip logging if prepare fails
        }

        $username = $_SESSION['username'] ?? 'system';
        $ipAddress = $_SERVER['REMOTE_ADDR'] ?? '';
        $oldJson = json_encode($oldValues);
        $newJson = json_encode($newValues);

        $stmt->bind_param("isssisss",
            $this->userId,
            $username,
            $action,
            $entity,
            $entityId,
            $oldJson,
            $newJson,
            $ipAddress
        );

        $stmt->execute();
    }
}
?>
