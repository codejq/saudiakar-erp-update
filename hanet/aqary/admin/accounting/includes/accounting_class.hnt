    public function saveCostCenter($data, $costCenterId = null) {
        $costCenterCode = trim((string)($data['cost_center_code'] ?? ''));
        $costCenterNameAr = trim((string)($data['cost_center_name_ar'] ?? ''));
        $costCenterNameEn = trim((string)($data['cost_center_name_en'] ?? ''));
        $parentCostCenterId = !empty($data['parent_cost_center_id']) ? (int)$data['parent_cost_center_id'] : null;
        $aqarId = !empty($data['aqar_id']) ? (int)$data['aqar_id'] : null;
        $subaqarId = !empty($data['subaqar_id']) ? (int)$data['subaqar_id'] : null;
        $isActive = isset($data['is_active']) ? (int)$data['is_active'] : 1;

        if ($costCenterCode === '') {
            return ['success' => false, 'message' => 'رمز مركز التكلفة مطلوب'];
        }

        if ($costCenterNameAr === '') {
            return ['success' => false, 'message' => 'اسم مركز التكلفة بالعربية مطلوب'];
        }

        if ($costCenterId) {
            $stmt = $this->db->prepare("UPDATE acc_cost_centers SET cost_center_code = ?, cost_center_name_ar = ?, cost_center_name_en = ?, parent_cost_center_id = ?, aqar_id = ?, subaqar_id = ?, is_active = ? WHERE cost_center_id = ?");
            if (!$stmt) {
                return ['success' => false, 'message' => 'فشل في تجهيز تحديث مركز التكلفة: ' . $this->db->error];
            }
            $costCenterId = (int)$costCenterId;
            $stmt->bind_param("sssiiiii", $costCenterCode, $costCenterNameAr, $costCenterNameEn, $parentCostCenterId, $aqarId, $subaqarId, $isActive, $costCenterId);
        } else {
            $stmt = $this->db->prepare("INSERT INTO acc_cost_centers (cost_center_code, cost_center_name_ar, cost_center_name_en, parent_cost_center_id, aqar_id, subaqar_id, is_active, formuid) VALUES (?, ?, ?, ?, ?, ?, ?, UUID())");
            if (!$stmt) {
                return ['success' => false, 'message' => 'فشل في تجهيز إضافة مركز التكلفة: ' . $this->db->error];
            }
            $stmt->bind_param("sssiiii", $costCenterCode, $costCenterNameAr, $costCenterNameEn, $parentCostCenterId, $aqarId, $subaqarId, $isActive);
        }

        if (!$stmt->execute()) {
            $error = $stmt->error;
            $stmt->close();
            if (strpos($error, 'Duplicate entry') !== false) {
                return ['success' => false, 'message' => 'رمز مركز التكلفة مستخدم بالفعل'];
            }
            return ['success' => false, 'message' => 'فشل في حفظ مركز التكلفة: ' . $error];
        }

        $savedId = $costCenterId ?: $stmt->insert_id;
        $stmt->close();

        return ['success' => true, 'cost_center_id' => $savedId];
    }

    public function toggleCostCenterStatus($costCenterId) {
        $costCenter = $this->getCostCenter($costCenterId);
        if (!$costCenter) {
