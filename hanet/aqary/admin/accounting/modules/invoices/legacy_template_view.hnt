<script>
const accountingSaudiCode = GenerateSaudiTaxCode(
    <?php echo json_encode($sellerName, JSON_UNESCAPED_UNICODE); ?>,
    <?php echo json_encode($sellerVat, JSON_UNESCAPED_UNICODE); ?>,
    <?php echo json_encode($qrDateTime, JSON_UNESCAPED_UNICODE); ?>,
    <?php echo json_encode(number_format($totalAmount, 2, '.', ''), JSON_UNESCAPED_UNICODE); ?>,
    <?php echo json_encode(number_format($vatAmount, 2, '.', ''), JSON_UNESCAPED_UNICODE); ?>
);

new QRCode("qrcode", {
    text: accountingSaudiCode,
    width: 90,
    height: 90,
    colorDark: "#10286e",
