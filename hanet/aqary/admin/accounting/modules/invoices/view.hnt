<?php
/**
 * Invoice View - ZATCA Compliant
 * عرض تفاصيل الفاتورة - تصميم احترافي
 *
 * @charset UTF-8
 * @version 2.0
 * @zatca Phase 2 Compliant
 */

$sc_title = "عرض الفاتورة";
$sc_id = "204";
include_once "../../../../header.hnt";
include_once "../../includes/accounting_class.hnt";
$accountingManager = new AccountingManager($db, $_SESSION['userid'] ?? 1);

// Get invoice ID
$invoiceId = isset($_GET['id']) ? intval($_GET['id']) : 0;

if (!$invoiceId) {
    echo '<div class="alert alert-danger m-4">لم يتم تحديد رقم الفاتورة</div>';
    require("../../../../foter.hnt");
    exit;
}

// Get invoice details
$stmt = $db->prepare("SELECT * FROM acc_invoices WHERE invoice_id = ?");
$stmt->bind_param('i', $invoiceId);
$stmt->execute();
$invoice = $stmt->get_result()->fetch_assoc();

if (!$invoice) {
    echo '<div class="alert alert-danger m-4">الفاتورة غير موجودة</div>';
    require("../../../../foter.hnt");
    exit;
}

// Get invoice items
$itemsStmt = $db->prepare("SELECT * FROM acc_invoice_items WHERE invoice_id = ?");
$itemsStmt->bind_param('i', $invoiceId);
$itemsStmt->execute();
$itemsResult = $itemsStmt->get_result();
$items = [];
while ($item = $itemsResult->fetch_assoc()) {
    $items[] = $item;
}

// Get submission log with full API response
$submissionLog = null;
$logStmt = $db->prepare("SELECT * FROM zatca_submission_log WHERE invoice_id = ? ORDER BY submission_date DESC LIMIT 1");
if ($logStmt) {
    $logStmt->bind_param('i', $invoiceId);
    $logStmt->execute();
    $submissionLog = $logStmt->get_result()->fetch_assoc();
}

// Get seller info from config or defaults
$sellerName = trim((string)($invoice['seller_name'] ?? ''));
$sellerVat = trim((string)($invoice['seller_vat_number'] ?? ''));
$sellerAddress = trim((string)($invoice['seller_address'] ?? ''));

if ($sellerName === '') {
    $sellerName = $zatca_company_name_ar ?? $bayanmaktabname ?? 'اسم الشركة';
}
if ($sellerVat === '') {
    $sellerVat = $zatca_vat_number ?? $vat_number ?? '300000000000003';
}
if ($sellerAddress === '') {
    $sellerAddress = $zatca_company_address_ar ?? $bayanaddress ?? 'المملكة العربية السعودية';
}

$invoiceTypeKey = trim((string)($invoice['invoice_type'] ?? 'standard'));
$documentLabelAr = 'فاتورة ضريبية';
if ($invoiceTypeKey === 'simplified') {
    $documentLabelAr = 'فاتورة مبسطة';
} elseif ($invoiceTypeKey === 'credit_note') {
    $documentLabelAr = 'إشعار دائن';
} elseif ($invoiceTypeKey === 'debit_note') {
    $documentLabelAr = 'إشعار مدين';
}

$isCreditNote = $invoiceTypeKey === 'credit_note';
$isAccountingNote = $invoiceTypeKey === 'credit_note' || $invoiceTypeKey === 'debit_note';
$displaySign = $isCreditNote ? -1 : 1;

// Calculate totals
$subtotal = $invoice['subtotal'] ?? 0;
$vatAmount = $invoice['vat_amount'] ?? 0;
$totalAmount = $invoice['total_amount'] ?? 0;
$paidAmount = floatval($invoice['paid_amount'] ?? 0);
$remainingAmount = isset($invoice['remaining_amount']) && $invoice['remaining_amount'] !== '' && $invoice['remaining_amount'] !== null
    ? floatval($invoice['remaining_amount'])
    : max(floatval($totalAmount) - $paidAmount, 0);
$invoiceDateDisplay = !empty($invoice['invoice_date']) ? date('d/m/Y', strtotime($invoice['invoice_date'])) : '-';
$dueDateRaw = $invoice['due_date'] ?? $invoice['invoice_date'] ?? null;
$dueDateDisplay = !empty($dueDateRaw) ? date('d/m/Y', strtotime($dueDateRaw)) : '-';
$paymentStatus = trim((string)($invoice['payment_status'] ?? ''));
if (!$isAccountingNote && $paymentStatus === '') {
    if ($remainingAmount <= 0 && floatval($totalAmount) > 0) {
        $paymentStatus = 'paid';
    } elseif ($paidAmount > 0) {
        $paymentStatus = 'partial';
    } else {
        $paymentStatus = 'unpaid';
    }
}
$paymentStatusAr = 'غير مدفوعة';
if ($isAccountingNote) {
    $paymentStatusAr = 'غير مطبق';
} elseif ($paymentStatus === 'paid') {
    $paymentStatusAr = 'مدفوعة';
} elseif ($paymentStatus === 'partial') {
    $paymentStatusAr = 'مدفوعة جزئياً';
}
$paymentAmountDisplay = $isAccountingNote ? '-' : number_format($paidAmount, 2) . ' / ' . number_format($remainingAmount, 2);
$invoiceNotes = trim((string)($invoice['notes'] ?? ''));

// Convert number to Arabic words (simplified)
function numberToArabicWords($number) {
    $ones = ['', 'واحد', 'اثنان', 'ثلاثة', 'أربعة', 'خمسة', 'ستة', 'سبعة', 'ثمانية', 'تسعة', 'عشرة',
             'أحد عشر', 'اثنا عشر', 'ثلاثة عشر', 'أربعة عشر', 'خمسة عشر', 'ستة عشر', 'سبعة عشر', 'ثمانية عشر', 'تسعة عشر'];
    $tens = ['', '', 'عشرون', 'ثلاثون', 'أربعون', 'خمسون', 'ستون', 'سبعون', 'ثمانون', 'تسعون'];
    $hundreds = ['', 'مائة', 'مائتان', 'ثلاثمائة', 'أربعمائة', 'خمسمائة', 'ستمائة', 'سبعمائة', 'ثمانمائة', 'تسعمائة'];
    $thousands = ['', 'ألف', 'ألفان', 'ثلاثة آلاف', 'أربعة آلاف', 'خمسة آلاف', 'ستة آلاف', 'سبعة آلاف', 'ثمانية آلاف', 'تسعة آلاف'];

    $number = intval($number);
    if ($number == 0) return 'صفر';
    if ($number < 20) return $ones[$number];

    $result = '';

    if ($number >= 1000) {
        $th = intval($number / 1000);
        if ($th < 10) $result .= $thousands[$th];
        else $result .= numberToArabicWords($th) . ' ألف';
        $number %= 1000;
        if ($number > 0) $result .= ' و ';
    }

    if ($number >= 100) {
        $result .= $hundreds[intval($number / 100)];
        $number %= 100;
        if ($number > 0) $result .= ' و ';
    }

    if ($number >= 20) {
        $t = intval($number / 10);
        $o = $number % 10;
        if ($o > 0) $result .= $ones[$o] . ' و ';
        $result .= $tens[$t];
    } elseif ($number > 0) {
        $result .= $ones[$number];
    }

    return $result;
}

$displayTotalAmount = $displaySign * floatval($totalAmount);
$wordsAmount = abs(floatval($displayTotalAmount));
$totalInWords = ($isCreditNote ? 'سالب ' : '') . numberToArabicWords(intval($wordsAmount)) . ' ريال';
$halalas = intval(($wordsAmount - intval($wordsAmount)) * 100);
if ($halalas > 0) {
    $totalInWords .= ' و ' . numberToArabicWords($halalas) . ' هللة';
}
$totalInWords .= ' فقط لا غير';
?>

