            <div class="detail-row">
                <span class="detail-label">UUID:</span>
                <span class="detail-value"><?php echo htmlspecialchars($invoice['zatca_uuid']); ?></span>
            </div>
            <?php endif; ?>
            <?php if (!empty($invoice['zatca_hash'])): ?>
            <div class="detail-row">
                <span class="detail-label">Hash:</span>
                <span class="detail-value"><?php echo htmlspecialchars($invoice['zatca_hash']); ?></span>
            </div>
            <?php endif; ?>
            <?php if (!empty($invoice['zatca_submission_date'])): ?>
            <div class="detail-row">
                <span class="detail-label">تاريخ الإرسال:</span>
                <span class="detail-value"><?php echo $invoice['zatca_submission_date']; ?></span>
            </div>
            <?php endif; ?>
        </div>
        <?php endif; ?>

        <!-- ZATCA Validation Messages from API Response -->
        <?php
        if (!empty($submissionLog['api_response'])):
            $apiResponse = json_decode($submissionLog['api_response'], true);
            $validationResults = $apiResponse['validation_results'] ?? [];
            $warningMessages = $validationResults['warningMessages'] ?? [];
            $errorMessages = $validationResults['errorMessages'] ?? [];

            if (!empty($warningMessages) || !empty($errorMessages)):
        ?>
        <div class="zatca-details no-print" style="margin-top: 20px;">
            <?php if (!empty($warningMessages)): ?>
            <div style="margin-bottom: 15px;">
                <strong style="color: #c05621; margin-bottom: 10px; display: block;">
                    <i class="bi bi-exclamation-triangle me-2"></i>تحذيرات ZATCA (<?php echo count($warningMessages); ?>)
                </strong>
                <ol style="margin: 0; padding-right: 20px; font-size: 0.9rem;">
                    <?php foreach ($warningMessages as $msg): ?>
                    <li style="margin-bottom: 8px;">
                        <strong>[<?php echo htmlspecialchars($msg['code'] ?? ''); ?>]</strong>
                        <?php echo htmlspecialchars($msg['message'] ?? ''); ?>
                    </li>
                    <?php endforeach; ?>
                </ol>
            </div>
            <?php endif; ?>

            <?php if (!empty($errorMessages)): ?>
            <div>
                <strong style="color: #c53030; margin-bottom: 10px; display: block;">
                    <i class="bi bi-x-circle me-2"></i>أخطاء ZATCA (<?php echo count($errorMessages); ?>)
                </strong>
                <ol style="margin: 0; padding-right: 20px; font-size: 0.9rem;">
                    <?php foreach ($errorMessages as $msg): ?>
                    <li style="margin-bottom: 8px;">
                        <strong>[<?php echo htmlspecialchars($msg['code'] ?? ''); ?>]</strong>
                        <?php echo htmlspecialchars($msg['message'] ?? ''); ?>
                    </li>
                    <?php endforeach; ?>
                </ol>
            </div>
            <?php endif; ?>
        </div>
        <?php
            endif;
        endif;
        ?>
    </div>
</div>

<!-- Result Modal -->
<div class="modal fade" id="resultModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 10px; overflow: hidden;">
            <div class="modal-header border-0" id="resultModalHeader" style="background: #48bb78;">
                <h5 class="modal-title text-white" id="resultModalTitle">
                    <i class="bi bi-check-circle me-2"></i>نتيجة العملية
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <p id="resultModalMessage" style="white-space: pre-wrap;"></p>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إغلاق</button>
            </div>
        </div>
    </div>
</div>

<script>
function submitToZatca(invoiceId) {
    if (window.confirm('هل تريد إرسال هذه الفاتورة إلى ZATCA؟')) {
        performZatcaSubmission(invoiceId);
    }
}

function performZatcaSubmission(invoiceId) {
    const loadingModal = new bootstrap.Modal(document.getElementById('resultModal'));
    const header = document.getElementById('resultModalHeader');
    const title = document.getElementById('resultModalTitle');
    const messageEl = document.getElementById('resultModalMessage');

    header.style.background = '#4299e1';
    title.innerHTML = '<i class="bi bi-hourglass-split me-2"></i>جاري الإرسال';
    messageEl.textContent = 'جاري إرسال الفاتورة إلى ZATCA...';
    loadingModal.show();

    const formData = new FormData();
    formData.append('action', 'submit_to_zatca');
    formData.append('invoice_id', invoiceId);

    fetch('index.hnt', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        loadingModal.hide();

        if (data.success) {
            let successMessage = data.message || 'تم إرسال الفاتورة بنجاح';

            if (data.zatca_uuid) {
                successMessage += '\n\nUUID: ' + data.zatca_uuid;
            }
            if (data.zatca_hash) {
                successMessage += '\nHash: ' + data.zatca_hash.substring(0, 40) + '...';
            }
            if (data.api_result) {
                if (data.api_result.status) {
                    successMessage += '\nStatus: ' + data.api_result.status;
                }
            }

            successMessage += '\n\nسيتم تحديث الصفحة خلال 6 ثواني...';

            showResultModal(true, successMessage);
            setTimeout(() => location.reload(), 6000);
        } else {
            let errorMessage = data.message || data.error || 'خطأ غير معروف';

            if (data.technical_details) {
                errorMessage += '\n\n--- تفاصيل تقنية ---';
                if (data.technical_details.error) {
                    errorMessage += '\nError: ' + data.technical_details.error;
                }
                if (data.technical_details.http_code) {
                    errorMessage += '\nHTTP Code: ' + data.technical_details.http_code;
                }
            }

            showResultModal(false, errorMessage);
        }
    })
    .catch(error => {
        loadingModal.hide();
        console.error('Error:', error);
        showResultModal(false, 'حدث خطأ أثناء الإرسال إلى ZATCA');
    });
}

function saveInvoiceNote(invoiceId) {
    const notesField = document.getElementById('invoiceNotes');
    const statusEl = document.getElementById('invoiceNotesStatus');
    const notes = notesField.value;

    statusEl.textContent = 'جاري الحفظ...';

    const formData = new FormData();
    formData.append('ajax_action', 'update_invoice_note');
    formData.append('invoice_id', invoiceId);
    formData.append('notes', notes);

    fetch('index.hnt', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            statusEl.textContent = data.message || 'تم حفظ الملاحظات بنجاح';
            setTimeout(() => {
                location.reload();
            }, 500);
        } else {
            statusEl.textContent = data.message || data.error || 'فشل في حفظ الملاحظات';
        }
    })
    .catch(() => {
        statusEl.textContent = 'حدث خطأ أثناء حفظ الملاحظات';
    });
}

function showResultModal(success, message) {
    const modalElement = document.getElementById('resultModal');
    const modal = new bootstrap.Modal(modalElement);
    const header = document.getElementById('resultModalHeader');
    const title = document.getElementById('resultModalTitle');
    const messageEl = document.getElementById('resultModalMessage');

    if (success) {
        header.style.background = 'linear-gradient(135deg, #28a745, #20c997)';
        title.innerHTML = '<i class="bi bi-check-circle me-2"></i>نجحت العملية';
    } else {
        header.style.background = 'linear-gradient(135deg, #dc3545, #c82333)';
        title.innerHTML = '<i class="bi bi-x-circle me-2"></i>فشلت العملية';
    }

    messageEl.textContent = message;

    modalElement.addEventListener('hidden.bs.modal', function() {
        modal.dispose();
        const backdrops = document.querySelectorAll('.modal-backdrop');
        backdrops.forEach(backdrop => backdrop.remove());
        document.body.classList.remove('modal-open');
        document.body.style.removeProperty('overflow');
        document.body.style.removeProperty('padding-right');
    }, { once: true });

    modal.show();
}
</script>

<script src="/aqary/js/qrcode.min.js"></script>
<script>
<?php if (!empty($invoice['zatca_qr_code'])): ?>
var qrcodeZatca = new QRCode("qrcode-zatca", {
    text: "<?php echo addslashes($invoice['zatca_qr_code']); ?>",
    width: 120,
    height: 120,
    colorDark: "#10286e",
    colorLight: "#ffffff",
    correctLevel: QRCode.CorrectLevel.L
});
<?php endif; ?>

<?php if (!empty($invoice['zatca_hash'])): ?>
var qrcodeHash = new QRCode("qrcode-hash", {
    text: "<?php echo addslashes($invoice['zatca_hash']); ?>",
    width: 120,
    height: 120,
    colorDark: "#2c5282",
    colorLight: "#ffffff",
    correctLevel: QRCode.CorrectLevel.L
});
<?php endif; ?>
</script>

