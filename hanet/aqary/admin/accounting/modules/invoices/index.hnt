    box-shadow: 0 4px 15px rgba(0,0,0,0.08);
}

.stats-value {
    font-size: 2rem;
    font-weight: bold;
    color: var(--primary-color);
}

#customerDropdown {
    box-shadow: 0 4px 15px rgba(0,0,0,0.15);
    border-radius: 8px;
    margin-top: 5px;
}

#customerDropdown .list-group-item {
    border: none;
    border-bottom: 1px solid #f0f0f0;
    transition: all 0.2s ease;
}

#customerDropdown .list-group-item:hover {
    background: #f8f9fa;
    transform: translateX(-3px);
}

#customerDropdown .list-group-item:last-child {
    border-bottom: none;
}

#customerDetails {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 2px solid #f0f0f0;
}
</style>

<div class="container-fluid p-4">
    <!-- Header -->
    <div class="page-header">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1 class="mb-2">
                    <i class="bi bi-receipt me-2"></i>الفواتير الإلكترونية
                </h1>
                <p class="mb-0 opacity-75">E-Invoices - ZATCA Compliant</p>
            </div>
            <div>
                <button class="btn btn-light btn-lg" onclick="window.location='../../index.hnt'">
                    <i class="bi bi-arrow-right me-2"></i>العودة
                </button>
                <button class="btn btn-add-invoice btn-lg ms-2" data-bs-toggle="modal" data-bs-target="#addInvoiceModal">
                    <i class="bi bi-plus-circle me-2"></i>فاتورة جديدة
                </button>
            </div>
        </div>
    </div>

    <!-- Statistics -->
