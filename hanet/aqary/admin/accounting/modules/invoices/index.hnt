<?php
/**
 * Invoices Module - ZATCA Compliant
 * الفواتير الإلكترونية
 *
 * @charset UTF-8
 * @version 1.0
 * @zatca Phase 2 Compliant
 */

$sc_title = "الفواتير الإلكترونية";
$sc_id = "204";
$use_accounting_theme = true;

// Export / template handler — runs before any HTML output
if (isset($_GET['export']) && in_array($_GET['export'], ['csv', 'xls', 'template'], true)) {
    include_once "../../../../reqloginajax.hnt";
    include_once "../../includes/accounting_class.hnt";

    $_fn       = date('Ymd_His');
    $_exp_type = $_GET['export'];

    if ($_exp_type === 'template') {
        $tpl_headers = ['رقم المجموعة', 'تاريخ الفاتورة (dd/mm/yyyy)', 'نوع المستند', 'اسم العميل', 'الرقم الضريبي للعميل', 'طريقة الدفع', 'ملاحظات', 'وصف البند', 'الكمية', 'السعر', 'نسبة الضريبة %', 'خصم'];
        header('Content-Type: text/csv; charset=UTF-8');
        header('Content-Disposition: attachment; filename="invoices_template_' . $_fn . '.csv"');
        $_out = fopen('php://output', 'w');
        fwrite($_out, "\xEF\xBB\xBF");
        fputcsv($_out, $tpl_headers, ',', '"', '\\');
        fputcsv($_out, ['1', date('d/m/Y'), 'standard', 'اسم العميل', '300000000000003', 'cash', 'ملاحظة اختيارية', 'خدمة إيجار', '1', '5000.00', '15', '0'], ',', '"', '\\');
        fputcsv($_out, ['1', '', '', '', '', '', '', 'رسوم صيانة', '1', '500.00', '15', '0'], ',', '"', '\\');
        fclose($_out);
        exit;
    }

    $exp_headers = ['رقم الفاتورة', 'التاريخ', 'نوع المستند', 'اسم العميل', 'الرقم الضريبي', 'المبلغ قبل الضريبة', 'ضريبة القيمة المضافة', 'الإجمالي', 'حالة السداد', 'حالة ZATCA'];
    $exp_rows    = [];
    $_er = $db->query("SELECT invoice_number, invoice_date, invoice_type, customer_name, customer_vat_number, subtotal, vat_amount, total_amount, payment_status, zatca_status FROM acc_invoices ORDER BY invoice_date DESC, invoice_id DESC");
    if ($_er) {
        while ($_inv = $_er->fetch_assoc()) {
            $_typeLabels = ['standard' => 'فاتورة ضريبية', 'simplified' => 'فاتورة مبسطة', 'credit_note' => 'إشعار دائن', 'debit_note' => 'إشعار مدين'];
            $exp_rows[] = [
                $_inv['invoice_number'],
                date('d/m/Y', strtotime($_inv['invoice_date'])),
                $_typeLabels[$_inv['invoice_type']] ?? $_inv['invoice_type'],
                $_inv['customer_name'],
                $_inv['customer_vat_number'] ?? '',
                number_format(floatval($_inv['subtotal']),    2, '.', ''),
                number_format(floatval($_inv['vat_amount']),  2, '.', ''),
                number_format(floatval($_inv['total_amount']), 2, '.', ''),
                $_inv['payment_status'] ?? '',
                $_inv['zatca_status'] ?? ''
            ];
        }
    }

    if ($_exp_type === 'csv') {
        header('Content-Type: text/csv; charset=UTF-8');
        header('Content-Disposition: attachment; filename="invoices_' . $_fn . '.csv"');
        $_out = fopen('php://output', 'w');
        fwrite($_out, "\xEF\xBB\xBF");
        fputcsv($_out, $exp_headers, ',', '"', '\\');
        foreach ($exp_rows as $_r) fputcsv($_out, $_r, ',', '"', '\\');
        fclose($_out);
        exit;
    }

    header('Content-Type: application/vnd.ms-excel; charset=UTF-8');
    header('Content-Disposition: attachment; filename="invoices_' . $_fn . '.xls"');
    echo '<html lang="ar" dir="rtl"><head><meta charset="UTF-8"></head><body><table border="1"><tr>';
    foreach ($exp_headers as $_h) echo '<th>' . htmlspecialchars($_h) . '</th>';
    echo '</tr>';
    foreach ($exp_rows as $_r) { echo '<tr>'; foreach ($_r as $_c) echo '<td>' . htmlspecialchars($_c) . '</td>'; echo '</tr>'; }
    echo '</table></body></html>';
    exit;
}

if ($_SERVER['REQUEST_METHOD'] != 'POST' && !isset($_POST['ajax_action'])) {
include_once "../../../../header.hnt";

// Add seller columns to acc_invoices (safe - checks if column exists first)
$checkCol = mysql_query("SHOW COLUMNS FROM acc_invoices LIKE 'seller_source'", $link);
if ($checkCol && mysql_num_rows($checkCol) == 0) {
    mysql_query("ALTER TABLE acc_invoices ADD COLUMN seller_source VARCHAR(150) DEFAULT NULL", $link);
}
$checkCol = mysql_query("SHOW COLUMNS FROM acc_invoices LIKE 'seller_supplier_id'", $link);
if ($checkCol && mysql_num_rows($checkCol) == 0) {
    mysql_query("ALTER TABLE acc_invoices ADD COLUMN seller_supplier_id INT(11) DEFAULT NULL", $link);
}
$checkCol = mysql_query("SHOW COLUMNS FROM acc_invoices LIKE 'seller_name'", $link);
if ($checkCol && mysql_num_rows($checkCol) == 0) {
    mysql_query("ALTER TABLE acc_invoices ADD COLUMN seller_name VARCHAR(255) DEFAULT NULL", $link);
}
$checkCol = mysql_query("SHOW COLUMNS FROM acc_invoices LIKE 'seller_vat_number'", $link);
if ($checkCol && mysql_num_rows($checkCol) == 0) {
    mysql_query("ALTER TABLE acc_invoices ADD COLUMN seller_vat_number VARCHAR(50) DEFAULT NULL", $link);
}
$checkCol = mysql_query("SHOW COLUMNS FROM acc_invoices LIKE 'seller_address'", $link);
if ($checkCol && mysql_num_rows($checkCol) == 0) {
    mysql_query("ALTER TABLE acc_invoices ADD COLUMN seller_address TEXT DEFAULT NULL", $link);
}



}
else {
include_once "../../../../reqloginajax.hnt";
}
include_once "../../includes/accounting_class.hnt";
// Include data.hnt to get $zatca_environment global variable
include_once __DIR__ . '/../../../../data.hnt';
$accountingManager = new AccountingManager($db, $_SESSION['userid'] ?? 1);
$accountingManager->ensureInvoiceDimensionColumnsExist();
$dimensionOptions = $accountingManager->getReportDimensionOptions();

// Handle ZATCA submission
if ($_SERVER['REQUEST_METHOD'] == 'POST' && isset($_POST['action']) && $_POST['action'] == 'submit_to_zatca') {
    header('Content-Type: application/json; charset=utf-8');

    $invoiceId = $_POST['invoice_id'] ?? 0;

    try {
        // Ensure ZATCA columns exist in acc_invoices table
        $checkColumns = $db->query("SHOW COLUMNS FROM acc_invoices LIKE 'zatca_status'");
        if ($checkColumns->num_rows == 0) {
            $alterSQL = "ALTER TABLE acc_invoices
                ADD COLUMN zatca_status VARCHAR(50) NULL AFTER payment_status,
                ADD COLUMN zatca_uuid VARCHAR(100) NULL AFTER zatca_status,
                ADD COLUMN zatca_hash VARCHAR(255) NULL AFTER zatca_uuid,
                ADD COLUMN zatca_qr_code TEXT NULL AFTER zatca_hash,
                ADD COLUMN zatca_xml TEXT NULL AFTER zatca_qr_code,
                ADD COLUMN zatca_submission_date DATETIME NULL AFTER zatca_xml";

            if (!$db->query($alterSQL)) {
                echo json_encode([
                    'success' => false,
                    'error' => 'فشل في إضافة أعمدة ZATCA: ' . $db->error
                ], JSON_UNESCAPED_UNICODE);
                exit;
            }
        }

        // Ensure acc_invoice_items table exists
        $checkTable = $db->query("SHOW TABLES LIKE 'acc_invoice_items'");
        if ($checkTable->num_rows == 0) {
            $createTable = "CREATE TABLE acc_invoice_items (
                item_id INT AUTO_INCREMENT PRIMARY KEY,
                invoice_id INT NOT NULL,
                item_description VARCHAR(255) NOT NULL,
                quantity DECIMAL(10,2) NOT NULL,
                unit_price DECIMAL(10,2) NOT NULL,
                vat_rate DECIMAL(5,2) DEFAULT 15.00,
                discount DECIMAL(10,2) DEFAULT 0,
                line_total DECIMAL(10,2) NOT NULL,
                created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                FOREIGN KEY (invoice_id) REFERENCES acc_invoices(invoice_id) ON DELETE CASCADE,
                INDEX idx_invoice (invoice_id)
            ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4";

            if (!$db->query($createTable)) {
                echo json_encode([
                    'success' => false,
                    'error' => 'فشل في إنشاء جدول عناصر الفاتورة: ' . $db->error
                ], JSON_UNESCAPED_UNICODE);
                exit;
            }
        }

        // Include ZATCA integration files
        require_once __DIR__ . '/../../../../admin/zatca/config/zatca_config.php';
        require_once __DIR__ . '/../../../../admin/zatca/config/phase2_config.php';
        require_once __DIR__ . '/../../../../admin/zatca/phase2/integration/Phase2Manager.php';

        // Get invoice details
        $stmt = $db->prepare("SELECT * FROM acc_invoices WHERE invoice_id = ?");
        $stmt->bind_param('i', $invoiceId);
        $stmt->execute();
        $invoice = $stmt->get_result()->fetch_assoc();

        if (!$invoice) {
            echo json_encode([
                'success' => false,
                'error' => 'الفاتورة غير موجودة'
            ], JSON_UNESCAPED_UNICODE);
            exit;
        }

        $invoiceSellerSource = trim((string)($invoice['seller_source'] ?? 'company'));
        $invoiceSellerVat = trim((string)($invoice['seller_vat_number'] ?? ''));
        $companyCertificateVat = trim((string)($zatca_vat_number ?? $vat_number ?? ''));

        if ($invoiceSellerSource !== 'company') {
            echo json_encode([
                'success' => false,
                'error' => 'لا يمكن إرسال الفاتورة إلى ZATCA لمورد آخر باستخدام شهادة المؤسسة الحالية',
                'technical_details' => [
                    'error' => 'certificate-permissions',
                    'error_detail' => 'Current ZATCA certificate can only be used for the company seller profile',
                    'invoice_seller_source' => $invoiceSellerSource,
                    'invoice_seller_vat_number' => $invoiceSellerVat,
                    'certificate_vat_number' => $companyCertificateVat
                ]
            ], JSON_UNESCAPED_UNICODE);
            exit;
        }

        if ($invoiceSellerVat !== '' && $companyCertificateVat !== '' && $invoiceSellerVat !== $companyCertificateVat) {
            echo json_encode([
                'success' => false,
                'error' => 'لا يمكن إرسال الفاتورة إلى ZATCA لأن الرقم الضريبي للبائع لا يطابق شهادة المؤسسة الحالية',
                'technical_details' => [
                    'error' => 'certificate-permissions',
                    'error_detail' => 'Invoice seller VAT number does not match the VAT number bound to the active ZATCA certificate',
                    'invoice_seller_source' => $invoiceSellerSource,
                    'invoice_seller_vat_number' => $invoiceSellerVat,
                    'certificate_vat_number' => $companyCertificateVat
                ]
            ], JSON_UNESCAPED_UNICODE);
            exit;
        }

        // Get invoice items
        $itemsStmt = $db->prepare("SELECT * FROM acc_invoice_items WHERE invoice_id = ?");
        $itemsStmt->bind_param('i', $invoiceId);
        $itemsStmt->execute();
        $itemsResult = $itemsStmt->get_result();
        $items = [];
        while ($item = $itemsResult->fetch_assoc()) {
            $items[] = $item;
        }

        // Initialize Phase2Manager (uses global $zatca_environment)
        $phase2Manager = new Phase2Manager($db);

        // Prepare invoice data for ZATCA
        $invoiceTypeKey = trim((string)($invoice['invoice_type'] ?? 'standard'));
        $isSimplifiedInvoice = $invoiceTypeKey === 'simplified';
        $isCreditNote = $invoiceTypeKey === 'credit_note';
        $isDebitNote = $invoiceTypeKey === 'debit_note';

        $zatcaInvoice = [
            'invoice_number' => $invoice['invoice_number'],
            'invoice_date' => $invoice['invoice_date'],
            'profile' => 'reporting:1.0',
            'invoice_type' => $isCreditNote ? '381' : ($isDebitNote ? '383' : '388'),
            'is_standard' => !$isSimplifiedInvoice,
            'is_credit' => $isCreditNote,
            'is_debit' => $isDebitNote,
            'currency' => 'SAR',
            'base_amount' => $invoice['subtotal'],
            'vat_amount' => $invoice['vat_amount'],
            'total_amount' => $invoice['total_amount'],
            'seller_name' => $invoice['seller_name'] ?? ($zatca_company_name_ar ?? $bayanmaktabname ?? ''),
            'seller_vat_number' => $invoice['seller_vat_number'] ?? ($zatca_vat_number ?? $vat_number ?? ''),
            'seller_address' => $invoice['seller_address'] ?? ($zatca_company_address_ar ?? $bayanaddress ?? ''),
            'note' => $invoice['notes'] ?? '',
            'customer' => [
                'name' => $invoice['customer_name'],
                'vat_number' => $invoice['customer_vat_number'] ?? '',
                'address' => $invoice['customer_address'] ?? ''
            ],
            'items' => array_map(function($item) {
                return [
                    'name' => $item['item_description'],
                    'quantity' => $item['quantity'],
                    'unit_price' => $item['unit_price'],
                    'tax_rate' => $item['vat_rate'],
                    'discount' => $item['discount'] ?? 0
                ];
            }, $items)
        ];

        // Create submission log table if not exists
        $createLogTable = "CREATE TABLE IF NOT EXISTS zatca_submission_log (
            log_id INT AUTO_INCREMENT PRIMARY KEY,
            invoice_id INT NOT NULL,
            submission_date DATETIME DEFAULT CURRENT_TIMESTAMP,
            status VARCHAR(20) NOT NULL,
            zatca_uuid VARCHAR(100) NULL,
            zatca_hash VARCHAR(255) NULL,
            api_response TEXT NULL,
            error_message TEXT NULL,
            INDEX idx_invoice (invoice_id),
            INDEX idx_status (status)
        ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4";
        $db->query($createLogTable);

        // Submit to ZATCA
        $invoiceType = $isSimplifiedInvoice ? 'simplified' : 'standard';
        $result = $phase2Manager->processInvoice($zatcaInvoice, $invoiceType, true);

        // Check if local processing (XML + signing) succeeded
        if ($result['success']) {
            // Ensure columns exist
            $checkUuidColumn = $db->query("SHOW COLUMNS FROM acc_invoices LIKE 'zatca_uuid'");
            if ($checkUuidColumn->num_rows == 0) {
                $db->query("ALTER TABLE acc_invoices ADD COLUMN zatca_uuid VARCHAR(100) NULL AFTER zatca_status");
            }

            $checkHashColumn = $db->query("SHOW COLUMNS FROM acc_invoices LIKE 'zatca_hash'");
            if ($checkHashColumn->num_rows == 0) {
                $db->query("ALTER TABLE acc_invoices ADD COLUMN zatca_hash VARCHAR(255) NULL AFTER zatca_uuid");
            }

            $checkSubmissionDateColumn = $db->query("SHOW COLUMNS FROM acc_invoices LIKE 'zatca_submission_date'");
            if ($checkSubmissionDateColumn->num_rows == 0) {
                $db->query("ALTER TABLE acc_invoices ADD COLUMN zatca_submission_date DATETIME NULL");
            }

            $checkErrorColumn = $db->query("SHOW COLUMNS FROM acc_invoices LIKE 'zatca_error'");
            if ($checkErrorColumn->num_rows == 0) {
                $db->query("ALTER TABLE acc_invoices ADD COLUMN zatca_error TEXT NULL");
            }

            // Check if actual ZATCA API submission succeeded
            $apiResult = $result['api_result'] ?? null;
            $zatcaSuccess = false;
            $zatcaError = null;
            $zatcaErrorDetails = null;

            if ($apiResult && isset($apiResult['success']) && $apiResult['success']) {
                // ZATCA API submission succeeded
                $zatcaSuccess = true;
                $finalStatus = 'submitted';
            } else {
                // ZATCA API submission failed or was not attempted
                if ($apiResult && isset($apiResult['error'])) {
                    $zatcaError = $apiResult['error'];

                    // Extract full technical details from API response
                    $zatcaErrorDetails = [
                        'error' => $apiResult['error'] ?? null,
                        'error_detail' => $apiResult['error_detail'] ?? null,
                        'http_code' => $apiResult['http_code'] ?? null,
                        'api_url' => $apiResult['api_url'] ?? null,
                        'validation_results' => $apiResult['validation_results'] ?? [],
                        'api_response' => $apiResult['data'] ?? null
                    ];
                } else {
                    $zatcaError = 'لم يتم إرسال الفاتورة إلى ZATCA - الشهادات أو الإعدادات مفقودة';
                }
                $finalStatus = 'signed_locally';
            }

            // Update invoice with results
            $zatcaUuid = $result['uuid'] ?? '';
            $zatcaHash = $result['hash'] ?? '';

            if ($zatcaSuccess) {
                // Save success result in zatca_error field (reusing field for both success and error messages)
                $zatcaResultMsg = 'SUCCESS: تم إرسال الفاتورة بنجاح';

                if ($apiResult) {
                    if (!empty($apiResult['status'])) {
                        $zatcaResultMsg .= ' | Status: ' . $apiResult['status'];
                    }
                    if (!empty($apiResult['cleared_invoice'])) {
                        $zatcaResultMsg .= ' | Cleared';
                    }
                    if (!empty($apiResult['reported_invoice'])) {
                        $zatcaResultMsg .= ' | Reported';
                    }

                    // ZATCA API returns validation_results as an OBJECT with:
                    // - infoMessages: array of {type, code, category, message, status}
                    // - warningMessages: array of {type, code, category, message, status}
                    // - errorMessages: array of {type, code, category, message, status}
                    // - status: overall status (PASS, WARNING, ERROR)
                    if (!empty($apiResult['validation_results']) && is_array($apiResult['validation_results'])) {
                        $vr = $apiResult['validation_results'];
                        $overallStatus = $vr['status'] ?? '';

                        // Count total messages
                        $infoCount = count($vr['infoMessages'] ?? []);
                        $warnCount = count($vr['warningMessages'] ?? []);
                        $errorCount = count($vr['errorMessages'] ?? []);
                        $totalCount = $infoCount + $warnCount + $errorCount;

                        $zatcaResultMsg .= " | Validations: {$totalCount} [{$overallStatus}]";

                        // Add warning messages
                        if (!empty($vr['warningMessages']) && is_array($vr['warningMessages'])) {
                            $zatcaResultMsg .= "\n\n⚠️ تحذيرات ({$warnCount}):";
                            foreach ($vr['warningMessages'] as $msg) {
                                $code = $msg['code'] ?? '';
                                $text = $msg['message'] ?? '';
                                $category = $msg['category'] ?? '';
                                $zatcaResultMsg .= "\n- [{$code}] ({$category}): {$text}";
                            }
                        }

                        // Add error messages
                        if (!empty($vr['errorMessages']) && is_array($vr['errorMessages'])) {
                            $zatcaResultMsg .= "\n\n❌ أخطاء ({$errorCount}):";
                            foreach ($vr['errorMessages'] as $msg) {
                                $code = $msg['code'] ?? '';
                                $text = $msg['message'] ?? '';
                                $category = $msg['category'] ?? '';
                                $zatcaResultMsg .= "\n- [{$code}] ({$category}): {$text}";
                            }
                        }

                        // Add info messages (optional, less important)
                        if (!empty($vr['infoMessages']) && is_array($vr['infoMessages'])) {
                            $zatcaResultMsg .= "\n\n✅ معلومات ({$infoCount}):";
                            foreach ($vr['infoMessages'] as $msg) {
                                $code = $msg['code'] ?? '';
                                $text = $msg['message'] ?? '';
                                $zatcaResultMsg .= "\n- [{$code}]: {$text}";
                            }
                        }
                    }
                }
                $updateStmt = $db->prepare("UPDATE acc_invoices SET zatca_status = ?, zatca_uuid = ?, zatca_hash = ?, zatca_submission_date = NOW(), zatca_error = ? WHERE invoice_id = ?");
                $updateStmt->bind_param('ssssi', $finalStatus, $zatcaUuid, $zatcaHash, $zatcaResultMsg, $invoiceId);
            } else {
                $updateStmt = $db->prepare("UPDATE acc_invoices SET zatca_status = ?, zatca_uuid = ?, zatca_hash = ?, zatca_error = ? WHERE invoice_id = ?");
                $updateStmt->bind_param('ssssi', $finalStatus, $zatcaUuid, $zatcaHash, $zatcaError, $invoiceId);
            }

            $updateStmt->execute();

            // Log the submission attempt
            $logStatus = $zatcaSuccess ? 'success' : 'failed';
            $apiResponseJson = $apiResult ? json_encode($apiResult, JSON_UNESCAPED_UNICODE) : null;

            $logStmt = $db->prepare("INSERT INTO zatca_submission_log (invoice_id, status, zatca_uuid, zatca_hash, api_response, error_message) VALUES (?, ?, ?, ?, ?, ?)");
            $logStmt->bind_param('isssss', $invoiceId, $logStatus, $zatcaUuid, $zatcaHash, $apiResponseJson, $zatcaError);
            $logStmt->execute();

            if ($zatcaSuccess) {
                echo json_encode([
                    'success' => true,
                    'message' => 'تم إرسال الفاتورة إلى ZATCA بنجاح',
                    'zatca_uuid' => $zatcaUuid,
                    'zatca_hash' => $zatcaHash,
                    'api_result' => $apiResult
                ], JSON_UNESCAPED_UNICODE);
            } else {
                echo json_encode([
                    'success' => false,
                    'error' => 'تم توقيع الفاتورة محلياً ولكن فشل الإرسال إلى ZATCA: ' . $zatcaError,
                    'technical_details' => $zatcaErrorDetails,
                    'zatca_uuid' => $zatcaUuid,
                    'zatca_hash' => $zatcaHash
                ], JSON_UNESCAPED_UNICODE);
            }
        } else {
            // Local processing failed (XML generation or signing failed)
            echo json_encode([
                'success' => false,
                'error' => $result['error'] ?? 'فشل في معالجة الفاتورة'
            ], JSON_UNESCAPED_UNICODE);
        }
    } catch (Exception $e) {
        echo json_encode([
            'success' => false,
            'error' => 'خطأ: ' . $e->getMessage()
        ], JSON_UNESCAPED_UNICODE);
    }

    exit;
}

// Handle AJAX actions
if ($_SERVER['REQUEST_METHOD'] == 'POST' && isset($_POST['ajax_action'])) {
    header('Content-Type: application/json; charset=utf-8');

    $action = $_POST['ajax_action'];
    $response = ['success' => false, 'message' => ''];

    switch ($action) {
        case 'search_customers':
            $searchTerm = $_POST['search'] ?? '';
            $query = "SELECT customer_id, customer_name, vat_number, phone, address FROM acc_customers WHERE is_active = 1 AND (customer_name LIKE ? OR vat_number LIKE ? OR phone LIKE ?) ORDER BY customer_name LIMIT 10";
            $stmt = $db->prepare($query);
            $searchParam = "%{$searchTerm}%";
            $stmt->bind_param('sss', $searchParam, $searchParam, $searchParam);
            $stmt->execute();
            $result = $stmt->get_result();
            $customers = [];
            while ($row = $result->fetch_assoc()) {
                $customers[] = $row;
            }
            $response = ['success' => true, 'customers' => $customers];
            break;

        case 'add_customer_quick':
            $name = trim($_POST['customer_name'] ?? '');
            $vatNumber = trim($_POST['vat_number'] ?? '');
            $phone = trim($_POST['phone'] ?? '');
            $address = trim($_POST['address'] ?? '');

            if (empty($name)) {
                $response = ['success' => false, 'error' => 'Customer name is required', 'message' => 'اسم العميل مطلوب'];
                break;
            }

            $query = "INSERT INTO acc_customers (customer_name, vat_number, phone, address, is_active, created_at, formuid) VALUES (?, ?, ?, ?, 1, NOW(), UUID())";
            $stmt = $db->prepare($query);
            $stmt->bind_param('ssss', $name, $vatNumber, $phone, $address);

            if ($stmt->execute()) {
                $customerId = $stmt->insert_id;
                $response = [
                    'success' => true,
                    'message' => 'تم إضافة العميل بنجاح',
                    'customer' => [
                        'customer_id' => $customerId,
                        'customer_name' => $name,
                        'vat_number' => $vatNumber,
                        'phone' => $phone,
                        'address' => $address
                    ]
                ];
            } else {
                $response = ['success' => false, 'error' => $db->error, 'message' => 'فشل في إضافة العميل: ' . $db->error];
            }
            break;

        case 'update_customer_quick':
            $customerId = intval($_POST['customer_id'] ?? 0);
            $name = trim($_POST['customer_name'] ?? '');
            $vatNumber = trim($_POST['vat_number'] ?? '');
            $phone = trim($_POST['phone'] ?? '');
            $address = trim($_POST['address'] ?? '');

            if (empty($customerId)) {
                $response = ['success' => false, 'error' => 'Customer ID is required', 'message' => 'معرف العميل مطلوب'];
                break;
            }

            if (empty($name)) {
                $response = ['success' => false, 'error' => 'Customer name is required', 'message' => 'اسم العميل مطلوب'];
                break;
            }

            $query = "UPDATE acc_customers SET customer_name = ?, vat_number = ?, phone = ?, address = ? WHERE customer_id = ?";
            $stmt = $db->prepare($query);
            $stmt->bind_param('ssssi', $name, $vatNumber, $phone, $address, $customerId);

            if ($stmt->execute()) {
                $response = [
                    'success' => true,
                    'message' => 'تم حفظ بيانات العميل بنجاح',
                    'customer' => [
                        'customer_id' => $customerId,
                        'customer_name' => $name,
                        'vat_number' => $vatNumber,
                        'phone' => $phone,
                        'address' => $address
                    ]
                ];
            } else {
                $response = ['success' => false, 'error' => $db->error, 'message' => 'فشل في حفظ بيانات العميل: ' . $db->error];
            }
            break;

        case 'add_supplier_quick':
            $name = trim($_POST['supplier_name'] ?? '');
            $vatNumber = trim($_POST['vat_number'] ?? '');
            $phone = trim($_POST['phone'] ?? '');
            $address = trim($_POST['address'] ?? '');

            if (empty($name)) {
                $response = ['success' => false, 'error' => 'Supplier name is required', 'message' => 'اسم المورد مطلوب'];
                break;
            }

            $query = "INSERT INTO acc_suppliers (supplier_name, vat_number, phone, email, address, contact_person, is_active, formuid) VALUES (?, ?, ?, '', ?, '', 1, UUID())";
            $stmt = $db->prepare($query);
            $stmt->bind_param('ssss', $name, $vatNumber, $phone, $address);

            if ($stmt->execute()) {
                $supplierId = $stmt->insert_id;
                $response = [
                    'success' => true,
                    'message' => 'تم إضافة المورد بنجاح',
                    'supplier' => [
                        'supplier_id' => $supplierId,
                        'supplier_name' => $name,
                        'vat_number' => $vatNumber,
                        'phone' => $phone,
                        'address' => $address
                    ]
                ];
            } else {
                $response = ['success' => false, 'error' => $db->error, 'message' => 'فشل في إضافة المورد: ' . $db->error];
            }
            break;

        case 'update_supplier_quick':
            $supplierId = intval($_POST['supplier_id'] ?? 0);
            $name = trim($_POST['supplier_name'] ?? '');
            $vatNumber = trim($_POST['vat_number'] ?? '');
            $phone = trim($_POST['phone'] ?? '');
            $address = trim($_POST['address'] ?? '');

            if (empty($supplierId)) {
                $response = ['success' => false, 'error' => 'Supplier ID is required', 'message' => 'معرف المورد مطلوب'];
                break;
            }

            if (empty($name)) {
                $response = ['success' => false, 'error' => 'Supplier name is required', 'message' => 'اسم المورد مطلوب'];
                break;
            }

            $query = "UPDATE acc_suppliers SET supplier_name = ?, vat_number = ?, phone = ?, address = ? WHERE supplier_id = ?";
            $stmt = $db->prepare($query);
            $stmt->bind_param('ssssi', $name, $vatNumber, $phone, $address, $supplierId);

            if ($stmt->execute()) {
                $response = [
                    'success' => true,
                    'message' => 'تم حفظ بيانات المورد بنجاح',
                    'supplier' => [
                        'supplier_id' => $supplierId,
                        'supplier_name' => $name,
                        'vat_number' => $vatNumber,
                        'phone' => $phone,
                        'address' => $address
                    ]
                ];
            } else {
                $response = ['success' => false, 'error' => $db->error, 'message' => 'فشل في حفظ بيانات المورد: ' . $db->error];
            }
            break;

        case 'create_invoice':
            $customerId = intval($_POST['customer_id'] ?? 0);

            if (empty($customerId)) {
                $response = ['success' => false, 'error' => 'Customer ID is required', 'message' => 'معرف العميل مطلوب'];
                break;
            }

            $invoiceData = [
                'invoice_type' => $_POST['invoice_type'],
                'customer_id' => $customerId,
                'customer_type' => $_POST['customer_type'] ?? 'tenant',
                'customer_name' => $_POST['customer_name'],
                'customer_vat_number' => $_POST['customer_vat_number'] ?? null,
                'customer_address' => $_POST['customer_address'] ?? null,
                'invoice_date' => $_POST['invoice_date'],
                'due_date' => $_POST['due_date'] ?? null,
                'payment_method' => $_POST['payment_method'] ?? 'cash',
                'notes' => $_POST['notes'] ?? null,
                'seller_source' => $_POST['seller_source'] ?? 'company',
                'seller_supplier_id' => !empty($_POST['seller_supplier_id']) ? intval($_POST['seller_supplier_id']) : null,
                'seller_name' => $_POST['seller_name'] ?? null,
                'seller_vat_number' => $_POST['seller_vat_number'] ?? null,
                'seller_address' => $_POST['seller_address'] ?? null,
                'journal_id' => isset($_POST['journal_id']) && $_POST['journal_id'] !== '' ? intval($_POST['journal_id']) : null,
                'cost_center_id' => isset($_POST['cost_center_id']) && $_POST['cost_center_id'] !== '' ? intval($_POST['cost_center_id']) : null,
                'tenant_id' => isset($_POST['tenant_id']) && $_POST['tenant_id'] !== '' ? intval($_POST['tenant_id']) : null,
                'owner_id' => isset($_POST['owner_id']) && $_POST['owner_id'] !== '' ? intval($_POST['owner_id']) : null,
                'aqar_id' => isset($_POST['aqar_id']) && $_POST['aqar_id'] !== '' ? intval($_POST['aqar_id']) : null,
                'subaqar_id' => isset($_POST['subaqar_id']) && $_POST['subaqar_id'] !== '' ? intval($_POST['subaqar_id']) : null,
                'egar_id' => isset($_POST['egar_id']) && $_POST['egar_id'] !== '' ? intval($_POST['egar_id']) : null
            ];

            $items = json_decode($_POST['items'], true);

            if (empty($items) || !is_array($items)) {
                $response = ['success' => false, 'error' => 'No items provided', 'message' => 'يجب إضافة بنود للفاتورة'];
                break;
            }

            $result = $accountingManager->createInvoice($invoiceData, $items);
            $response = $result;
            if (!isset($response['message'])) {
                $response['message'] = $result['success'] ? 'تم إنشاء الفاتورة بنجاح' : ($result['error'] ?? 'فشل في إنشاء الفاتورة');
            }
            break;

        case 'update_invoice_note':
            $invoiceId = intval($_POST['invoice_id'] ?? 0);
            $notes = $_POST['notes'] ?? null;

            if (empty($invoiceId)) {
                $response = ['success' => false, 'error' => 'Invoice ID is required', 'message' => 'معرف الفاتورة مطلوب'];
                break;
            }

            $query = "UPDATE acc_invoices SET notes = ? WHERE invoice_id = ?";
            $stmt = $db->prepare($query);
            $stmt->bind_param('si', $notes, $invoiceId);

            if ($stmt->execute()) {
                $response = [
                    'success' => true,
                    'message' => 'تم حفظ الملاحظات بنجاح',
                    'notes' => $notes
                ];
            } else {
                $response = ['success' => false, 'error' => $db->error, 'message' => 'فشل في حفظ الملاحظات: ' . $db->error];
            }
            break;

        case 'get_invoice':
            $invoiceId = $_POST['invoice_id'];
            $query = "SELECT * FROM acc_invoices WHERE invoice_id = ?";
            $stmt = $db->prepare($query);
            $stmt->bind_param('i', $invoiceId);
            $stmt->execute();
            $result = $stmt->get_result();

            if ($invoice = $result->fetch_assoc()) {
                $response['success'] = true;
                $response['invoice'] = $invoice;
            }
            break;

        case 'get_invoice_with_items':
            $invoiceId = intval($_POST['invoice_id'] ?? 0);
            if (empty($invoiceId)) {
                $response = ['success' => false, 'error' => 'معرف الفاتورة مطلوب'];
                break;
            }
            $stmt = $db->prepare("SELECT * FROM acc_invoices WHERE invoice_id = ?");
            $stmt->bind_param('i', $invoiceId);
            $stmt->execute();
            $inv = $stmt->get_result()->fetch_assoc();
            if (!$inv) {
                $response = ['success' => false, 'error' => 'الفاتورة غير موجودة'];
                break;
            }
            $itemsStmt = $db->prepare("SELECT * FROM acc_invoice_items WHERE invoice_id = ? ORDER BY item_id ASC");
            $itemsStmt->bind_param('i', $invoiceId);
            $itemsStmt->execute();
            $itemsResult = $itemsStmt->get_result();
            $invItems = [];
            while ($itm = $itemsResult->fetch_assoc()) {
                $invItems[] = $itm;
            }
            $customerPhone = '';
            if (!empty($inv['customer_id'])) {
                $phoneStmt = $db->prepare("SELECT phone FROM acc_customers WHERE customer_id = ?");
                if ($phoneStmt) {
                    $phoneStmt->bind_param('i', $inv['customer_id']);
                    $phoneStmt->execute();
                    $phoneRow = $phoneStmt->get_result()->fetch_assoc();
                    if ($phoneRow) $customerPhone = $phoneRow['phone'] ?? '';
                }
            }
            $supplierPhone = '';
            if (!empty($inv['seller_supplier_id'])) {
                $supplierPhoneStmt = $db->prepare("SELECT phone FROM acc_suppliers WHERE supplier_id = ?");
                if ($supplierPhoneStmt) {
                    $supplierPhoneStmt->bind_param('i', $inv['seller_supplier_id']);
                    $supplierPhoneStmt->execute();
                    $supplierPhoneRow = $supplierPhoneStmt->get_result()->fetch_assoc();
                    if ($supplierPhoneRow) $supplierPhone = $supplierPhoneRow['phone'] ?? '';
                }
            }
            $response = ['success' => true, 'invoice' => $inv, 'items' => $invItems, 'customer_phone' => $customerPhone, 'supplier_phone' => $supplierPhone];
            break;

        case 'update_invoice':
            $invoiceId = intval($_POST['invoice_id'] ?? 0);
            if (empty($invoiceId)) {
                $response = ['success' => false, 'message' => 'معرف الفاتورة مطلوب'];
                break;
            }
            $checkStmt = $db->prepare("SELECT zatca_status FROM acc_invoices WHERE invoice_id = ?");
            $checkStmt->bind_param('i', $invoiceId);
            $checkStmt->execute();
            $checkRow = $checkStmt->get_result()->fetch_assoc();
            if (!$checkRow) {
                $response = ['success' => false, 'message' => 'الفاتورة غير موجودة'];
                break;
            }
            if ($checkRow['zatca_status'] === 'submitted') {
                $response = ['success' => false, 'message' => 'لا يمكن تعديل فاتورة تم إرسالها لـ ZATCA'];
                break;
            }
            $updItems = json_decode($_POST['items'], true);
            if (empty($updItems) || !is_array($updItems)) {
                $response = ['success' => false, 'message' => 'يجب إضافة بنود للفاتورة'];
                break;
            }
            $updSubtotal = 0;
            $updVatTotal = 0;
            foreach ($updItems as $ui) {
                $uQty = floatval($ui['quantity'] ?? 0);
                $uPrice = floatval($ui['unit_price'] ?? 0);
                $uLineSub = $uQty * $uPrice;
                $uLineVat = $uLineSub * (floatval($ui['vat_rate'] ?? 15) / 100);
                $updSubtotal += $uLineSub;
                $updVatTotal += $uLineVat;
            }
            $updTotal = $updSubtotal + $updVatTotal;
            $updInvoiceType = $_POST['invoice_type'] ?? 'standard';
            $updInvoiceDate = $_POST['invoice_date'] ?? date('Y-m-d');
            $updDueDate = !empty($_POST['due_date']) ? $_POST['due_date'] : null;
            $updCustomerId = intval($_POST['customer_id'] ?? 0);
            $updCustomerType = $_POST['customer_type'] ?? 'tenant';
            $updCustomerName = $_POST['customer_name'] ?? '';
            $updCustomerVat = $_POST['customer_vat_number'] ?? null;
            $updCustomerAddr = $_POST['customer_address'] ?? null;
            $updPayMethod = $_POST['payment_method'] ?? 'cash';
            $updNotes = $_POST['notes'] ?? null;
            $updSellerSrc = $_POST['seller_source'] ?? 'company';
            $updSellerSid = !empty($_POST['seller_supplier_id']) ? intval($_POST['seller_supplier_id']) : null;
            $updSellerName = $_POST['seller_name'] ?? null;
            $updSellerVatN = $_POST['seller_vat_number'] ?? null;
            $updSellerAddr = $_POST['seller_address'] ?? null;
            $updJournalId = isset($_POST['journal_id']) && $_POST['journal_id'] !== '' ? intval($_POST['journal_id']) : null;
            $updCostCenterId = isset($_POST['cost_center_id']) && $_POST['cost_center_id'] !== '' ? intval($_POST['cost_center_id']) : null;
            $updTenantId = isset($_POST['tenant_id']) && $_POST['tenant_id'] !== '' ? intval($_POST['tenant_id']) : null;
            $updOwnerId = isset($_POST['owner_id']) && $_POST['owner_id'] !== '' ? intval($_POST['owner_id']) : null;
            $updAqarId = isset($_POST['aqar_id']) && $_POST['aqar_id'] !== '' ? intval($_POST['aqar_id']) : null;
            $updSubaqarId = isset($_POST['subaqar_id']) && $_POST['subaqar_id'] !== '' ? intval($_POST['subaqar_id']) : null;
            $updEgarId = isset($_POST['egar_id']) && $_POST['egar_id'] !== '' ? intval($_POST['egar_id']) : null;
            $db->begin_transaction();
            try {
                $updStmt = $db->prepare("UPDATE acc_invoices SET invoice_type=?, invoice_date=?, due_date=?, journal_id=?, cost_center_id=?, tenant_id=?, owner_id=?, aqar_id=?, subaqar_id=?, egar_id=?, customer_id=?, customer_type=?, customer_name=?, customer_vat_number=?, customer_address=?, subtotal=?, vat_amount=?, total_amount=?, payment_method=?, notes=?, seller_source=?, seller_supplier_id=?, seller_name=?, seller_vat_number=?, seller_address=? WHERE invoice_id=?");
                $updStmt->bind_param('sssiiiiiiiissssdddsssisssi', $updInvoiceType, $updInvoiceDate, $updDueDate, $updJournalId, $updCostCenterId, $updTenantId, $updOwnerId, $updAqarId, $updSubaqarId, $updEgarId, $updCustomerId, $updCustomerType, $updCustomerName, $updCustomerVat, $updCustomerAddr, $updSubtotal, $updVatTotal, $updTotal, $updPayMethod, $updNotes, $updSellerSrc, $updSellerSid, $updSellerName, $updSellerVatN, $updSellerAddr, $invoiceId);
                $updStmt->execute();
                $delStmt = $db->prepare("DELETE FROM acc_invoice_items WHERE invoice_id = ?");
                $delStmt->bind_param('i', $invoiceId);
                $delStmt->execute();
                $insStmt = $db->prepare("INSERT INTO acc_invoice_items (invoice_id, item_description, quantity, unit_price, vat_rate, discount, line_total) VALUES (?, ?, ?, ?, ?, ?, ?)");
                foreach ($updItems as $ui) {
                    $uDesc = $ui['description'] ?? '';
                    $uQty = floatval($ui['quantity'] ?? 0);
                    $uPrice = floatval($ui['unit_price'] ?? 0);
                    $uVatR = floatval($ui['vat_rate'] ?? 15);
                    $uDisc = floatval($ui['discount'] ?? 0);
                    $uLineT = $uQty * $uPrice * (1 + $uVatR / 100) - $uDisc;
                    $insStmt->bind_param('isddddd', $invoiceId, $uDesc, $uQty, $uPrice, $uVatR, $uDisc, $uLineT);
                    $insStmt->execute();
                }
                $db->commit();
                $response = ['success' => true, 'message' => 'تم تعديل الفاتورة بنجاح'];
            } catch (Exception $e) {
                $db->rollback();
                $response = ['success' => false, 'message' => 'فشل في تعديل الفاتورة: ' . $e->getMessage()];
            }
            break;

        case 'import_invoices':
            if (empty($_FILES['import_file']['tmp_name'])) {
                $response = ['success' => false, 'message' => 'لم يتم رفع أي ملف'];
                break;
            }
            $_handle = fopen($_FILES['import_file']['tmp_name'], 'r');
            if (!$_handle) {
                $response = ['success' => false, 'message' => 'تعذر قراءة الملف'];
                break;
            }
            $_bom = fread($_handle, 3);
            if ($_bom !== "\xEF\xBB\xBF") rewind($_handle);
            fgetcsv($_handle, 0, ',', '"', '\\'); // skip header
            // Build customer name→id cache
            $_custRes = $db->query("SELECT customer_id, customer_name, vat_number FROM acc_customers WHERE is_active = 1");
            $_custMap = [];
            if ($_custRes) { while ($_cr = $_custRes->fetch_assoc()) { $_custMap[mb_strtolower($_cr['customer_name'])] = $_cr; } }
            $_groups  = [];
            $errors   = [];
            $lineNum  = 1;
            while (($_row = fgetcsv($_handle, 0, ',', '"', '\\')) !== false) {
                $lineNum++;
                if (count($_row) < 8 || empty(trim($_row[0]))) continue;
                $_gk    = trim($_row[0]);
                $_date  = trim($_row[1] ?? '');
                $_type  = trim($_row[2] ?? '') ?: 'standard';
                $_cname = trim($_row[3] ?? '');
                $_cvat  = trim($_row[4] ?? '');
                $_pay   = trim($_row[5] ?? '') ?: 'cash';
                $_notes = trim($_row[6] ?? '');
                $_idesc = trim($_row[7] ?? '');
                $_qty   = floatval($_row[8] ?? 1);
                $_price = floatval($_row[9] ?? 0);
                $_vrate = floatval($_row[10] ?? 15);
                $_disc  = floatval($_row[11] ?? 0);
                if (!isset($_groups[$_gk])) $_groups[$_gk] = ['meta' => null, 'items' => []];
                if ($_date && $_cname && !$_groups[$_gk]['meta']) {
                    if (strpos($_date, '/') !== false) {
                        $_dp = explode('/', $_date);
                        if (count($_dp) === 3) $_date = $_dp[2].'-'.$_dp[1].'-'.$_dp[0];
                    }
                    $_groups[$_gk]['meta'] = [
                        'invoice_type' => in_array($_type, ['standard','simplified','credit_note','debit_note']) ? $_type : 'standard',
                        'customer_name' => $_cname, 'customer_vat' => $_cvat,
                        'invoice_date' => $_date, 'payment_method' => $_pay, 'notes' => $_notes
                    ];
                }
                if ($_idesc) {
                    $_groups[$_gk]['items'][] = ['description' => $_idesc, 'quantity' => $_qty, 'unit_price' => $_price, 'vat_rate' => $_vrate, 'discount' => $_disc];
                }
            }
            fclose($_handle);
            $imported = 0;
            foreach ($_groups as $_gk => $_g) {
                if (!$_g['meta']) { $errors[] = "مجموعة $_gk: بيانات الفاتورة ناقصة (تاريخ أو عميل)"; continue; }
                if (empty($_g['items'])) { $errors[] = "مجموعة $_gk: لا توجد بنود"; continue; }
                // Resolve or create customer
                $_custKey = mb_strtolower($_g['meta']['customer_name']);
                if (isset($_custMap[$_custKey])) {
                    $_custId = $_custMap[$_custKey]['customer_id'];
                } else {
                    $_insC = $db->prepare("INSERT INTO acc_customers (customer_name, vat_number, is_active, created_at, formuid) VALUES (?, ?, 1, NOW(), UUID())");
                    $_insC->bind_param('ss', $_g['meta']['customer_name'], $_g['meta']['customer_vat']);
                    $_insC->execute();
                    $_custId = $_insC->insert_id;
                    $_custMap[$_custKey] = ['customer_id' => $_custId, 'customer_name' => $_g['meta']['customer_name']];
                }
                $_invData = [
                    'invoice_type' => $_g['meta']['invoice_type'],
                    'customer_id'  => $_custId, 'customer_type' => 'tenant',
                    'customer_name' => $_g['meta']['customer_name'],
                    'customer_vat_number' => $_g['meta']['customer_vat'],
                    'customer_address' => null,
                    'invoice_date' => $_g['meta']['invoice_date'],
                    'due_date' => null, 'payment_method' => $_g['meta']['payment_method'],
                    'notes' => $_g['meta']['notes'], 'seller_source' => 'company',
                    'seller_supplier_id' => null, 'seller_name' => null,
                    'seller_vat_number' => null, 'seller_address' => null,
                    'journal_id' => null, 'cost_center_id' => null,
                    'tenant_id' => null, 'owner_id' => null, 'aqar_id' => null, 'subaqar_id' => null, 'egar_id' => null
                ];
                $_invItems = array_map(fn($_i) => [
                    'description' => $_i['description'], 'quantity' => $_i['quantity'],
                    'unit_price'  => $_i['unit_price'],  'vat_rate' => $_i['vat_rate'], 'discount' => $_i['discount']
                ], $_g['items']);
                $_res = $accountingManager->createInvoice($_invData, $_invItems);
                if ($_res['success']) { $imported++; } else { $errors[] = "مجموعة $_gk: " . ($_res['error'] ?? 'خطأ غير معروف'); }
            }
            $msg = "تم استيراد $imported فاتورة بنجاح";
            if (!empty($errors)) $msg .= "\n\nتنبيهات:\n" . implode("\n", $errors);
            $response = ['success' => true, 'message' => $msg, 'imported' => $imported, 'errors' => $errors];
            break;
    }

    echo json_encode($response, JSON_UNESCAPED_UNICODE);
    exit;
}

// Get invoices
$invoicesQuery = "SELECT * FROM acc_invoices ORDER BY invoice_date DESC, invoice_id DESC LIMIT 50";
$invoicesResult = $db->query($invoicesQuery);
$invoices = [];
$invoicesQueryError = '';
$invoiceTableCount = 0;
if ($invoicesResult) {
    while ($row = $invoicesResult->fetch_assoc()) {
        $invoices[] = $row;
    }
} else {
    $invoicesQueryError = $db->error;
}

$invoiceCountResult = $db->query("SELECT COUNT(*) AS total FROM acc_invoices");
if ($invoiceCountResult) {
    $invoiceCountRow = $invoiceCountResult->fetch_assoc();
    $invoiceTableCount = isset($invoiceCountRow['total']) ? (int)$invoiceCountRow['total'] : 0;
}

// Get VAT rate from settings
$vatRate = $accountingManager->getSetting('default_vat_rate', 15);

$defaultSellerName = $zatca_company_name_ar ?? $bayanmaktabname ?? 'اسم الشركة';
$defaultSellerVat = $zatca_vat_number ?? $vat_number ?? '300000000000003';
$defaultSellerAddress = $zatca_company_address_ar ?? $bayanaddress ?? 'المملكة العربية السعودية';

$suppliers = [];
$suppliersResult = $db->query("SELECT supplier_id, supplier_name, vat_number, phone, address, city, country, is_active FROM acc_suppliers WHERE is_active = 1 ORDER BY supplier_name ASC");
if ($suppliersResult) {
    while ($supplierRow = $suppliersResult->fetch_assoc()) {
        $suppliers[] = $supplierRow;
    }
}
?>



<style>
:root {
    --primary-color: #4e627f;
}

.invoice-card {
    background: white;
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 1rem;
    box-shadow: 0 4px 15px rgba(0,0,0,0.08);
    transition: all 0.3s ease;
}

.invoice-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.12);
}

.invoice-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 1rem;
    border-bottom: 2px solid #f0f0f0;
    margin-bottom: 1rem;
}

.invoice-number {
    font-weight: 700;
    font-size: 1.2rem;
    color: var(--primary-color);
}

.badge-zatca {
    background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
    color: white;
    padding: 0.5rem 1rem;
    border-radius: 20px;
    font-weight: 600;
}

.badge-pending {
    background: linear-gradient(135deg, #ffc107 0%, #ff9800 100%);
    color: white;
}

.badge-paid {
    background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
    color: white;
}

.btn-add-invoice {
    background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
    border: none;
    color: white;
    padding: 0.75rem 1.5rem;
    border-radius: 10px;
    font-weight: 600;
}

.item-row {
    background: #f8f9fa;
    padding: 1rem;
    border-radius: 8px;
    margin-bottom: 0.5rem;
}

.total-section {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 1.5rem;
    border-radius: 12px;
    margin-top: 1rem;
}

.qr-code-preview {
    width: 150px;
    height: 150px;
    background: white;
    border: 2px solid #ddd;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.zatca-status {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
}

.stats-card {
    background: white;
    border-radius: 12px;
    padding: 1.5rem;
    text-align: center;
    box-shadow: 0 4px 15px rgba(0,0,0,0.08);
}

.stats-value {
    font-size: 2rem;
    font-weight: bold;
    color: var(--primary-color);
}

.seller-preview {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    padding: 12px;
    margin-top: 10px;
}

.seller-preview-title {
    font-weight: 700;
    color: #2d3748;
    margin-bottom: 6px;
}

.selection-panel {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 14px;
    height: 100%;
}

#customerDropdown,
#sellerDropdown {
    box-shadow: 0 4px 15px rgba(0,0,0,0.15);
    border-radius: 8px;
    margin-top: 5px;
}

#customerDropdown .list-group-item,
#sellerDropdown .list-group-item {
    border: none;
    border-bottom: 1px solid #f0f0f0;
    transition: all 0.2s ease;
}

#customerDropdown .list-group-item:hover,
#sellerDropdown .list-group-item:hover {
    background: #f8f9fa;
    transform: translateX(-3px);
}

#customerDropdown .list-group-item:last-child,
#sellerDropdown .list-group-item:last-child {
    border-bottom: none;
}

#customerDetails {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 2px solid #f0f0f0;
}
</style>

