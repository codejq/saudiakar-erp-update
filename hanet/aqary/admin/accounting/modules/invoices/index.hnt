                <button class="btn btn-light btn-lg" onclick="window.location='../../index.hnt'">
                    <i class="bi bi-arrow-right me-2"></i>العودة
                </button>
                <button class="btn btn-add-invoice btn-lg" data-bs-toggle="modal" data-bs-target="#addInvoiceModal">
                    <i class="bi bi-plus-circle me-2"></i>فاتورة جديدة
                </button>
            </div>
        </div>
    </div>

    <!-- Statistics -->
    <div class="row g-3 mb-4">
        <?php
        $totalInvoices = count($invoices);
        $totalAmount = array_reduce($invoices, function($carry, $inv) {
            $sign = (($inv['invoice_type'] ?? 'standard') === 'credit_note') ? -1 : 1;
            return $carry + ($sign * floatval($inv['total_amount'] ?? 0));
        }, 0);
        $paidInvoices = count(array_filter($invoices, function($inv) {
            $invoiceType = $inv['invoice_type'] ?? 'standard';
            return !in_array($invoiceType, ['credit_note', 'debit_note'], true)
                && isset($inv['payment_status']) && $inv['payment_status'] == 'paid';
        }));
        $pendingInvoices = count(array_filter($invoices, function($inv) {
            $invoiceType = $inv['invoice_type'] ?? 'standard';
            return !in_array($invoiceType, ['credit_note', 'debit_note'], true)
                && (!isset($inv['payment_status']) || $inv['payment_status'] != 'paid');
        }));
        ?>
        <div class="col-md-3">
            <div class="stats-card">
                <div class="stats-value"><?php echo $totalInvoices; ?></div>
                <div class="text-muted">إجمالي المستندات</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stats-card">
                <div class="stats-value text-success"><?php echo $paidInvoices; ?></div>
                <div class="text-muted">فواتير مدفوعة</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stats-card">
                <div class="stats-value text-warning"><?php echo $pendingInvoices; ?></div>
                <div class="text-muted">فواتير معلقة</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stats-card">
                <div class="stats-value"><?php echo number_format($totalAmount, 2); ?></div>
                <div class="text-muted">إجمالي المبلغ (ر.س)</div>
            </div>
        </div>
    </div>

    <!-- Invoices List -->
    <div class="row">
        <div class="col-12">
            <?php if (empty($invoices)): ?>
            <div class="card border-0 shadow-sm" style="border-radius: 15px;">
                <div class="card-body text-center p-5">
                    <?php if (!empty($invoicesQueryError)): ?>
                    <div class="alert alert-danger text-start mb-4">
                        <strong>خطأ في قراءة الفواتير:</strong><br>
                        <small><?php echo htmlspecialchars($invoicesQueryError); ?></small>
                    </div>
                    <?php elseif ($invoiceTableCount > 0): ?>
                    <div class="alert alert-warning text-start mb-4">
                        <strong>تنبيه:</strong><br>
                        <small>يوجد <?php echo $invoiceTableCount; ?> فاتورة في الجدول ولكن لم يتم عرضها في القائمة الحالية.</small>
                    </div>
                    <?php endif; ?>
                    <div class="mb-4">
                        <i class="bi bi-receipt" style="font-size: 5rem; color: #667eea;"></i>
                    </div>
                    <h3 class="mb-3">لا توجد فواتير بعد</h3>
                    <p class="text-muted mb-4">ابدأ بإنشاء أول فاتورة إلكترونية متوافقة مع متطلبات ZATCA</p>
                    <button class="btn btn-add-invoice btn-lg" data-bs-toggle="modal" data-bs-target="#addInvoiceModal">
                        <i class="bi bi-plus-circle me-2"></i>إنشاء فاتورة جديدة
                    </button>
                    <div class="mt-4">
                        <small class="text-muted">
                            أو يمكنك
                            <a href="../../sync_amlak.hnt" class="text-decoration-none">مزامنة الفواتير من نظام العقارات</a>
                        </small>
                    </div>
                </div>
            </div>
            <?php else: ?>
            <?php foreach ($invoices as $invoice): ?>
            <?php
                $invoiceTypeKey = trim((string)($invoice['invoice_type'] ?? 'standard'));
                $invoiceTypeLabel = 'فاتورة ضريبية';
                if ($invoiceTypeKey === 'simplified') {
                    $invoiceTypeLabel = 'فاتورة مبسطة';
                } elseif ($invoiceTypeKey === 'credit_note') {
                    $invoiceTypeLabel = 'إشعار دائن';
                } elseif ($invoiceTypeKey === 'debit_note') {
                    $invoiceTypeLabel = 'إشعار مدين';
                }
                $isCreditNote = $invoiceTypeKey === 'credit_note';
                $isAccountingNote = $invoiceTypeKey === 'credit_note' || $invoiceTypeKey === 'debit_note';
                $displaySign = $isCreditNote ? -1 : 1;
            ?>
            <div class="invoice-card">
                <div class="invoice-header">
                    <div>
                        <span class="invoice-number"><?php echo $invoice['invoice_number']; ?></span>
                        <span class="text-muted ms-3"><?php echo date('d/m/Y', strtotime($invoice['invoice_date'])); ?></span>
                    </div>
                    <div>
                        <?php if (isset($invoice['zatca_status']) && $invoice['zatca_status'] == 'submitted'): ?>
                        <span class="badge badge-zatca">
                            <i class="bi bi-check-circle me-1"></i>ZATCA
                        </span>
                        <?php endif; ?>

                        <?php if (isset($invoice['payment_status']) && $invoice['payment_status'] == 'paid'): ?>
                        <span class="badge badge-paid ms-2">مدفوعة</span>
                        <?php elseif (!$isAccountingNote && isset($invoice['payment_status'])): ?>
                        <span class="badge badge-pending ms-2">معلقة</span>
                        <?php endif; ?>
                        <span class="badge bg-secondary ms-2"><?php echo $invoiceTypeLabel; ?></span>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <strong>النوع:</strong> <?php echo $invoiceTypeLabel; ?><br>
                        <strong>العميل:</strong> <?php echo $invoice['customer_name']; ?><br>
                        <?php if ($invoice['customer_vat_number']): ?>
                        <small class="text-muted">الرقم الضريبي: <?php echo $invoice['customer_vat_number']; ?></small>
                        <?php endif; ?>
                    </div>
                    <div class="col-md-6 text-end">
                        <div class="mb-2">
                            <strong>المبلغ قبل الضريبة:</strong>
                            <?php echo number_format($displaySign * floatval($invoice['subtotal']), 2); ?> ر.س
                        </div>
                        <div class="mb-2">
                            <strong>ضريبة القيمة المضافة:</strong>
                            <?php echo number_format($displaySign * floatval($invoice['vat_amount']), 2); ?> ر.س
                        </div>
                        <div class="h5 mb-0">
                            <strong>الإجمالي:</strong>
                            <span class="text-primary"><?php echo number_format($displaySign * floatval($invoice['total_amount']), 2); ?> ر.س</span>
                        </div>
                    </div>
                </div>

                <?php if (!empty($invoice['zatca_error'])): ?>
                <?php if (strpos($invoice['zatca_error'], 'SUCCESS:') === 0): ?>
                <div class="alert alert-success mt-2 mb-2" style="padding: 10px; font-size: 0.9em;">
                    <i class="bi bi-check-circle me-2"></i>
                    <strong>نتيجة ZATCA:</strong>
                    <br><small><?php echo htmlspecialchars($invoice['zatca_error']); ?></small>
                </div>
                <?php else: ?>
                <div class="alert alert-danger mt-2 mb-2" style="padding: 10px; font-size: 0.9em;">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    <strong>خطأ في الإرسال إلى ZATCA:</strong>
                    <br><small><?php echo htmlspecialchars($invoice['zatca_error']); ?></small>
                </div>
                <?php endif; ?>
                <?php endif; ?>

                <div class="d-flex gap-2">
                    <button class="btn btn-sm btn-outline-primary" onclick="viewInvoice(<?php echo $invoice['invoice_id']; ?>)">
                        <i class="bi bi-eye me-1"></i>عرض
                    </button>
                    <button class="btn btn-sm btn-outline-success" onclick="printInvoice(<?php echo $invoice['invoice_id']; ?>)">
                        <i class="bi bi-printer me-1"></i>طباعة
                    </button>
                    <?php if (empty($invoice['zatca_status']) || $invoice['zatca_status'] != 'submitted'): ?>
                    <button class="btn btn-sm btn-outline-secondary" onclick="editInvoice(<?php echo $invoice['invoice_id']; ?>)">
                        <i class="bi bi-pencil me-1"></i>تعديل
                    </button>
                    <button class="btn btn-sm btn-outline-info" onclick="submitToZatca(<?php echo $invoice['invoice_id']; ?>)">
                        <i class="bi bi-send me-1"></i>إرسال لـ ZATCA
                    </button>
                    <?php endif; ?>
                    <?php if (!$isAccountingNote && isset($invoice['payment_status']) && $invoice['payment_status'] != 'paid'): ?>
                    <button class="btn btn-sm btn-outline-warning" onclick="recordPayment(<?php echo $invoice['invoice_id']; ?>)">
                        <i class="bi bi-cash me-1"></i>تسجيل دفعة
                    </button>
                    <?php endif; ?>
                </div>
            </div>
            <?php endforeach; ?>
            <?php endif; ?>
        </div>
    </div>
</div>

