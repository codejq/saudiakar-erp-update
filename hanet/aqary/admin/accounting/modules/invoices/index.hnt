                            <select class="form-select" id="invoice_owner_id" name="owner_id">
                                <option value="">بدون</option>
                                <?php foreach ($dimensionOptions['owners'] as $owner): ?>
                                <option value="<?php echo (int)$owner['owner_id']; ?>"><?php echo htmlspecialchars($owner['owner_name'], ENT_QUOTES, 'UTF-8'); ?></option>
                                <?php endforeach; ?>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">العقد</label>
                            <select class="form-select" id="invoice_egar_id" name="egar_id">
                                <option value="">بدون</option>
                                <?php foreach ($dimensionOptions['contracts'] as $contract): ?>
                                <option value="<?php echo (int)$contract['egar_id']; ?>"><?php echo htmlspecialchars((trim((string)$contract['contract_number']) !== '' ? $contract['contract_number'] : ('عقد #' . $contract['egar_id'])), ENT_QUOTES, 'UTF-8'); ?></option>
                                <?php endforeach; ?>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">ملاحظات</label>
                            <textarea class="form-control" name="notes" rows="2"></textarea>
                        </div>
                    </div>

                    <h6 class="mb-3"><i class="bi bi-list-ul me-2"></i>بنود الفاتورة</h6>

                    <div id="invoiceItems">
                        <!-- Items will be added here -->
                    </div>

                    <button type="button" class="btn btn-outline-primary mb-3" onclick="addItem()">
                        <i class="bi bi-plus-circle me-2"></i>إضافة بند
                    </button>

                    <div class="total-section">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-2">المجموع قبل الضريبة: <span id="subtotalDisplay">0.00</span> ر.س</div>
                                <div class="mb-2">ضريبة القيمة المضافة (<?php echo $vatRate; ?>%): <span id="vatDisplay">0.00</span> ر.س</div>
                                <div class="h4 mb-0">الإجمالي: <span id="totalDisplay">0.00</span> ر.س</div>
                            </div>
                            <div class="col-md-6 text-center">
                                <div class="qr-code-preview">
                                    <i class="bi bi-qr-code" style="font-size: 3rem; color: #ddd;"></i>
                                </div>
                                <small class="text-white-50 mt-2 d-block">سيتم إنشاء رمز QR بعد الحفظ</small>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                <button type="button" class="btn btn-primary" id="submitInvoiceBtn" onclick="submitInvoice()">
                    <i class="bi bi-check-circle me-2"></i>حفظ الفاتورة
                </button>
            </div>
        </div>
