<script>
const vatRate = <?php echo $vatRate; ?>;
let itemCounter = 0;

function addItem() {
    itemCounter++;
    const itemHtml = `
        <div class="item-row" id="item_${itemCounter}">
            <div class="row g-2">
                <div class="col-md-4">
                    <input type="text" class="form-control" name="item_description_${itemCounter}" placeholder="وصف الصنف" required>
                </div>
                <div class="col-md-2">
                    <input type="number" step="0.01" class="form-control quantity-input" name="quantity_${itemCounter}" placeholder="الكمية" value="1" onchange="calculateTotals()" required>
                </div>
                <div class="col-md-2">
                    <input type="number" step="0.01" class="form-control price-input" name="unit_price_${itemCounter}" placeholder="السعر" value="0" onchange="calculateTotals()" required>
                </div>
                <div class="col-md-2">
                    <input type="number" step="0.01" class="form-control" name="vat_rate_${itemCounter}" placeholder="الضريبة %" value="${vatRate}" readonly>
                </div>
                <div class="col-md-1">
                    <input type="text" class="form-control item-total" name="total_${itemCounter}" placeholder="المجموع" readonly>
                </div>
                <div class="col-md-1">
                    <button type="button" class="btn btn-danger btn-sm" onclick="removeItem(${itemCounter})">
                        <i class="bi bi-trash"></i>
                    </button>
                </div>
            </div>
        </div>
    `;

    document.getElementById('invoiceItems').insertAdjacentHTML('beforeend', itemHtml);
}

function removeItem(itemId) {
    document.getElementById('item_' + itemId).remove();
    calculateTotals();
}

function calculateTotals() {
    let subtotal = 0;

    for (let i = 1; i <= itemCounter; i++) {
        const quantityInput = document.querySelector(`[name="quantity_${i}"]`);
        const priceInput = document.querySelector(`[name="unit_price_${i}"]`);
        const totalInput = document.querySelector(`[name="total_${i}"]`);

        if (quantityInput && priceInput) {
            const quantity = parseFloat(quantityInput.value) || 0;
            const price = parseFloat(priceInput.value) || 0;
            const itemTotal = quantity * price;

            if (totalInput) {
                totalInput.value = itemTotal.toFixed(2);
            }

            subtotal += itemTotal;
        }
    }

    const vat = subtotal * (vatRate / 100);
    const total = subtotal + vat;

    document.getElementById('subtotalDisplay').textContent = subtotal.toFixed(2);
    document.getElementById('vatDisplay').textContent = vat.toFixed(2);
    document.getElementById('totalDisplay').textContent = total.toFixed(2);
}

function submitInvoice() {
    const form = document.getElementById('addInvoiceForm');
    const formData = new FormData(form);

    // Collect items
    const items = [];
    for (let i = 1; i <= itemCounter; i++) {
        const descInput = document.querySelector(`[name="item_description_${i}"]`);
        if (descInput && descInput.value) {
            const quantity = parseFloat(document.querySelector(`[name="quantity_${i}"]`).value) || 0;
            const unitPrice = parseFloat(document.querySelector(`[name="unit_price_${i}"]`).value) || 0;
            const vatRate = parseFloat(document.querySelector(`[name="vat_rate_${i}"]`).value) || 0;

            items.push({
                description: descInput.value,
                quantity: quantity,
                unit_price: unitPrice,
                vat_rate: vatRate,
                vat_amount: (quantity * unitPrice * vatRate / 100),
                total_amount: quantity * unitPrice * (1 + vatRate / 100)
            });
        }
    }

    if (items.length === 0) {
        showResultModal(false, 'يجب إضافة بند واحد على الأقل');
        return;
    }

    formData.append('ajax_action', 'create_invoice');
    formData.append('items', JSON.stringify(items));

    fetch('index.hnt', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        showResultModal(data.success, data.message || (data.error ? data.error : 'خطأ غير معروف'));

        if (data.success) {
            const modal = bootstrap.Modal.getInstance(document.getElementById('addInvoiceModal'));
            if (modal) {
                modal.hide();
            }
            setTimeout(() => location.reload(), 1500);
        }
    })
    .catch(error => {
        console.error('Error:', error);
        showResultModal(false, 'حدث خطأ أثناء الحفظ');
    });
}

function viewInvoice(invoiceId) {
    window.location = 'view.hnt?id=' + invoiceId;
}

function printInvoice(invoiceId) {
    window.open('print.hnt?id=' + invoiceId, '_blank');
}

let selectedExistingCustomerSnapshot = null;

function getCustomerFormState() {
    return {
        customer_name: document.getElementById('customer_name').value.trim(),
        vat_number: document.getElementById('customer_vat_number').value.trim(),
        phone: document.getElementById('customer_phone').value.trim(),
        address: document.getElementById('customer_address').value.trim()
    };
}

function resetCustomerSaveState() {
    selectedExistingCustomerSnapshot = null;
    document.getElementById('saveCustomerInfoContainer').style.display = 'none';
}

function updateSaveCustomerButtonVisibility() {
    const customerId = document.getElementById('selectedCustomerId').value;
    const container = document.getElementById('saveCustomerInfoContainer');
    const button = document.getElementById('saveCustomerInfoBtn');
    const current = getCustomerFormState();

    if (isNewCustomer && !customerId) {
        const hasNewCustomerData = current.customer_name || current.vat_number || current.phone || current.address;
        button.innerHTML = '<i class="bi bi-save me-1"></i>حفظ العميل';
        container.style.display = hasNewCustomerData ? 'block' : 'none';
        return;
    }

    button.innerHTML = '<i class="bi bi-save me-1"></i>حفظ بيانات العميل';

    if (!customerId || !selectedExistingCustomerSnapshot) {
        container.style.display = 'none';
        return;
    }

    const hasChanges = current.customer_name !== selectedExistingCustomerSnapshot.customer_name ||
        current.vat_number !== selectedExistingCustomerSnapshot.vat_number ||
        current.phone !== selectedExistingCustomerSnapshot.phone ||
        current.address !== selectedExistingCustomerSnapshot.address;

    container.style.display = hasChanges ? 'block' : 'none';
}

function createCustomerQuick(current, successMessage) {
    const formData = new FormData();
    formData.append('ajax_action', 'add_customer_quick');
    formData.append('customer_name', current.customer_name);
    formData.append('vat_number', current.vat_number);
    formData.append('phone', current.phone);
    formData.append('address', current.address);

    return fetch('index.hnt', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        if (!data.success) {
            throw new Error(data.message || 'فشل في إضافة العميل');
        }

        document.getElementById('selectedCustomerId').value = data.customer.customer_id;
        customerSearchInput.value = current.customer_name;
        isNewCustomer = false;
        selectedExistingCustomerSnapshot = {
            customer_name: current.customer_name,
            vat_number: current.vat_number,
            phone: current.phone,
            address: current.address
        };
        updateSaveCustomerButtonVisibility();

        if (successMessage) {
            showResultModal(true, successMessage);
        }

        return data;
    });
}

function saveCustomerInfo() {
    const customerId = document.getElementById('selectedCustomerId').value;

    const current = getCustomerFormState();

    if (!current.customer_name) {
        showResultModal(false, 'اسم العميل مطلوب');
        return;
    }

    if (isNewCustomer && !customerId) {
        createCustomerQuick(current, 'تم حفظ العميل بنجاح')
            .catch(error => {
                console.error('Error:', error);
                showResultModal(false, error.message || 'حدث خطأ أثناء حفظ العميل');
            });
        return;
    }

    const formData = new FormData();
    formData.append('ajax_action', 'update_customer_quick');
    formData.append('customer_id', customerId);
    formData.append('customer_name', current.customer_name);
    formData.append('vat_number', current.vat_number);
    formData.append('phone', current.phone);
    formData.append('address', current.address);

    fetch('index.hnt', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            selectedExistingCustomerSnapshot = {
                customer_name: current.customer_name,
                vat_number: current.vat_number,
                phone: current.phone,
                address: current.address
            };
            customerSearchInput.value = current.customer_name;
            updateSaveCustomerButtonVisibility();
            showResultModal(true, data.message || 'تم حفظ بيانات العميل بنجاح');
        } else {
            showResultModal(false, data.message || 'فشل في حفظ بيانات العميل');
        }
    })
    .catch(error => {
        console.error('Error:', error);
        showResultModal(false, 'حدث خطأ أثناء حفظ بيانات العميل');
    });
}

function submitToZatca(invoiceId) {
    console.log('submitToZatca called with invoice ID:', invoiceId);

    // Check if custom confirm function exists
    if (typeof confirm === 'function' && confirm.length >= 3) {
        // Use custom confirm dialog
        confirm('هل تريد إرسال هذه الفاتورة إلى ZATCA؟', 'تأكيد الإرسال', function() {
            console.log('User confirmed, proceeding with submission');
            performZatcaSubmission(invoiceId);
        }, function() {
            console.log('User cancelled ZATCA submission');
        });
    } else {
        // Fallback to native confirm
        if (window.confirm('هل تريد إرسال هذه الفاتورة إلى ZATCA؟')) {
            console.log('User confirmed, proceeding with submission');
            performZatcaSubmission(invoiceId);
        }
    }
}

function performZatcaSubmission(invoiceId) {
    // Show loading message
    const loadingModal = new bootstrap.Modal(document.getElementById('resultModal'));
    const header = document.getElementById('resultModalHeader');
    const title = document.getElementById('resultModalTitle');
    const messageEl = document.getElementById('resultModalMessage');

    header.style.background = 'linear-gradient(135deg, #0891b2, #06b6d4)';
    title.innerHTML = '<i class="bi bi-hourglass-split me-2"></i>جاري الإرسال';
    messageEl.textContent = 'جاري إرسال الفاتورة إلى ZATCA...';
    loadingModal.show();

    // Submit to ZATCA
    const formData = new FormData();
    formData.append('action', 'submit_to_zatca');
    formData.append('invoice_id', invoiceId);

    fetch('index.hnt', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        // Build detailed error message
        let errorMessage = data.message || data.error || 'خطأ غير معروف';

        // Add technical details if available
        if (!data.success && data.technical_details) {
            errorMessage += '\n\n--- تفاصيل تقنية من ZATCA API ---';

            if (data.technical_details.api_url) {
                errorMessage += '\nAPI URL: ' + data.technical_details.api_url;
            }

            if (data.technical_details.http_code) {
                errorMessage += '\nHTTP Status Code: ' + data.technical_details.http_code;
            }

            if (data.technical_details.error) {
                errorMessage += '\nError: ' + data.technical_details.error;
            }

            if (data.technical_details.error_detail) {
                errorMessage += '\nDetail: ' + data.technical_details.error_detail;
            }

            if (data.technical_details.validation_results && data.technical_details.validation_results.length > 0) {
                errorMessage += '\n\nValidation Results:';
                data.technical_details.validation_results.forEach((result, index) => {
                    errorMessage += '\n' + (index + 1) + '. ' + JSON.stringify(result, null, 2);
                });
            }

            if (data.technical_details.api_response) {
                errorMessage += '\n\nFull API Response:\n' + JSON.stringify(data.technical_details.api_response, null, 2);
            }

            // Log to console for developers
            console.error('ZATCA API Error Details:', data.technical_details);
        }

        // Build success message with ZATCA result details
        if (data.success) {
            let successMessage = data.message || 'تم إرسال الفاتورة بنجاح';

            // Add ZATCA result details
            if (data.zatca_uuid) {
                successMessage += '\n\n✅ UUID: ' + data.zatca_uuid;
            }
            if (data.zatca_hash) {
                successMessage += '\n✅ Hash: ' + data.zatca_hash.substring(0, 40) + '...';
            }
            if (data.api_result) {
                if (data.api_result.status) {
                    successMessage += '\n✅ Status: ' + data.api_result.status;
                }
                if (data.api_result.cleared_invoice) {
                    successMessage += '\n✅ Invoice Cleared Successfully';
                }
                if (data.api_result.reported_invoice) {
                    successMessage += '\n✅ Invoice Reported Successfully';
                }
                if (data.api_result.validation_results && data.api_result.validation_results.length > 0) {
                    successMessage += '\n\n📋 Validation Results:';
                    data.api_result.validation_results.forEach((result, index) => {
                        if (result.status) {
                            successMessage += '\n  ' + (index + 1) + '. ' + result.status;
                        }
                    });
                }
                if (data.api_result.warnings && data.api_result.warnings.length > 0) {
                    successMessage += '\n\n⚠️ Warnings:';
                    data.api_result.warnings.forEach((warning, index) => {
                        successMessage += '\n  ' + (index + 1) + '. ' + warning;
                    });
                }
            }

            showResultModal(true, successMessage, null, {
                autoReloadSeconds: 6
            });
        } else {
            showResultModal(false, errorMessage, data.technical_details);
        }
    })
    .catch(error => {
        console.error('Error:', error);
        showResultModal(false, 'حدث خطأ أثناء الإرسال إلى ZATCA');
    });
}

let resultModalReloadTimer = null;
let resultModalCountdownTimer = null;

function clearResultModalTimers() {
    if (resultModalReloadTimer) {
        clearTimeout(resultModalReloadTimer);
        resultModalReloadTimer = null;
    }

    if (resultModalCountdownTimer) {
        clearInterval(resultModalCountdownTimer);
        resultModalCountdownTimer = null;
    }
}

function showResultModal(success, message, technicalDetails, options = {}) {
    const modalElement = document.getElementById('resultModal');
    const modal = new bootstrap.Modal(modalElement);
    const header = document.getElementById('resultModalHeader');
    const title = document.getElementById('resultModalTitle');
    const messageEl = document.getElementById('resultModalMessage');
    const autoReloadSeconds = options.autoReloadSeconds || 0;

    clearResultModalTimers();

    if (success) {
        header.style.background = 'linear-gradient(135deg, #28a745, #20c997)';
        title.innerHTML = '<i class="bi bi-check-circle me-2"></i>نجحت العملية';
    } else {
        header.style.background = 'linear-gradient(135deg, #dc3545, #c82333)';
        title.innerHTML = '<i class="bi bi-x-circle me-2"></i>فشلت العملية';
    }

    // Format message with technical details if available
    if (technicalDetails) {
        messageEl.innerHTML = '<div style="white-space: pre-wrap; font-family: monospace; text-align: left; direction: ltr;">' +
                              message.replace(/</g, '&lt;').replace(/>/g, '&gt;') +
                              '</div>';
    } else {
        messageEl.innerHTML = '<div style="white-space: pre-wrap;">' + message.replace(/</g, '&lt;').replace(/>/g, '&gt;') + '</div>';

        if (success && autoReloadSeconds > 0) {
            const countdownWrapper = document.createElement('div');
            countdownWrapper.className = 'mt-3 alert alert-info mb-0';
            countdownWrapper.innerHTML = 'سيتم تحديث الصفحة خلال <strong id="resultModalCountdownValue">' + autoReloadSeconds + '</strong> ثانية. يمكنك إغلاق هذه النافذة لإلغاء التحديث التلقائي.';
            messageEl.appendChild(countdownWrapper);

            let remainingSeconds = autoReloadSeconds;
            const countdownValue = document.getElementById('resultModalCountdownValue');

            resultModalCountdownTimer = setInterval(() => {
                remainingSeconds -= 1;
                if (remainingSeconds <= 0) {
                    clearInterval(resultModalCountdownTimer);
                    resultModalCountdownTimer = null;
                    return;
                }

                if (countdownValue) {
                    countdownValue.textContent = remainingSeconds;
                }
            }, 1000);

            resultModalReloadTimer = setTimeout(() => {
                clearResultModalTimers();
                location.reload();
            }, autoReloadSeconds * 1000);
        }
    }

    // Clean up modal and backdrop when hidden
    modalElement.addEventListener('hidden.bs.modal', function() {
        clearResultModalTimers();
        modal.dispose();
        // Remove any remaining backdrops
        const backdrops = document.querySelectorAll('.modal-backdrop');
        backdrops.forEach(backdrop => backdrop.remove());
        // Restore body scroll
        document.body.classList.remove('modal-open');
        document.body.style.removeProperty('overflow');
        document.body.style.removeProperty('padding-right');
    }, { once: true });

    modal.show();
}

function recordPayment(invoiceId) {
    window.location = '../payments/index.hnt?invoice_id=' + encodeURIComponent(invoiceId);
}

// Customer autocomplete functionality
let searchTimeout;
const customerSearchInput = document.getElementById('customerSearch');
const customerDropdown = document.getElementById('customerDropdown');
const customerDetails = document.getElementById('customerDetails');
let isNewCustomer = false;

customerSearchInput.addEventListener('input', function() {
    const searchTerm = this.value.trim();

    clearTimeout(searchTimeout);

    if (searchTerm.length < 2) {
        customerDropdown.style.display = 'none';
        return;
    }

    searchTimeout = setTimeout(() => {
        searchCustomers(searchTerm);
    }, 300);
});

function searchCustomers(searchTerm) {
    const formData = new FormData();
    formData.append('ajax_action', 'search_customers');
    formData.append('search', searchTerm);

    fetch('index.hnt', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        if (data.success && data.customers.length > 0) {
            displayCustomerDropdown(data.customers);
        } else {
            customerDropdown.style.display = 'none';
        }
    })
    .catch(error => {
        console.error('Error:', error);
    });
}

function displayCustomerDropdown(customers) {
    customerDropdown.innerHTML = '';

    customers.forEach(customer => {
        const item = document.createElement('a');
        item.href = '#';
        item.className = 'list-group-item list-group-item-action';
        item.innerHTML = `
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <strong>${customer.customer_name}</strong>
                    ${customer.vat_number ? '<br><small class="text-muted">الرقم الضريبي: ' + customer.vat_number + '</small>' : ''}
                    ${customer.phone ? '<br><small class="text-muted">الهاتف: ' + customer.phone + '</small>' : ''}
                </div>
            </div>
        `;

        item.addEventListener('click', function(e) {
            e.preventDefault();
            selectCustomer(customer);
        });

        customerDropdown.appendChild(item);
    });

    customerDropdown.style.display = 'block';
}

function selectCustomer(customer) {
    isNewCustomer = false;

    // Fill customer fields
    document.getElementById('selectedCustomerId').value = customer.customer_id;
    document.getElementById('customer_name').value = customer.customer_name;
    document.getElementById('customer_vat_number').value = customer.vat_number || '';
    document.getElementById('customer_phone').value = customer.phone || '';
    document.getElementById('customer_address').value = customer.address || '';

    // Update search input
    customerSearchInput.value = customer.customer_name;

    // Show customer details
    customerDetails.style.display = 'block';
    customerDetails.querySelectorAll('.col-md-6, .col-md-12').forEach(el => {
        if (el.id === 'saveCustomerInfoContainer') {
            return;
        }
        el.style.display = 'block';
    });

    // Hide dropdown
    customerDropdown.style.display = 'none';

    selectedExistingCustomerSnapshot = {
        customer_name: customer.customer_name || '',
        vat_number: customer.vat_number || '',
        phone: customer.phone || '',
        address: customer.address || ''
    };
    updateSaveCustomerButtonVisibility();
}

// Add new customer button
document.getElementById('addNewCustomerBtn').addEventListener('click', function() {
    isNewCustomer = true;

    // Clear all fields
    document.getElementById('selectedCustomerId').value = '';
    document.getElementById('customer_name').value = customerSearchInput.value;
    document.getElementById('customer_vat_number').value = '';
    document.getElementById('customer_phone').value = '';
    document.getElementById('customer_address').value = '';

    // Show customer details
    customerDetails.style.display = 'block';
    customerDetails.querySelectorAll('.col-md-6, .col-md-12').forEach(el => {
        if (el.id === 'saveCustomerInfoContainer') {
            return;
        }
        el.style.display = 'block';
    });

    // Hide dropdown
    customerDropdown.style.display = 'none';

    // Make fields editable for new customer
    document.getElementById('customer_name').readOnly = false;
    document.getElementById('customer_vat_number').readOnly = false;
    document.getElementById('customer_phone').readOnly = false;
    document.getElementById('customer_address').readOnly = false;

    resetCustomerSaveState();
    updateSaveCustomerButtonVisibility();

    // Focus on customer name
    document.getElementById('customer_name').focus();
});

['customer_name', 'customer_vat_number', 'customer_phone', 'customer_address'].forEach(function(fieldId) {
    document.getElementById(fieldId).addEventListener('input', updateSaveCustomerButtonVisibility);
});

// Hide dropdown when clicking outside
document.addEventListener('click', function(e) {
    if (!customerSearchInput.contains(e.target) && !customerDropdown.contains(e.target)) {
        customerDropdown.style.display = 'none';
    }
});

// Modified submitInvoice to handle new customer creation
const originalSubmitInvoice = submitInvoice;
submitInvoice = function() {
    // If it's a new customer, create them first
    if (isNewCustomer && !document.getElementById('selectedCustomerId').value) {
        const customerName = document.getElementById('customer_name').value.trim();
        const vatNumber = document.getElementById('customer_vat_number').value.trim();
        const phone = document.getElementById('customer_phone').value.trim();
        const address = document.getElementById('customer_address').value.trim();

        if (!customerName) {
            showResultModal(false, 'اسم العميل مطلوب');
            return;
        }

        createCustomerQuick({
            customer_name: customerName,
            vat_number: vatNumber,
            phone: phone,
            address: address
        })
        .then(() => {
            originalSubmitInvoice();
        })
        .catch(error => {
            console.error('Error:', error);
            showResultModal(false, error.message || 'حدث خطأ أثناء إضافة العميل');
        });
    } else {
        // Customer already exists or selected, proceed normally
        originalSubmitInvoice();
    }
};

// Add initial item
addItem();
</script>

