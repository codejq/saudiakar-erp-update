        <?php
        $totalInvoices = count($invoices);
        $totalAmount = array_sum(array_column($invoices, 'total_amount'));
        $paidInvoices = count(array_filter($invoices, function($inv) {
            return isset($inv['payment_status']) && $inv['payment_status'] == 'paid';
        }));
        $pendingInvoices = $totalInvoices - $paidInvoices;
        ?>
        <div class="col-md-3">
            <div class="stats-card">
                <div class="stats-value"><?php echo $totalInvoices; ?></div>
