<script>
const vatRate = <?php echo $vatRate; ?>;
let itemCounter = 0;
const suppliersData = <?php echo json_encode(array_map(function($supplier) {
    $supplierAddress = trim(($supplier['address'] ?? '') . (!empty($supplier['city']) ? ' - ' . $supplier['city'] : '') . (!empty($supplier['country']) ? ' - ' . $supplier['country'] : ''));
    return [
        'supplier_id' => (int)$supplier['supplier_id'],
        'supplier_name' => $supplier['supplier_name'],
        'vat_number' => $supplier['vat_number'] ?? '',
        'phone' => $supplier['phone'] ?? '',
        'address' => $supplierAddress
    ];
}, $suppliers), JSON_UNESCAPED_UNICODE); ?>;
const defaultSeller = {
    source: 'company',
    supplier_id: '',
    name: <?php echo json_encode($defaultSellerName, JSON_UNESCAPED_UNICODE); ?>,
    vat_number: <?php echo json_encode($defaultSellerVat, JSON_UNESCAPED_UNICODE); ?>,
    phone: '',
    address: <?php echo json_encode($defaultSellerAddress, JSON_UNESCAPED_UNICODE); ?>
};

const invoiceTypeLabels = {
    standard: 'فاتورة ضريبية',
    simplified: 'فاتورة مبسطة',
    credit_note: 'إشعار دائن',
    debit_note: 'إشعار مدين'
};

function setInvoiceTypeValue(type) {
    const invoiceTypeSelect = document.querySelector('[name="invoice_type"]');
    const normalizedType = type || 'standard';

    if (!invoiceTypeSelect) {
        return;
    }

    invoiceTypeSelect.value = normalizedType;

    if (window.jQuery) {
        window.jQuery(invoiceTypeSelect).val(normalizedType).trigger('change');
        return;
    }

    invoiceTypeSelect.dispatchEvent(new Event('change', { bubbles: true }));
}

function getInvoiceTypeLabel(type) {
    return invoiceTypeLabels[type] || invoiceTypeLabels.standard;
}

function formatDateForDisplay(isoDate) {
    if (!isoDate) {
        return '';
    }

    const parts = String(isoDate).split('-');
    if (parts.length !== 3) {
        return isoDate;
    }

    return parts[2] + '/' + parts[1] + '/' + parts[0];
}

function normalizeDisplayDateValue(value) {
    return String(value || '').trim().replace(/[-.]/g, '/');
}

function parseDisplayDateToIso(value) {
    const normalized = normalizeDisplayDateValue(value);

    if (!normalized) {
        return '';
    }

    const displayMatch = normalized.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);
    if (displayMatch) {
        const day = displayMatch[1].padStart(2, '0');
        const month = displayMatch[2].padStart(2, '0');
        const year = displayMatch[3];
        return year + '-' + month + '-' + day;
    }

    const isoMatch = normalized.match(/^(\d{4})\/(\d{1,2})\/(\d{1,2})$/);
    if (isoMatch) {
        const year = isoMatch[1];
        const month = isoMatch[2].padStart(2, '0');
        const day = isoMatch[3].padStart(2, '0');
        return year + '-' + month + '-' + day;
    }

    return null;
}

function getTodayDisplayDate() {
    return formatDateForDisplay(new Date().toISOString().split('T')[0]);
}

function setDateInputDisplayValue(fieldName, isoDate) {
    const input = document.querySelector('[name="' + fieldName + '"]');
    if (!input) {
        return;
    }

    input.value = formatDateForDisplay(isoDate);
}

function initInvoiceDatepickers() {
    if (!window.jQuery || !window.jQuery.fn || !window.jQuery.fn.datepicker) {
        return;
    }

    const $dateInputs = window.jQuery('.datepicker-input');
    if (!$dateInputs.length) {
        return;
    }

    $dateInputs.each(function() {
        const $input = window.jQuery(this);
        if ($input.data('datepicker')) {
            $input.datepicker('destroy');
        }

        $input.data('calendartype', 'gregorian');
        $input.attr('data-calendartype', 'gregorian');
    });

    $dateInputs.datepicker({
        format: 'dd/mm/yyyy',
        language: 'ar',
        rtl: true,
        autoclose: true,
        todayHighlight: true,
        calendarType: 'gregorian',
        container: '#addInvoiceModal',
        orientation: 'bottom auto',
        weekStart: 0,
        zIndexOffset: 2050
    });

    window.jQuery('.invoice-date-picker-trigger').off('click').on('click', function() {
        const $input = window.jQuery(this).siblings('input.datepicker-input');
        $input.focus();
        $input.datepicker('show');
    });

    $dateInputs.off('click.invoiceDatepicker').on('click.invoiceDatepicker', function() {
        window.jQuery(this).datepicker('show');
    });
}

function isCreditNoteTypeSelected() {
    return (document.querySelector('[name="invoice_type"]')?.value || 'standard') === 'credit_note';
}

function updateInvoiceModalLabels() {
    const invoiceType = document.querySelector('[name="invoice_type"]')?.value || 'standard';
    const invoiceTypeLabel = getInvoiceTypeLabel(invoiceType);
    const editInvoiceField = document.getElementById('edit_invoice_id');
    const invoiceNumber = editInvoiceField.getAttribute('data-invoice-number') || '';
    const isEditing = !!editInvoiceField.value;

    document.getElementById('addInvoiceModalLabel').innerHTML = isEditing
        ? '<i class="bi bi-pencil me-2"></i>تعديل ' + invoiceTypeLabel + (invoiceNumber ? ' - ' + invoiceNumber : '')
        : '<i class="bi bi-plus-circle me-2"></i>' + (invoiceType === 'credit_note'
            ? 'إشعار دائن جديد'
            : (invoiceType === 'debit_note'
                ? 'إشعار مدين جديد'
                : (invoiceType === 'simplified' ? 'فاتورة مبسطة جديدة' : 'فاتورة جديدة')));

    document.getElementById('submitInvoiceBtn').innerHTML = '<i class="bi bi-check-circle me-2"></i>' + (isEditing ? 'حفظ التعديلات' : 'حفظ ' + invoiceTypeLabel);
}

function addItem() {
    itemCounter++;
    const itemHtml = `
        <div class="item-row" id="item_${itemCounter}">
            <div class="row g-2">
                <div class="col-md-4">
                    <input type="text" class="form-control" name="item_description_${itemCounter}" placeholder="وصف الصنف" required>
                </div>
                <div class="col-md-2">
                    <input type="number" step="0.01" class="form-control quantity-input" name="quantity_${itemCounter}" placeholder="الكمية" value="1" onchange="calculateTotals()" required>
                </div>
                <div class="col-md-2">
                    <input type="number" step="0.01" class="form-control price-input" name="unit_price_${itemCounter}" placeholder="السعر" value="0" onchange="calculateTotals()" required>
                </div>
                <div class="col-md-2">
                    <input type="number" step="0.01" class="form-control" name="vat_rate_${itemCounter}" placeholder="الضريبة %" value="${vatRate}" readonly>
                </div>
                <div class="col-md-1">
                    <input type="text" class="form-control item-total" name="total_${itemCounter}" placeholder="المجموع" readonly>
                </div>
                <div class="col-md-1">
                    <button type="button" class="btn btn-danger btn-sm" onclick="removeItem(${itemCounter})">
                        <i class="bi bi-trash"></i>
                    </button>
                </div>
            </div>
        </div>
    `;

    document.getElementById('invoiceItems').insertAdjacentHTML('beforeend', itemHtml);
}

function removeItem(itemId) {
    document.getElementById('item_' + itemId).remove();
    calculateTotals();
}

function calculateTotals() {
    let subtotal = 0;

    for (let i = 1; i <= itemCounter; i++) {
        const quantityInput = document.querySelector(`[name="quantity_${i}"]`);
        const priceInput = document.querySelector(`[name="unit_price_${i}"]`);
        const totalInput = document.querySelector(`[name="total_${i}"]`);

        if (quantityInput && priceInput) {
            const quantity = parseFloat(quantityInput.value) || 0;
            const price = parseFloat(priceInput.value) || 0;
            const itemTotal = quantity * price;
            const itemDisplayTotal = isCreditNoteTypeSelected() ? -itemTotal : itemTotal;

            if (totalInput) {
                totalInput.value = itemDisplayTotal.toFixed(2);
            }

            subtotal += itemTotal;
        }
    }

    const vat = subtotal * (vatRate / 100);
    const total = subtotal + vat;
    const summaryDisplaySign = isCreditNoteTypeSelected() ? -1 : 1;

    document.getElementById('subtotalDisplay').textContent = (summaryDisplaySign * subtotal).toFixed(2);
    document.getElementById('vatDisplay').textContent = (summaryDisplaySign * vat).toFixed(2);
    document.getElementById('totalDisplay').textContent = (summaryDisplaySign * total).toFixed(2);
}

function applySellerSnapshot(seller) {
    document.getElementById('seller_source').value = seller.source || 'company';
    document.getElementById('seller_supplier_id').value = seller.supplier_id || '';
    document.getElementById('seller_name').value = seller.name || '';
    document.getElementById('seller_vat_number').value = seller.vat_number || '';
    document.getElementById('seller_address').value = seller.address || '';
    document.getElementById('sellerSearch').value = seller.name || '';
    document.getElementById('seller_display_name').value = seller.name || '';
    document.getElementById('seller_display_vat_number').value = seller.vat_number || '';
    document.getElementById('seller_display_phone').value = seller.phone || '';
    document.getElementById('seller_display_address').value = seller.address || '';
}

let selectedExistingSupplierSnapshot = null;
let isNewSupplier = false;

function getSupplierFormState() {
    return {
        supplier_name: document.getElementById('seller_display_name').value.trim(),
        vat_number: document.getElementById('seller_display_vat_number').value.trim(),
        phone: document.getElementById('seller_display_phone').value.trim(),
        address: document.getElementById('seller_display_address').value.trim()
    };
}

function syncSellerSnapshotFromForm() {
    const current = getSupplierFormState();
    document.getElementById('seller_name').value = current.supplier_name;
    document.getElementById('seller_vat_number').value = current.vat_number;
    document.getElementById('seller_address').value = current.address;
    document.getElementById('sellerSearch').value = current.supplier_name;
}

function resetSupplierSaveState() {
    selectedExistingSupplierSnapshot = null;
    document.getElementById('saveSupplierInfoContainer').style.display = 'none';
}

function updateSaveSupplierButtonVisibility() {
    syncSellerSnapshotFromForm();
    const supplierId = document.getElementById('seller_supplier_id').value;
    const source = document.getElementById('seller_source').value;
    const container = document.getElementById('saveSupplierInfoContainer');
    const button = document.getElementById('saveSupplierInfoBtn');
    const current = getSupplierFormState();

    if (source === 'company') {
        container.style.display = 'none';
        return;
    }

    if (isNewSupplier && !supplierId) {
        const hasNewSupplierData = current.supplier_name || current.vat_number || current.phone || current.address;
        button.innerHTML = '<i class="bi bi-save me-1"></i>حفظ المورد';
        container.style.display = hasNewSupplierData ? 'block' : 'none';
        return;
    }

    button.innerHTML = '<i class="bi bi-save me-1"></i>حفظ بيانات المورد';

    if (!supplierId || !selectedExistingSupplierSnapshot) {
        container.style.display = 'none';
        return;
    }

    const hasChanges = current.supplier_name !== selectedExistingSupplierSnapshot.supplier_name ||
        current.vat_number !== selectedExistingSupplierSnapshot.vat_number ||
        current.phone !== selectedExistingSupplierSnapshot.phone ||
        current.address !== selectedExistingSupplierSnapshot.address;

    container.style.display = hasChanges ? 'block' : 'none';
}

function createSupplierQuick(current, successMessage) {
    const formData = new FormData();
    formData.append('ajax_action', 'add_supplier_quick');
    formData.append('supplier_name', current.supplier_name);
    formData.append('vat_number', current.vat_number);
    formData.append('phone', current.phone);
    formData.append('address', current.address);

    return fetch('index.hnt', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        if (!data.success) {
            throw new Error(data.message || 'فشل في إضافة المورد');
        }

        suppliersData.push({
            supplier_id: data.supplier.supplier_id,
            supplier_name: data.supplier.supplier_name,
            vat_number: data.supplier.vat_number || '',
            phone: data.supplier.phone || '',
            address: data.supplier.address || ''
        });

        document.getElementById('seller_source').value = 'supplier';
        document.getElementById('seller_supplier_id').value = data.supplier.supplier_id;
        isNewSupplier = false;
        selectedExistingSupplierSnapshot = {
            supplier_name: current.supplier_name,
            vat_number: current.vat_number,
            phone: current.phone,
            address: current.address
        };
        syncSellerSnapshotFromForm();
        updateSaveSupplierButtonVisibility();

        if (successMessage) {
            showResultModal(true, successMessage);
        }

        return data;
    });
}

function saveSupplierInfo() {
    const supplierId = document.getElementById('seller_supplier_id').value;
    const current = getSupplierFormState();

    if (!current.supplier_name) {
        showResultModal(false, 'اسم المورد مطلوب');
        return;
    }

    if (isNewSupplier && !supplierId) {
        createSupplierQuick(current, 'تم حفظ المورد بنجاح')
            .catch(error => {
                console.error('Error:', error);
                showResultModal(false, error.message || 'حدث خطأ أثناء حفظ المورد');
            });
        return;
    }

    const formData = new FormData();
    formData.append('ajax_action', 'update_supplier_quick');
    formData.append('supplier_id', supplierId);
    formData.append('supplier_name', current.supplier_name);
    formData.append('vat_number', current.vat_number);
    formData.append('phone', current.phone);
    formData.append('address', current.address);

    fetch('index.hnt', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            const supplierIndex = suppliersData.findIndex(function(item) {
                return String(item.supplier_id) === String(supplierId);
            });
            if (supplierIndex !== -1) {
                suppliersData[supplierIndex].supplier_name = current.supplier_name;
                suppliersData[supplierIndex].vat_number = current.vat_number;
                suppliersData[supplierIndex].phone = current.phone;
                suppliersData[supplierIndex].address = current.address;
            }
            selectedExistingSupplierSnapshot = {
                supplier_name: current.supplier_name,
                vat_number: current.vat_number,
                phone: current.phone,
                address: current.address
            };
            syncSellerSnapshotFromForm();
            updateSaveSupplierButtonVisibility();
            showResultModal(true, data.message || 'تم حفظ بيانات المورد بنجاح');
        } else {
            showResultModal(false, data.message || 'فشل في حفظ بيانات المورد');
        }
    })
    .catch(error => {
        console.error('Error:', error);
        showResultModal(false, 'حدث خطأ أثناء حفظ بيانات المورد');
    });
}

function searchSellers(searchTerm) {
    const term = searchTerm.trim().toLowerCase();
    const sellerDropdown = document.getElementById('sellerDropdown');

    const matches = suppliersData.filter(supplier => {
        if (!term) {
            return true;
        }

        return (supplier.supplier_name || '').toLowerCase().includes(term) ||
            (supplier.vat_number || '').toLowerCase().includes(term) ||
            (supplier.phone || '').toLowerCase().includes(term) ||
            (supplier.address || '').toLowerCase().includes(term);
    });

    displaySellerDropdown(matches, term);
}

function displaySellerDropdown(suppliers, term) {
    const sellerDropdown = document.getElementById('sellerDropdown');
    sellerDropdown.innerHTML = '';

    if (!term || defaultSeller.name.toLowerCase().includes(term) || defaultSeller.vat_number.toLowerCase().includes(term)) {
        const companyItem = document.createElement('a');
        companyItem.href = '#';
        companyItem.className = 'list-group-item list-group-item-action';
        companyItem.innerHTML = `
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <strong>${defaultSeller.name}</strong>
                    <br><small class="text-primary">مؤسستنا - الافتراضي</small>
                    ${defaultSeller.vat_number ? '<br><small class="text-muted">الرقم الضريبي: ' + defaultSeller.vat_number + '</small>' : ''}
                </div>
            </div>
        `;
        companyItem.addEventListener('click', function(e) {
            e.preventDefault();
            selectSeller(defaultSeller);
        });
        sellerDropdown.appendChild(companyItem);
    }

    suppliers.forEach(supplier => {
        const item = document.createElement('a');
        item.href = '#';
        item.className = 'list-group-item list-group-item-action';
        item.innerHTML = `
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <strong>${supplier.supplier_name}</strong>
                    ${supplier.vat_number ? '<br><small class="text-muted">الرقم الضريبي: ' + supplier.vat_number + '</small>' : ''}
                    ${supplier.phone ? '<br><small class="text-muted">الهاتف: ' + supplier.phone + '</small>' : ''}
                    ${supplier.address ? '<br><small class="text-muted">' + supplier.address + '</small>' : ''}
                </div>
            </div>
        `;

        item.addEventListener('click', function(e) {
            e.preventDefault();
            selectSeller({
                source: 'supplier',
                supplier_id: supplier.supplier_id,
                name: supplier.supplier_name,
                vat_number: supplier.vat_number || '',
                phone: supplier.phone || '',
                address: supplier.address || ''
            });
        });

        sellerDropdown.appendChild(item);
    });

    sellerDropdown.style.display = sellerDropdown.children.length ? 'block' : 'none';
}

function selectSeller(seller) {
    isNewSupplier = false;
    applySellerSnapshot(seller);
    if ((seller.source || 'company') === 'supplier' && seller.supplier_id) {
        selectedExistingSupplierSnapshot = {
            supplier_name: seller.name || '',
            vat_number: seller.vat_number || '',
            phone: seller.phone || '',
            address: seller.address || ''
        };
    } else {
        resetSupplierSaveState();
    }
    updateSaveSupplierButtonVisibility();
    document.getElementById('sellerDropdown').style.display = 'none';
}

function submitInvoice() {
    const form = document.getElementById('addInvoiceForm');
    const formData = new FormData(form);
    syncSellerSnapshotFromForm();

    const invoiceDateInput = document.querySelector('[name="invoice_date"]');
    const dueDateInput = document.querySelector('[name="due_date"]');
    const invoiceDateIso = parseDisplayDateToIso(invoiceDateInput ? invoiceDateInput.value : '');
    const dueDateIso = parseDisplayDateToIso(dueDateInput ? dueDateInput.value : '');

    if (!invoiceDateIso) {
        showResultModal(false, 'يرجى إدخال تاريخ الفاتورة بصيغة dd/mm/yyyy');
        return;
    }

    if (dueDateInput && dueDateInput.value.trim() !== '' && !dueDateIso) {
        showResultModal(false, 'يرجى إدخال تاريخ الاستحقاق بصيغة dd/mm/yyyy');
        return;
    }

    formData.set('invoice_date', invoiceDateIso);
    formData.set('due_date', dueDateIso || '');

    if (!document.getElementById('seller_name').value.trim()) {
        showResultModal(false, 'بيانات البائع غير مكتملة');
        return;
    }

    // Collect items
    const items = [];
    for (let i = 1; i <= itemCounter; i++) {
        const descInput = document.querySelector(`[name="item_description_${i}"]`);
        if (descInput && descInput.value) {
            const quantity = parseFloat(document.querySelector(`[name="quantity_${i}"]`).value) || 0;
            const unitPrice = parseFloat(document.querySelector(`[name="unit_price_${i}"]`).value) || 0;
            const vatRate = parseFloat(document.querySelector(`[name="vat_rate_${i}"]`).value) || 0;

            items.push({
                description: descInput.value,
                quantity: quantity,
                unit_price: unitPrice,
                vat_rate: vatRate,
                vat_amount: (quantity * unitPrice * vatRate / 100),
                total_amount: quantity * unitPrice * (1 + vatRate / 100)
            });
        }
    }

    if (items.length === 0) {
        showResultModal(false, 'يجب إضافة بند واحد على الأقل');
        return;
    }

    const editInvoiceId = document.getElementById('edit_invoice_id').value;
    if (editInvoiceId) {
        formData.append('ajax_action', 'update_invoice');
        formData.append('invoice_id', editInvoiceId);
    } else {
        formData.append('ajax_action', 'create_invoice');
    }
    formData.append('items', JSON.stringify(items));

    fetch('index.hnt', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        showResultModal(data.success, data.message || (data.error ? data.error : 'خطأ غير معروف'));

        if (data.success) {
            const modal = bootstrap.Modal.getInstance(document.getElementById('addInvoiceModal'));
            if (modal) {
                modal.hide();
            }
            setTimeout(() => location.reload(), 1500);
        }
    })
    .catch(error => {
        console.error('Error:', error);
        showResultModal(false, 'حدث خطأ أثناء الحفظ');
    });
}

function viewInvoice(invoiceId) {
    window.location = 'view.hnt?id=' + invoiceId;
}

function printInvoice(invoiceId) {
    window.open('print.hnt?id=' + invoiceId, '_blank');
}

function editInvoice(invoiceId) {
    const formData = new FormData();
    formData.append('ajax_action', 'get_invoice_with_items');
    formData.append('invoice_id', invoiceId);

    fetch('index.hnt', { method: 'POST', body: formData })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        if (!data.success) {
            showResultModal(false, data.error || 'فشل في تحميل بيانات الفاتورة');
            return;
        }
        var inv = data.invoice;
        var invItems = data.items;

        document.getElementById('edit_invoice_id').value = inv.invoice_id;
        document.getElementById('edit_invoice_id').setAttribute('data-invoice-number', inv.invoice_number || '');

        setInvoiceTypeValue(inv.invoice_type || 'standard');
        setDateInputDisplayValue('invoice_date', inv.invoice_date || '');
        setDateInputDisplayValue('due_date', inv.due_date || inv.invoice_date || '');
        document.querySelector('[name="customer_type"]').value = inv.customer_type || 'tenant';
        document.querySelector('[name="payment_method"]').value = inv.payment_method || 'cash';
        document.querySelector('[name="notes"]').value = inv.notes || '';

        document.getElementById('selectedCustomerId').value = inv.customer_id || '';
        document.getElementById('invoice_journal_id').value = inv.journal_id || '';
        document.getElementById('invoice_cost_center_id').value = inv.cost_center_id || '';
        document.getElementById('invoice_tenant_id').value = inv.tenant_id || '';
        document.getElementById('invoice_owner_id').value = inv.owner_id || '';
        document.getElementById('invoice_aqar_id').value = inv.aqar_id || '';
        document.getElementById('invoice_subaqar_id').value = inv.subaqar_id || '';
        document.getElementById('invoice_egar_id').value = inv.egar_id || '';
        document.getElementById('customerSearch').value = inv.customer_name || '';
        document.getElementById('customer_name').value = inv.customer_name || '';
        document.getElementById('customer_vat_number').value = inv.customer_vat_number || '';
        document.getElementById('customer_phone').value = data.customer_phone || '';
        document.getElementById('customer_address').value = inv.customer_address || '';
        document.getElementById('customerDetails').style.display = 'block';
        isNewCustomer = false;
        selectedExistingCustomerSnapshot = {
            customer_name: inv.customer_name || '',
            vat_number: inv.customer_vat_number || '',
            phone: data.customer_phone || '',
            address: inv.customer_address || ''
        };

        selectSeller({
            source: inv.seller_source || 'company',
            supplier_id: inv.seller_supplier_id || '',
            name: inv.seller_name || defaultSeller.name,
            vat_number: inv.seller_vat_number || defaultSeller.vat_number,
            phone: data.supplier_phone || '',
            address: inv.seller_address || defaultSeller.address
        });

        document.getElementById('invoiceItems').innerHTML = '';
        itemCounter = 0;
        if (invItems && invItems.length > 0) {
            invItems.forEach(function(item) {
                addItem();
                var idx = itemCounter;
                document.querySelector('[name="item_description_' + idx + '"]').value = item.item_description || '';
                document.querySelector('[name="quantity_' + idx + '"]').value = item.quantity || 1;
                document.querySelector('[name="unit_price_' + idx + '"]').value = item.unit_price || 0;
                document.querySelector('[name="vat_rate_' + idx + '"]').value = item.vat_rate || vatRate;
            });
        } else {
            addItem();
        }
        calculateTotals();

        var modal = new bootstrap.Modal(document.getElementById('addInvoiceModal'));
        modal.show();
    })
    .catch(function(error) {
        console.error('Error:', error);
        showResultModal(false, 'حدث خطأ أثناء تحميل بيانات الفاتورة');
    });
}

function resetInvoiceForm() {
    document.getElementById('edit_invoice_id').value = '';
    document.getElementById('edit_invoice_id').setAttribute('data-invoice-number', '');
    document.getElementById('addInvoiceForm').reset();
    setInvoiceTypeValue('standard');
    var today = getTodayDisplayDate();
    document.querySelector('[name="invoice_date"]').value = today;
    document.querySelector('[name="due_date"]').value = today;
    document.getElementById('selectedCustomerId').value = '';
    document.getElementById('invoice_journal_id').value = '';
    document.getElementById('invoice_cost_center_id').value = '';
    document.getElementById('invoice_tenant_id').value = '';
    document.getElementById('invoice_owner_id').value = '';
    document.getElementById('invoice_aqar_id').value = '';
    document.getElementById('invoice_subaqar_id').value = '';
    document.getElementById('invoice_egar_id').value = '';
    document.getElementById('customerSearch').value = '';
    document.getElementById('customerDetails').style.display = 'none';
    document.getElementById('invoiceItems').innerHTML = '';
    itemCounter = 0;
    isNewCustomer = false;
    selectedExistingCustomerSnapshot = null;
    isNewSupplier = false;
    resetSupplierSaveState();
    applySellerSnapshot(defaultSeller);
    addItem();
    calculateTotals();
}

let selectedExistingCustomerSnapshot = null;

function getCustomerFormState() {
    return {
        customer_name: document.getElementById('customer_name').value.trim(),
        vat_number: document.getElementById('customer_vat_number').value.trim(),
        phone: document.getElementById('customer_phone').value.trim(),
        address: document.getElementById('customer_address').value.trim()
    };
}

function resetCustomerSaveState() {
    selectedExistingCustomerSnapshot = null;
    document.getElementById('saveCustomerInfoContainer').style.display = 'none';
}

function updateSaveCustomerButtonVisibility() {
    const customerId = document.getElementById('selectedCustomerId').value;
    const container = document.getElementById('saveCustomerInfoContainer');
    const button = document.getElementById('saveCustomerInfoBtn');
    const current = getCustomerFormState();

    if (isNewCustomer && !customerId) {
        const hasNewCustomerData = current.customer_name || current.vat_number || current.phone || current.address;
        button.innerHTML = '<i class="bi bi-save me-1"></i>حفظ العميل';
        container.style.display = hasNewCustomerData ? 'block' : 'none';
        return;
    }

    button.innerHTML = '<i class="bi bi-save me-1"></i>حفظ بيانات العميل';

    if (!customerId || !selectedExistingCustomerSnapshot) {
        container.style.display = 'none';
        return;
    }

    const hasChanges = current.customer_name !== selectedExistingCustomerSnapshot.customer_name ||
        current.vat_number !== selectedExistingCustomerSnapshot.vat_number ||
        current.phone !== selectedExistingCustomerSnapshot.phone ||
        current.address !== selectedExistingCustomerSnapshot.address;

    container.style.display = hasChanges ? 'block' : 'none';
}

function createCustomerQuick(current, successMessage) {
    const formData = new FormData();
    formData.append('ajax_action', 'add_customer_quick');
    formData.append('customer_name', current.customer_name);
    formData.append('vat_number', current.vat_number);
    formData.append('phone', current.phone);
    formData.append('address', current.address);

    return fetch('index.hnt', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        if (!data.success) {
            throw new Error(data.message || 'فشل في إضافة العميل');
        }

        document.getElementById('selectedCustomerId').value = data.customer.customer_id;
        customerSearchInput.value = current.customer_name;
        isNewCustomer = false;
        selectedExistingCustomerSnapshot = {
            customer_name: current.customer_name,
            vat_number: current.vat_number,
            phone: current.phone,
            address: current.address
        };
        updateSaveCustomerButtonVisibility();

        if (successMessage) {
            showResultModal(true, successMessage);
        }

        return data;
    });
}

function saveCustomerInfo() {
    const customerId = document.getElementById('selectedCustomerId').value;

    const current = getCustomerFormState();

    if (!current.customer_name) {
        showResultModal(false, 'اسم العميل مطلوب');
        return;
    }

    if (isNewCustomer && !customerId) {
        createCustomerQuick(current, 'تم حفظ العميل بنجاح')
            .catch(error => {
                console.error('Error:', error);
                showResultModal(false, error.message || 'حدث خطأ أثناء حفظ العميل');
            });
        return;
    }

    const formData = new FormData();
    formData.append('ajax_action', 'update_customer_quick');
    formData.append('customer_id', customerId);
    formData.append('customer_name', current.customer_name);
    formData.append('vat_number', current.vat_number);
    formData.append('phone', current.phone);
    formData.append('address', current.address);

    fetch('index.hnt', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            selectedExistingCustomerSnapshot = {
                customer_name: current.customer_name,
                vat_number: current.vat_number,
                phone: current.phone,
                address: current.address
            };
            customerSearchInput.value = current.customer_name;
            updateSaveCustomerButtonVisibility();
            showResultModal(true, data.message || 'تم حفظ بيانات العميل بنجاح');
        } else {
            showResultModal(false, data.message || 'فشل في حفظ بيانات العميل');
        }
    })
    .catch(error => {
        console.error('Error:', error);
        showResultModal(false, 'حدث خطأ أثناء حفظ بيانات العميل');
    });
}

function submitToZatca(invoiceId) {
    console.log('submitToZatca called with invoice ID:', invoiceId);

    // Check if custom confirm function exists
    if (typeof confirm === 'function' && confirm.length >= 3) {
        // Use custom confirm dialog
        confirm('هل تريد إرسال هذه الفاتورة إلى ZATCA؟', 'تأكيد الإرسال', function() {
            console.log('User confirmed, proceeding with submission');
            performZatcaSubmission(invoiceId);
        }, function() {
            console.log('User cancelled ZATCA submission');
        });
    } else {
        // Fallback to native confirm
        if (window.confirm('هل تريد إرسال هذه الفاتورة إلى ZATCA؟')) {
            console.log('User confirmed, proceeding with submission');
            performZatcaSubmission(invoiceId);
        }
    }
}

function performZatcaSubmission(invoiceId) {
    // Show loading message
    const loadingModal = new bootstrap.Modal(document.getElementById('resultModal'));
    const header = document.getElementById('resultModalHeader');
    const title = document.getElementById('resultModalTitle');
    const messageEl = document.getElementById('resultModalMessage');

    header.style.background = 'linear-gradient(135deg, #0891b2, #06b6d4)';
    title.innerHTML = '<i class="bi bi-hourglass-split me-2"></i>جاري الإرسال';
    messageEl.textContent = 'جاري إرسال الفاتورة إلى ZATCA...';
    loadingModal.show();

    // Submit to ZATCA
    const formData = new FormData();
    formData.append('action', 'submit_to_zatca');
    formData.append('invoice_id', invoiceId);

    fetch('index.hnt', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        // Build detailed error message
        let errorMessage = data.message || data.error || 'خطأ غير معروف';

        // Add technical details if available
        if (!data.success && data.technical_details) {
            errorMessage += '\n\n--- تفاصيل تقنية من ZATCA API ---';

            if (data.technical_details.api_url) {
                errorMessage += '\nAPI URL: ' + data.technical_details.api_url;
            }

            if (data.technical_details.http_code) {
                errorMessage += '\nHTTP Status Code: ' + data.technical_details.http_code;
            }

            if (data.technical_details.error) {
                errorMessage += '\nError: ' + data.technical_details.error;
            }

            if (data.technical_details.error_detail) {
                errorMessage += '\nDetail: ' + data.technical_details.error_detail;
            }

            if (data.technical_details.validation_results && data.technical_details.validation_results.length > 0) {
                errorMessage += '\n\nValidation Results:';
                data.technical_details.validation_results.forEach((result, index) => {
                    errorMessage += '\n' + (index + 1) + '. ' + JSON.stringify(result, null, 2);
                });
            }

            if (data.technical_details.api_response) {
                errorMessage += '\n\nFull API Response:\n' + JSON.stringify(data.technical_details.api_response, null, 2);
            }

            // Log to console for developers
            console.error('ZATCA API Error Details:', data.technical_details);
        }

        // Build success message with ZATCA result details
        if (data.success) {
            let successMessage = data.message || 'تم إرسال الفاتورة بنجاح';

            // Add ZATCA result details
            if (data.zatca_uuid) {
                successMessage += '\n\n✅ UUID: ' + data.zatca_uuid;
            }
            if (data.zatca_hash) {
                successMessage += '\n✅ Hash: ' + data.zatca_hash.substring(0, 40) + '...';
            }
            if (data.api_result) {
                if (data.api_result.status) {
                    successMessage += '\n✅ Status: ' + data.api_result.status;
                }
                if (data.api_result.cleared_invoice) {
                    successMessage += '\n✅ Invoice Cleared Successfully';
                }
                if (data.api_result.reported_invoice) {
                    successMessage += '\n✅ Invoice Reported Successfully';
                }
                if (data.api_result.validation_results && data.api_result.validation_results.length > 0) {
                    successMessage += '\n\n📋 Validation Results:';
                    data.api_result.validation_results.forEach((result, index) => {
                        if (result.status) {
                            successMessage += '\n  ' + (index + 1) + '. ' + result.status;
                        }
                    });
                }
                if (data.api_result.warnings && data.api_result.warnings.length > 0) {
                    successMessage += '\n\n⚠️ Warnings:';
                    data.api_result.warnings.forEach((warning, index) => {
                        successMessage += '\n  ' + (index + 1) + '. ' + warning;
                    });
                }
            }

            showResultModal(true, successMessage, null, {
                autoReloadSeconds: 6
            });
        } else {
            showResultModal(false, errorMessage, data.technical_details);
        }
    })
    .catch(error => {
        console.error('Error:', error);
        showResultModal(false, 'حدث خطأ أثناء الإرسال إلى ZATCA');
    });
}

let resultModalReloadTimer = null;
let resultModalCountdownTimer = null;

function clearResultModalTimers() {
    if (resultModalReloadTimer) {
        clearTimeout(resultModalReloadTimer);
        resultModalReloadTimer = null;
    }

    if (resultModalCountdownTimer) {
        clearInterval(resultModalCountdownTimer);
        resultModalCountdownTimer = null;
    }
}

function showResultModal(success, message, technicalDetails, options = {}) {
    const modalElement = document.getElementById('resultModal');
    const modal = new bootstrap.Modal(modalElement);
    const header = document.getElementById('resultModalHeader');
    const title = document.getElementById('resultModalTitle');
    const messageEl = document.getElementById('resultModalMessage');
    const autoReloadSeconds = options.autoReloadSeconds || 0;

    clearResultModalTimers();

    if (success) {
        header.style.background = 'linear-gradient(135deg, #28a745, #20c997)';
        title.innerHTML = '<i class="bi bi-check-circle me-2"></i>نجحت العملية';
    } else {
        header.style.background = 'linear-gradient(135deg, #dc3545, #c82333)';
        title.innerHTML = '<i class="bi bi-x-circle me-2"></i>فشلت العملية';
    }

    // Format message with technical details if available
    if (technicalDetails) {
        messageEl.innerHTML = '<div style="white-space: pre-wrap; font-family: monospace; text-align: left; direction: ltr;">' +
                              message.replace(/</g, '&lt;').replace(/>/g, '&gt;') +
                              '</div>';
    } else {
        messageEl.innerHTML = '<div style="white-space: pre-wrap;">' + message.replace(/</g, '&lt;').replace(/>/g, '&gt;') + '</div>';

        if (success && autoReloadSeconds > 0) {
            const countdownWrapper = document.createElement('div');
            countdownWrapper.className = 'mt-3 alert alert-info mb-0';
            countdownWrapper.innerHTML = 'سيتم تحديث الصفحة خلال <strong id="resultModalCountdownValue">' + autoReloadSeconds + '</strong> ثانية. يمكنك إغلاق هذه النافذة لإلغاء التحديث التلقائي.';
            messageEl.appendChild(countdownWrapper);

            let remainingSeconds = autoReloadSeconds;
            const countdownValue = document.getElementById('resultModalCountdownValue');

            resultModalCountdownTimer = setInterval(() => {
                remainingSeconds -= 1;
                if (remainingSeconds <= 0) {
                    clearInterval(resultModalCountdownTimer);
                    resultModalCountdownTimer = null;
                    return;
                }

                if (countdownValue) {
                    countdownValue.textContent = remainingSeconds;
                }
            }, 1000);

            resultModalReloadTimer = setTimeout(() => {
                clearResultModalTimers();
                location.reload();
            }, autoReloadSeconds * 1000);
        }
    }

    // Clean up modal and backdrop when hidden
    modalElement.addEventListener('hidden.bs.modal', function() {
        clearResultModalTimers();
        modal.dispose();
        // Remove any remaining backdrops
        const backdrops = document.querySelectorAll('.modal-backdrop');
        backdrops.forEach(backdrop => backdrop.remove());
        // Restore body scroll
        document.body.classList.remove('modal-open');
        document.body.style.removeProperty('overflow');
        document.body.style.removeProperty('padding-right');
    }, { once: true });

    modal.show();
}

function recordPayment(invoiceId) {
    window.location = '../payments/index.hnt?invoice_id=' + encodeURIComponent(invoiceId);
}

// Customer autocomplete functionality
let searchTimeout;
const customerSearchInput = document.getElementById('customerSearch');
const customerDropdown = document.getElementById('customerDropdown');
const customerDetails = document.getElementById('customerDetails');
const sellerSearchInput = document.getElementById('sellerSearch');
const sellerDropdown = document.getElementById('sellerDropdown');
let isNewCustomer = false;

customerSearchInput.addEventListener('input', function() {
    const searchTerm = this.value.trim();

    clearTimeout(searchTimeout);

    if (searchTerm.length < 2) {
        customerDropdown.style.display = 'none';
        return;
    }

    searchTimeout = setTimeout(() => {
        searchCustomers(searchTerm);
    }, 300);
});

function searchCustomers(searchTerm) {
    const formData = new FormData();
    formData.append('ajax_action', 'search_customers');
    formData.append('search', searchTerm);

    fetch('index.hnt', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        if (data.success && data.customers.length > 0) {
            displayCustomerDropdown(data.customers);
        } else {
            customerDropdown.style.display = 'none';
        }
    })
    .catch(error => {
        console.error('Error:', error);
    });
}

function displayCustomerDropdown(customers) {
    customerDropdown.innerHTML = '';

    customers.forEach(customer => {
        const item = document.createElement('a');
        item.href = '#';
        item.className = 'list-group-item list-group-item-action';
        item.innerHTML = `
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <strong>${customer.customer_name}</strong>
                    ${customer.vat_number ? '<br><small class="text-muted">الرقم الضريبي: ' + customer.vat_number + '</small>' : ''}
                    ${customer.phone ? '<br><small class="text-muted">الهاتف: ' + customer.phone + '</small>' : ''}
                </div>
            </div>
        `;

        item.addEventListener('click', function(e) {
            e.preventDefault();
            selectCustomer(customer);
        });

        customerDropdown.appendChild(item);
    });

    customerDropdown.style.display = 'block';
}

function selectCustomer(customer) {
    isNewCustomer = false;

    // Fill customer fields
    document.getElementById('selectedCustomerId').value = customer.customer_id;
    document.getElementById('customer_name').value = customer.customer_name;
    document.getElementById('customer_vat_number').value = customer.vat_number || '';
    document.getElementById('customer_phone').value = customer.phone || '';
    document.getElementById('customer_address').value = customer.address || '';

    // Update search input
    customerSearchInput.value = customer.customer_name;

    // Show customer details
    customerDetails.style.display = 'block';
    customerDetails.querySelectorAll('.col-md-6, .col-md-12').forEach(el => {
        if (el.id === 'saveCustomerInfoContainer') {
            return;
        }
        el.style.display = 'block';
    });

    // Hide dropdown
    customerDropdown.style.display = 'none';

    selectedExistingCustomerSnapshot = {
        customer_name: customer.customer_name || '',
        vat_number: customer.vat_number || '',
        phone: customer.phone || '',
        address: customer.address || ''
    };
    updateSaveCustomerButtonVisibility();
}

// Add new customer button
document.getElementById('addNewCustomerBtn').addEventListener('click', function() {
    isNewCustomer = true;

    // Clear all fields
    document.getElementById('selectedCustomerId').value = '';
    document.getElementById('customer_name').value = customerSearchInput.value;
    document.getElementById('customer_vat_number').value = '';
    document.getElementById('customer_phone').value = '';
    document.getElementById('customer_address').value = '';

    // Show customer details
    customerDetails.style.display = 'block';
    customerDetails.querySelectorAll('.col-md-6, .col-md-12').forEach(el => {
        if (el.id === 'saveCustomerInfoContainer') {
            return;
        }
        el.style.display = 'block';
    });

    // Hide dropdown
    customerDropdown.style.display = 'none';

    // Make fields editable for new customer
    document.getElementById('customer_name').readOnly = false;
    document.getElementById('customer_vat_number').readOnly = false;
    document.getElementById('customer_phone').readOnly = false;
    document.getElementById('customer_address').readOnly = false;

    resetCustomerSaveState();
    updateSaveCustomerButtonVisibility();

    // Focus on customer name
    document.getElementById('customer_name').focus();
});

['customer_name', 'customer_vat_number', 'customer_phone', 'customer_address'].forEach(function(fieldId) {
    document.getElementById(fieldId).addEventListener('input', updateSaveCustomerButtonVisibility);
});

document.getElementById('addNewSupplierBtn').addEventListener('click', function() {
    isNewSupplier = true;
    document.getElementById('seller_source').value = 'supplier';
    document.getElementById('seller_supplier_id').value = '';
    document.getElementById('seller_display_name').value = sellerSearchInput.value.trim();
    document.getElementById('seller_display_vat_number').value = '';
    document.getElementById('seller_display_phone').value = '';
    document.getElementById('seller_display_address').value = '';
    selectedExistingSupplierSnapshot = null;
    updateSaveSupplierButtonVisibility();
    document.getElementById('seller_display_name').focus();
});

['seller_display_name', 'seller_display_vat_number', 'seller_display_phone', 'seller_display_address'].forEach(function(fieldId) {
    document.getElementById(fieldId).addEventListener('input', updateSaveSupplierButtonVisibility);
});

document.querySelector('[name="invoice_type"]').addEventListener('change', function() {
    updateInvoiceModalLabels();
    calculateTotals();
});

initInvoiceDatepickers();

sellerSearchInput.addEventListener('input', function() {
    searchSellers(this.value);
});

sellerSearchInput.addEventListener('focus', function() {
    searchSellers(this.value);
});

document.getElementById('useCompanySellerBtn').addEventListener('click', function() {
    selectSeller(defaultSeller);
});

// Hide dropdown when clicking outside
document.addEventListener('click', function(e) {
    if (!customerSearchInput.contains(e.target) && !customerDropdown.contains(e.target)) {
        customerDropdown.style.display = 'none';
    }

    if (!sellerSearchInput.contains(e.target) && !sellerDropdown.contains(e.target) && !document.getElementById('useCompanySellerBtn').contains(e.target)) {
        sellerDropdown.style.display = 'none';
    }
});

// Modified submitInvoice to handle new customer creation
const originalSubmitInvoice = submitInvoice;
submitInvoice = function() {
    if (isNewSupplier && !document.getElementById('seller_supplier_id').value) {
        const supplierName = document.getElementById('seller_display_name').value.trim();
        const vatNumber = document.getElementById('seller_display_vat_number').value.trim();
        const phone = document.getElementById('seller_display_phone').value.trim();
        const address = document.getElementById('seller_display_address').value.trim();

        if (!supplierName) {
            showResultModal(false, 'اسم المورد مطلوب');
            return;
        }

        createSupplierQuick({
            supplier_name: supplierName,
            vat_number: vatNumber,
            phone: phone,
            address: address
        })
        .then(() => {
            originalSubmitInvoice();
        })
        .catch(error => {
            console.error('Error:', error);
            showResultModal(false, error.message || 'حدث خطأ أثناء إضافة المورد');
        });
        return;
    }

    // If it's a new customer, create them first
    if (isNewCustomer && !document.getElementById('selectedCustomerId').value) {
        const customerName = document.getElementById('customer_name').value.trim();
        const vatNumber = document.getElementById('customer_vat_number').value.trim();
        const phone = document.getElementById('customer_phone').value.trim();
        const address = document.getElementById('customer_address').value.trim();

        if (!customerName) {
            showResultModal(false, 'اسم العميل مطلوب');
            return;
        }

        createCustomerQuick({
            customer_name: customerName,
            vat_number: vatNumber,
            phone: phone,
            address: address
        })
        .then(() => {
            originalSubmitInvoice();
        })
        .catch(error => {
            console.error('Error:', error);
            showResultModal(false, error.message || 'حدث خطأ أثناء إضافة العميل');
        });
    } else {
        // Customer already exists or selected, proceed normally
        originalSubmitInvoice();
    }
};

// Add initial item
applySellerSnapshot(defaultSeller);
addItem();

document.getElementById('addInvoiceModal').addEventListener('hidden.bs.modal', function() {
    if (document.getElementById('edit_invoice_id').value) {
        resetInvoiceForm();
    }
});

var urlParams = new URLSearchParams(window.location.search);
var editParam = urlParams.get('edit');
if (editParam) {
    editInvoice(parseInt(editParam));
}

function submitInvoicesImport() {
    const fileInput = document.getElementById('import_invoices_file');
    if (!fileInput.files.length) {
        alert('يرجى اختيار ملف CSV أولاً');
        return;
    }

    const btn = document.getElementById('importInvoicesSubmitBtn');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>جاري الاستيراد...';

    const formData = new FormData();
    formData.append('ajax_action', 'import_invoices');
    formData.append('import_file', fileInput.files[0]);

    fetch('index.hnt', { method: 'POST', body: formData })
        .then(r => r.json())
        .then(data => {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-upload me-2"></i>استيراد';

            const resultDiv = document.getElementById('importInvoicesResult');
            resultDiv.style.display = 'block';
            const cls  = data.imported > 0 ? 'alert-success' : 'alert-warning';
            const icon = data.imported > 0 ? 'check-circle' : 'exclamation-triangle';
            resultDiv.innerHTML = `<div class="alert ${cls}"><i class="bi bi-${icon} me-2"></i>${data.message.replace(/\n/g, '<br>')}</div>`;

            if (data.imported > 0) setTimeout(() => location.reload(), 2000);
        })
        .catch(() => {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-upload me-2"></i>استيراد';
            showResultModal(false, 'حدث خطأ أثناء الاستيراد', false);
        });
}

document.addEventListener('DOMContentLoaded', function() {
    const importModal = document.getElementById('importInvoicesModal');
    if (importModal) {
        importModal.addEventListener('show.bs.modal', function() {
            document.getElementById('import_invoices_file').value = '';
            const r   = document.getElementById('importInvoicesResult');
            r.style.display = 'none';
            r.innerHTML = '';
            const btn = document.getElementById('importInvoicesSubmitBtn');
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-upload me-2"></i>استيراد';
        });
    }
});
</script>

