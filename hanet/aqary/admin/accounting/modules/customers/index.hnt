$sc_title = "إدارة العملاء";
$sc_id = "209";
$use_accounting_theme = true;

// Export / template handler — runs before any HTML output
if (isset($_GET['export']) && in_array($_GET['export'], ['csv', 'xls', 'template'], true)) {
    include_once "../../../../reqloginajax.hnt";

    $_fn       = date('Ymd_His');
    $_exp_type = $_GET['export'];

    if ($_exp_type === 'template') {
        header('Content-Type: text/csv; charset=UTF-8');
        header('Content-Disposition: attachment; filename="customers_template_' . $_fn . '.csv"');
        $_out = fopen('php://output', 'w');
        fwrite($_out, "\xEF\xBB\xBF");
        fputcsv($_out, ['اسم العميل', 'الرقم الضريبي', 'رقم الهاتف', 'البريد الإلكتروني', 'العنوان'], ',', '"', '\\');
        fputcsv($_out, ['شركة الأمثلة للتجارة', '300000000000003', '0500000000', 'info@example.com', 'الرياض - حي العليا'], ',', '"', '\\');
        fclose($_out);
        exit;
    }

    $_search = isset($_GET['search']) ? trim($_GET['search']) : '';
    $_wc = "WHERE is_active = 1";
    $_bind_types = '';
    $_bind_params = [];
    if ($_search !== '') {
        $_wc .= " AND (customer_name LIKE ? OR vat_number LIKE ? OR phone LIKE ? OR email LIKE ?)";
        $_sp = "%{$_search}%";
        $_bind_types = 'ssss';
        $_bind_params = [$_sp, $_sp, $_sp, $_sp];
    }

    $exp_headers = ['اسم العميل', 'الرقم الضريبي', 'رقم الهاتف', 'البريد الإلكتروني', 'العنوان'];
    $exp_rows    = [];
    $_er_stmt = $db->prepare("SELECT customer_name, vat_number, phone, email, address FROM acc_customers {$_wc} ORDER BY customer_name");
    if ($_er_stmt) {
        if ($_bind_types !== '') $_er_stmt->bind_param($_bind_types, ...$_bind_params);
        $_er_stmt->execute();
        $_er = $_er_stmt->get_result();
        while ($_c = $_er->fetch_assoc()) {
            $exp_rows[] = [$_c['customer_name'], $_c['vat_number'] ?? '', $_c['phone'] ?? '', $_c['email'] ?? '', $_c['address'] ?? ''];
        }
    }

    if ($_exp_type === 'csv') {
        header('Content-Type: text/csv; charset=UTF-8');
        header('Content-Disposition: attachment; filename="customers_' . $_fn . '.csv"');
        $_out = fopen('php://output', 'w');
        fwrite($_out, "\xEF\xBB\xBF");
        fputcsv($_out, $exp_headers, ',', '"', '\\');
        foreach ($exp_rows as $_r) fputcsv($_out, $_r, ',', '"', '\\');
        fclose($_out);
        exit;
    }

    header('Content-Type: application/vnd.ms-excel; charset=UTF-8');
    header('Content-Disposition: attachment; filename="customers_' . $_fn . '.xls"');
    echo '<html lang="ar" dir="rtl"><head><meta charset="UTF-8"></head><body><table border="1"><tr>';
    foreach ($exp_headers as $_h) echo '<th>' . htmlspecialchars($_h) . '</th>';
    echo '</tr>';
    foreach ($exp_rows as $_r) {
        echo '<tr>';
        foreach ($_r as $_c) echo '<td>' . htmlspecialchars($_c) . '</td>';
        echo '</tr>';
    }
    echo '</table></body></html>';
    exit;
}

if(isset($_POST['ajax_action'])){
    include_once "../../../../reqloginajax.hnt";
}
else {
    include_once "../../../../header.hnt";
}
    include_once "../../includes/accounting_class.hnt";

// Handle AJAX actions
if ($_SERVER['REQUEST_METHOD'] == 'POST' && isset($_POST['ajax_action'])) {
    header('Content-Type: application/json; charset=utf-8');

    $action = $_POST['ajax_action'];
    $response = ['success' => false, 'message' => ''];

    switch ($action) {
        case 'add_customer':
            $name = $_POST['customer_name'];
            $vatNumber = $_POST['vat_number'] ?? null;
            $phone = $_POST['phone'] ?? null;
            $email = $_POST['email'] ?? null;
            $address = $_POST['address'] ?? null;

            $query = "INSERT INTO acc_customers (customer_name, vat_number, phone, email, address, created_at)
                      VALUES (?, ?, ?, ?, ?, NOW())";
            $stmt = $db->prepare($query);
            $stmt->bind_param('sssss', $name, $vatNumber, $phone, $email, $address);

            if ($stmt->execute()) {
                $response['success'] = true;
                $response['message'] = 'تم إضافة العميل بنجاح';
            } else {
                $response['message'] = 'فشل في إضافة العميل';
            }
            break;

        case 'import_customers':
            if (empty($_FILES['import_file']['tmp_name'])) {
                $response = ['success' => false, 'message' => 'لم يتم رفع أي ملف'];
                break;
            }
            $handle = fopen($_FILES['import_file']['tmp_name'], 'r');
            if (!$handle) {
                $response = ['success' => false, 'message' => 'تعذر قراءة الملف'];
                break;
            }
            $bom = fread($handle, 3);
            if ($bom !== "\xEF\xBB\xBF") rewind($handle);
            fgetcsv($handle, 0, ',', '"', '\\'); // skip header row

            $imported = 0;
            $errors   = [];
            $lineNum  = 1;

            while (($row = fgetcsv($handle, 0, ',', '"', '\\')) !== false) {
                $lineNum++;
                if (count($row) < 1 || empty(trim($row[0]))) continue;

                $_name    = trim($row[0]);
                $_vat     = trim($row[1] ?? '');
                $_phone   = trim($row[2] ?? '');
                $_email   = trim($row[3] ?? '');
                $_address = trim($row[4] ?? '');

                // Skip duplicates
                $_chk = $db->prepare("SELECT customer_id FROM acc_customers WHERE customer_name = ? LIMIT 1");
                if ($_chk) {
                    $_chk->bind_param('s', $_name);
                    $_chk->execute();
                    if ($_chk->get_result()->num_rows > 0) {
                        $errors[] = "سطر $lineNum: العميل '$_name' موجود مسبقاً — تم تخطيه";
                        continue;
                    }
                }

                $_ins = $db->prepare("INSERT INTO acc_customers (customer_name, vat_number, phone, email, address, is_active, created_at) VALUES (?, ?, ?, ?, ?, 1, NOW())");
                if (!$_ins) { $errors[] = "سطر $lineNum: خطأ داخلي"; continue; }
                $_vat_val = $_vat ?: null;
                $_phn_val = $_phone ?: null;
                $_eml_val = $_email ?: null;
                $_adr_val = $_address ?: null;
                $_ins->bind_param('sssss', $_name, $_vat_val, $_phn_val, $_eml_val, $_adr_val);
                if ($_ins->execute()) {
                    $imported++;
                } else {
                    $errors[] = "سطر $lineNum: فشل إضافة '$_name'";
                }
            }
            fclose($handle);

            $msg = "تم استيراد $imported عميل بنجاح";
            if (!empty($errors)) $msg .= "\n\nتنبيهات:\n" . implode("\n", $errors);
            $response = ['success' => true, 'message' => $msg, 'imported' => $imported, 'errors' => $errors];
            break;
    }

    echo json_encode($response, JSON_UNESCAPED_UNICODE);
    exit;
}

// Create customers table if not exists
$createTableQuery = "
CREATE TABLE IF NOT EXISTS acc_customers (
    customer_id INT AUTO_INCREMENT PRIMARY KEY,
    customer_name VARCHAR(255) NOT NULL,
    vat_number VARCHAR(15),
    phone VARCHAR(20),
    email VARCHAR(100),
    address TEXT,
    is_active TINYINT(1) DEFAULT 1,
    created_at DATETIME,
    formuid VARCHAR(36)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci
";
$db->query($createTableQuery);

// Pagination and filters
$page = isset($_GET['page']) ? (int)$_GET['page'] : 1;
$perPage = 20;
$offset = ($page - 1) * $perPage;

$search = isset($_GET['search']) ? trim($_GET['search']) : '';
$filterBalance = isset($_GET['filter_balance']) ? $_GET['filter_balance'] : 'all';

// Build WHERE clause
$whereConditions = ["is_active = 1"];
$params = [];
$types = '';

if (!empty($search)) {
    $whereConditions[] = "(customer_name LIKE ? OR vat_number LIKE ? OR phone LIKE ? OR email LIKE ?)";
    $searchParam = "%{$search}%";
    $params[] = $searchParam;
    $params[] = $searchParam;
    $params[] = $searchParam;
    $params[] = $searchParam;
    $types .= 'ssss';
}

$whereClause = implode(' AND ', $whereConditions);

// Get total count
$countQuery = "SELECT COUNT(*) as total FROM acc_customers WHERE {$whereClause}";
if (!empty($params)) {
    $stmt = $db->prepare($countQuery);
    $stmt->bind_param($types, ...$params);
    $stmt->execute();
    $totalResult = $stmt->get_result()->fetch_assoc();
} else {
    $totalResult = $db->query($countQuery)->fetch_assoc();
}
$totalCustomers = $totalResult['total'];
$totalPages = ceil($totalCustomers / $perPage);

// Get customers with pagination
$customersQuery = "SELECT * FROM acc_customers WHERE {$whereClause} ORDER BY customer_name LIMIT ? OFFSET ?";
$params[] = $perPage;
$params[] = $offset;
$types .= 'ii';

$stmt = $db->prepare($customersQuery);
if (!empty($params)) {
    $stmt->bind_param($types, ...$params);
}
$stmt->execute();
$customersResult = $stmt->get_result();

$customers = [];
if ($customersResult) {
    while ($row = $customersResult->fetch_assoc()) {
        // Get customer invoices
        $invoiceQuery = "SELECT COUNT(*) as count, SUM(total_amount) as total, SUM(total_amount - paid_amount) as balance
                        FROM acc_invoices WHERE customer_name = ?";
        $stmt2 = $db->prepare($invoiceQuery);
        $stmt2->bind_param('s', $row['customer_name']);
        $stmt2->execute();
        $invoiceData = $stmt2->get_result()->fetch_assoc();

        $row['invoice_count'] = $invoiceData['count'] ?? 0;
        $row['total_sales'] = $invoiceData['total'] ?? 0;
        $row['balance'] = $invoiceData['balance'] ?? 0;

        $customers[] = $row;
    }
}

// Apply balance filter if needed
if ($filterBalance == 'with_balance') {
    $customers = array_filter($customers, function($c) { return $c['balance'] > 0; });
} elseif ($filterBalance == 'no_balance') {
    $customers = array_filter($customers, function($c) { return $c['balance'] <= 0; });
}
?>


