$sc_title = "إدارة العملاء";
$sc_id = "209";
$use_accounting_theme = true;
if(isset($_POST['ajax_action'])){
    include_once "../../../../reqloginajax.hnt";
}
else {
    include_once "../../../../header.hnt";
}
    include_once "../../includes/accounting_class.hnt";

// Handle AJAX actions
if ($_SERVER['REQUEST_METHOD'] == 'POST' && isset($_POST['ajax_action'])) {
    header('Content-Type: application/json; charset=utf-8');

    $action = $_POST['ajax_action'];
    $response = ['success' => false, 'message' => ''];

    switch ($action) {
        case 'add_customer':
            $name = $_POST['customer_name'];
            $vatNumber = $_POST['vat_number'] ?? null;
            $phone = $_POST['phone'] ?? null;
            $email = $_POST['email'] ?? null;
            $address = $_POST['address'] ?? null;

            $query = "INSERT INTO acc_customers (customer_name, vat_number, phone, email, address, created_at)
                      VALUES (?, ?, ?, ?, ?, NOW())";
            $stmt = $db->prepare($query);
            $stmt->bind_param('sssss', $name, $vatNumber, $phone, $email, $address);

            if ($stmt->execute()) {
                $response['success'] = true;
                $response['message'] = 'تم إضافة العميل بنجاح';
            } else {
                $response['message'] = 'فشل في إضافة العميل';
            }
            break;
    }

    echo json_encode($response, JSON_UNESCAPED_UNICODE);
    exit;
}

// Create customers table if not exists
$createTableQuery = "
CREATE TABLE IF NOT EXISTS acc_customers (
    customer_id INT AUTO_INCREMENT PRIMARY KEY,
    customer_name VARCHAR(255) NOT NULL,
    vat_number VARCHAR(15),
    phone VARCHAR(20),
    email VARCHAR(100),
    address TEXT,
    is_active TINYINT(1) DEFAULT 1,
    created_at DATETIME,
    formuid VARCHAR(36)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci
";
$db->query($createTableQuery);

// Pagination and filters
$page = isset($_GET['page']) ? (int)$_GET['page'] : 1;
$perPage = 20;
$offset = ($page - 1) * $perPage;

$search = isset($_GET['search']) ? trim($_GET['search']) : '';
$filterBalance = isset($_GET['filter_balance']) ? $_GET['filter_balance'] : 'all';

// Build WHERE clause
$whereConditions = ["is_active = 1"];
$params = [];
$types = '';

if (!empty($search)) {
    $whereConditions[] = "(customer_name LIKE ? OR vat_number LIKE ? OR phone LIKE ? OR email LIKE ?)";
    $searchParam = "%{$search}%";
    $params[] = $searchParam;
    $params[] = $searchParam;
    $params[] = $searchParam;
    $params[] = $searchParam;
    $types .= 'ssss';
}

$whereClause = implode(' AND ', $whereConditions);

// Get total count
$countQuery = "SELECT COUNT(*) as total FROM acc_customers WHERE {$whereClause}";
if (!empty($params)) {
    $stmt = $db->prepare($countQuery);
    $stmt->bind_param($types, ...$params);
    $stmt->execute();
    $totalResult = $stmt->get_result()->fetch_assoc();
} else {
    $totalResult = $db->query($countQuery)->fetch_assoc();
}
$totalCustomers = $totalResult['total'];
$totalPages = ceil($totalCustomers / $perPage);

// Get customers with pagination
$customersQuery = "SELECT * FROM acc_customers WHERE {$whereClause} ORDER BY customer_name LIMIT ? OFFSET ?";
$params[] = $perPage;
$params[] = $offset;
$types .= 'ii';

$stmt = $db->prepare($customersQuery);
if (!empty($params)) {
    $stmt->bind_param($types, ...$params);
}
$stmt->execute();
$customersResult = $stmt->get_result();

$customers = [];
if ($customersResult) {
    while ($row = $customersResult->fetch_assoc()) {
        // Get customer invoices
        $invoiceQuery = "SELECT COUNT(*) as count, SUM(total_amount) as total, SUM(total_amount - paid_amount) as balance
                        FROM acc_invoices WHERE customer_name = ?";
        $stmt2 = $db->prepare($invoiceQuery);
        $stmt2->bind_param('s', $row['customer_name']);
        $stmt2->execute();
        $invoiceData = $stmt2->get_result()->fetch_assoc();

        $row['invoice_count'] = $invoiceData['count'] ?? 0;
        $row['total_sales'] = $invoiceData['total'] ?? 0;
        $row['balance'] = $invoiceData['balance'] ?? 0;

        $customers[] = $row;
    }
}

// Apply balance filter if needed
if ($filterBalance == 'with_balance') {
    $customers = array_filter($customers, function($c) { return $c['balance'] > 0; });
} elseif ($filterBalance == 'no_balance') {
    $customers = array_filter($customers, function($c) { return $c['balance'] <= 0; });
}
?>


