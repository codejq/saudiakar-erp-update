                </div>

                <a href="index.hnt?export=template" class="btn btn-outline-success mb-4">
                    <i class="bi bi-download me-2"></i>تحميل القالب (CSV)
                </a>

                <div class="table-responsive mb-4">
                    <table class="table table-sm table-bordered align-middle">
                        <thead class="table-light text-center">
                            <tr><th>العمود</th><th>القيم المقبولة</th><th>مثال</th></tr>
                        </thead>
                        <tbody class="small">
                            <tr><td>اسم العميل *</td><td>نص (يجب أن يكون فريداً)</td><td>شركة الأمثلة للتجارة</td></tr>
                            <tr><td>الرقم الضريبي</td><td>15 رقماً يبدأ بـ 3</td><td>300000000000003</td></tr>
                            <tr><td>رقم الهاتف</td><td>نص</td><td>0500000000</td></tr>
                            <tr><td>البريد الإلكتروني</td><td>بريد إلكتروني صالح</td><td>info@example.com</td></tr>
                            <tr><td>العنوان</td><td>نص اختياري</td><td>الرياض - حي العليا</td></tr>
                        </tbody>
                    </table>
                </div>

                <form id="importCustomersForm" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label class="form-label fw-bold">اختر ملف CSV</label>
                        <input type="file" class="form-control" id="import_customers_file"
                               name="import_file" accept=".csv,.txt">
                        <div class="form-text">العملاء الموجودون مسبقاً سيتم تخطيهم وإدراجهم في التنبيهات</div>
                    </div>
                </form>

                <div id="importCustomersResult" style="display:none;"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                <button type="button" class="btn btn-primary" id="importCustomersSubmitBtn"
                        onclick="submitCustomersImport()">
                    <i class="bi bi-upload me-2"></i>استيراد
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Result Modal -->
<div class="modal fade" id="resultModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header" id="resultModalHeader">
                <h5 class="modal-title text-white" id="resultModalTitle"></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p id="resultModalMessage"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إغلاق</button>
            </div>
        </div>
    </div>
</div>



<script>
function submitCustomer() {
    const form = document.getElementById('addCustomerForm');
    const formData = new FormData(form);
    formData.append('ajax_action', 'add_customer');

    fetch('index.hnt', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        const modal = bootstrap.Modal.getInstance(document.getElementById('addCustomerModal'));
        modal.hide();

        showResultModal(data.success, data.message);

        if (data.success) {
            setTimeout(() => location.reload(), 1500);
        }
    })
    .catch(error => {
        console.error('Error:', error);
        showResultModal(false, 'حدث خطأ أثناء الحفظ');
    });
}

function viewStatement(customerId, customerName) {
    window.location = '../reports/customer_statement.hnt?customer_name=' + encodeURIComponent(customerName);
}

function createInvoice(customerName, vatNumber) {
    window.location = '../invoices/index.hnt?customer_name=' + encodeURIComponent(customerName) + '&vat_number=' + (vatNumber || '');
}

function submitCustomersImport() {
    const fileInput = document.getElementById('import_customers_file');
    if (!fileInput.files.length) {
        alert('يرجى اختيار ملف CSV أولاً');
        return;
    }

    const btn = document.getElementById('importCustomersSubmitBtn');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>جاري الاستيراد...';

    const formData = new FormData();
    formData.append('ajax_action', 'import_customers');
    formData.append('import_file', fileInput.files[0]);

    fetch('index.hnt', { method: 'POST', body: formData })
        .then(r => r.json())
        .then(data => {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-upload me-2"></i>استيراد';

            const resultDiv = document.getElementById('importCustomersResult');
            resultDiv.style.display = 'block';
            const cls  = data.imported > 0 ? 'alert-success' : 'alert-warning';
            const icon = data.imported > 0 ? 'check-circle' : 'exclamation-triangle';
            resultDiv.innerHTML = `<div class="alert ${cls}">
                <i class="bi bi-${icon} me-2"></i>
                ${data.message.replace(/\n/g, '<br>')}
            </div>`;

            if (data.imported > 0) setTimeout(() => location.reload(), 2000);
        })
        .catch(() => {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-upload me-2"></i>استيراد';
            showResultModal(false, 'حدث خطأ أثناء الاستيراد');
        });
}

document.addEventListener('DOMContentLoaded', function() {
    const importCustomersModal = document.getElementById('importCustomersModal');
    if (importCustomersModal) {
        importCustomersModal.addEventListener('show.bs.modal', function() {
            document.getElementById('import_customers_file').value = '';
            const r   = document.getElementById('importCustomersResult');
            r.style.display = 'none';
            r.innerHTML = '';
            const btn = document.getElementById('importCustomersSubmitBtn');
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-upload me-2"></i>استيراد';
        });
    }
});

function showResultModal(success, message) {
    const modal = new bootstrap.Modal(document.getElementById('resultModal'));
    const header = document.getElementById('resultModalHeader');
    const title = document.getElementById('resultModalTitle');
    const messageEl = document.getElementById('resultModalMessage');

    if (success) {
        header.style.background = 'linear-gradient(135deg, #28a745, #20c997)';
        title.innerHTML = '<i class="bi bi-check-circle me-2"></i>نجحت العملية';
    } else {
        header.style.background = 'linear-gradient(135deg, #dc3545, #c82333)';
        title.innerHTML = '<i class="bi bi-x-circle me-2"></i>فشلت العملية';
    }

    messageEl.textContent = message;
    modal.show();
}
</script>

<?php require("../../../../foter.hnt"); ?>
