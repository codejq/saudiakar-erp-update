                    <div class="total-row">
                        <div class="row">
                            <div class="col-6 text-end">
                                إجمالي المدين: <span id="editTotalDebit">0.00</span> ر.س
                            </div>
                            <div class="col-6 text-end">
                                إجمالي الدائن: <span id="editTotalCredit">0.00</span> ر.س
                            </div>
                        </div>
                        <div class="text-center mt-2" id="editBalanceWarning" style="display:none;">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            القيد غير متوازن!
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                <button type="button" class="btn btn-primary" onclick="submitEditEntry()">
                    <i class="bi bi-save me-2"></i>حفظ التعديلات
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Import Entries Modal -->
<div class="modal fade" id="importEntriesModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-upload me-2"></i>استيراد القيود اليومية من CSV
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-info mb-3">
                    <h6 class="mb-2"><i class="bi bi-info-circle me-2"></i>خطوات الاستيراد</h6>
                    <ol class="mb-0 small">
                        <li>حمّل القالب أدناه</li>
                        <li>أضف القيود — كل قيد له <strong>رقم مجموعة</strong> فريد، كرر نفس الرقم في كل بنود القيد</li>
                        <li>أدخل التاريخ والوصف في السطر الأول من كل مجموعة فقط</li>
                        <li>احفظ الملف بصيغة CSV (UTF-8) وارفعه</li>
                    </ol>
                </div>

                <a href="index.hnt?export=template" class="btn btn-outline-success mb-4">
                    <i class="bi bi-download me-2"></i>تحميل القالب (CSV)
                </a>

                <div class="table-responsive mb-4">
                    <table class="table table-sm table-bordered align-middle">
                        <thead class="table-light text-center">
                            <tr>
                                <th>العمود</th>
                                <th>القيم المقبولة</th>
                                <th>مثال</th>
                            </tr>
                        </thead>
                        <tbody class="small">
                            <tr><td>رقم المجموعة *</td><td>رقم (نفس الرقم لبنود القيد الواحد)</td><td>1</td></tr>
                            <tr><td>تاريخ القيد *</td><td>dd/mm/yyyy (السطر الأول فقط)</td><td>15/01/2025</td></tr>
                            <tr><td>نوع القيد</td><td>manual / opening / closing / adjustment</td><td>manual</td></tr>
                            <tr><td>وصف القيد *</td><td>نص (السطر الأول فقط)</td><td>قيد إيراد إيجار</td></tr>
                            <tr><td>الحالة</td><td>draft / posted</td><td>draft</td></tr>
                            <tr><td>رمز الحساب *</td><td>رمز حساب ورقي موجود في النظام</td><td>1010</td></tr>
                            <tr><td>بيان البند</td><td>نص</td><td>نقد وارد</td></tr>
                            <tr><td>مدين</td><td>رقم</td><td>1000.00</td></tr>
                            <tr><td>دائن</td><td>رقم</td><td>0.00</td></tr>
                        </tbody>
                    </table>
                </div>

                <form id="importEntriesForm" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label class="form-label fw-bold">اختر ملف CSV</label>
                        <input type="file" class="form-control" id="import_entries_file" name="import_file" accept=".csv,.txt">
                        <div class="form-text">الحسابات غير الموجودة أو القيود غير المتوازنة سيتم الإبلاغ عنها كتنبيهات</div>
                    </div>
                </form>

                <div id="importEntriesResult" style="display:none;"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                <button type="button" class="btn btn-primary" id="importEntriesSubmitBtn" onclick="submitEntriesImport()">
                    <i class="bi bi-upload me-2"></i>استيراد
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Result Modal -->
<div class="modal fade" id="resultModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header" id="resultModalHeader">
                <h5 class="modal-title text-white" id="resultModalTitle"></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p id="resultModalMessage"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إغلاق</button>
            </div>
        </div>
    </div>
</div>



<script src="../../includes/dimension_autocomplete.js"></script>
<script>
const accounts = <?php echo json_encode($accounts); ?>;
const journals = <?php echo json_encode($journals); ?>;
const costCenters = <?php echo json_encode($costCenters); ?>;
const entriesData = <?php echo json_encode($entries); ?>;
const entryLinesData = <?php echo json_encode($entryLines); ?>;
const dimTenants    = <?php echo json_encode($dimTenants); ?>;
const dimOwners     = <?php echo json_encode($dimOwners); ?>;
const dimProperties = <?php echo json_encode($dimProperties); ?>;
const dimContracts  = <?php echo json_encode($dimContracts); ?>;
const dimAjaxUrl    = '../../ajax/get_dimensions.hnt';
let lineCounter = 0;

function addLine() {
    lineCounter++;
    const lineHtml = `
        <div class="entry-line-row" id="line_${lineCounter}">
            <div class="row g-2">
                <div class="col-md-4">
                    <select class="form-control account-select" name="account_id_${lineCounter}" required>
                        <option value="">اختر الحساب</option>
                        ${accounts.map(acc => `<option value="${acc.account_id}">${acc.account_code} - ${acc.account_name_ar}</option>`).join('')}
                    </select>
                </div>
                <div class="col-md-3">
                    <input type="text" class="form-control" name="description_${lineCounter}" placeholder="البيان" required>
                </div>
                <div class="col-md-2">
                    <select class="form-control" name="cost_center_${lineCounter}">
                        <option value="">بدون مركز تكلفة</option>
                        ${costCenters.map(cc => `<option value="${cc.cost_center_id}">${cc.cost_center_code} - ${cc.cost_center_name_ar}</option>`).join('')}
                    </select>
                </div>
                <div class="col-md-2">
                    <input type="number" step="0.01" class="form-control debit-input" name="debit_${lineCounter}" placeholder="مدين" value="0" onchange="calculateTotals()">
                </div>
                <div class="col-md-1">
                    <input type="number" step="0.01" class="form-control credit-input" name="credit_${lineCounter}" placeholder="دائن" value="0" onchange="calculateTotals()">
                </div>
                <div class="col-md-1">
                    <button type="button" class="btn btn-danger btn-sm" onclick="removeLine(${lineCounter})">
                        <i class="bi bi-trash"></i>
                    </button>
                </div>
            </div>
        </div>
    `;

    document.getElementById('entryLines').insertAdjacentHTML('beforeend', lineHtml);
}

function removeLine(lineId) {
    document.getElementById('line_' + lineId).remove();
    calculateTotals();
}

function calculateTotals() {
    let totalDebit = 0;
    let totalCredit = 0;

    document.querySelectorAll('.debit-input').forEach(input => {
        totalDebit += parseFloat(input.value) || 0;
    });

    document.querySelectorAll('.credit-input').forEach(input => {
        totalCredit += parseFloat(input.value) || 0;
    });

    document.getElementById('totalDebit').textContent = totalDebit.toFixed(2);
    document.getElementById('totalCredit').textContent = totalCredit.toFixed(2);

    const warning = document.getElementById('balanceWarning');
    if (Math.abs(totalDebit - totalCredit) > 0.01) {
        warning.style.display = 'block';
    } else {
        warning.style.display = 'none';
    }
}

function submitEntry(status) {
    const form = document.getElementById('addEntryForm');
    const formData = new FormData(form);
    const linesContainer = document.getElementById('entryLines');

    // Collect lines
    const lines = [];
    for (let i = 1; i <= lineCounter; i++) {
        const accountSelect = linesContainer.querySelector(`[name="account_id_${i}"]`);
        if (accountSelect && accountSelect.value) {
            lines.push({
                account_id: accountSelect.value,
                description: linesContainer.querySelector(`[name="description_${i}"]`).value,
                debit_amount: parseFloat(linesContainer.querySelector(`[name="debit_${i}"]`).value) || 0,
                credit_amount: parseFloat(linesContainer.querySelector(`[name="credit_${i}"]`).value) || 0,
                cost_center_id: linesContainer.querySelector(`[name="cost_center_${i}"]`)?.value || null
            });
        }
    }

    if (lines.length < 2) {
        showResultModal(false, 'يجب إضافة بندين على الأقل');
        return;
    }

    formData.append('ajax_action', 'create_entry');
    formData.append('status', status);
    formData.append('lines', JSON.stringify(lines));

    fetch('index.hnt', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        const modal = bootstrap.Modal.getInstance(document.getElementById('addEntryModal'));
        modal.hide();

        showResultModal(data.success, data.message);

        if (data.success) {
            setTimeout(() => location.reload(), 1500);
        }
    })
    .catch(error => {
        console.error('Error:', error);
        showResultModal(false, 'حدث خطأ أثناء الحفظ');
    });
}

function postEntry(entryId) {
    confirm('هل تريد ترحيل هذا القيد؟', 'تأكيد الترحيل', function() {
        const formData = new FormData();
        formData.append('ajax_action', 'post_entry');
        formData.append('entry_id', entryId);

        fetch('index.hnt', {
            method: 'POST',
            body: formData
        })
        .then(response => response.json())
        .then(data => {
            showResultModal(data.success, data.message);
            if (data.success) {
                setTimeout(() => location.reload(), 1500);
            }
        });
    }, function() {});
}

function deleteEntry(entryId) {
    confirm('هل أنت متأكد من حذف هذا القيد؟\n\nتنبيه: يمكن حذف المسودات فقط. القيود المرحّلة تحتاج إلى قيد عكسي.', 'تأكيد الحذف', function() {
        const formData = new FormData();
        formData.append('ajax_action', 'delete_entry');
        formData.append('entry_id', entryId);

        fetch('index.hnt', {
            method: 'POST',
            body: formData
        })
        .then(response => response.json())
        .then(data => {
            showResultModal(data.success, data.message);
            if (data.success) {
                setTimeout(() => location.reload(), 1500);
            }
        });
    }, function() {});
}

function showResultModal(success, message) {
    const modal = new bootstrap.Modal(document.getElementById('resultModal'));
    const header = document.getElementById('resultModalHeader');
    const title = document.getElementById('resultModalTitle');
    const messageEl = document.getElementById('resultModalMessage');

    if (success) {
        header.style.background = 'linear-gradient(135deg, #28a745, #20c997)';
        title.innerHTML = '<i class="bi bi-check-circle me-2"></i>نجحت العملية';
    } else {
        header.style.background = 'linear-gradient(135deg, #dc3545, #c82333)';
        title.innerHTML = '<i class="bi bi-x-circle me-2"></i>فشلت العملية';
    }

    messageEl.textContent = message;
    modal.show();
}

function submitEntriesImport() {
    const fileInput = document.getElementById('import_entries_file');
    if (!fileInput.files.length) {
        alert('يرجى اختيار ملف CSV أولاً');
        return;
    }

    const btn = document.getElementById('importEntriesSubmitBtn');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>جاري الاستيراد...';

    const formData = new FormData();
    formData.append('ajax_action', 'import_entries');
    formData.append('import_file', fileInput.files[0]);

    fetch('index.hnt', { method: 'POST', body: formData })
        .then(r => r.json())
        .then(data => {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-upload me-2"></i>استيراد';

            const resultDiv = document.getElementById('importEntriesResult');
            resultDiv.style.display = 'block';
            const cls  = data.imported > 0 ? 'alert-success' : 'alert-warning';
            const icon = data.imported > 0 ? 'check-circle' : 'exclamation-triangle';
            resultDiv.innerHTML = `<div class="alert ${cls}"><i class="bi bi-${icon} me-2"></i>${data.message.replace(/\n/g, '<br>')}</div>`;

            if (data.imported > 0) {
                setTimeout(() => location.reload(), 2000);
            }
        })
        .catch(() => {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-upload me-2"></i>استيراد';
            showResultModal(false, 'حدث خطأ أثناء الاستيراد');
        });
}

document.addEventListener('DOMContentLoaded', function() {
    const importModal = document.getElementById('importEntriesModal');
    if (importModal) {
        importModal.addEventListener('show.bs.modal', function() {
            document.getElementById('import_entries_file').value = '';
            const r = document.getElementById('importEntriesResult');
            r.style.display = 'none';
            r.innerHTML = '';
            const btn = document.getElementById('importEntriesSubmitBtn');
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-upload me-2"></i>استيراد';
        });
    }
});

// Add initial lines
addLine();
addLine();

// ── Dimension Autocomplete ────────────────────────────────────────────────────

/**
 * Initialize autocomplete fields for the given modal prefix ('add' or 'edit').
 * Called once on DOMContentLoaded so the elements are ready.
 */
function initDimAC(prefix) {
    var isEdit = (prefix === 'edit');

    AccountingDimAC.init(
        document.getElementById(prefix + '_tenant_text'),
        document.getElementById(isEdit ? 'edit_tenant_id' : 'add_tenant_id'),
        dimTenants, {}
    );
    AccountingDimAC.init(
        document.getElementById(prefix + '_owner_text'),
        document.getElementById(isEdit ? 'edit_owner_id' : 'add_owner_id'),
        dimOwners, {}
    );
    AccountingDimAC.init(
        document.getElementById(prefix + '_property_text'),
        document.getElementById(isEdit ? 'edit_aqar_id' : 'add_property_id'),
        dimProperties, {
            onSelect: function(item) { loadUnitsForPrefix(prefix, item.id); },
            onClear:  function()     { clearUnitForPrefix(prefix); }
        }
    );
    AccountingDimAC.init(
        document.getElementById(prefix + '_unit_text'),
        document.getElementById(isEdit ? 'edit_subaqar_id' : 'add_unit_id'),
        [], {}
    );
    AccountingDimAC.init(
        document.getElementById(prefix + '_contract_text'),
        document.getElementById(isEdit ? 'edit_egar_id' : 'add_contract_id'),
        dimContracts, {}
    );
}

/** Load unit list for the chosen property, then optionally select a unit by ID. */
function loadUnitsForPrefix(prefix, aqarId, cb) {
    var isEdit   = (prefix === 'edit');
    var unitText = document.getElementById(prefix + '_unit_text');
    var unitHid  = document.getElementById(isEdit ? 'edit_subaqar_id' : 'add_unit_id');
    if (!unitText) return;
    unitText.value = '';
    if (unitHid) unitHid.value = '';
    unitText.placeholder = 'جاري التحميل...';
    AccountingDimAC.fetchItems(dimAjaxUrl, 'unit', aqarId, function(items) {
        if (unitText._dimAc) unitText._dimAc.setItems(items);
        unitText.placeholder = items.length ? 'ابحث عن وحدة...' : 'لا توجد وحدات';
        if (cb) cb();
    });
}

/** Clear the unit autocomplete for the given prefix. */
function clearUnitForPrefix(prefix) {
    var isEdit   = (prefix === 'edit');
    var unitText = document.getElementById(prefix + '_unit_text');
    var unitHid  = document.getElementById(isEdit ? 'edit_subaqar_id' : 'add_unit_id');
    if (unitText) {
        unitText.value = '';
        unitText.placeholder = 'اختر عقاراً أولاً';
        if (unitText._dimAc) unitText._dimAc.setItems([]);
    }
    if (unitHid) unitHid.value = '';
}

/** Set autocomplete text label from a pre-loaded items array by ID. */
function setDimACById(textId, id, items) {
    if (!id) return;
    var el = document.getElementById(textId);
    if (!el) return;
    if (el._dimAc) {
        el._dimAc.selectById(id);
    }
}

// Init autocomplete for both modals once elements are in DOM
initDimAC('add');
initDimAC('edit');

// Reset add modal fields when it opens
document.getElementById('addEntryModal').addEventListener('show.bs.modal', function() {
    ['add_tenant_text','add_owner_text','add_property_text','add_unit_text','add_contract_text'].forEach(function(id) {
        var el = document.getElementById(id);
        if (el && el._dimAc) el._dimAc.clear();
        else if (el) el.value = '';
    });
    ['add_tenant_id','add_owner_id','add_property_id','add_unit_id','add_contract_id'].forEach(function(id) {
        var el = document.getElementById(id);
        if (el) el.value = '';
    });
    clearUnitForPrefix('add');
});

// Edit functionality
let editLineCounter = 0;
let currentEditEntry = null;

function editEntry(entryId) {
    // Fetch entry details
    fetch(`index.hnt?entry_id=${entryId}`)
        .then(response => response.text())
        .then(html => {
            // Parse the HTML to extract entry data
            const parser = new DOMParser();
            const doc = parser.parseFromString(html, 'text/html');

            // Get entry from PHP data (we'll use a simpler approach - fetch via AJAX with JSON)
            fetchEntryData(entryId);
        });
}

function fetchEntryData(entryId) {
    const entry = entriesData.find(e => e.entry_id == entryId);
    if (!entry) {
        alert('القيد غير موجود');
        return;
    }

    // Populate edit form
    document.getElementById('edit_entry_id').value = entry.entry_id;
    var _dp = document.getElementById('edit_entry_date');
    if (entry.entry_date) {
        var _p = entry.entry_date.split('-');
        _dp.value = _p.length === 3 ? _p[2]+'/'+_p[1]+'/'+_p[0] : entry.entry_date;
    } else { _dp.value = ''; }
    document.getElementById('edit_entry_type').value = entry.entry_type;
    document.getElementById('edit_journal_id').value = entry.journal_id || '';
    document.getElementById('edit_tenant_id').value = entry.tenant_id || '';
    document.getElementById('edit_owner_id').value = entry.owner_id || '';
    document.getElementById('edit_aqar_id').value = entry.aqar_id || '';
    document.getElementById('edit_subaqar_id').value = entry.subaqar_id || '';
    document.getElementById('edit_egar_id').value = entry.egar_id || '';
    document.getElementById('edit_description').value = entry.description;

    // Populate autocomplete text labels
    setDimACById('edit_tenant_text',   entry.tenant_id,  dimTenants);
    setDimACById('edit_owner_text',    entry.owner_id,   dimOwners);
    setDimACById('edit_property_text', entry.aqar_id,    dimProperties);
    setDimACById('edit_contract_text', entry.egar_id,    dimContracts);
    // Units depend on property — load via AJAX then select
    if (entry.aqar_id) {
        loadUnitsForPrefix('edit', entry.aqar_id, function() {
            setDimACById('edit_unit_text', entry.subaqar_id, null);
        });
    } else {
        clearUnitForPrefix('edit');
    }

    // Fetch and populate lines
    fetchEntryLines(entryId);

    // Show modal
    const modal = new bootstrap.Modal(document.getElementById('editEntryModal'));
    modal.show();
}

function fetchEntryLines(entryId) {
    // Clear existing lines
    document.getElementById('editEntryLines').innerHTML = '';
    editLineCounter = 0;

    // Get lines from embedded data
    const lines = entryLinesData[entryId] || [];

    if (lines.length > 0) {
        lines.forEach(line => {
            addEditLine(line);
        });
        calculateEditTotals();
    } else {
        // Fallback: add empty lines
        addEditLine();
        addEditLine();
    }
}

function addEditLine(lineData = null) {
    editLineCounter++;
    const lineHtml = `
        <div class="entry-line-row" id="edit_line_${editLineCounter}">
            <div class="row g-2">
                <div class="col-md-4">
                    <select class="form-control account-select" name="account_id_${editLineCounter}" required>
                        <option value="">اختر الحساب</option>
                        ${accounts.map(acc => `<option value="${acc.account_id}" ${lineData && lineData.account_id == acc.account_id ? 'selected' : ''}>${acc.account_code} - ${acc.account_name_ar}</option>`).join('')}
                    </select>
                </div>
                <div class="col-md-3">
                    <input type="text" class="form-control" name="description_${editLineCounter}" placeholder="البيان" value="${lineData ? lineData.description : ''}" required>
                </div>
                <div class="col-md-2">
                    <select class="form-control" name="cost_center_${editLineCounter}">
                        <option value="">بدون مركز تكلفة</option>
                        ${costCenters.map(cc => `<option value="${cc.cost_center_id}" ${lineData && lineData.cost_center_id == cc.cost_center_id ? 'selected' : ''}>${cc.cost_center_code} - ${cc.cost_center_name_ar}</option>`).join('')}
                    </select>
                </div>
                <div class="col-md-2">
                    <input type="number" step="0.01" class="form-control edit-debit-input" name="debit_${editLineCounter}" placeholder="مدين" value="${lineData ? lineData.debit_amount : '0'}" onchange="calculateEditTotals()">
                </div>
                <div class="col-md-1">
                    <input type="number" step="0.01" class="form-control edit-credit-input" name="credit_${editLineCounter}" placeholder="دائن" value="${lineData ? lineData.credit_amount : '0'}" onchange="calculateEditTotals()">
                </div>
                <div class="col-md-1">
                    <button type="button" class="btn btn-danger btn-sm" onclick="removeEditLine(${editLineCounter})">
                        <i class="bi bi-trash"></i>
                    </button>
                </div>
            </div>
        </div>
    `;

    document.getElementById('editEntryLines').insertAdjacentHTML('beforeend', lineHtml);
}

function removeEditLine(lineId) {
    document.getElementById('edit_line_' + lineId).remove();
    calculateEditTotals();
}

function calculateEditTotals() {
    let totalDebit = 0;
    let totalCredit = 0;

    document.querySelectorAll('.edit-debit-input').forEach(input => {
        totalDebit += parseFloat(input.value) || 0;
    });

    document.querySelectorAll('.edit-credit-input').forEach(input => {
        totalCredit += parseFloat(input.value) || 0;
    });

    document.getElementById('editTotalDebit').textContent = totalDebit.toFixed(2);
    document.getElementById('editTotalCredit').textContent = totalCredit.toFixed(2);

    const warning = document.getElementById('editBalanceWarning');
    if (Math.abs(totalDebit - totalCredit) > 0.01) {
        warning.style.display = 'block';
    } else {
        warning.style.display = 'none';
    }
}

function submitEditEntry() {
    const form = document.getElementById('editEntryForm');
    const formData = new FormData(form);
    const linesContainer = document.getElementById('editEntryLines');

    // Collect lines
    const lines = [];
    for (let i = 1; i <= editLineCounter; i++) {
        const accountSelect = linesContainer.querySelector(`[name="account_id_${i}"]`);
        if (accountSelect && accountSelect.value) {
            lines.push({
                account_id: accountSelect.value,
                description: linesContainer.querySelector(`[name="description_${i}"]`).value,
                debit_amount: parseFloat(linesContainer.querySelector(`[name="debit_${i}"]`).value) || 0,
                credit_amount: parseFloat(linesContainer.querySelector(`[name="credit_${i}"]`).value) || 0,
                cost_center_id: linesContainer.querySelector(`[name="cost_center_${i}"]`)?.value || null
            });
        }
    }

    if (lines.length < 2) {
        showResultModal(false, 'يجب إضافة بندين على الأقل');
        return;
    }

    formData.append('ajax_action', 'update_entry');
    formData.append('lines', JSON.stringify(lines));

    fetch('index.hnt', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        const modal = bootstrap.Modal.getInstance(document.getElementById('editEntryModal'));
        modal.hide();

        showResultModal(data.success, data.message);

        if (data.success) {
            setTimeout(() => location.reload(), 1500);
        }
    })
    .catch(error => {
        console.error('Error:', error);
        showResultModal(false, 'حدث خطأ أثناء الحفظ');
    });
}
</script>

<script>
$(document).ready(function() {
    function initDatepickers(ctx) {
        $(ctx || document).find('.datepicker-input').each(function() {
            if (!$(this).data('datepicker')) {
                $(this).datepicker({
                    format: 'dd/mm/yyyy',
                    language: 'ar',
                    rtl: true,
                    autoclose: true,
                    todayHighlight: true,
                    calendarType: 'gregorian',
                    container: '#journal-entries-main',
                    orientation: 'bottom auto',
                    weekStart: 0,
                    zIndexOffset: 2050
                });
            }
        });
        $(ctx || document).find('.input-group-text').off('click.dp').on('click.dp', function() {
            $(this).prev('.datepicker-input').datepicker('show');
        });
    }

    initDatepickers();

    $('#addEntryModal, #editEntryModal').on('shown.bs.modal', function() {
        initDatepickers(this);
    });
});
</script>
<?php require("../../../../foter.hnt"); ?>
