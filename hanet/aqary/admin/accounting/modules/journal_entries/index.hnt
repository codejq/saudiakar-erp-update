<?php
/**
 * Journal Entries Module
 * القيود اليومية
 *
 * @charset UTF-8
 * @version 1.0
 */

$sc_title = "القيود اليومية";
$sc_id = "202";
$use_accounting_theme = true;

// Export / template handler — runs before any HTML output
if (isset($_GET['export']) && in_array($_GET['export'], ['csv', 'xls', 'template'], true)) {
    include_once "../../../../reqloginajax.hnt";
    include_once "../../includes/accounting_class.hnt";

    $_fn       = date('Ymd_His');
    $_exp_type = $_GET['export'];

    if ($_exp_type === 'template') {
        $tpl_headers = ['رقم المجموعة', 'تاريخ القيد (dd/mm/yyyy)', 'نوع القيد', 'وصف القيد', 'الحالة', 'رمز الحساب', 'بيان البند', 'مدين', 'دائن'];
        header('Content-Type: text/csv; charset=UTF-8');
        header('Content-Disposition: attachment; filename="journal_entries_template_' . $_fn . '.csv"');
        $_out = fopen('php://output', 'w');
        fwrite($_out, "\xEF\xBB\xBF");
        fputcsv($_out, $tpl_headers, ',', '"', '\\');
        fputcsv($_out, ['1', date('d/m/Y'), 'manual', 'قيد مثال', 'draft', '1010', 'نقد وارد', '1000.00', '0.00'], ',', '"', '\\');
        fputcsv($_out, ['1', '', '', '', '', '2010', 'بنك', '0.00', '1000.00'], ',', '"', '\\');
        fclose($_out);
        exit;
    }

    // Apply same filters as main page
    $_search     = isset($_GET['search'])     ? $db->real_escape_string($_GET['search'])     : '';
    $_status     = isset($_GET['status'])     ? $db->real_escape_string($_GET['status'])     : '';
    $_etype      = isset($_GET['entry_type']) ? $db->real_escape_string($_GET['entry_type']) : '';
    $_date_from  = isset($_GET['date_from'])  ? $_GET['date_from']  : '';
    $_date_to    = isset($_GET['date_to'])    ? $_GET['date_to']    : '';
    foreach (['_date_from', '_date_to'] as $_df) {
        if ($$_df && strpos($$_df, '/') !== false) {
            $_dp = explode('/', $$_df);
            if (count($_dp) === 3) $$_df = $_dp[2].'-'.$_dp[1].'-'.$_dp[0];
        }
    }
    $_where = [];
    if ($_search)    $_where[] = "(entry_number LIKE '%$_search%' OR description LIKE '%$_search%')";
    if ($_status)    $_where[] = "status = '$_status'";
    if ($_etype)     $_where[] = "entry_type = '$_etype'";
    if ($_date_from) $_where[] = "entry_date >= '$_date_from'";
    if ($_date_to)   $_where[] = "entry_date <= '$_date_to'";
    $_wc = !empty($_where) ? 'WHERE ' . implode(' AND ', $_where) : '';

    $_er = $db->query("SELECT * FROM acc_journal_entries $_wc ORDER BY entry_date DESC, entry_id DESC");
    $_eids = [];
    $_emap = [];
    while ($_row = $_er->fetch_assoc()) { $_eids[] = $_row['entry_id']; $_emap[$_row['entry_id']] = $_row; }

    $exp_headers = ['رقم القيد', 'تاريخ القيد', 'نوع القيد', 'الحالة', 'وصف القيد', 'رمز الحساب', 'اسم الحساب', 'بيان البند', 'مدين', 'دائن'];
    $exp_rows = [];
    if (!empty($_eids)) {
        $_lr = $db->query("SELECT jel.*, acc.account_code, acc.account_name_ar
                           FROM acc_journal_entry_lines jel
                           JOIN acc_chart_of_accounts acc ON jel.account_id = acc.account_id
                           WHERE jel.entry_id IN (" . implode(',', $_eids) . ")
                           ORDER BY jel.entry_id, jel.line_number");
        while ($_l = $_lr->fetch_assoc()) {
            $_e = $_emap[$_l['entry_id']];
            $exp_rows[] = [
                $_e['entry_number'],
                date('d/m/Y', strtotime($_e['entry_date'])),
                $_e['entry_type'],
                $_e['status'],
                $_e['description'],
                $_l['account_code'],
                $_l['account_name_ar'],
                $_l['description'],
                number_format(floatval($_l['debit_amount']),  2, '.', ''),
                number_format(floatval($_l['credit_amount']), 2, '.', '')
            ];
        }
    }

    if ($_exp_type === 'csv') {
        header('Content-Type: text/csv; charset=UTF-8');
        header('Content-Disposition: attachment; filename="journal_entries_' . $_fn . '.csv"');
        $_out = fopen('php://output', 'w');
        fwrite($_out, "\xEF\xBB\xBF");
        fputcsv($_out, $exp_headers, ',', '"', '\\');
        foreach ($exp_rows as $_r) fputcsv($_out, $_r, ',', '"', '\\');
        fclose($_out);
        exit;
    }

    header('Content-Type: application/vnd.ms-excel; charset=UTF-8');
    header('Content-Disposition: attachment; filename="journal_entries_' . $_fn . '.xls"');
    echo '<html lang="ar" dir="rtl"><head><meta charset="UTF-8"></head><body><table border="1"><tr>';
    foreach ($exp_headers as $_h) echo '<th>' . htmlspecialchars($_h) . '</th>';
    echo '</tr>';
    foreach ($exp_rows as $_r) { echo '<tr>'; foreach ($_r as $_c) echo '<td>' . htmlspecialchars($_c) . '</td>'; echo '</tr>'; }
    echo '</table></body></html>';
    exit;
}

if(isset($_POST['ajax_action'])){
    include_once "../../../../reqloginajax.hnt";
}
else {
    include_once "../../../../header.hnt";
}
    include_once "../../includes/accounting_class.hnt";

$accountingManager = new AccountingManager($db, $_SESSION['userid'] ?? 1);
$journals = $accountingManager->getActiveJournals();
$costCenters = $accountingManager->getActiveCostCenters();
$dimensionOptions = $accountingManager->getReportDimensionOptions();
$dimTenants    = array_map(fn($t) => ['id' => (int)$t['tenant_id'],    'label' => $t['tenant_name']],   $dimensionOptions['tenants']);
$dimOwners     = array_map(fn($o) => ['id' => (int)$o['owner_id'],     'label' => $o['owner_name']],    $dimensionOptions['owners']);
$dimProperties = array_map(fn($p) => ['id' => (int)$p['property_id'], 'label' => $p['property_name']], $dimensionOptions['properties']);
$dimContracts  = array_map(fn($c) => ['id' => (int)$c['egar_id'],      'label' => ($c['contract_number'] ?: 'عقد #' . $c['egar_id'])], $dimensionOptions['contracts']);

// Handle AJAX actions
if ($_SERVER['REQUEST_METHOD'] == 'POST' && isset($_POST['ajax_action'])) {
    header('Content-Type: application/json; charset=utf-8');

    // Convert entry_date from DD/MM/YYYY to YYYY-MM-DD if submitted by datepicker
    if (!empty($_POST['entry_date']) && strpos($_POST['entry_date'], '/') !== false) {
        $_p = explode('/', $_POST['entry_date']);
        if (count($_p) === 3) $_POST['entry_date'] = $_p[2].'-'.$_p[1].'-'.$_p[0];
    }

    $action = $_POST['ajax_action'];
    $response = ['success' => false, 'message' => ''];

    switch ($action) {
        case 'create_entry':
            if (empty($_POST['entry_date'])) {
                $response = ['success' => false, 'error' => 'Entry date is required', 'message' => 'تاريخ القيد مطلوب'];
                break;
            }

            if (empty($_POST['description'])) {
                $response = ['success' => false, 'error' => 'Description is required', 'message' => 'وصف القيد مطلوب'];
                break;
            }

            $lines = json_decode($_POST['lines'], true);

            if (empty($lines) || !is_array($lines)) {
                $response = ['success' => false, 'error' => 'No entry lines provided', 'message' => 'يجب إضافة بنود للقيد'];
                break;
            }

            if (count($lines) < 2) {
                $response = ['success' => false, 'error' => 'Minimum 2 lines required', 'message' => 'يجب إضافة بندين على الأقل للقيد'];
                break;
            }

            $data = [
                'entry_date' => $_POST['entry_date'],
                'entry_type' => $_POST['entry_type'] ?? 'manual',
                'journal_id' => $_POST['journal_id'] ?? null,
                'tenant_id' => $_POST['tenant_id'] ?? null,
                'owner_id' => $_POST['owner_id'] ?? null,
                'aqar_id' => $_POST['aqar_id'] ?? null,
                'subaqar_id' => $_POST['subaqar_id'] ?? null,
                'egar_id' => $_POST['egar_id'] ?? null,
                'reference_type' => $_POST['reference_type'] ?? null,
                'reference_id' => $_POST['reference_id'] ?? null,
                'description' => $_POST['description'],
                'status' => $_POST['status'] ?? 'draft'
            ];

            $result = $accountingManager->createJournalEntry($data, $lines);
            $response = $result;
            if (!isset($response['message'])) {
                $response['message'] = $result['success'] ? 'تم إنشاء القيد بنجاح' : ($result['error'] ?? 'فشل في إنشاء القيد');
            }
            break;

        case 'update_entry':
            $entryId = intval($_POST['entry_id'] ?? 0);

            if (empty($entryId)) {
                $response = ['success' => false, 'error' => 'Entry ID is required', 'message' => 'معرف القيد مطلوب'];
                break;
            }

            $checkEntry = $db->query("SELECT entry_id, status FROM acc_journal_entries WHERE entry_id = $entryId");
            if (!$checkEntry || $checkEntry->num_rows == 0) {
                $response = ['success' => false, 'error' => 'Entry not found', 'message' => 'القيد غير موجود'];
                break;
            }

            if (empty($_POST['entry_date'])) {
                $response = ['success' => false, 'error' => 'Entry date is required', 'message' => 'تاريخ القيد مطلوب'];
                break;
            }

            if (empty($_POST['description'])) {
                $response = ['success' => false, 'error' => 'Description is required', 'message' => 'وصف القيد مطلوب'];
                break;
            }

            $lines = json_decode($_POST['lines'], true);

            if (empty($lines) || !is_array($lines)) {
                $response = ['success' => false, 'error' => 'No entry lines provided', 'message' => 'يجب إضافة بنود للقيد'];
                break;
            }

            if (count($lines) < 2) {
                $response = ['success' => false, 'error' => 'Minimum 2 lines required', 'message' => 'يجب إضافة بندين على الأقل للقيد'];
                break;
            }

            $data = [
                'entry_date' => $_POST['entry_date'],
                'entry_type' => $_POST['entry_type'] ?? 'manual',
                'journal_id' => $_POST['journal_id'] ?? null,
                'tenant_id' => $_POST['tenant_id'] ?? null,
                'owner_id' => $_POST['owner_id'] ?? null,
                'aqar_id' => $_POST['aqar_id'] ?? null,
                'subaqar_id' => $_POST['subaqar_id'] ?? null,
                'egar_id' => $_POST['egar_id'] ?? null,
                'description' => $_POST['description']
            ];

            // Delete old lines
            if (!$db->query("DELETE FROM acc_journal_entry_lines WHERE entry_id = $entryId")) {
                $response = ['success' => false, 'error' => $db->error, 'message' => 'فشل في حذف البنود القديمة: ' . $db->error];
                break;
            }

            // Update entry (allow editing of both draft and posted entries)
            $updateSql = "UPDATE acc_journal_entries SET
                         entry_date = '{$data['entry_date']}',
                         entry_type = '{$data['entry_type']}',
                         journal_id = " . (!empty($data['journal_id']) ? (int)$data['journal_id'] : 'NULL') . ",
                         tenant_id = " . (!empty($data['tenant_id']) ? (int)$data['tenant_id'] : 'NULL') . ",
                         owner_id = " . (!empty($data['owner_id']) ? (int)$data['owner_id'] : 'NULL') . ",
                         aqar_id = " . (!empty($data['aqar_id']) ? (int)$data['aqar_id'] : 'NULL') . ",
                         subaqar_id = " . (!empty($data['subaqar_id']) ? (int)$data['subaqar_id'] : 'NULL') . ",
                         egar_id = " . (!empty($data['egar_id']) ? (int)$data['egar_id'] : 'NULL') . ",
                         description = '{$db->real_escape_string($data['description'])}'
                         WHERE entry_id = $entryId";

            if ($db->query($updateSql)) {
                // Insert new lines
                $totalDebit = 0;
                $totalCredit = 0;
                $lineNumber = 1;
                $insertSuccess = true;

                foreach ($lines as $line) {
                    $accountId = intval($line['account_id']);
                    $desc = $db->real_escape_string($line['description']);
                    $debit = floatval($line['debit_amount']);
                    $credit = floatval($line['credit_amount']);
                    $costCenterId = isset($line['cost_center_id']) && $line['cost_center_id'] !== '' ? (int)$line['cost_center_id'] : 'NULL';

                    $totalDebit += $debit;
                    $totalCredit += $credit;

                    $lineSql = "INSERT INTO acc_journal_entry_lines
                               (entry_id, line_number, account_id, description, debit_amount, credit_amount, cost_center_id, formuid)
                               VALUES ($entryId, $lineNumber, $accountId, '$desc', $debit, $credit, $costCenterId, UUID())";
                    if (!$db->query($lineSql)) {
                        $insertSuccess = false;
                        $response = ['success' => false, 'error' => $db->error, 'message' => 'فشل في إضافة البند رقم ' . $lineNumber . ': ' . $db->error];
                        break;
                    }
                    $lineNumber++;
                }

                if ($insertSuccess) {
                    // Check if balanced
                    if (abs($totalDebit - $totalCredit) > 0.01) {
                        $response = ['success' => false, 'error' => 'Entry is not balanced', 'message' => 'القيد غير متوازن. المدين: ' . number_format($totalDebit, 2) . ' - الدائن: ' . number_format($totalCredit, 2)];
                    } else {
                        // Update totals
                        $db->query("UPDATE acc_journal_entries SET total_debit = $totalDebit, total_credit = $totalCredit WHERE entry_id = $entryId");
                        $response = ['success' => true, 'message' => 'تم تحديث القيد بنجاح'];
                    }
                }
            } else {
                $response = ['success' => false, 'error' => $db->error, 'message' => 'فشل في تحديث القيد: ' . $db->error];
            }
            break;

        case 'post_entry':
            $entryId = intval($_POST['entry_id'] ?? 0);

            if (empty($entryId)) {
                $response = ['success' => false, 'error' => 'Entry ID is required', 'message' => 'معرف القيد مطلوب'];
                break;
            }

            $checkEntry = $db->query("SELECT status FROM acc_journal_entries WHERE entry_id = $entryId");
            if (!$checkEntry || $checkEntry->num_rows == 0) {
                $response = ['success' => false, 'error' => 'Entry not found', 'message' => 'القيد غير موجود'];
                break;
            }

            $entryData = $checkEntry->fetch_assoc();
            if ($entryData['status'] == 'posted') {
                $response = ['success' => false, 'error' => 'Entry already posted', 'message' => 'القيد مرحّل بالفعل'];
                break;
            }

            if ($entryData['status'] == 'cancelled') {
                $response = ['success' => false, 'error' => 'Cannot post cancelled entry', 'message' => 'لا يمكن ترحيل قيد ملغي'];
                break;
            }

            $result = $accountingManager->postJournalEntry($entryId);
            $response = $result;
            if (!isset($response['message'])) {
                $response['message'] = $result['success'] ? 'تم ترحيل القيد بنجاح' : ($result['error'] ?? 'فشل في ترحيل القيد');
            }
            break;

        case 'delete_entry':
            $entryId = intval($_POST['entry_id'] ?? 0);

            if (empty($entryId)) {
                $response = ['success' => false, 'error' => 'Entry ID is required', 'message' => 'معرف القيد مطلوب'];
                break;
            }

            // Only allow deletion of draft entries (not posted)
            $checkQuery = "SELECT entry_number, status FROM acc_journal_entries WHERE entry_id = $entryId";
            $checkResult = $db->query($checkQuery);

            if ($checkResult && $checkResult->num_rows > 0) {
                $entry = $checkResult->fetch_assoc();

                if ($entry['status'] == 'draft') {
                    // Delete entry lines first
                    if (!$db->query("DELETE FROM acc_journal_entry_lines WHERE entry_id = $entryId")) {
                        $response = ['success' => false, 'error' => $db->error, 'message' => 'فشل في حذف بنود القيد: ' . $db->error];
                        break;
                    }

                    // Delete the entry
                    if ($db->query("DELETE FROM acc_journal_entries WHERE entry_id = $entryId")) {
                        $response = ['success' => true, 'message' => 'تم حذف القيد ' . $entry['entry_number'] . ' بنجاح'];
                    } else {
                        $response = ['success' => false, 'error' => $db->error, 'message' => 'فشل في حذف القيد: ' . $db->error];
                    }
                } else {
                    $statusText = $entry['status'] == 'posted' ? 'مرحّل' : 'ملغي';
                    $response = ['success' => false, 'error' => 'Cannot delete ' . $entry['status'] . ' entry', 'message' => 'لا يمكن حذف قيد ' . $statusText . '. القيد رقم: ' . $entry['entry_number']];
                }
            } else {
                $response = ['success' => false, 'error' => 'Entry not found', 'message' => 'القيد غير موجود في النظام'];
            }
            break;

        case 'import_entries':
            if (empty($_FILES['import_file']['tmp_name'])) {
                $response = ['success' => false, 'message' => 'لم يتم رفع أي ملف'];
                break;
            }
            $handle = fopen($_FILES['import_file']['tmp_name'], 'r');
            if (!$handle) {
                $response = ['success' => false, 'message' => 'تعذر قراءة الملف'];
                break;
            }
            $bom = fread($handle, 3);
            if ($bom !== "\xEF\xBB\xBF") rewind($handle);
            fgetcsv($handle, 0, ',', '"', '\\'); // skip header
            // Build account-code → account_id map
            $_allAcc = $accountingManager->getAllAccounts(['is_active' => 1, 'is_leaf' => 1]);
            $_accMap = [];
            foreach ($_allAcc as $_a) $_accMap[$_a['account_code']] = $_a['account_id'];
            // Read and group rows by group-number column
            $_groups = [];
            $errors  = [];
            $lineNum = 1;
            while (($row = fgetcsv($handle, 0, ',', '"', '\\')) !== false) {
                $lineNum++;
                if (count($row) < 6 || empty(trim($row[0]))) continue;
                $_gk   = trim($row[0]);
                $_date = trim($row[1] ?? '');
                $_type = trim($row[2] ?? '') ?: 'manual';
                $_desc = trim($row[3] ?? '');
                $_stat = trim($row[4] ?? '') ?: 'draft';
                $_acc  = trim($row[5] ?? '');
                $_ld   = trim($row[6] ?? '');
                $_dr   = floatval($row[7] ?? 0);
                $_cr   = floatval($row[8] ?? 0);
                if (!isset($_groups[$_gk])) $_groups[$_gk] = ['meta' => null, 'lines' => []];
                if ($_date && $_desc && !$_groups[$_gk]['meta']) {
                    if (strpos($_date, '/') !== false) {
                        $_dp = explode('/', $_date);
                        if (count($_dp) === 3) $_date = $_dp[2].'-'.$_dp[1].'-'.$_dp[0];
                    }
                    $_groups[$_gk]['meta'] = [
                        'entry_date'  => $_date,
                        'entry_type'  => in_array($_type, ['manual','opening','closing','adjustment']) ? $_type : 'manual',
                        'description' => $_desc,
                        'status'      => in_array($_stat, ['draft','posted']) ? $_stat : 'draft',
                        'journal_id'  => null, 'tenant_id' => null, 'owner_id' => null,
                        'aqar_id'     => null, 'subaqar_id' => null, 'egar_id' => null,
                        'reference_type' => null, 'reference_id' => null
                    ];
                }
                if ($_acc) {
                    $_groups[$_gk]['lines'][] = ['account_code' => $_acc, 'description' => $_ld, 'debit_amount' => $_dr, 'credit_amount' => $_cr, 'cost_center_id' => null];
                }
            }
            fclose($handle);
            $imported = 0;
            foreach ($_groups as $_gk => $_g) {
                if (!$_g['meta']) { $errors[] = "مجموعة $_gk: تاريخ أو وصف القيد مفقود"; continue; }
                if (count($_g['lines']) < 2) { $errors[] = "مجموعة $_gk: يجب إضافة بندين على الأقل"; continue; }
                $_resolved = [];
                $_ok = true;
                foreach ($_g['lines'] as $_li) {
                    if (!isset($_accMap[$_li['account_code']])) {
                        $errors[] = "مجموعة $_gk: رمز الحساب '{$_li['account_code']}' غير موجود";
                        $_ok = false; break;
                    }
                    $_li['account_id'] = $_accMap[$_li['account_code']];
                    $_resolved[] = $_li;
                }
                if (!$_ok) continue;
                $_res = $accountingManager->createJournalEntry($_g['meta'], $_resolved);
                if ($_res['success']) {
                    $imported++;
                    if ($_g['meta']['status'] === 'posted' && !empty($_res['entry_id'])) {
                        $accountingManager->postJournalEntry($_res['entry_id']);
                    }
                } else {
                    $errors[] = "مجموعة $_gk: " . ($_res['error'] ?? 'خطأ غير معروف');
                }
            }
            $msg = "تم استيراد $imported قيد بنجاح";
            if (!empty($errors)) $msg .= "\n\nتنبيهات:\n" . implode("\n", $errors);
            $response = ['success' => true, 'message' => $msg, 'imported' => $imported, 'errors' => $errors];
            break;
    }

    echo json_encode($response, JSON_UNESCAPED_UNICODE);
    exit;
}

// Pagination and filters
$page = isset($_GET['page']) ? max(1, intval($_GET['page'])) : 1;
$perPage = 20;
$offset = ($page - 1) * $perPage;

// Filter parameters
$search = isset($_GET['search']) ? $db->real_escape_string($_GET['search']) : '';
$status = isset($_GET['status']) ? $_GET['status'] : '';
$entryType = isset($_GET['entry_type']) ? $_GET['entry_type'] : '';
$dateFrom = isset($_GET['date_from']) ? $_GET['date_from'] : '';
$dateTo   = isset($_GET['date_to'])   ? $_GET['date_to']   : '';
// Convert DD/MM/YYYY → YYYY-MM-DD if submitted by datepicker
foreach (['dateFrom', 'dateTo'] as $_df) {
    if ($$_df && strpos($$_df, '/') !== false) {
        $_p = explode('/', $$_df);
        if (count($_p) === 3) $$_df = $_p[2].'-'.$_p[1].'-'.$_p[0];
    }
}

// Build WHERE clause
$where = [];
if ($search) {
    $where[] = "(entry_number LIKE '%$search%' OR description LIKE '%$search%')";
}
if ($status) {
    $where[] = "status = '$status'";
}
if ($entryType) {
    $where[] = "entry_type = '$entryType'";
}
if ($dateFrom) {
    $where[] = "entry_date >= '$dateFrom'";
}
if ($dateTo) {
    $where[] = "entry_date <= '$dateTo'";
}

$whereClause = !empty($where) ? 'WHERE ' . implode(' AND ', $where) : '';

// Count total entries
$countQuery = "SELECT COUNT(*) as total FROM acc_journal_entries $whereClause";
$countResult = $db->query($countQuery);
$totalEntries = $countResult->fetch_assoc()['total'];
$totalPages = ceil($totalEntries / $perPage);

// Get entries
$entriesQuery = "SELECT * FROM acc_journal_entries $whereClause ORDER BY entry_date DESC, entry_id DESC LIMIT $perPage OFFSET $offset";
$entriesResult = $db->query($entriesQuery);
$entries = [];
if ($entriesResult) {
    while ($row = $entriesResult->fetch_assoc()) {
        $entries[] = $row;
    }
}

// Get all accounts for dropdown
$accounts = $accountingManager->getAllAccounts(['is_active' => 1, 'is_leaf' => 1]);

// Get all entry lines for the current page entries
$entryLines = [];
if (!empty($entries)) {
    $entryIds = array_column($entries, 'entry_id');
    $entryIdsStr = implode(',', $entryIds);
    $linesQuery = "SELECT jel.*, acc.account_code, acc.account_name_ar
                   FROM acc_journal_entry_lines jel
                   JOIN acc_chart_of_accounts acc ON jel.account_id = acc.account_id
                   WHERE jel.entry_id IN ($entryIdsStr)
                   ORDER BY jel.entry_id, jel.line_number";
    $linesResult = $db->query($linesQuery);
    if ($linesResult) {
        while ($row = $linesResult->fetch_assoc()) {
            $entryId = $row['entry_id'];
            if (!isset($entryLines[$entryId])) {
                $entryLines[$entryId] = [];
            }
            $entryLines[$entryId][] = $row;
        }
    }
}
?>

