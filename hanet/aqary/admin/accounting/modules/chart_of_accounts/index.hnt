<script>
const chartAccounts = <?php echo json_encode(array_map(function ($acc) {
    return [
        'account_id' => (int)$acc['account_id'],
        'account_code' => (string)$acc['account_code'],
        'account_name_ar' => (string)$acc['account_name_ar'],
        'account_type' => (string)$acc['account_type'],
        'account_level' => (int)$acc['account_level'],
        'parent_account_id' => isset($acc['parent_account_id']) ? (int)$acc['parent_account_id'] : 0
    ];
}, $accounts), JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES); ?>;

function getAccountFormElements() {
    const form = document.getElementById('addAccountForm');
    if (!form) {
        return {};
    }

    return {
        form,
        accountIdInput: form.querySelector('[name="account_id"]'),
        accountCodeInput: form.querySelector('[name="account_code"]'),
        accountTypeSelect: form.querySelector('[name="account_type"]'),
        parentAccountSelect: form.querySelector('[name="parent_account_id"]')
    };
}

function getAccountModalElements() {
    return {
        modal: document.getElementById('addAccountModal'),
        title: document.getElementById('accountModalTitle'),
        submitButton: document.getElementById('accountModalSubmitButton')
    };
}

function getViewModalElements() {
    return {
        modal: document.getElementById('viewAccountModal'),
        title: document.getElementById('viewAccountModalTitle'),
        body: document.getElementById('viewAccountModalBody')
    };
}

function getAccountTypeLabel(accountType) {
    const labels = {
        asset: 'أصول',
        liability: 'خصوم',
        equity: 'حقوق ملكية',
        revenue: 'إيرادات',
        expense: 'مصروفات'
    };

    return labels[accountType] || accountType || '-';
}

function fetchAccountDetails(accountId) {
    const formData = new FormData();
    formData.append('ajax_action', 'get_account');
    formData.append('account_id', accountId);

    return fetch('index.hnt', {
        method: 'POST',
        body: formData
    }).then(function (response) {
        return response.json();
    });
}

function getChildAccounts(parentAccountId, accountType) {
    return chartAccounts.filter(function (account) {
        return Number(account.parent_account_id) === Number(parentAccountId) && (!accountType || account.account_type === accountType);
    });
}

function generateNextAccountCode(parentCode, childAccounts) {
    const normalizedParentCode = String(parentCode || '').trim();
    if (!normalizedParentCode) {
        return '';
    }

    let maxSuffix = 0;

    childAccounts.forEach(function (account) {
        const childCode = String(account.account_code || '').trim();
        if (!childCode.startsWith(normalizedParentCode)) {
            return;
        }

        const suffix = childCode.slice(normalizedParentCode.length);
        if (!/^\d+$/.test(suffix)) {
            return;
        }

        maxSuffix = Math.max(maxSuffix, parseInt(suffix, 10));
    });

    const nextSuffix = String(maxSuffix + 1).padStart(2, '0');
    return normalizedParentCode + nextSuffix;
}

function setSelectValueWithChange(selectElement, value) {
    if (!selectElement) {
        return;
    }

    if (window.jQuery && window.jQuery.fn && window.jQuery.fn.select2 && window.jQuery(selectElement).data('select2')) {
        window.jQuery(selectElement).val(value).trigger('change');
        return;
    }

    selectElement.value = value;
    if (window.jQuery) {
        window.jQuery(selectElement).trigger('change');
    } else {
        selectElement.dispatchEvent(new Event('change', { bubbles: true }));
    }
}

function initializeAddAccountModalSelects() {
    if (!window.jQuery || !window.jQuery.fn || typeof window.jQuery.fn.select2 === 'undefined') {
        return;
    }

    const $modal = window.jQuery('#addAccountModal');
    if (!$modal.length) {
        return;
    }

    $modal.find('select').each(function () {
        const $select = window.jQuery(this);
        if ($select.hasClass('select2-hidden-accessible')) {
            $select.select2('destroy');
        }

        $select.select2({
            theme: 'bootstrap-5',
            width: '100%',
            dir: 'rtl',
            dropdownParent: $modal,
            language: {
                noResults: function() {
                    return 'لا توجد نتائج';
                },
                searching: function() {
                    return 'جاري البحث...';
                }
            }
        });
    });
}

function syncAccountTypeFromParent() {
    const elements = getAccountFormElements();
    const parentAccountSelect = elements.parentAccountSelect;
    const accountTypeSelect = elements.accountTypeSelect;

    if (!parentAccountSelect || !accountTypeSelect) {
        return null;
    }

    const selectedOption = parentAccountSelect.options[parentAccountSelect.selectedIndex];
    if (!selectedOption || !selectedOption.value) {
        return null;
    }

    const parentType = selectedOption.getAttribute('data-account-type') || '';
    if (parentType && accountTypeSelect.value !== parentType) {
        setSelectValueWithChange(accountTypeSelect, parentType);
    }

    return selectedOption;
}

function updateGeneratedAccountCode() {
    const elements = getAccountFormElements();
    const form = elements.form;
    const accountCodeInput = elements.accountCodeInput;
    const accountTypeSelect = elements.accountTypeSelect;
    const parentAccountSelect = elements.parentAccountSelect;

    if (!form || !accountCodeInput || !accountTypeSelect || !parentAccountSelect) {
        return;
    }

    const selectedOption = parentAccountSelect.options[parentAccountSelect.selectedIndex];
    if (!selectedOption || !selectedOption.value) {
        return;
    }

    if (form.dataset.mode === 'edit' && form.dataset.allowEditAutoCode !== 'true') {
        return;
    }

    const parentCode = selectedOption.getAttribute('data-account-code') || '';
    const accountType = accountTypeSelect.value || selectedOption.getAttribute('data-account-type') || '';
    const childAccounts = getChildAccounts(selectedOption.value, accountType);
    const generatedCode = generateNextAccountCode(parentCode, childAccounts);

    if (generatedCode) {
        accountCodeInput.value = generatedCode;
    }
}

function resetAccountForm() {
    const elements = getAccountFormElements();
    const modalElements = getAccountModalElements();
    if (!elements.form) {
        return;
    }

    elements.form.reset();
    elements.form.dataset.mode = 'create';
    elements.form.dataset.allowEditAutoCode = 'true';

    if (elements.accountIdInput) {
        elements.accountIdInput.value = '';
    }

    if (modalElements.title) {
        modalElements.title.innerHTML = '<i class="bi bi-plus-circle me-2"></i>إضافة حساب جديد';
    }

    if (modalElements.submitButton) {
        const label = modalElements.submitButton.querySelector('span');
        if (label) {
            label.textContent = 'حفظ';
        }
    }

    setSelectValueWithChange(elements.parentAccountSelect, '');
    setSelectValueWithChange(elements.accountTypeSelect, '');
    updateGeneratedAccountCode();
}

function populateAccountForm(account) {
    const elements = getAccountFormElements();
    const modalElements = getAccountModalElements();
    if (!elements.form) {
        return;
    }

    elements.form.dataset.mode = 'edit';
    elements.form.dataset.allowEditAutoCode = 'false';

    if (elements.accountIdInput) {
        elements.accountIdInput.value = account.account_id || '';
    }

    elements.accountCodeInput.value = account.account_code || '';
    elements.form.querySelector('[name="account_name_ar"]').value = account.account_name_ar || '';
    elements.form.querySelector('[name="account_name_en"]').value = account.account_name_en || '';
    elements.form.querySelector('[name="account_category"]').value = account.account_category || '';
    const obVal  = parseFloat(account.opening_balance || 0);
    document.getElementById('opening_balance_amount').value = Math.abs(obVal).toFixed(2);
    document.getElementById(obVal < 0 ? 'ob_credit' : 'ob_debit').checked = true;
    elements.form.querySelector('[name="vat_applicable"]').value = account.vat_applicable || 0;
    elements.form.querySelector('[name="description"]').value = account.description || '';

    setSelectValueWithChange(elements.parentAccountSelect, account.parent_account_id || '');
    setSelectValueWithChange(elements.accountTypeSelect, account.account_type || '');

    if (modalElements.title) {
        modalElements.title.innerHTML = '<i class="bi bi-pencil-square me-2"></i>تعديل الحساب';
    }

    if (modalElements.submitButton) {
        const label = modalElements.submitButton.querySelector('span');
        if (label) {
            label.textContent = 'تحديث';
        }
    }
}

function openCreateAccountModal() {
    resetAccountForm();
    initializeAddAccountModalSelects();
    const modalElements = getAccountModalElements();
    if (modalElements.modal) {
        new bootstrap.Modal(modalElements.modal).show();
    }
}

function openEditAccountModal(accountId) {
    fetchAccountDetails(accountId)
        .then(function (data) {
            if (!data.success || !data.account) {
                showResultModal(false, data.message || 'تعذر تحميل بيانات الحساب');
                return;
            }

            populateAccountForm(data.account);
            initializeAddAccountModalSelects();

            const modalElements = getAccountModalElements();
            if (modalElements.modal) {
                new bootstrap.Modal(modalElements.modal).show();
            }
        })
        .catch(function () {
            showResultModal(false, 'حدث خطأ أثناء تحميل بيانات الحساب');
        });
}

function renderViewAccountModal(account) {
    const viewModalElements = getViewModalElements();
    if (!viewModalElements.body || !viewModalElements.title) {
        return;
    }

    viewModalElements.title.innerHTML = '<i class="bi bi-eye me-2"></i>' + (account.account_name_ar || 'عرض الحساب');
    viewModalElements.body.innerHTML = [
        ['رمز الحساب', account.account_code || '-'],
        ['اسم الحساب (عربي)', account.account_name_ar || '-'],
        ['اسم الحساب (إنجليزي)', account.account_name_en || '-'],
        ['نوع الحساب', getAccountTypeLabel(account.account_type)],
        ['الحساب الرئيسي', account.parent_account_code ? account.parent_account_code + ' - ' + (account.parent_account_name || '') : 'لا يوجد'],
        ['التصنيف', account.account_category || '-'],
        ['الرصيد الافتتاحي', (function() {
            const v = parseFloat(account.opening_balance || 0);
            const amt = Math.abs(v).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            const side = v < 0 ? 'دائن' : 'مدين';
            return amt + ' ر.س <span class="badge ' + (v < 0 ? 'bg-success' : 'bg-primary') + ' ms-1">' + side + '</span>';
        })()],
        ['الرصيد الحالي', Number(account.current_balance || 0).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' ر.س'],
        ['خاضع للضريبة', String(account.vat_applicable) === '1' ? 'نعم' : 'لا'],
        ['الوصف', account.description || '-']
    ].map(function (item) {
        return '<div class="col-md-6"><div class="border rounded-3 p-3 h-100"><div class="text-muted small mb-1">' + item[0] + '</div><div class="fw-semibold">' + item[1] + '</div></div></div>';
    }).join('');

    if (viewModalElements.modal) {
        new bootstrap.Modal(viewModalElements.modal).show();
    }
}

function initializeAccountCodeGenerator() {
    const elements = getAccountFormElements();
    const form = elements.form;
    const accountTypeSelect = elements.accountTypeSelect;
    const parentAccountSelect = elements.parentAccountSelect;

    if (!form || !accountTypeSelect || !parentAccountSelect) {
        return;
    }

    parentAccountSelect.addEventListener('change', function () {
        syncAccountTypeFromParent();
        updateGeneratedAccountCode();
    });

    accountTypeSelect.addEventListener('change', function () {
        updateGeneratedAccountCode();
        updateOpeningBalanceSide();
    });

    if (window.jQuery) {
        const $document = window.jQuery(document);
        $document.off('change.accountCodeGenerator select2:select.accountCodeGenerator', '#addAccountForm [name="parent_account_id"]');
        $document.on('change.accountCodeGenerator select2:select.accountCodeGenerator', '#addAccountForm [name="parent_account_id"]', function () {
            syncAccountTypeFromParent();
            updateGeneratedAccountCode();
        });

        $document.off('change.accountCodeGenerator select2:select.accountCodeGenerator', '#addAccountForm [name="account_type"]');
        $document.on('change.accountCodeGenerator select2:select.accountCodeGenerator', '#addAccountForm [name="account_type"]', function () {
            updateGeneratedAccountCode();
        });
    }

    const modalElement = document.getElementById('addAccountModal');
    if (modalElement) {
        modalElement.addEventListener('shown.bs.modal', function () {
            initializeAddAccountModalSelects();
            updateGeneratedAccountCode();
            // Only auto-select the normal side when creating a new account.
            // In edit mode populateAccountForm already set the correct side from the stored value.
            const f = document.getElementById('addAccountForm');
            if (!f || f.dataset.mode !== 'edit') {
                updateOpeningBalanceSide();
            }
        });

        modalElement.addEventListener('hidden.bs.modal', function () {
            resetAccountForm();
        });
    }
}

document.addEventListener('DOMContentLoaded', function () {
    initializeAddAccountModalSelects();
    initializeAccountCodeGenerator();
});

// Auto-select normal debit/credit side based on account type.
// Debit-normal: asset, expense  |  Credit-normal: liability, equity, revenue
function updateOpeningBalanceSide() {
    const type = document.querySelector('#addAccountForm [name="account_type"]')?.value;
    if (!type) return;
    const side = ['asset', 'expense'].includes(type) ? 'debit' : 'credit';
    const radio = document.getElementById('ob_' + side);
    if (radio) radio.checked = true;
}

function submitAccount() {
    const form = document.getElementById('addAccountForm');
    const formData = new FormData(form);
    formData.append('ajax_action', form.dataset.mode === 'edit' ? 'update_account' : 'create_account');

    fetch('index.hnt', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        const modal = bootstrap.Modal.getInstance(document.getElementById('addAccountModal'));
        modal.hide();

        showResultModal(data.success, data.message);

        if (data.success) {
            setTimeout(() => location.reload(), 1500);
        }
    })
    .catch(error => {
        console.error('Error:', error);
        showResultModal(false, 'حدث خطأ أثناء الحفظ');
    });
}

function showResultModal(success, message) {
    const modal = new bootstrap.Modal(document.getElementById('resultModal'));
    const header = document.getElementById('resultModalHeader');
    const title = document.getElementById('resultModalTitle');
    const messageEl = document.getElementById('resultModalMessage');

    if (success) {
        header.style.background = 'linear-gradient(135deg, #28a745, #20c997)';
        title.innerHTML = '<i class="bi bi-check-circle me-2"></i>نجحت العملية';
    } else {
        header.style.background = 'linear-gradient(135deg, #dc3545, #c82333)';
        title.innerHTML = '<i class="bi bi-x-circle me-2"></i>فشلت العملية';
    }

    messageEl.textContent = message;
    modal.show();
}

function viewAccount(accountId) {
    fetchAccountDetails(accountId)
        .then(function (data) {
            if (!data.success || !data.account) {
                showResultModal(false, data.message || 'تعذر تحميل بيانات الحساب');
                return;
            }

            renderViewAccountModal(data.account);
        })
        .catch(function () {
            showResultModal(false, 'حدث خطأ أثناء تحميل بيانات الحساب');
        });
}
</script>

<?php require("../../../../foter.hnt"); ?>
