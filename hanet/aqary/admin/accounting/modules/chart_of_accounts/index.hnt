<?php
/**
 * Chart of Accounts Module
 * دليل الحسابات
 *
 * @charset UTF-8
 * @version 1.0
 */

$sc_title = "دليل الحسابات";
$sc_id = "201";
$use_accounting_theme = true;
if(isset($_POST['ajax_action'])){
    include_once "../../../../reqloginajax.hnt";
    include_once "../../includes/accounting_class.hnt";
}
else {
    include_once "../../../../header.hnt";
    include_once "../../includes/accounting_class.hnt";
}
$accountingManager = new AccountingManager($db, $_SESSION['userid'] ?? 1);

// Handle AJAX actions
if ($_SERVER['REQUEST_METHOD'] == 'POST' && isset($_POST['ajax_action'])) {
    header('Content-Type: application/json; charset=utf-8');

    $action = $_POST['ajax_action'];
    $response = ['success' => false, 'message' => ''];

    switch ($action) {
        case 'create_account':
            $data = [
                'account_code' => $_POST['account_code'],
                'account_name_ar' => $_POST['account_name_ar'],
                'account_name_en' => $_POST['account_name_en'],
                'parent_account_id' => $_POST['parent_account_id']?? null,
                'account_type' => $_POST['account_type'],
                'account_category' => $_POST['account_category'],
                'is_leaf' => $_POST['is_leaf'] ?? 1,
                'opening_balance' => (function() {
                    $amt  = abs(floatval($_POST['opening_balance_amount'] ?? 0));
                    return (($_POST['opening_balance_side'] ?? 'debit') === 'credit') ? -$amt : $amt;
                })(),
                'is_active' => 1,
                'vat_applicable' => $_POST['vat_applicable'] ?? 0,
                'description' => $_POST['description'] ?? ''
            ];

            $result = $accountingManager->createAccount($data);
            $response = $result;
            if (!isset($response['message'])) {
                $response['message'] = $result['success'] ? 'تم إنشاء الحساب بنجاح' : 'فشل في إنشاء الحساب';
            }
            break;

        case 'update_account':
            $accountId = (int)($_POST['account_id'] ?? 0);
            $data = [
                'account_code' => $_POST['account_code'],
                'account_name_ar' => $_POST['account_name_ar'],
                'account_name_en' => $_POST['account_name_en'],
                'parent_account_id' => $_POST['parent_account_id'] ?? null,
                'account_type' => $_POST['account_type'],
                'account_category' => $_POST['account_category'],
                'is_leaf' => $_POST['is_leaf'] ?? 1,
                'opening_balance' => (function() {
                    $amt  = abs(floatval($_POST['opening_balance_amount'] ?? 0));
                    return (($_POST['opening_balance_side'] ?? 'debit') === 'credit') ? -$amt : $amt;
                })(),
                'vat_applicable' => $_POST['vat_applicable'] ?? 0,
                'description' => $_POST['description'] ?? ''
            ];

            $result = $accountingManager->updateAccount($accountId, $data);
            $response = $result;
            if (!isset($response['message'])) {
                $response['message'] = $result['success'] ? 'تم تحديث الحساب بنجاح' : 'فشل في تحديث الحساب';
            }
            break;

        case 'get_account':
            $accountId = $_POST['account_id'];
            $account = $accountingManager->getAccount($accountId);
            if ($account) {
                $account['current_balance'] = $accountingManager->getAccountBalance($accountId);
                if (!empty($account['parent_account_id'])) {
                    $parentAccount = $accountingManager->getAccount($account['parent_account_id']);
                    if ($parentAccount) {
                        $account['parent_account_name'] = $parentAccount['account_name_ar'];
                        $account['parent_account_code'] = $parentAccount['account_code'];
                    }
                }
                $response['success'] = true;
                $response['account'] = $account;
            }
            break;
    }

    echo json_encode($response, JSON_UNESCAPED_UNICODE);
    exit;
}

// Get all accounts
$accounts = $accountingManager->getAllAccounts(['is_active' => 1]);

// Function to build hierarchical tree
function buildAccountTree($accounts, $parentId = null) {
    $branch = [];
    foreach ($accounts as $account) {
        if ($account['parent_account_id'] == $parentId) {
            $children = buildAccountTree($accounts, $account['account_id']);
            if ($children) {
                $account['children'] = $children;
            }
            $branch[] = $account;
        }
    }
    return $branch;
}

// Function to flatten tree with proper levels
function flattenTree($tree, $level = 1) {
    $flat = [];
    foreach ($tree as $node) {
        $node['display_level'] = $level;
        $children = $node['children'] ?? [];
        unset($node['children']);
        $flat[] = $node;
        if ($children) {
            $flat = array_merge($flat, flattenTree($children, $level + 1));
        }
    }
    return $flat;
}

// Group accounts by type with hierarchy
$accountsByType = [
    'asset' => [],
    'liability' => [],
    'equity' => [],
    'revenue' => [],
    'expense' => []
];

foreach ($accounts as $account) {
    $accountsByType[$account['account_type']][] = $account;
}

// Build hierarchical structure for each type
foreach ($accountsByType as $type => $typeAccounts) {
    $tree = buildAccountTree($typeAccounts);
    $accountsByType[$type] = flattenTree($tree);
}
?>



