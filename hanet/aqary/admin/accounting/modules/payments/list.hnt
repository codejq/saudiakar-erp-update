                                <?php echo htmlspecialchars(getPaymentMethodLabel($payment['payment_method'])); ?>
                            </span>
                        </td>
                        <td><?php echo htmlspecialchars($payment['description']); ?></td>
                        <td class="text-end fw-bold text-success"><?php echo number_format((float)$payment['amount'], 2); ?> ر.س</td>
                        <td>
                            <span class="status-badge <?php echo getPaymentStatusClass($payment['payment_status']); ?>">
                                <?php echo htmlspecialchars(getPaymentStatusLabel($payment['payment_status'])); ?>
                            </span>
                        </td>
                        <?php if (!$isPrintMode): ?>
                        <td>
                            <div class="d-flex gap-2">
                                <a class="btn btn-sm btn-outline-primary" href="../invoices/view.hnt?id=<?php echo (int)$payment['invoice_id']; ?>" title="عرض الفاتورة">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a class="btn btn-sm btn-outline-secondary" href="../reports/customer_statement.hnt?customer_id=<?php echo (int)$payment['customer_id']; ?>&date_from=<?php echo urlencode($dateFrom); ?>&date_to=<?php echo urlencode($dateTo); ?>" title="كشف حساب العميل">
                                    <i class="bi bi-receipt"></i>
                                </a>
                            </div>
                        </td>
                        <?php endif; ?>
                    </tr>
                    <?php endforeach; ?>
                </tbody>
            </table>
        </div>
        <?php endif; ?>
