<?php
/**
 * Payments List
 * سجل المدفوعات
 *
 * @charset UTF-8
 * @version 1.0
 */

$sc_title = "سجل المدفوعات";
$sc_id = "205";
$use_accounting_theme = true;
include_once "../../../../nocash.hnt";
include_once "../../../../connectdb.hnt";
include_once "../../includes/accounting_class.hnt";

function getPaymentMethodLabel($method) {
    switch ($method) {
        case 'cash':
            return 'نقداً';
        case 'bank_transfer':
            return 'تحويل بنكي';
        case 'credit_card':
            return 'بطاقة ائتمان';
        case 'cheque':
            return 'شيك';
        default:
            return 'غير محدد';
    }
}

function getPaymentStatusLabel($status) {
    switch ($status) {
        case 'paid':
            return 'مسدد';
        case 'partial':
            return 'جزئي';
        case 'unpaid':
            return 'غير مدفوع';
        case 'overdue':
            return 'متأخر';
        default:
            return 'غير محدد';
    }
}

function getPaymentStatusClass($status) {
    switch ($status) {
        case 'paid':
            return 'status-paid';
        case 'partial':
            return 'status-partial';
        case 'overdue':
            return 'status-overdue';
        default:
            return 'status-default';
    }
}

function bindStatementParams($stmt, $types, $params) {
    if ($stmt && $types !== '' && !empty($params)) {
        $stmt->bind_param($types, ...$params);
    }
}

$dateFrom = $_GET['date_from'] ?? date('Y-01-01');
$dateTo = $_GET['date_to'] ?? date('Y-m-d');
// Convert DD/MM/YYYY to YYYY-MM-DD if submitted by datepicker
foreach (['dateFrom', 'dateTo'] as $_df) {
    if ($$_df && strpos($$_df, '/') !== false) {
        $_p = explode('/', $$_df);
        if (count($_p) === 3) $$_df = $_p[2].'-'.$_p[1].'-'.$_p[0];
    }
}
$customerId = isset($_GET['customer_id']) ? (int)$_GET['customer_id'] : 0;
$paymentMethod = trim($_GET['payment_method'] ?? '');
$search = trim($_GET['search'] ?? '');
$exportType = trim($_GET['export'] ?? '');
$isPrintMode = isset($_GET['print']) && $_GET['print'] === '1';
$currentPage = max(1, (int)($_GET['page'] ?? 1));
$pageSize = 25;

$allowedPaymentMethods = ['cash', 'bank_transfer', 'credit_card', 'cheque'];
if (!in_array($paymentMethod, $allowedPaymentMethods, true)) {
    $paymentMethod = '';
}
if (!in_array($exportType, ['csv', 'xls'], true)) {
    $exportType = '';
}

$customersQuery = "SELECT customer_id, customer_name, customer_code FROM acc_customers WHERE is_active = 1 ORDER BY customer_name ASC";
$customersResult = $db->query($customersQuery);
$customers = [];
if ($customersResult) {
    while ($row = $customersResult->fetch_assoc()) {
        $customers[] = $row;
    }
}

$paymentsQuery = "
    SELECT
        je.entry_id,
        je.entry_number,
        je.entry_date,
        je.description,
        je.status,
        je.notes,
        inv.invoice_id,
        inv.invoice_number,
        inv.customer_id,
        inv.customer_name,
        inv.payment_status,
        SUM(ar_line.credit_amount) AS amount,
        COALESCE(
            NULLIF(TRIM(je.notes), ''),
            CASE
                WHEN MAX(debit_line.account_id) = 3 THEN 'bank_transfer'
                WHEN MAX(debit_line.account_id) = 2 THEN 'cash'
                ELSE ''
            END
        ) AS payment_method
    FROM acc_journal_entries je
    INNER JOIN acc_invoices inv
        ON je.reference_type = 'invoice'
        AND je.reference_id = inv.invoice_id
    INNER JOIN acc_journal_entry_lines ar_line
        ON je.entry_id = ar_line.entry_id
        AND ar_line.account_id = 4
        AND ar_line.credit_amount > 0
    LEFT JOIN acc_journal_entry_lines debit_line
        ON je.entry_id = debit_line.entry_id
        AND debit_line.debit_amount > 0
        AND debit_line.account_id <> 4
    WHERE je.status = 'posted'
        AND je.reference_type = 'invoice'
        AND je.reference_id IS NOT NULL
        AND je.entry_date BETWEEN ? AND ?
";

$types = 'ss';
$params = [$dateFrom, $dateTo];

if ($customerId > 0) {
    $paymentsQuery .= " AND inv.customer_id = ?";
    $types .= 'i';
    $params[] = $customerId;
}

if ($search !== '') {
    $paymentsQuery .= " AND (
        je.entry_number LIKE ?
        OR inv.invoice_number LIKE ?
        OR inv.customer_name LIKE ?
        OR je.description LIKE ?
    )";
    $types .= 'ssss';
    $searchLike = '%' . $search . '%';
    $params[] = $searchLike;
    $params[] = $searchLike;
    $params[] = $searchLike;
    $params[] = $searchLike;
}

$paymentsQuery .= "
    GROUP BY
        je.entry_id,
        je.entry_number,
        je.entry_date,
        je.description,
        je.status,
        je.notes,
        inv.invoice_id,
        inv.invoice_number,
        inv.customer_id,
        inv.customer_name,
        inv.payment_status
";

$filteredPaymentsQuery = "SELECT payment_rows.* FROM (" . $paymentsQuery . ") payment_rows WHERE 1=1";
$filteredTypes = $types;
$filteredParams = $params;

if ($paymentMethod !== '') {
    $filteredPaymentsQuery .= " AND payment_rows.payment_method = ?";
    $filteredTypes .= 's';
    $filteredParams[] = $paymentMethod;
}

$countQuery = "SELECT COUNT(*) AS total_rows FROM (" . $filteredPaymentsQuery . ") payment_rows_count";
$countStmt = $db->prepare($countQuery);
$totalRows = 0;
if ($countStmt) {
    bindStatementParams($countStmt, $filteredTypes, $filteredParams);
    $countStmt->execute();
    $totalRows = (int)($countStmt->get_result()->fetch_assoc()['total_rows'] ?? 0);
}

$totalPages = max(1, (int)ceil($totalRows / $pageSize));
if (!$isPrintMode && $exportType === '' && $currentPage > $totalPages) {
    $currentPage = $totalPages;
}

$statsQuery = "
    SELECT
        COUNT(*) AS total_payments,
        COALESCE(SUM(payment_rows.amount), 0) AS total_collected,
        COUNT(DISTINCT payment_rows.customer_id) AS unique_customers,
        COALESCE(SUM(CASE WHEN DATE_FORMAT(payment_rows.entry_date, '%Y-%m') = ? THEN 1 ELSE 0 END), 0) AS current_month_payments
    FROM (" . $filteredPaymentsQuery . ") payment_rows
";
$statsStmt = $db->prepare($statsQuery);
$statsTypes = 's' . $filteredTypes;
$statsParams = array_merge([date('Y-m')], $filteredParams);
$paymentsStats = [
    'total_payments' => 0,
    'total_collected' => 0,
    'unique_customers' => 0,
    'current_month_payments' => 0
];
if ($statsStmt) {
    bindStatementParams($statsStmt, $statsTypes, $statsParams);
    $statsStmt->execute();
    $paymentsStats = array_merge($paymentsStats, $statsStmt->get_result()->fetch_assoc() ?: []);
}

$paymentsDataQuery = $filteredPaymentsQuery . " ORDER BY payment_rows.entry_date DESC, payment_rows.entry_id DESC";
$paymentsDataTypes = $filteredTypes;
$paymentsDataParams = $filteredParams;
if (!$isPrintMode && $exportType === '') {
    $paymentsDataQuery .= " LIMIT ? OFFSET ?";
    $paymentsDataTypes .= 'ii';
    $paymentsDataParams[] = $pageSize;
    $paymentsDataParams[] = ($currentPage - 1) * $pageSize;
}

$stmt = $db->prepare($paymentsDataQuery);
if ($stmt) {
    bindStatementParams($stmt, $paymentsDataTypes, $paymentsDataParams);
    $stmt->execute();
    $paymentsResult = $stmt->get_result();
} else {
    $paymentsResult = false;
}

$payments = [];
if ($paymentsResult) {
    while ($row = $paymentsResult->fetch_assoc()) {
        $payments[] = $row;
    }
}

$baseFilterParams = [
    'date_from' => $dateFrom,
    'date_to' => $dateTo
];
if ($customerId > 0) {
    $baseFilterParams['customer_id'] = $customerId;
}
if ($paymentMethod !== '') {
    $baseFilterParams['payment_method'] = $paymentMethod;
}
if ($search !== '') {
    $baseFilterParams['search'] = $search;
}

if ($exportType !== '') {
    $filenameDate = date('Ymd_His');
    if ($exportType === 'csv') {
        header('Content-Type: text/csv; charset=UTF-8');
        header('Content-Disposition: attachment; filename="payments_' . $filenameDate . '.csv"');
        $output = fopen('php://output', 'w');
        fwrite($output, "\xEF\xBB\xBF");
        fputcsv($output, ['التاريخ', 'رقم القيد', 'رقم الفاتورة', 'العميل', 'طريقة الدفع', 'البيان', 'المبلغ', 'الحالة']);
        foreach ($payments as $payment) {
            fputcsv($output, [
                $payment['entry_date'],
                $payment['entry_number'],
                $payment['invoice_number'],
                $payment['customer_name'],
                getPaymentMethodLabel($payment['payment_method']),
                $payment['description'],
                number_format((float)$payment['amount'], 2, '.', ''),
                getPaymentStatusLabel($payment['payment_status'])
            ]);
        }
        fclose($output);
        exit;
    }

    header('Content-Type: application/vnd.ms-excel; charset=UTF-8');
    header('Content-Disposition: attachment; filename="payments_' . $filenameDate . '.xls"');
    echo '<html lang="ar" dir="rtl"><head><meta charset="UTF-8"></head><body>';
    echo '<table border="1">';
    echo '<tr><th>التاريخ</th><th>رقم القيد</th><th>رقم الفاتورة</th><th>العميل</th><th>طريقة الدفع</th><th>البيان</th><th>المبلغ</th><th>الحالة</th></tr>';
    foreach ($payments as $payment) {
        echo '<tr>';
        echo '<td>' . htmlspecialchars($payment['entry_date']) . '</td>';
        echo '<td>' . htmlspecialchars($payment['entry_number']) . '</td>';
        echo '<td>' . htmlspecialchars($payment['invoice_number']) . '</td>';
        echo '<td>' . htmlspecialchars($payment['customer_name']) . '</td>';
        echo '<td>' . htmlspecialchars(getPaymentMethodLabel($payment['payment_method'])) . '</td>';
        echo '<td>' . htmlspecialchars($payment['description']) . '</td>';
        echo '<td>' . number_format((float)$payment['amount'], 2) . '</td>';
        echo '<td>' . htmlspecialchars(getPaymentStatusLabel($payment['payment_status'])) . '</td>';
        echo '</tr>';
    }
    echo '</table></body></html>';
    exit;
}

$totalPayments = (int)$paymentsStats['total_payments'];
$totalCollected = (float)$paymentsStats['total_collected'];
$uniqueCustomersCount = (int)$paymentsStats['unique_customers'];
$currentMonthPayments = (int)$paymentsStats['current_month_payments'];

include_once "../../../../header.hnt";
?>

<style>
