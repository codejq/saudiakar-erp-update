    <?php if (!$isPrintMode && $exportType === '' && $totalPages > 1): ?>
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mt-4 no-print">
        <div class="text-muted">
            عرض <?php echo number_format(($currentPage - 1) * $pageSize + 1); ?> - <?php echo number_format(min($currentPage * $pageSize, $totalRows)); ?>
            من أصل <?php echo number_format($totalRows); ?> دفعة
        </div>
        <nav aria-label="Pagination">
            <ul class="pagination mb-0">
                <li class="page-item <?php echo $currentPage <= 1 ? 'disabled' : ''; ?>">
                    <a class="page-link" href="list.hnt?<?php echo htmlspecialchars(http_build_query(array_merge($baseFilterParams, ['page' => max(1, $currentPage - 1)]))); ?>">السابق</a>
                </li>
                <?php
                $startPage = max(1, $currentPage - 2);
                $endPage = min($totalPages, $currentPage + 2);
                for ($page = $startPage; $page <= $endPage; $page++):
                ?>
                <li class="page-item <?php echo $page === $currentPage ? 'active' : ''; ?>">
                    <a class="page-link" href="list.hnt?<?php echo htmlspecialchars(http_build_query(array_merge($baseFilterParams, ['page' => $page]))); ?>"><?php echo $page; ?></a>
                </li>
                <?php endfor; ?>
                <li class="page-item <?php echo $currentPage >= $totalPages ? 'disabled' : ''; ?>">
                    <a class="page-link" href="list.hnt?<?php echo htmlspecialchars(http_build_query(array_merge($baseFilterParams, ['page' => min($totalPages, $currentPage + 1)]))); ?>">التالي</a>
                </li>
            </ul>
        </nav>
    </div>
    <?php endif; ?>
</div>

<?php if ($isPrintMode): ?>
<script>
window.addEventListener('load', function() {
    window.print();
});
</script>
<?php endif; ?>

<script>
$(document).ready(function() {
    $('.datepicker-input').each(function() {
        $(this).datepicker({
            format: 'dd/mm/yyyy',
            language: 'ar',
            rtl: true,
            autoclose: true,
            todayHighlight: true,
            calendarType: 'gregorian',
            orientation: 'bottom right',
            weekStart: 0
        });
    });
    $('.input-group-text').on('click', function() {
        $(this).prev('.datepicker-input').datepicker('show');
    });
});
</script>
