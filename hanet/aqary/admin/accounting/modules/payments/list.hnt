                </a>
                <a href="list.hnt?<?php echo htmlspecialchars(http_build_query(array_merge($baseFilterParams, ['export' => 'xls']))); ?>" class="btn btn-outline-success">
                    <i class="bi bi-file-earmark-excel me-2"></i>تصدير Excel
                </a>
