 * @version 1.0
 */

$sc_title = "المدفوعات";
$sc_id = "205";
$use_accounting_theme = true;

// Export / template handler — runs before any HTML output
if (isset($_GET['export']) && in_array($_GET['export'], ['csv', 'xls', 'template'], true)) {
    include_once "../../../../reqloginajax.hnt";
    include_once "../../includes/accounting_class.hnt";

    $_fn       = date('Ymd_His');
    $_exp_type = $_GET['export'];

    if ($_exp_type === 'template') {
        $tpl_headers = ['تاريخ الدفعة (dd/mm/yyyy)', 'رقم الفاتورة', 'المبلغ', 'طريقة الدفع', 'ملاحظات'];
        header('Content-Type: text/csv; charset=UTF-8');
        header('Content-Disposition: attachment; filename="payments_template_' . $_fn . '.csv"');
        $_out = fopen('php://output', 'w');
        fwrite($_out, "\xEF\xBB\xBF");
        fputcsv($_out, $tpl_headers, ',', '"', '\\');
        fputcsv($_out, [date('d/m/Y'), 'INV-001', '5000.00', 'cash', ''], ',', '"', '\\');
        fclose($_out);
        exit;
    }

    $exp_headers = ['رقم القيد', 'تاريخ الدفعة', 'رقم الفاتورة', 'اسم العميل', 'المبلغ', 'طريقة الدفع', 'حالة الفاتورة', 'البيان'];
    $exp_rows    = [];
    $_er = $db->query("
        SELECT je.entry_number, je.entry_date, inv.invoice_number, inv.customer_name,
               SUM(ar_line.credit_amount) AS amount,
               COALESCE(NULLIF(TRIM(je.notes),''),
                   CASE WHEN MAX(dl.account_id)=3 THEN 'bank_transfer'
                        WHEN MAX(dl.account_id)=2 THEN 'cash' ELSE '' END) AS payment_method,
               inv.payment_status, je.description
        FROM acc_journal_entries je
        INNER JOIN acc_invoices inv ON je.reference_id = inv.invoice_id AND je.reference_type = 'invoice'
        INNER JOIN acc_journal_entry_lines ar_line ON je.entry_id = ar_line.entry_id AND ar_line.account_id = 4 AND ar_line.credit_amount > 0
        LEFT  JOIN acc_journal_entry_lines dl ON je.entry_id = dl.entry_id AND dl.debit_amount > 0 AND dl.account_id <> 4
        WHERE je.status = 'posted' AND je.reference_type = 'invoice' AND je.reference_id IS NOT NULL
        GROUP BY je.entry_id, je.entry_number, je.entry_date, je.description, je.notes,
                 inv.invoice_id, inv.invoice_number, inv.customer_name, inv.payment_status
        ORDER BY je.entry_date DESC, je.entry_id DESC");
    if ($_er) {
        while ($_p = $_er->fetch_assoc()) {
            $exp_rows[] = [
                $_p['entry_number'],
                date('d/m/Y', strtotime($_p['entry_date'])),
                $_p['invoice_number'],
                $_p['customer_name'],
                number_format(floatval($_p['amount']), 2, '.', ''),
                $_p['payment_method'],
                $_p['payment_status'],
                $_p['description']
            ];
        }
    }

    if ($_exp_type === 'csv') {
        header('Content-Type: text/csv; charset=UTF-8');
        header('Content-Disposition: attachment; filename="payments_' . $_fn . '.csv"');
        $_out = fopen('php://output', 'w');
        fwrite($_out, "\xEF\xBB\xBF");
        fputcsv($_out, $exp_headers, ',', '"', '\\');
        foreach ($exp_rows as $_r) fputcsv($_out, $_r, ',', '"', '\\');
        fclose($_out);
        exit;
    }

    header('Content-Type: application/vnd.ms-excel; charset=UTF-8');
    header('Content-Disposition: attachment; filename="payments_' . $_fn . '.xls"');
    echo '<html lang="ar" dir="rtl"><head><meta charset="UTF-8"></head><body><table border="1"><tr>';
    foreach ($exp_headers as $_h) echo '<th>' . htmlspecialchars($_h) . '</th>';
    echo '</tr>';
    foreach ($exp_rows as $_r) { echo '<tr>'; foreach ($_r as $_c) echo '<td>' . htmlspecialchars($_c) . '</td>'; echo '</tr>'; }
    echo '</table></body></html>';
    exit;
}

if ($_SERVER['REQUEST_METHOD'] == 'POST' && isset($_POST['ajax_action'])) {
    include_once "../../../../reqloginajax.hnt";
}
else {
    include_once "../../../../header.hnt";

}

include_once "../../includes/accounting_class.hnt";
$accountingManager = new AccountingManager($db, $_SESSION['userid'] ?? 1);
$accountingManager->ensureInvoiceDimensionColumnsExist();
$journals = $accountingManager->getActiveJournals();
$costCenters = $accountingManager->getActiveCostCenters();
$defaultReceiptJournalId = $accountingManager->getDefaultJournalIdByCode('REC');

// Handle AJAX actions
if ($_SERVER['REQUEST_METHOD'] == 'POST' && isset($_POST['ajax_action'])) {
    header('Content-Type: application/json; charset=utf-8');

    $action = $_POST['ajax_action'];
    $response = ['success' => false, 'message' => ''];

    switch ($action) {
        case 'record_payment':
            $invoiceId = $_POST['invoice_id'];
            $amount = $_POST['amount'];
            $paymentMethod = $_POST['payment_method'];
            // Convert DD/MM/YYYY to YYYY-MM-DD if submitted by datepicker
            if (!empty($_POST['payment_date']) && strpos($_POST['payment_date'], '/') !== false) {
                $_p = explode('/', $_POST['payment_date']);
                if (count($_p) === 3) $_POST['payment_date'] = $_p[2].'-'.$_p[1].'-'.$_p[0];
            }
            $paymentDate = $_POST['payment_date'];
            $notes = $_POST['notes'] ?? '';

            // Get invoice
            $invoiceQuery = "SELECT * FROM acc_invoices WHERE invoice_id = ?";
            $stmt = $db->prepare($invoiceQuery);
            if (!$stmt) {
                $response['message'] = 'فشل في تجهيز استعلام الفاتورة: ' . $db->error;
                echo json_encode($response, JSON_UNESCAPED_UNICODE);
                exit;
            }
            $stmt->bind_param('i', $invoiceId);
            $stmt->execute();
            $invoice = $stmt->get_result()->fetch_assoc();

            if (!$invoice) {
                $response['message'] = 'الفاتورة غير موجودة';
                echo json_encode($response, JSON_UNESCAPED_UNICODE);
                exit;
            }

            $invoiceEntryContext = $accountingManager->getInvoiceDimensionContext((int)$invoiceId);

            $journalId = !empty($_POST['journal_id']) ? (int)$_POST['journal_id'] : $defaultReceiptJournalId;
            $costCenterId = isset($_POST['cost_center_id']) && $_POST['cost_center_id'] !== '' ? (int)$_POST['cost_center_id'] : ($invoiceEntryContext['cost_center_id'] ?? null);

            // Create journal entry for payment
            $entryData = [
                'entry_date' => $paymentDate,
                'entry_type' => 'payment',
                'journal_id' => $journalId,
                'tenant_id' => $invoiceEntryContext['tenant_id'] ?? null,
                'owner_id' => $invoiceEntryContext['owner_id'] ?? null,
                'aqar_id' => $invoiceEntryContext['aqar_id'] ?? null,
                'subaqar_id' => $invoiceEntryContext['subaqar_id'] ?? null,
                'egar_id' => $invoiceEntryContext['egar_id'] ?? null,
                'invoice_id' => $invoiceId,
                'reference_type' => 'invoice',
                'reference_id' => $invoiceId,
                'description' => "دفعة للفاتورة {$invoice['invoice_number']} - {$invoice['customer_name']}",
                'status' => 'posted'
            ];

            // Determine cash/bank account based on payment method
            $cashAccountId = 2; // Default to cash account (1111)
            if ($paymentMethod == 'bank_transfer') {
                $cashAccountId = 3; // Bank account (1112)
            }

            $lines = [
                [
                    'account_id' => $cashAccountId,
                    'description' => "استلام دفعة - {$invoice['customer_name']}",
                    'debit_amount' => $amount,
                    'credit_amount' => 0,
                    'cost_center_id' => $costCenterId
                ],
                [
                    'account_id' => 4, // Accounts Receivable (1121)
                    'description' => "تسديد فاتورة {$invoice['invoice_number']}",
                    'debit_amount' => 0,
                    'credit_amount' => $amount,
                    'cost_center_id' => $costCenterId
                ]
            ];

            $result = $accountingManager->createJournalEntry($entryData, $lines);

            if ($result['success']) {
                // Update invoice payment status
                $paidAmount = $invoice['paid_amount'] + $amount;
                $remainingAmount = max(0, $invoice['total_amount'] - $paidAmount);
                $paymentStatus = ($paidAmount >= $invoice['total_amount']) ? 'paid' : 'partial';

                if (!empty($result['entry_id'])) {
                    $paymentEntryUpdate = $db->prepare("UPDATE acc_journal_entries SET notes = ? WHERE entry_id = ?");
                    if ($paymentEntryUpdate) {
                        $paymentEntryUpdate->bind_param('si', $paymentMethod, $result['entry_id']);
                        $paymentEntryUpdate->execute();
                    }
                }

                $updateQuery = "UPDATE acc_invoices SET paid_amount = ?, remaining_amount = ?, payment_status = ?, payment_method = ? WHERE invoice_id = ?";
                $stmt = $db->prepare($updateQuery);
                if (!$stmt) {
                    $response['message'] = 'فشل في تجهيز تحديث الفاتورة: ' . $db->error;
                    echo json_encode($response, JSON_UNESCAPED_UNICODE);
                    exit;
                }
                $stmt->bind_param('ddssi', $paidAmount, $remainingAmount, $paymentStatus, $paymentMethod, $invoiceId);
                $stmt->execute();

                $response['success'] = true;
                $response['message'] = 'تم تسجيل الدفعة بنجاح';
            } else {
                $response['message'] = 'فشل في تسجيل الدفعة';
            }
            break;

        case 'import_payments':
            if (empty($_FILES['import_file']['tmp_name'])) {
                $response = ['success' => false, 'message' => 'لم يتم رفع أي ملف'];
                break;
            }
            $handle = fopen($_FILES['import_file']['tmp_name'], 'r');
            if (!$handle) {
                $response = ['success' => false, 'message' => 'تعذر قراءة الملف'];
                break;
            }
            $bom = fread($handle, 3);
            if ($bom !== "\xEF\xBB\xBF") rewind($handle);
            fgetcsv($handle, 0, ',', '"', '\\'); // skip header row

            $imported = 0;
            $errors   = [];
            $lineNum  = 1;

            while (($row = fgetcsv($handle, 0, ',', '"', '\\')) !== false) {
                $lineNum++;
                if (count($row) < 3 || empty(trim($row[1]))) continue;

                $_date_raw    = trim($row[0] ?? '');
                $_invoice_num = trim($row[1]);
                $_amount_raw  = trim($row[2] ?? '0');
                $_pay_method  = trim($row[3] ?? 'cash');
                $_notes       = trim($row[4] ?? '');

                // Convert DD/MM/YYYY → YYYY-MM-DD
                if (strpos($_date_raw, '/') !== false) {
                    $_dp = explode('/', $_date_raw);
                    $_pay_date = count($_dp) === 3 ? "{$_dp[2]}-{$_dp[1]}-{$_dp[0]}" : date('Y-m-d');
                } else {
                    $_pay_date = $_date_raw ?: date('Y-m-d');
                }

                $_amount = floatval(str_replace(',', '', $_amount_raw));
                if ($_amount <= 0) { $errors[] = "سطر $lineNum: المبلغ غير صالح ($_amount_raw)"; continue; }

                $_valid_methods = ['cash', 'bank_transfer', 'credit_card', 'cheque'];
                if (!in_array($_pay_method, $_valid_methods, true)) $_pay_method = 'cash';

                $_inv_stmt = $db->prepare("SELECT * FROM acc_invoices WHERE invoice_number = ? AND payment_status IN ('unpaid','partial') LIMIT 1");
                if (!$_inv_stmt) { $errors[] = "سطر $lineNum: خطأ داخلي"; continue; }
                $_inv_stmt->bind_param('s', $_invoice_num);
                $_inv_stmt->execute();
                $_invoice = $_inv_stmt->get_result()->fetch_assoc();
                if (!$_invoice) { $errors[] = "سطر $lineNum: الفاتورة '$_invoice_num' غير موجودة أو مدفوعة بالكامل"; continue; }

                $_cash_acc = ($_pay_method === 'bank_transfer') ? 3 : 2;

                $_entry_data = [
                    'entry_date'     => $_pay_date,
                    'entry_type'     => 'payment',
                    'journal_id'     => $defaultReceiptJournalId,
                    'reference_type' => 'invoice',
                    'reference_id'   => $_invoice['invoice_id'],
                    'description'    => "دفعة للفاتورة {$_invoice['invoice_number']} - {$_invoice['customer_name']}",
                    'status'         => 'posted',
                    'notes'          => $_pay_method
                ];
                $_lines = [
                    ['account_id' => $_cash_acc, 'description' => "استلام دفعة - {$_invoice['customer_name']}", 'debit_amount' => $_amount, 'credit_amount' => 0],
                    ['account_id' => 4,           'description' => "تسديد فاتورة {$_invoice['invoice_number']}",  'debit_amount' => 0, 'credit_amount' => $_amount]
                ];
                $_result = $accountingManager->createJournalEntry($_entry_data, $_lines);

                if ($_result['success']) {
                    if (!empty($_result['entry_id']) && !empty($_notes)) {
                        $_nstmt = $db->prepare("UPDATE acc_journal_entries SET notes = ? WHERE entry_id = ?");
                        if ($_nstmt) { $_nstmt->bind_param('si', $_notes, $_result['entry_id']); $_nstmt->execute(); }
                    }
                    $_paid_new      = $_invoice['paid_amount'] + $_amount;
                    $_remaining_new = max(0, $_invoice['total_amount'] - $_paid_new);
                    $_status_new    = ($_paid_new >= $_invoice['total_amount']) ? 'paid' : 'partial';
                    $_upd = $db->prepare("UPDATE acc_invoices SET paid_amount=?, remaining_amount=?, payment_status=?, payment_method=? WHERE invoice_id=?");
                    if ($_upd) { $_upd->bind_param('ddssi', $_paid_new, $_remaining_new, $_status_new, $_pay_method, $_invoice['invoice_id']); $_upd->execute(); }
                    $imported++;
                } else {
                    $errors[] = "سطر $lineNum: فشل تسجيل دفعة الفاتورة '$_invoice_num'";
                }
            }
            fclose($handle);

            $msg = "تم استيراد $imported دفعة بنجاح";
            if (!empty($errors)) $msg .= "\n\nتنبيهات:\n" . implode("\n", $errors);
            $response = ['success' => true, 'message' => $msg, 'imported' => $imported, 'errors' => $errors];
            break;
    }

    echo json_encode($response, JSON_UNESCAPED_UNICODE);
    exit;
}

// Get recent payments (from journal entries)
$paymentsQuery = "
    SELECT
        je.entry_id,
        je.entry_number,
        je.entry_date,
        je.description,
        je.notes,
        inv.invoice_id,
        inv.invoice_number,
        inv.customer_id,
        inv.customer_name,
        inv.payment_status,
        SUM(ar_line.credit_amount) AS amount,
        COALESCE(
            NULLIF(TRIM(je.notes), ''),
            CASE
                WHEN MAX(debit_line.account_id) = 3 THEN 'bank_transfer'
                WHEN MAX(debit_line.account_id) = 2 THEN 'cash'
                ELSE ''
            END
        ) AS payment_method
    FROM acc_journal_entries je
    INNER JOIN acc_invoices inv
        ON je.reference_id = inv.invoice_id
        AND je.reference_type = 'invoice'
    INNER JOIN acc_journal_entry_lines ar_line
        ON je.entry_id = ar_line.entry_id
        AND ar_line.account_id = 4
        AND ar_line.credit_amount > 0
    LEFT JOIN acc_journal_entry_lines debit_line
        ON je.entry_id = debit_line.entry_id
        AND debit_line.debit_amount > 0
        AND debit_line.account_id <> 4
    WHERE je.status = 'posted'
        AND je.reference_type = 'invoice'
        AND je.reference_id IS NOT NULL
    GROUP BY
        je.entry_id,
        je.entry_number,
        je.entry_date,
        je.description,
        je.notes,
        inv.invoice_id,
        inv.invoice_number,
        inv.customer_id,
        inv.customer_name,
        inv.payment_status
    ORDER BY je.entry_date DESC, je.entry_id DESC
    LIMIT 50
";
$paymentsResult = $db->query($paymentsQuery);
$payments = [];
if ($paymentsResult) {
    while ($row = $paymentsResult->fetch_assoc()) {
        $payments[] = $row;
    }
}

// Get unpaid/partial invoices
$unpaidQuery = "SELECT inv.*, je.tenant_id, je.owner_id, je.aqar_id, je.subaqar_id, je.egar_id,
               MAX(jel.cost_center_id) AS default_cost_center_id
               FROM acc_invoices inv
               LEFT JOIN acc_journal_entries je
                   ON je.reference_type = 'invoice' AND je.reference_id = inv.invoice_id
               LEFT JOIN acc_journal_entry_lines jel
                   ON je.entry_id = jel.entry_id
               WHERE inv.payment_status IN ('unpaid', 'partial')
               GROUP BY inv.invoice_id, je.entry_id, je.tenant_id, je.owner_id, je.aqar_id, je.subaqar_id, je.egar_id
               ORDER BY inv.invoice_date DESC";
$unpaidResult = $db->query($unpaidQuery);
$unpaidInvoices = [];
if ($unpaidResult) {
    while ($row = $unpaidResult->fetch_assoc()) {
        $unpaidInvoices[] = $row;
    }
}

$preselectedInvoiceId = intval($_GET['invoice_id'] ?? 0);
$preselectedInvoice = null;
if ($preselectedInvoiceId > 0) {
    foreach ($unpaidInvoices as $invoice) {
        if ((int)$invoice['invoice_id'] === $preselectedInvoiceId) {
            $preselectedInvoice = $invoice;
            break;
        }
    }
}
