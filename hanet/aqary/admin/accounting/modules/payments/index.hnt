<script>
function showQuickPaymentModal() {
    // Show invoice selector, clear form
    document.getElementById('invoice_select_div').style.display = 'block';
    document.getElementById('invoice_select').value = '';
    document.getElementById('payment_invoice_id').value = '';
    document.getElementById('payment_invoice_number').value = '';
    document.getElementById('payment_due_amount').value = '';
    document.getElementById('payment_amount').value = '';
    document.getElementById('payment_journal_id').value = '<?php echo (int)$defaultReceiptJournalId; ?>';
    document.getElementById('payment_cost_center_id').value = '';

    const modal = new bootstrap.Modal(document.getElementById('paymentModal'));
    modal.show();
}

function selectInvoice() {
    const select = document.getElementById('invoice_select');
    const option = select.options[select.selectedIndex];

    if (option.value) {
        const invoiceId = option.value;
        const invoiceNumber = option.getAttribute('data-number');
        const dueAmount = parseFloat(option.getAttribute('data-due'));
        const costCenterId = option.getAttribute('data-cost-center');

        document.getElementById('payment_invoice_id').value = invoiceId;
        document.getElementById('payment_invoice_number').value = invoiceNumber;
        document.getElementById('payment_due_amount').value = dueAmount.toFixed(2) + ' ر.س';
        document.getElementById('payment_amount').value = dueAmount.toFixed(2);
        document.getElementById('payment_cost_center_id').value = costCenterId && costCenterId !== '0' ? costCenterId : '';
    }
}

function showPaymentModal(invoiceId, invoiceNumber, dueAmount, costCenterId = '') {
    // Hide invoice selector when called from invoice card
    document.getElementById('invoice_select_div').style.display = 'none';

    document.getElementById('payment_invoice_id').value = invoiceId;
    document.getElementById('payment_invoice_number').value = invoiceNumber;
    document.getElementById('payment_due_amount').value = dueAmount.toFixed(2) + ' ر.س';
    document.getElementById('payment_amount').value = dueAmount.toFixed(2);
    document.getElementById('payment_journal_id').value = '<?php echo (int)$defaultReceiptJournalId; ?>';
    document.getElementById('payment_cost_center_id').value = costCenterId ? String(costCenterId) : '';

    const modal = new bootstrap.Modal(document.getElementById('paymentModal'));
    modal.show();
}

function submitPayment() {
    const form = document.getElementById('paymentForm');
    const formData = new FormData(form);
    formData.append('ajax_action', 'record_payment');

    fetch('index.hnt', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        const modal = bootstrap.Modal.getInstance(document.getElementById('paymentModal'));
        modal.hide();

        showResultModal(data.success, data.message);

        if (data.success) {
            setTimeout(() => location.reload(), 1500);
        }
    })
    .catch(error => {
        console.error('Error:', error);
        showResultModal(false, 'حدث خطأ أثناء تسجيل الدفعة');
    });
}

function showResultModal(success, message) {
    const modal = new bootstrap.Modal(document.getElementById('resultModal'));
    const header = document.getElementById('resultModalHeader');
    const title = document.getElementById('resultModalTitle');
    const messageEl = document.getElementById('resultModalMessage');

    if (success) {
        header.style.background = 'linear-gradient(135deg, #28a745, #20c997)';
        title.innerHTML = '<i class="bi bi-check-circle me-2"></i>نجحت العملية';
    } else {
        header.style.background = 'linear-gradient(135deg, #dc3545, #c82333)';
        title.innerHTML = '<i class="bi bi-x-circle me-2"></i>فشلت العملية';
    }

    messageEl.textContent = message;
    modal.show();
}

function submitPaymentsImport() {
    const fileInput = document.getElementById('import_payments_file');
    if (!fileInput.files.length) {
        alert('يرجى اختيار ملف CSV أولاً');
        return;
    }

    const btn = document.getElementById('importPaymentsSubmitBtn');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>جاري الاستيراد...';

    const formData = new FormData();
    formData.append('ajax_action', 'import_payments');
    formData.append('import_file', fileInput.files[0]);

    fetch('index.hnt', { method: 'POST', body: formData })
        .then(r => r.json())
        .then(data => {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-upload me-2"></i>استيراد';

            const resultDiv = document.getElementById('importPaymentsResult');
            resultDiv.style.display = 'block';
            const cls  = data.imported > 0 ? 'alert-success' : 'alert-warning';
            const icon = data.imported > 0 ? 'check-circle' : 'exclamation-triangle';
            resultDiv.innerHTML = `<div class="alert ${cls}">
                <i class="bi bi-${icon} me-2"></i>
                ${data.message.replace(/\n/g, '<br>')}
            </div>`;

            if (data.imported > 0) setTimeout(() => location.reload(), 2000);
        })
        .catch(() => {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-upload me-2"></i>استيراد';
            showResultModal(false, 'حدث خطأ أثناء الاستيراد');
        });
}

document.addEventListener('DOMContentLoaded', function() {
    <?php if ($preselectedInvoice): ?>
    showPaymentModal(
        <?php echo (int)$preselectedInvoice['invoice_id']; ?>,
        <?php echo json_encode($preselectedInvoice['invoice_number'], JSON_UNESCAPED_UNICODE); ?>,
        <?php echo (float)($preselectedInvoice['total_amount'] - $preselectedInvoice['paid_amount']); ?>,
        <?php echo (int)($preselectedInvoice['default_cost_center_id'] ?? 0); ?>
    );
    <?php endif; ?>

    const importPaymentsModal = document.getElementById('importPaymentsModal');
    if (importPaymentsModal) {
        importPaymentsModal.addEventListener('show.bs.modal', function() {
            document.getElementById('import_payments_file').value = '';
            const r   = document.getElementById('importPaymentsResult');
            r.style.display = 'none';
            r.innerHTML = '';
            const btn = document.getElementById('importPaymentsSubmitBtn');
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-upload me-2"></i>استيراد';
        });
    }
});
</script>

<script>
$(document).ready(function() {
    $('.datepicker-input').each(function() {
        $(this).datepicker({
            format: 'dd/mm/yyyy',
            language: 'ar',
            rtl: true,
            autoclose: true,
            todayHighlight: true,
            calendarType: 'gregorian',
            orientation: 'bottom right',
            weekStart: 0,
            container: 'body'
        });
    });
    $('.input-group-text').on('click', function() {
        $(this).prev('.datepicker-input').datepicker('show');
    });
});
</script>
