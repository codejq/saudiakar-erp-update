<?php
/**
 * Customer Statement Report
 * كشف حساب العميل
 *
 * @charset UTF-8
 * @version 1.0
 */

$sc_title = "كشف حساب العميل";
$sc_id = "210";
$use_accounting_theme = true;
include_once "../../../../nocash.hnt";
include_once "../../../../connectdb.hnt";
include_once "../../../../header.hnt";
include_once "../../includes/accounting_class.hnt";

$accountingManager = new AccountingManager($db, $_SESSION['userid'] ?? 1);

// Get all customers for the dropdown
$dimensionOptions = $accountingManager->getReportDimensionOptions();
$customers = $dimensionOptions['customers'];

// Get parameters
$customerId = $_GET['customer_id'] ?? '';
$dateFrom = $_GET['date_from'] ?? date('Y-01-01');
$dateTo = $_GET['date_to'] ?? date('Y-m-d');
$filters = [
    'journal_id' => !empty($_GET['journal_id']) ? (int)$_GET['journal_id'] : null,
    'cost_center_id' => !empty($_GET['cost_center_id']) ? (int)$_GET['cost_center_id'] : null,
    'aqar_id' => !empty($_GET['aqar_id']) ? (int)$_GET['aqar_id'] : null,
    'tenant_id' => !empty($_GET['tenant_id']) ? (int)$_GET['tenant_id'] : null,
    'owner_id' => !empty($_GET['owner_id']) ? (int)$_GET['owner_id'] : null,
    'egar_id' => !empty($_GET['egar_id']) ? (int)$_GET['egar_id'] : null
];

// Initialize variables
$customerName = '';
$transactions = [];
$totalInvoices = 0;
$totalPayments = 0;
$balance = 0;
$openingBalance = 0;

// Only process if customer is selected
if (!empty($customerId)) {
    $statementData = $accountingManager->getCustomerStatementData((int)$customerId, $dateFrom, $dateTo, $filters);
    $customerName = $statementData['customer_name'];
    $transactions = $statementData['transactions'];
    $totalInvoices = $statementData['total_invoices'];
    $totalPayments = $statementData['total_payments'];
    $balance = $statementData['balance'];
    $openingBalance = $statementData['opening_balance'];
}
?>


<style>
:root {
    --primary-color: var(--accounting-primary-color, #4e627f);
}

.report-card {
    background: white;
    border-radius: 15px;
    padding: 2rem;
    box-shadow: 0 4px 15px rgba(0,0,0,0.08);
}

