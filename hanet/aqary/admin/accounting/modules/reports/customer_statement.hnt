    <?php if (!empty($customerId) && !empty($customerName)): ?>
    <!-- Summary Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="summary-card" style="border-right: 4px solid #dc3545;">
                <div class="text-muted mb-2">إجمالي الفواتير</div>
                <div class="summary-value text-danger"><?php echo number_format($totalInvoices, 2); ?> ر.س</div>
