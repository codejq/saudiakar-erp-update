        </div>
        <div class="col-md-4">
            <div class="summary-card" style="border-right: 4px solid #667eea;">
                <div class="text-muted mb-2">الرصيد المستحق</div>
                <div class="summary-value text-primary"><?php echo number_format($balance, 2); ?> ر.س</div>
            </div>
        </div>
    </div>

    <!-- Report -->
    <div class="report-card">
        <div class="customer-header">
            <h3 style="color: #667eea; margin-bottom: 10px;"><?php echo htmlspecialchars($customerName); ?></h3>
            <p class="text-muted mb-0">كشف حساب من <?php echo $dateFrom; ?> إلى <?php echo $dateTo; ?></p>
        </div>

        <table class="statement-table">
            <thead>
                <tr>
                    <th>التاريخ</th>
                    <th>المرجع</th>
                    <th>البيان</th>
                    <th>مدين</th>
                    <th>دائن</th>
                    <th>الرصيد</th>
                </tr>
            </thead>
            <tbody>
                <?php if (empty($transactions)): ?>
                <tr>
                    <td colspan="6" class="text-center text-muted">لا توجد حركات في هذه الفترة</td>
                </tr>
                <?php else: ?>
                <?php foreach ($transactions as $trans): ?>
                <tr>
                    <td><?php echo $trans['date']; ?></td>
                    <td><?php echo htmlspecialchars($trans['reference']); ?></td>
                    <td><?php echo htmlspecialchars($trans['description']); ?></td>
                    <td class="text-end"><?php echo $trans['debit'] > 0 ? number_format($trans['debit'], 2) : '-'; ?></td>
                    <td class="text-end"><?php echo $trans['credit'] > 0 ? number_format($trans['credit'], 2) : '-'; ?></td>
                    <td class="text-end fw-bold"><?php echo number_format($trans['balance'], 2); ?></td>
                </tr>
                <?php endforeach; ?>
                <tr style="background: #e9ecef; font-weight: bold;">
                    <td colspan="3">الإجمالي</td>
                    <td class="text-end"><?php echo number_format($totalInvoices, 2); ?></td>
                    <td class="text-end"><?php echo number_format($totalPayments, 2); ?></td>
                    <td class="text-end"><?php echo number_format($balance, 2); ?></td>
