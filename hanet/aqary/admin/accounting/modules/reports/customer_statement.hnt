<?php
/**
 * Customer Statement Report
 * كشف حساب العميل
 *
 * @charset UTF-8
 * @version 1.0
 */

$sc_title = "كشف حساب العميل";
$sc_id = "210";
$use_accounting_theme = true;
include_once "../../../../nocash.hnt";
include_once "../../../../connectdb.hnt";
include_once "../../../../header.hnt";

// Get all customers for the dropdown
$customersQuery = "SELECT customer_id, customer_name, customer_code FROM acc_customers WHERE is_active = 1 ORDER BY customer_name";
$customersResult = $db->query($customersQuery);
$customers = $customersResult->fetch_all(MYSQLI_ASSOC);

// Get parameters
$customerId = $_GET['customer_id'] ?? '';
$dateFrom = $_GET['date_from'] ?? date('Y-01-01');
$dateTo = $_GET['date_to'] ?? date('Y-m-d');

// Initialize variables
$customerName = '';
$invoices = [];
$payments = [];
$transactions = [];
$totalInvoices = 0;
$totalPayments = 0;
$balance = 0;

// Only process if customer is selected
if (!empty($customerId)) {
    // Get customer name
    $customerQuery = "SELECT customer_name FROM acc_customers WHERE customer_id = ?";
    $stmt = $db->prepare($customerQuery);
    $stmt->bind_param('i', $customerId);
    $stmt->execute();
    $customerResult = $stmt->get_result()->fetch_assoc();
    $customerName = $customerResult['customer_name'] ?? '';

    if ($customerName) {
        // Get invoices
        $invoicesQuery = "
            SELECT
                invoice_id,
                invoice_number,
                invoice_date,
                invoice_type,
                subtotal,
                vat_amount,
                total_amount,
                paid_amount,
                payment_status
            FROM acc_invoices
            WHERE customer_id = ?
            AND invoice_date BETWEEN ? AND ?
            ORDER BY invoice_date, invoice_id
        ";
        $stmt = $db->prepare($invoicesQuery);
        $stmt->bind_param('iss', $customerId, $dateFrom, $dateTo);
        $stmt->execute();
        $invoices = $stmt->get_result()->fetch_all(MYSQLI_ASSOC);

        // Get payments
        $paymentsQuery = "
            SELECT
                je.entry_number,
                je.entry_date,
                je.description,
                SUM(jel.credit_amount) as amount
            FROM acc_journal_entries je
            INNER JOIN acc_journal_entry_lines jel ON je.entry_id = jel.entry_id
            INNER JOIN acc_invoices inv ON je.reference_type = 'invoice' AND je.reference_id = inv.invoice_id
            WHERE je.reference_type = 'invoice'
            AND je.reference_id IS NOT NULL
            AND je.status = 'posted'
            AND inv.customer_id = ?
            AND jel.account_id = 4
            AND jel.credit_amount > 0
            AND je.entry_date BETWEEN ? AND ?
            GROUP BY je.entry_id
            ORDER BY je.entry_date
        ";
        $stmt = $db->prepare($paymentsQuery);
        $stmt->bind_param('iss', $customerId, $dateFrom, $dateTo);
        $stmt->execute();
        $payments = $stmt->get_result()->fetch_all(MYSQLI_ASSOC);

        // Combine and sort transactions
        $transactions = [];
        foreach ($invoices as $inv) {
            $transactions[] = [
                'date' => $inv['invoice_date'],
                'type' => 'invoice',
                'reference' => $inv['invoice_number'],
                'description' => 'فاتورة ' . $inv['invoice_type'],
                'debit' => $inv['total_amount'],
                'credit' => 0,
                'balance' => 0
            ];
        }
        foreach ($payments as $pay) {
            $transactions[] = [
                'date' => $pay['entry_date'],
                'type' => 'payment',
                'reference' => $pay['entry_number'],
                'description' => $pay['description'],
                'debit' => 0,
                'credit' => $pay['amount'],
                'balance' => 0
            ];
        }

        // Sort by date
        usort($transactions, function($a, $b) {
            return strcmp($a['date'], $b['date']);
        });

        // Calculate running balance
        $runningBalance = 0;
        foreach ($transactions as &$trans) {
            $runningBalance += $trans['debit'] - $trans['credit'];
            $trans['balance'] = $runningBalance;
        }
        unset($trans);

        // Calculate totals from displayed transactions
        $totalInvoices = 0;
        $totalPayments = 0;
        foreach ($transactions as $trans) {
            $totalInvoices += (float)$trans['debit'];
            $totalPayments += (float)$trans['credit'];
        }
        $balance = $runningBalance;
    }
}
?>


