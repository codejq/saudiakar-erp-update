<?php
/**
 * Balance Sheet Report
 * الميزانية العمومية
 *
 * @charset UTF-8
 * @version 1.0
 */

$sc_title = "الميزانية العمومية";
$sc_id = "207";
$use_accounting_theme = true;
include_once "../../../../nocash.hnt";
include_once "../../../../connectdb.hnt";
include_once "../../../../header.hnt";
include_once "../../includes/accounting_class.hnt";

$accountingManager = new AccountingManager($db, $_SESSION['userid'] ?? 1);

// Get date
$asOfDate = $_GET['as_of_date'] ?? date('Y-m-d');

// Get Assets
$assetsQuery = "
    SELECT
        acc.account_id,
        acc.account_code,
        acc.account_name_ar,
        acc.account_category,
        acc.opening_balance + COALESCE(SUM(jel.debit_amount - jel.credit_amount), 0) as balance
    FROM acc_chart_of_accounts acc
    LEFT JOIN acc_journal_entry_lines jel ON acc.account_id = jel.account_id
    LEFT JOIN acc_journal_entries je ON jel.entry_id = je.entry_id
        AND je.status = 'posted'
        AND je.entry_date <= ?
    WHERE acc.account_type = 'asset' AND acc.is_active = 1
    GROUP BY acc.account_id
    HAVING balance != 0
    ORDER BY acc.account_code
";
$stmt = $db->prepare($assetsQuery);
$stmt->bind_param('s', $asOfDate);
$stmt->execute();
$assets = $stmt->get_result()->fetch_all(MYSQLI_ASSOC);

// Get Liabilities
$liabilitiesQuery = "
    SELECT
        acc.account_id,
        acc.account_code,
        acc.account_name_ar,
        acc.account_category,
        acc.opening_balance + COALESCE(SUM(jel.credit_amount - jel.debit_amount), 0) as balance
    FROM acc_chart_of_accounts acc
    LEFT JOIN acc_journal_entry_lines jel ON acc.account_id = jel.account_id
    LEFT JOIN acc_journal_entries je ON jel.entry_id = je.entry_id
        AND je.status = 'posted'
        AND je.entry_date <= ?
    WHERE acc.account_type = 'liability' AND acc.is_active = 1
    GROUP BY acc.account_id
    HAVING balance != 0
    ORDER BY acc.account_code
";
$stmt = $db->prepare($liabilitiesQuery);
$stmt->bind_param('s', $asOfDate);
$stmt->execute();
$liabilities = $stmt->get_result()->fetch_all(MYSQLI_ASSOC);

// Get Equity
$equityQuery = "
    SELECT
        acc.account_id,
        acc.account_code,
        acc.account_name_ar,
        acc.account_category,
        acc.opening_balance + COALESCE(SUM(jel.credit_amount - jel.debit_amount), 0) as balance
    FROM acc_chart_of_accounts acc
    LEFT JOIN acc_journal_entry_lines jel ON acc.account_id = jel.account_id
    LEFT JOIN acc_journal_entries je ON jel.entry_id = je.entry_id
        AND je.status = 'posted'
        AND je.entry_date <= ?
    WHERE acc.account_type = 'equity' AND acc.is_active = 1
    GROUP BY acc.account_id
    HAVING balance != 0
    ORDER BY acc.account_code
";
$stmt = $db->prepare($equityQuery);
$stmt->bind_param('s', $asOfDate);
$stmt->execute();
$equity = $stmt->get_result()->fetch_all(MYSQLI_ASSOC);

// Calculate totals
$totalAssets = array_sum(array_column($assets, 'balance'));
$totalLiabilities = array_sum(array_column($liabilities, 'balance'));
$totalEquity = array_sum(array_column($equity, 'balance'));

// Group assets by category
$assetsByCategory = [];
foreach ($assets as $asset) {
    $category = $asset['account_category'] ?: 'أخرى';
    if (!isset($assetsByCategory[$category])) {
        $assetsByCategory[$category] = [];
    }
    $assetsByCategory[$category][] = $asset;
}

// Group liabilities by category
$liabilitiesByCategory = [];
foreach ($liabilities as $liability) {
    $category = $liability['account_category'] ?: 'أخرى';
    if (!isset($liabilitiesByCategory[$category])) {
        $liabilitiesByCategory[$category] = [];
    }
    $liabilitiesByCategory[$category][] = $liability;
}
?>
 
