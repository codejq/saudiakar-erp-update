        <div class="balance-sheet-container">
            <!-- Assets -->
            <div class="section">
                <div class="section-header">
                    <i class="bi bi-building me-2"></i>الأصول
                </div>

                <?php if (empty($assetsByCategory)): ?>
                <div class="text-center text-muted py-3">لا توجد أصول</div>
                <?php else: ?>
                <?php foreach ($assetsByCategory as $category => $categoryAssets): ?>
                <div class="category-header"><?php echo $category; ?></div>
                <?php foreach ($categoryAssets as $asset): ?>
                <div class="account-line">
                    <span><?php echo $asset['account_code']; ?> - <?php echo $asset['account_name_ar']; ?></span>
                    <span><?php echo number_format($asset['balance'], 2); ?></span>
                </div>
                <?php endforeach; ?>
                <?php endforeach; ?>
                <?php endif; ?>

                <div class="total">
                    <span>إجمالي الأصول</span>
                    <span><?php echo number_format($totalAssets, 2); ?> ر.س</span>
                </div>
            </div>

            <!-- Liabilities & Equity -->
            <div class="section">
                <div class="section-header">
                    <i class="bi bi-credit-card me-2"></i>الخصوم وحقوق الملكية
                </div>

                <!-- Liabilities -->
                <h6 class="mt-3 mb-2 fw-bold">الخصوم</h6>
                <?php if (empty($liabilitiesByCategory)): ?>
                <div class="text-center text-muted py-2">لا توجد خصوم</div>
                <?php else: ?>
                <?php foreach ($liabilitiesByCategory as $category => $categoryLiabilities): ?>
                <div class="category-header"><?php echo $category; ?></div>
                <?php foreach ($categoryLiabilities as $liability): ?>
                <div class="account-line">
                    <span><?php echo $liability['account_code']; ?> - <?php echo $liability['account_name_ar']; ?></span>
                    <span><?php echo number_format($liability['balance'], 2); ?></span>
                </div>
                <?php endforeach; ?>
                <?php endforeach; ?>
                <?php endif; ?>

                <div class="subtotal">
                    <span>إجمالي الخصوم</span>
                    <span><?php echo number_format($totalLiabilities, 2); ?> ر.س</span>
                </div>

                <!-- Equity -->
                <h6 class="mt-3 mb-2 fw-bold">حقوق الملكية</h6>
                <?php if (empty($equity)): ?>
                <div class="text-center text-muted py-2">لا توجد حقوق ملكية</div>
                <?php else: ?>
                <?php foreach ($equity as $eq): ?>
                <div class="account-line">
                    <span><?php echo $eq['account_code']; ?> - <?php echo $eq['account_name_ar']; ?></span>
                    <span><?php echo number_format($eq['balance'], 2); ?></span>
                </div>
                <?php endforeach; ?>
                <?php endif; ?>

                <div class="subtotal">
                    <span>إجمالي حقوق الملكية</span>
                    <span><?php echo number_format($totalEquity, 2); ?> ر.س</span>
                </div>

                <div class="total">
                    <span>إجمالي الخصوم وحقوق الملكية</span>
                    <span><?php echo number_format($totalLiabilities + $totalEquity, 2); ?> ر.س</span>
                </div>
            </div>
        </div>

        <!-- Balance Check -->
        <div class="balance-check">
            <?php if (abs($totalAssets - ($totalLiabilities + $totalEquity)) < 0.01): ?>
            <i class="bi bi-check-circle me-2" style="font-size: 2rem;"></i>
            <h5 class="mb-0">الميزانية متوازنة</h5>
            <p class="mb-0 opacity-75">الأصول = الخصوم + حقوق الملكية</p>
            <?php else: ?>
