<?php
/**
 * VAT Report
 * تقرير ضريبة القيمة المضافة
 *
 * @charset UTF-8
 * @version 1.0
 */

$sc_title = "تقرير ضريبة القيمة المضافة";
$sc_id = "208";
$use_accounting_theme = true;
include_once "../../../../nocash.hnt";
include_once "../../../../connectdb.hnt";
include_once "../../../../header.hnt";

// Get date range
$dateFrom = $_GET['date_from'] ?? date('Y-m-01');
$dateTo = $_GET['date_to'] ?? date('Y-m-t');
// Convert DD/MM/YYYY to YYYY-MM-DD if submitted by datepicker
foreach (['dateFrom', 'dateTo'] as $_df) {
    if ($$_df && strpos($$_df, '/') !== false) {
        $_p = explode('/', $$_df);
        if (count($_p) === 3) $$_df = $_p[2].'-'.$_p[1].'-'.$_p[0];
    }
}

// Get sales (output VAT)
$salesQuery = "
    SELECT
        invoice_number,
        customer_name,
        invoice_date,
        subtotal,
        vat_amount,
        total_amount
    FROM acc_invoices
    WHERE invoice_date BETWEEN ? AND ?
    AND invoice_type IN ('standard', 'simplified')
    ORDER BY invoice_date
";
$stmt = $db->prepare($salesQuery);
$stmt->bind_param('ss', $dateFrom, $dateTo);
$stmt->execute();
$sales = $stmt->get_result()->fetch_all(MYSQLI_ASSOC);

// Get purchases (input VAT) - from journal entries with VAT
$purchasesQuery = "
    SELECT
        je.entry_number,
        je.entry_date,
        je.description,
        SUM(jel.debit_amount) as amount,
        SUM(jel.debit_amount) * 0.15 as vat_amount
    FROM acc_journal_entries je
    JOIN acc_journal_entry_lines jel ON je.entry_id = jel.entry_id
    JOIN acc_chart_of_accounts acc ON jel.account_id = acc.account_id
    WHERE je.entry_date BETWEEN ? AND ?
    AND je.status = 'posted'
    AND acc.vat_applicable = 1
    AND acc.account_type = 'expense'
    GROUP BY je.entry_id
    ORDER BY je.entry_date
";
$stmt = $db->prepare($purchasesQuery);
$stmt->bind_param('ss', $dateFrom, $dateTo);
$stmt->execute();
$purchases = $stmt->get_result()->fetch_all(MYSQLI_ASSOC);

// Calculate totals
$totalSalesAmount = array_sum(array_column($sales, 'subtotal'));
$totalSalesVAT = array_sum(array_column($sales, 'vat_amount'));

$totalPurchasesAmount = array_sum(array_column($purchases, 'amount'));
$totalPurchasesVAT = array_sum(array_column($purchases, 'vat_amount'));

$netVAT = $totalSalesVAT - $totalPurchasesVAT;
?>


