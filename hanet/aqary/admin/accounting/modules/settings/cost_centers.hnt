                        <button class="btn btn-sm btn-outline-<?php echo (int)$costCenter['is_active'] === 1 ? 'warning' : 'success'; ?>" onclick="toggleCostCenterStatus(<?php echo (int)$costCenter['cost_center_id']; ?>)">
