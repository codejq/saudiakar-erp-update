<?php
$sc_title = "إدارة مراكز التكلفة";
$sc_id = "2082";
$use_accounting_theme = true;

if (isset($_POST['ajax_action'])) {
    include_once "../../../../reqloginajax.hnt";
} else {
    include_once "../../../../header.hnt";
}
include_once "../../includes/accounting_class.hnt";

$accountingManager = new AccountingManager($db, $_SESSION['userid'] ?? 1);

if ($_SERVER['REQUEST_METHOD'] == 'POST' && isset($_POST['ajax_action'])) {
    header('Content-Type: application/json; charset=utf-8');

    $action = $_POST['ajax_action'];
    $response = ['success' => false, 'message' => ''];

    switch ($action) {
        case 'save_cost_center':
            $costCenterId = !empty($_POST['cost_center_id']) ? (int)$_POST['cost_center_id'] : null;
            $result = $accountingManager->saveCostCenter([
                'cost_center_code' => $_POST['cost_center_code'] ?? '',
                'cost_center_name_ar' => $_POST['cost_center_name_ar'] ?? '',
                'cost_center_name_en' => $_POST['cost_center_name_en'] ?? '',
                'parent_cost_center_id' => $_POST['parent_cost_center_id'] ?? null,
                'aqar_id' => $_POST['aqar_id'] ?? null,
                'subaqar_id' => $_POST['subaqar_id'] ?? null,
                'is_active' => isset($_POST['is_active']) ? 1 : 0
            ], $costCenterId);
            $response = $result;
            if (!isset($response['message'])) {
                $response['message'] = !empty($result['success']) ? 'تم حفظ مركز التكلفة بنجاح' : 'فشل في حفظ مركز التكلفة';
            }
            break;

        case 'toggle_cost_center_status':
            $costCenterId = !empty($_POST['cost_center_id']) ? (int)$_POST['cost_center_id'] : 0;
            $result = $accountingManager->toggleCostCenterStatus($costCenterId);
            $response = $result;
            if (!isset($response['message'])) {
                $response['message'] = !empty($result['success']) ? 'تم تحديث حالة مركز التكلفة' : 'فشل في تحديث حالة مركز التكلفة';
            }
            break;
    }

    echo json_encode($response, JSON_UNESCAPED_UNICODE);
    exit;
}

$search = trim($_GET['search'] ?? '');
$statusFilter = $_GET['status'] ?? '';
$costCenters = $accountingManager->getCostCenters();
$parentOptions = $accountingManager->getCostCenters(true);

if ($search !== '') {
    $costCenters = array_values(array_filter($costCenters, function ($costCenter) use ($search) {
        $needle = mb_strtolower($search);
        return mb_stripos(mb_strtolower((string)$costCenter['cost_center_code']), $needle) !== false
            || mb_stripos(mb_strtolower((string)$costCenter['cost_center_name_ar']), $needle) !== false
            || mb_stripos(mb_strtolower((string)$costCenter['cost_center_name_en']), $needle) !== false
            || mb_stripos((string)($costCenter['aqar_id'] ?? ''), $search) !== false;
    }));
}

if ($statusFilter !== '') {
    $isActive = $statusFilter === 'active' ? 1 : 0;
    $costCenters = array_values(array_filter($costCenters, function ($costCenter) use ($isActive) {
        return (int)$costCenter['is_active'] === $isActive;
    }));
}
?>

