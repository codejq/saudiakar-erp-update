                <h5 class="modal-title text-white" id="resultModalTitle"></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p id="resultModalMessage"></p>
            </div>
        </div>
    </div>
</div>

<script>
function openCostCenterModal(costCenter = null) {
    document.getElementById('costCenterForm').reset();
    document.getElementById('cost_center_id').value = costCenter ? costCenter.cost_center_id : '';
    document.getElementById('cost_center_code').value = costCenter ? costCenter.cost_center_code : '';
    document.getElementById('cost_center_name_ar').value = costCenter ? costCenter.cost_center_name_ar : '';
    document.getElementById('cost_center_name_en').value = costCenter ? (costCenter.cost_center_name_en || '') : '';
    document.getElementById('parent_cost_center_id').value = costCenter && costCenter.parent_cost_center_id ? costCenter.parent_cost_center_id : '';
    document.getElementById('aqar_id').value = costCenter && costCenter.aqar_id ? costCenter.aqar_id : '';
    document.getElementById('subaqar_id').value = costCenter && costCenter.subaqar_id ? costCenter.subaqar_id : '';
    document.getElementById('cost_center_is_active').checked = costCenter ? Number(costCenter.is_active) === 1 : true;
    document.getElementById('costCenterModalTitle').textContent = costCenter ? 'تعديل مركز التكلفة' : 'مركز تكلفة جديد';
    new bootstrap.Modal(document.getElementById('costCenterModal')).show();
}

function saveCostCenter() {
    const formData = new FormData(document.getElementById('costCenterForm'));
    formData.append('ajax_action', 'save_cost_center');

    fetch('cost_centers.hnt', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        const modal = bootstrap.Modal.getInstance(document.getElementById('costCenterModal'));
        if (modal) modal.hide();
        showResultModal(data.success, data.message || 'تمت العملية');
        if (data.success) {
            setTimeout(() => window.location.reload(), 1200);
        }
    })
    .catch(() => showResultModal(false, 'حدث خطأ أثناء حفظ مركز التكلفة'));
}

function toggleCostCenterStatus(costCenterId) {
    const formData = new FormData();
    formData.append('ajax_action', 'toggle_cost_center_status');
    formData.append('cost_center_id', costCenterId);

    fetch('cost_centers.hnt', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        showResultModal(data.success, data.message || 'تمت العملية');
        if (data.success) {
            setTimeout(() => window.location.reload(), 1200);
        }
    })
    .catch(() => showResultModal(false, 'حدث خطأ أثناء تحديث الحالة'));
}

function showResultModal(success, message) {
    const header = document.getElementById('resultModalHeader');
    const title = document.getElementById('resultModalTitle');
    const body = document.getElementById('resultModalMessage');
    header.style.background = success ? 'linear-gradient(135deg, #28a745, #20c997)' : 'linear-gradient(135deg, #dc3545, #c82333)';
    title.innerHTML = success ? '<i class="bi bi-check-circle me-2"></i>نجحت العملية' : '<i class="bi bi-x-circle me-2"></i>فشلت العملية';
    body.textContent = message;
    new bootstrap.Modal(document.getElementById('resultModal')).show();
}
</script>

