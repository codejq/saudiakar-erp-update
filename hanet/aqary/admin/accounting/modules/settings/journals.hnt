<?php
$sc_title = "إدارة دفاتر اليومية";
$sc_id = "2081";
$use_accounting_theme = true;

if (isset($_POST['ajax_action'])) {
    include_once "../../../../reqloginajax.hnt";
} else {
    include_once "../../../../header.hnt";
}
include_once "../../includes/accounting_class.hnt";

$accountingManager = new AccountingManager($db, $_SESSION['userid'] ?? 1);

if ($_SERVER['REQUEST_METHOD'] == 'POST' && isset($_POST['ajax_action'])) {
    header('Content-Type: application/json; charset=utf-8');

    $action = $_POST['ajax_action'];
    $response = ['success' => false, 'message' => ''];

    switch ($action) {
        case 'save_journal':
            $journalId = !empty($_POST['journal_id']) ? (int)$_POST['journal_id'] : null;
            $result = $accountingManager->saveJournal([
                'journal_code' => $_POST['journal_code'] ?? '',
                'journal_name_ar' => $_POST['journal_name_ar'] ?? '',
                'journal_name_en' => $_POST['journal_name_en'] ?? '',
                'journal_type' => $_POST['journal_type'] ?? 'general',
                'is_active' => isset($_POST['is_active']) ? 1 : 0
            ], $journalId);
            $response = $result;
            if (!isset($response['message'])) {
                $response['message'] = !empty($result['success']) ? 'تم حفظ دفتر اليومية بنجاح' : 'فشل في حفظ دفتر اليومية';
            }
            break;

        case 'toggle_journal_status':
            $journalId = !empty($_POST['journal_id']) ? (int)$_POST['journal_id'] : 0;
            $result = $accountingManager->toggleJournalStatus($journalId);
            $response = $result;
            if (!isset($response['message'])) {
                $response['message'] = !empty($result['success']) ? 'تم تحديث حالة دفتر اليومية' : 'فشل في تحديث حالة دفتر اليومية';
            }
            break;
    }

    echo json_encode($response, JSON_UNESCAPED_UNICODE);
    exit;
}

$search = trim($_GET['search'] ?? '');
$statusFilter = $_GET['status'] ?? '';
$journals = $accountingManager->getJournals();

if ($search !== '') {
    $journals = array_values(array_filter($journals, function ($journal) use ($search) {
        $needle = mb_strtolower($search);
        return mb_stripos(mb_strtolower((string)$journal['journal_code']), $needle) !== false
            || mb_stripos(mb_strtolower((string)$journal['journal_name_ar']), $needle) !== false
            || mb_stripos(mb_strtolower((string)$journal['journal_name_en']), $needle) !== false;
    }));
}

if ($statusFilter !== '') {
    $isActive = $statusFilter === 'active' ? 1 : 0;
    $journals = array_values(array_filter($journals, function ($journal) use ($isActive) {
        return (int)$journal['is_active'] === $isActive;
    }));
}
?>

