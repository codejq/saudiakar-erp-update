<div class="modal fade" id="resultModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header" id="resultModalHeader">
                <h5 class="modal-title text-white" id="resultModalTitle"></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p id="resultModalMessage"></p>
            </div>
        </div>
    </div>
</div>

<script>
function openJournalModal(journal = null) {
    document.getElementById('journalForm').reset();
    document.getElementById('journal_id').value = journal ? journal.journal_id : '';
    document.getElementById('journal_code').value = journal ? journal.journal_code : '';
    document.getElementById('journal_name_ar').value = journal ? journal.journal_name_ar : '';
    document.getElementById('journal_name_en').value = journal ? (journal.journal_name_en || '') : '';
    document.getElementById('journal_type').value = journal ? journal.journal_type : 'general';
    document.getElementById('journal_is_active').checked = journal ? Number(journal.is_active) === 1 : true;
    document.getElementById('journalModalTitle').textContent = journal ? 'تعديل دفتر اليومية' : 'دفتر يومية جديد';
    new bootstrap.Modal(document.getElementById('journalModal')).show();
}

function saveJournal() {
    const formData = new FormData(document.getElementById('journalForm'));
    formData.append('ajax_action', 'save_journal');

    fetch('journals.hnt', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        const modal = bootstrap.Modal.getInstance(document.getElementById('journalModal'));
        if (modal) modal.hide();
        showResultModal(data.success, data.message || 'تمت العملية');
        if (data.success) {
            setTimeout(() => window.location.reload(), 1200);
        }
    })
    .catch(() => showResultModal(false, 'حدث خطأ أثناء حفظ دفتر اليومية'));
}

function toggleJournalStatus(journalId) {
    const formData = new FormData();
    formData.append('ajax_action', 'toggle_journal_status');
    formData.append('journal_id', journalId);

    fetch('journals.hnt', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        showResultModal(data.success, data.message || 'تمت العملية');
        if (data.success) {
            setTimeout(() => window.location.reload(), 1200);
        }
    })
    .catch(() => showResultModal(false, 'حدث خطأ أثناء تحديث الحالة'));
}

function showResultModal(success, message) {
    const header = document.getElementById('resultModalHeader');
    const title = document.getElementById('resultModalTitle');
    const body = document.getElementById('resultModalMessage');
    header.style.background = success ? 'linear-gradient(135deg, #28a745, #20c997)' : 'linear-gradient(135deg, #dc3545, #c82333)';
    title.innerHTML = success ? '<i class="bi bi-check-circle me-2"></i>نجحت العملية' : '<i class="bi bi-x-circle me-2"></i>فشلت العملية';
    body.textContent = message;
    new bootstrap.Modal(document.getElementById('resultModal')).show();
}
</script>

