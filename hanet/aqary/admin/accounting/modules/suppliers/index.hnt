$sc_title = "إدارة الموردين";
$sc_id = "206";
$use_accounting_theme = true;

// Export / template handler — runs before any HTML output
if (isset($_GET['export']) && in_array($_GET['export'], ['csv', 'xls', 'template'], true)) {
    include_once "../../../../reqloginajax.hnt";

    $_fn       = date('Ymd_His');
    $_exp_type = $_GET['export'];

    if ($_exp_type === 'template') {
        header('Content-Type: text/csv; charset=UTF-8');
        header('Content-Disposition: attachment; filename="suppliers_template_' . $_fn . '.csv"');
        $_out = fopen('php://output', 'w');
        fwrite($_out, "\xEF\xBB\xBF");
        fputcsv($_out, ['اسم المورد', 'الرقم الضريبي', 'رقم الهاتف', 'البريد الإلكتروني', 'جهة الاتصال', 'العنوان'], ',', '"', '\\');
        fputcsv($_out, ['شركة التوريدات العامة', '300000000000003', '0112345678', 'supplier@example.com', 'أحمد محمد', 'الرياض - المنطقة الصناعية'], ',', '"', '\\');
        fclose($_out);
        exit;
    }

    $exp_headers = ['اسم المورد', 'الرقم الضريبي', 'رقم الهاتف', 'البريد الإلكتروني', 'جهة الاتصال', 'العنوان'];
    $exp_rows    = [];
    $_er = $db->query("SELECT supplier_name, vat_number, phone, email, contact_person, address FROM acc_suppliers WHERE is_active = 1 ORDER BY supplier_name");
    if ($_er) {
        while ($_s = $_er->fetch_assoc()) {
            $exp_rows[] = [
                $_s['supplier_name'],
                $_s['vat_number']     ?? '',
                $_s['phone']          ?? '',
                $_s['email']          ?? '',
                $_s['contact_person'] ?? '',
                $_s['address']        ?? ''
            ];
        }
    }

    if ($_exp_type === 'csv') {
        header('Content-Type: text/csv; charset=UTF-8');
        header('Content-Disposition: attachment; filename="suppliers_' . $_fn . '.csv"');
        $_out = fopen('php://output', 'w');
        fwrite($_out, "\xEF\xBB\xBF");
        fputcsv($_out, $exp_headers, ',', '"', '\\');
        foreach ($exp_rows as $_r) fputcsv($_out, $_r, ',', '"', '\\');
        fclose($_out);
        exit;
    }

    header('Content-Type: application/vnd.ms-excel; charset=UTF-8');
    header('Content-Disposition: attachment; filename="suppliers_' . $_fn . '.xls"');
    echo '<html lang="ar" dir="rtl"><head><meta charset="UTF-8"></head><body><table border="1"><tr>';
    foreach ($exp_headers as $_h) echo '<th>' . htmlspecialchars($_h) . '</th>';
    echo '</tr>';
    foreach ($exp_rows as $_r) {
        echo '<tr>';
        foreach ($_r as $_c) echo '<td>' . htmlspecialchars($_c) . '</td>';
        echo '</tr>';
    }
    echo '</table></body></html>';
    exit;
}

if(isset($_POST['ajax_action'])){
    include_once "../../../../reqloginajax.hnt";
}
else {
    include_once "../../../../header.hnt";
}
    include_once "../../includes/accounting_class.hnt";

$accountingManager = new AccountingManager($db, $_SESSION['userid'] ?? 1);

// Handle AJAX actions
if ($_SERVER['REQUEST_METHOD'] == 'POST' && isset($_POST['ajax_action'])) {
    header('Content-Type: application/json; charset=utf-8');

    $action = $_POST['ajax_action'];
    $response = ['success' => false, 'message' => ''];

    switch ($action) {
        case 'add_supplier':
            $stmt = $db->prepare("
                INSERT INTO acc_suppliers 
                (supplier_name, vat_number, phone, email, address, contact_person, is_active, formuid)
                VALUES (?, ?, ?, ?, ?, ?, 1, UUID())
            ");

            $stmt->bind_param("ssssss",
                $_POST['supplier_name'],
                $_POST['vat_number'],
                $_POST['phone'],
                $_POST['email'],
                $_POST['address'],
                $_POST['contact_person']
            );

            if ($stmt->execute()) {
                $response['success'] = true;
                $response['message'] = 'تم إضافة المورد بنجاح';
                $response['supplier_id'] = $stmt->insert_id;
            } else {
                $response['message'] = 'فشل في إضافة المورد: ' . $stmt->error;
            }
            break;

        case 'import_suppliers':
            if (empty($_FILES['import_file']['tmp_name'])) {
                $response = ['success' => false, 'message' => 'لم يتم رفع أي ملف'];
                break;
            }
            $handle = fopen($_FILES['import_file']['tmp_name'], 'r');
            if (!$handle) {
                $response = ['success' => false, 'message' => 'تعذر قراءة الملف'];
                break;
            }
            $bom = fread($handle, 3);
            if ($bom !== "\xEF\xBB\xBF") rewind($handle);
            fgetcsv($handle, 0, ',', '"', '\\'); // skip header row

            $imported = 0;
            $errors   = [];
            $lineNum  = 1;

            while (($row = fgetcsv($handle, 0, ',', '"', '\\')) !== false) {
                $lineNum++;
                if (count($row) < 1 || empty(trim($row[0]))) continue;

                $_name    = trim($row[0]);
                $_vat     = trim($row[1] ?? '');
                $_phone   = trim($row[2] ?? '');
                $_email   = trim($row[3] ?? '');
                $_contact = trim($row[4] ?? '');
                $_address = trim($row[5] ?? '');

                // Skip duplicates
                $_chk = $db->prepare("SELECT supplier_id FROM acc_suppliers WHERE supplier_name = ? LIMIT 1");
                if ($_chk) {
                    $_chk->bind_param('s', $_name);
                    $_chk->execute();
                    if ($_chk->get_result()->num_rows > 0) {
                        $errors[] = "سطر $lineNum: المورد '$_name' موجود مسبقاً — تم تخطيه";
                        continue;
                    }
                }

                $_ins = $db->prepare("INSERT INTO acc_suppliers (supplier_name, vat_number, phone, email, contact_person, address, is_active, formuid) VALUES (?, ?, ?, ?, ?, ?, 1, UUID())");
                if (!$_ins) { $errors[] = "سطر $lineNum: خطأ داخلي"; continue; }
                $_vat_val = $_vat ?: null;
                $_phn_val = $_phone ?: null;
                $_eml_val = $_email ?: null;
                $_cnt_val = $_contact ?: null;
                $_adr_val = $_address ?: null;
                $_ins->bind_param('ssssss', $_name, $_vat_val, $_phn_val, $_eml_val, $_cnt_val, $_adr_val);
                if ($_ins->execute()) {
                    $imported++;
                } else {
                    $errors[] = "سطر $lineNum: فشل إضافة '$_name'";
                }
            }
            fclose($handle);

            $msg = "تم استيراد $imported مورد بنجاح";
            if (!empty($errors)) $msg .= "\n\nتنبيهات:\n" . implode("\n", $errors);
            $response = ['success' => true, 'message' => $msg, 'imported' => $imported, 'errors' => $errors];
            break;
    }

    echo json_encode($response, JSON_UNESCAPED_UNICODE);
    exit;
}

// Get suppliers
$suppliersQuery = "SELECT * FROM acc_suppliers ORDER BY supplier_name ASC";
$suppliersResult = $db->query($suppliersQuery);
$suppliers = [];
if ($suppliersResult) {
    while ($row = $suppliersResult->fetch_assoc()) {
        $suppliers[] = $row;
    }
}
