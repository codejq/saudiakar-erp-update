<script>
function submitSupplier() {
    const form = document.getElementById('addSupplierForm');
    const formData = new FormData(form);
    formData.append('ajax_action', 'add_supplier');

    fetch('index.hnt', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        const modal = bootstrap.Modal.getInstance(document.getElementById('addSupplierModal'));
        modal.hide();

        showResultModal(data.success, data.message);

        if (data.success) {
            setTimeout(() => location.reload(), 1500);
        }
    })
    .catch(error => {
        showResultModal(false, 'حدث خطأ في الاتصال');
    });
}

function viewSupplier(supplierId) {
    window.location = 'view.hnt?id=' + supplierId;
}

function editSupplier(supplierId) {
    window.location = 'edit.hnt?id=' + supplierId;
}

function submitSuppliersImport() {
    const fileInput = document.getElementById('import_suppliers_file');
    if (!fileInput.files.length) {
        alert('يرجى اختيار ملف CSV أولاً');
        return;
    }

    const btn = document.getElementById('importSuppliersSubmitBtn');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>جاري الاستيراد...';

    const formData = new FormData();
    formData.append('ajax_action', 'import_suppliers');
    formData.append('import_file', fileInput.files[0]);

    fetch('index.hnt', { method: 'POST', body: formData })
        .then(r => r.json())
        .then(data => {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-upload me-2"></i>استيراد';

            const resultDiv = document.getElementById('importSuppliersResult');
            resultDiv.style.display = 'block';
            const cls  = data.imported > 0 ? 'alert-success' : 'alert-warning';
            const icon = data.imported > 0 ? 'check-circle' : 'exclamation-triangle';
            resultDiv.innerHTML = `<div class="alert ${cls}">
                <i class="bi bi-${icon} me-2"></i>
                ${data.message.replace(/\n/g, '<br>')}
            </div>`;

            if (data.imported > 0) setTimeout(() => location.reload(), 2000);
        })
        .catch(() => {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-upload me-2"></i>استيراد';
            showResultModal(false, 'حدث خطأ أثناء الاستيراد');
        });
}

document.addEventListener('DOMContentLoaded', function() {
    const importSuppliersModal = document.getElementById('importSuppliersModal');
    if (importSuppliersModal) {
        importSuppliersModal.addEventListener('show.bs.modal', function() {
            document.getElementById('import_suppliers_file').value = '';
            const r   = document.getElementById('importSuppliersResult');
            r.style.display = 'none';
            r.innerHTML = '';
            const btn = document.getElementById('importSuppliersSubmitBtn');
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-upload me-2"></i>استيراد';
        });
    }
});

function showResultModal(success, message) {
    const modal = new bootstrap.Modal(document.getElementById('resultModal'));
    const header = document.getElementById('resultModalHeader');
    const title = document.getElementById('resultModalTitle');
    const messageEl = document.getElementById('resultModalMessage');

    if (success) {
        header.style.background = 'linear-gradient(135deg, #28a745, #20c997)';
        title.innerHTML = '<i class="bi bi-check-circle me-2"></i>نجحت العملية';
    } else {
        header.style.background = 'linear-gradient(135deg, #dc3545, #c82333)';
        title.innerHTML = '<i class="bi bi-x-circle me-2"></i>فشلت العملية';
    }

    messageEl.textContent = message;
    modal.show();
}
</script>

