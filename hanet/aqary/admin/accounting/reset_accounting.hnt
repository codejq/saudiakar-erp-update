<?php
/**
 * Accounting Reset - resets selected accounting tables
 * Same pattern as restoreallamlaktabel.hnt
 */

$sc_title = "إعادة تعيين المحاسبة";
$sc_id = "200";

$is_ajax_request = isset($_POST['ajax_submit']) && $_POST['ajax_submit'] == '1';

if ($is_ajax_request) {
    include_once "../../reqloginajax.hnt";
} else {
    include_once "../../nocash.hnt";
    $_SERVER['HTTP_REFERER'] = "index.hnt";
    include_once "../../header.hnt";
}

include_once "../../connectdb.hnt";

// All resettable accounting tables
$allTables = [
    'acc_customers'           => 'العملاء',
    'acc_fiscal_years'        => 'السنوات المالية',
    'acc_invoices'            => 'الفواتير',
    'acc_invoice_items'       => 'بنود الفواتير',
    'acc_journal_entries'     => 'القيود اليومية',
    'acc_journal_entry_lines' => 'بنود القيود اليومية',
    'acc_suppliers'           => 'الموردين',
];

// ── Backup only ───────────────────────────────────────────────
if (isset($_POST['backup_only']) && $_POST['backup_only'] == '1') {
    $batchFile = '../../mysqldump.bat';
    $backupSuccess = false;
    $backupMessage = '';

    if (file_exists($batchFile)) {
        $command = 'cmd /c "' . realpath($batchFile) . '" 2>&1';
        $output = []; $returnCode = 0;
        exec($command, $output, $returnCode);
        if ($returnCode === 0) {
            $backupSuccess = true;
            $backupMessage = 'تم إنشاء نسخة احتياطية بنجاح في ' . date('Y-m-d H:i:s');
        } else {
            $backupMessage = 'فشل النسخ الاحتياطي: ' . implode(' ', $output);
        }
    } else {
        $backupMessage = 'خطأ: لم يتم العثور على mysqldump.bat';
    }

    if ($is_ajax_request) {
        header('Content-Type: application/json; charset=utf-8');
        echo json_encode(['success' => $backupSuccess, 'message' => $backupMessage], JSON_UNESCAPED_UNICODE);
        exit;
    }
}

// ── Reset selected tables ─────────────────────────────────────
if (isset($_POST['codeacc']) && isset($_POST['selected_tables'])) {
    $codeacc = trim($_POST['codeacc']);
    $selectedTables = is_array($_POST['selected_tables']) ? $_POST['selected_tables'] : [];

    // Whitelist — only allow known tables
    $selectedTables = array_filter($selectedTables, fn($t) => array_key_exists($t, $allTables));

    if ($codeacc !== '99381144accounting') {
        if ($is_ajax_request) {
            header('Content-Type: application/json; charset=utf-8');
            echo json_encode(['success' => false, 'message' => 'رمز التأكيد غير صحيح'], JSON_UNESCAPED_UNICODE);
            exit;
        }
        $error_message = 'رمز التأكيد غير صحيح';
    } elseif (empty($selectedTables)) {
        if ($is_ajax_request) {
            header('Content-Type: application/json; charset=utf-8');
            echo json_encode(['success' => false, 'message' => 'لم تحدد أي جدول'], JSON_UNESCAPED_UNICODE);
            exit;
        }
        $error_message = 'لم تحدد أي جدول';
    } else {
        // Backup first
        $batchFile = '../../mysqldump.bat';
        $backupSuccess = false;
        $backupMessage = '';

        if (file_exists($batchFile)) {
            $command = 'cmd /c "' . realpath($batchFile) . '" 2>&1';
            $output = []; $returnCode = 0;
            exec($command, $output, $returnCode);
            if ($returnCode === 0) {
                $backupSuccess = true;
                $backupMessage = 'تم إنشاء نسخة احتياطية بنجاح';
            } else {
                $backupMessage = 'فشل النسخ الاحتياطي: ' . implode(' ', $output);
                if ($is_ajax_request) {
                    header('Content-Type: application/json; charset=utf-8');
                    echo json_encode(['success' => false, 'message' => $backupMessage], JSON_UNESCAPED_UNICODE);
                    exit;
                }
            }
        } else {
            $backupMessage = 'تحذير: لم يتم العثور على ملف النسخ الاحتياطي';
            $backupSuccess = true; // proceed anyway
        }

        if ($backupSuccess) {
            $failedTables = [];
            $db->query("SET FOREIGN_KEY_CHECKS = 0");
            foreach ($selectedTables as $table) {
                if (!$db->query("TRUNCATE TABLE `$table`")) {
                    $failedTables[] = $allTables[$table] . ' (' . $db->error . ')';
                }
            }
            $db->query("SET FOREIGN_KEY_CHECKS = 1");

            if (empty($failedTables)) {
                $successMessage = 'تم إعادة تعيين ' . count($selectedTables) . ' جدول بنجاح';
                if ($is_ajax_request) {
                    header('Content-Type: application/json; charset=utf-8');
                    echo json_encode(['success' => true, 'message' => $successMessage, 'backupMessage' => $backupMessage], JSON_UNESCAPED_UNICODE);
                    exit;
                }
            } else {
                $errorMessage = 'فشل مسح: ' . implode('، ', $failedTables);
                if ($is_ajax_request) {
                    header('Content-Type: application/json; charset=utf-8');
                    echo json_encode(['success' => false, 'message' => $errorMessage], JSON_UNESCAPED_UNICODE);
                    exit;
                }
            }
        }
    }
}

if ($is_ajax_request) exit;
?>

