                <strong>تحذير:</strong> ستُحذف جميع البيانات في الجداول المحددة بشكل نهائي.
                سيتم إنشاء نسخة احتياطية تلقائياً قبل البدء.
                <br><span class="text-danger fw-bold">هذه العملية لا يمكن التراجع عنها!</span>
              </div>
            </div>
          </div>

          <form id="resetAccForm" method="post" action="?">

            <!-- Table selection -->
            <div class="card bg-light border-0 mb-4">
              <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                  <h6 class="mb-0 fw-bold"><i class="bi bi-table me-2"></i>اختر الجداول المراد إعادة تعيينها</h6>
                  <div class="d-flex gap-2">
                    <button type="button" class="btn btn-sm btn-outline-danger" id="selectAll">تحديد الكل</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary" id="deselectAll">إلغاء الكل</button>
                  </div>
                </div>
                <div class="row g-2">
                  <?php foreach ($allTables as $tableName => $tableLabel): ?>
                  <div class="col-md-6">
                    <label for="tbl_<?= $tableName ?>" class="table-check-item d-flex justify-content-between align-items-center gap-3 border rounded-3 px-3 py-2 cursor-pointer" style="background:#fff7ed; border-color:#fed7aa !important; cursor:pointer;">
                      <div class="d-flex align-items-center gap-2">
                        <input class="form-check-input table-checkbox flex-shrink-0" type="checkbox"
                               name="selected_tables[]"
                               value="<?= $tableName ?>"
                               id="tbl_<?= $tableName ?>"
                               style="width:1.2em;height:1.2em;accent-color:#dc3545;">
                        <span class="fw-semibold"><?= $tableLabel ?></span>
                      </div>
                      <small class="text-muted font-monospace"><?= $tableName ?></small>
                    </label>
                  </div>
                  <?php endforeach; ?>
                </div>
              </div>
            </div>

            <!-- Security code -->
            <div class="card bg-light border-0 mb-4">
              <div class="card-body text-center py-4">
                <p class="mb-3"><i class="bi bi-key-fill me-2"></i>انقل رمز التأكيد إلى المربع واضغط على زر إعادة التعيين</p>
                <div class="mb-3">
                  <input type="text" class="form-control form-control-lg text-center"
                         id="codeacc" name="codeacc"
                         placeholder="أدخل الرمز هنا" required autocomplete="off">
                </div>
                <div class="alert alert-dark d-inline-block mb-0">
                  <strong>رمز التأكيد:</strong>
                  <h3 class="mb-0 mt-2 font-monospace">99381144accounting</h3>
                </div>
              </div>
            </div>

            <!-- Buttons -->
            <div class="d-flex justify-content-center gap-3 flex-wrap">
              <button type="button" class="btn btn-info btn-lg text-white" id="backupOnlyBtn">
                <i class="bi bi-database-fill-down me-2"></i>نسخة احتياطية فقط
              </button>
              <button type="submit" class="btn btn-danger btn-lg" id="resetBtn">
                <i class="bi bi-arrow-counterclockwise me-2"></i>إعادة التعيين
              </button>
              <a href="index.hnt" class="btn btn-secondary btn-lg">
                <i class="bi bi-x-circle me-2"></i>إلغاء
              </a>
            </div>

          </form>
          <?php endif; ?>

        </div>
