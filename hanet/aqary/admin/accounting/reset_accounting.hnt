</div>

<!-- Confirm Modal -->
<div class="modal fade" id="confirmAccModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header bg-danger text-white border-0">
        <h5 class="modal-title"><i class="bi bi-exclamation-triangle-fill me-2"></i>تأكيد إعادة التعيين</h5>
      </div>
      <div class="modal-body text-center py-4">
        <i class="bi bi-exclamation-octagon text-danger" style="font-size:4rem;"></i>
        <h5 class="mt-3">سيتم حذف البيانات المحددة نهائياً</h5>
        <div id="selectedTablesList" class="mt-3 text-start"></div>
      </div>
      <div class="modal-footer border-0 justify-content-center">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
          <i class="bi bi-x-circle me-2"></i>إلغاء
        </button>
        <button type="button" class="btn btn-danger" id="confirmResetAccBtn">
          <i class="bi bi-trash-fill me-2"></i>نعم، إعادة التعيين
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Loading Overlay -->
<div id="loadingOverlay" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.75);z-index:9999;">
  <div class="d-flex justify-content-center align-items-center h-100">
    <div class="text-center text-white">
      <div class="spinner-border mb-3" style="width:4rem;height:4rem;" role="status"></div>
      <h4 id="loadingMsg">جاري التنفيذ...</h4>
      <p class="text-white-50">الرجاء الانتظار، لا تغلق الصفحة</p>
    </div>
  </div>
</div>

<script>
$(function () {
  const confirmModal = new bootstrap.Modal(document.getElementById('confirmAccModal'));

  // Highlight checked rows
  function updateHighlight() {
    $('.table-checkbox').each(function () {
      var $label = $(this).closest('.table-check-item');
      if ($(this).is(':checked')) {
        $label.css({ background: '#fee2e2', borderColor: '#dc3545' });
      } else {
        $label.css({ background: '#fff7ed', borderColor: '#fed7aa' });
      }
    });
  }
  $(document).on('change', '.table-checkbox', updateHighlight);

  // Select / Deselect all
  $('#selectAll').on('click', function () { $('.table-checkbox').prop('checked', true); updateHighlight(); });
  $('#deselectAll').on('click', function () { $('.table-checkbox').prop('checked', false); updateHighlight(); });

  // Backup only
  $('#backupOnlyBtn').on('click', function () {
    $('#loadingOverlay').fadeIn();
    $('#loadingMsg').text('جاري إنشاء النسخة الاحتياطية...');
    $.post('reset_accounting.hnt', { backup_only: '1', ajax_submit: '1' }, function (r) {
      $('#loadingOverlay').fadeOut();
      showBootstrapNotification(r.message, r.success ? 'success' : 'error', 5000);
    }, 'json').fail(function () {
      $('#loadingOverlay').fadeOut();
      showBootstrapNotification('خطأ في الاتصال', 'error');
    });
  });

  // Form submit — show confirm modal
  $('#resetAccForm').on('submit', function (e) {
    e.preventDefault();

    if ($('.table-checkbox:checked').length === 0) {
      showBootstrapNotification('يرجى تحديد جدول واحد على الأقل', 'error');
      return;
    }

    if ($('#codeacc').val().trim() !== '99381144accounting') {
      showBootstrapNotification('رمز التأكيد غير صحيح', 'error');
      return;
    }

    // List selected tables in modal
    let list = '<ul class="list-group">';
    $('.table-checkbox:checked').each(function () {
      list += '<li class="list-group-item list-group-item-danger py-2">' +
              '<i class="bi bi-table me-2"></i>' + $(this).next('label').find('span:first').text() +
              '</li>';
    });
    list += '</ul>';
    $('#selectedTablesList').html(list);
    confirmModal.show();
  });

  // Confirmed — submit via AJAX
  $('#confirmResetAccBtn').on('click', function () {
    confirmModal.hide();
    $('#loadingOverlay').fadeIn();
    $('#loadingMsg').text('جاري إنشاء النسخة الاحتياطية...');

    setTimeout(function () { $('#loadingMsg').text('جاري مسح البيانات...'); }, 4000);

    $.ajax({
      url: 'reset_accounting.hnt',
      type: 'POST',
      data: $('#resetAccForm').serialize() + '&ajax_submit=1',
      dataType: 'json',
      timeout: 120000,
      success: function (r) {
        $('#loadingOverlay').fadeOut();
        if (r.success) {
          showBootstrapNotification(r.message + (r.backupMessage ? ' — ' + r.backupMessage : ''), 'success', 6000);
          setTimeout(function () { window.location.href = 'index.hnt'; }, 3000);
        } else {
          showBootstrapNotification(r.message, 'error', 8000);
        }
      },
      error: function (xhr, status) {
        $('#loadingOverlay').fadeOut();
        showBootstrapNotification(status === 'timeout' ? 'انتهت مهلة الانتظار' : 'خطأ في الاتصال', 'error');
      }
    });
  });
});
</script>

<?php require("../../foter.hnt"); ?>
