// AJAX handler to fetch bank accounts for property
if ($is_ajax_request && isset($_POST['action']) && $_POST['action'] == 'get_bank_accounts') {
    header('Content-Type: application/json; charset=utf-8');
    $idsubaqar = isset($_POST['idsubaqar']) ? intval($_POST['idsubaqar']) : 0;
    
    if ($idsubaqar > 0) {
        // Get idaqar from idsubaqar
        $sql = "SELECT idaqar FROM amlakdetails WHERE idsubaqar='$idsubaqar'";
        $result = mysql_query($sql, $link);
        $row = mysql_fetch_array($result);
        $idaqar = $row ? intval($row['idaqar']) : 0;
        
        // Fetch bank accounts: company accounts (ownerid2=0) OR property accounts (ownerid2=idaqar)
        $sql = "SELECT id, bankname, acountholder, acountnumber, iban 
                FROM bankacounts 
                WHERE ownerid2 = 0 OR ownerid2 = '$idaqar'
                ORDER BY ownerid2 DESC, id DESC";
        $result = mysql_query($sql, $link);
        
        $accounts = [];
        while ($row = mysql_fetch_assoc($result)) {
            $accounts[] = $row;
        }
        
        echo json_encode(['success' => true, 'accounts' => $accounts], JSON_UNESCAPED_UNICODE | JSON_INVALID_UTF8_SUBSTITUTE);
    } else {
        echo json_encode(['success' => false, 'message' => 'معرف الوحدة غير صحيح'], JSON_UNESCAPED_UNICODE);
    }
    exit;
}

// Check for duplicate form submission
if (isset($_REQUEST['formuid']) && $_REQUEST['formuid']) {
    $formuid = mysql_real_escape_string($_REQUEST['formuid'], $link);
    $sql = "SELECT COUNT(idsanad) AS dd FROM sanad WHERE formuid = '$formuid'";
    $row = mysql_fetch_array(mysql_query($sql, $link));
    if ($row['dd']) {
        if ($is_ajax_request) {
            header('Content-Type: application/json; charset=utf-8');
            echo json_encode(['success' => false, 'message' => 'حدث خطأ: محاولة تكرار الدفع'], JSON_UNESCAPED_UNICODE);
            exit;
        } else {
            echo "<div class='alert alert-danger text-center'>حدث خطأ: محاولة تكرار الدفع</div>";
            exit();
        }
    }
}

