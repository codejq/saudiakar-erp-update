// Database schema updates
if (!$is_ajax_request) {
    if (!file_exists('update_2022')) {
        file_put_contents('update_2022', time());
    }
    @mysql_query("ALTER TABLE sanad ADD attachedimages varchar(500) NOT NULL", $link);
    @mysql_query("ALTER TABLE mostagereen ADD mostagervatnumber varchar(100) NOT NULL", $link);
    @mysql_query("ALTER TABLE sanad ADD mostagervatnumber varchar(100) NOT NULL", $link);
    @mysql_query("ALTER TABLE eradat ADD kastid int(11) NOT NULL", $link);
    @mysql_query("ALTER TABLE sanad ADD bankid int(11) NOT NULL DEFAULT 0", $link);
