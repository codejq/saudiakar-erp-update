					<?php if ($report != 1): ?>
						<form name="form" method="get" action="?" id="collectorsForm">
							<input type="hidden" name="formuid" id="formuid"
								value="<?= str_replace('.', '', microtime(true) . rand(11111, 99999) . rand(11111, 99999) . rand(111, 999) . rand(111, 999)); ?>">
