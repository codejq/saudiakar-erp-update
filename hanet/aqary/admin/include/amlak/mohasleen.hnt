										$result = mysql_query($sql, $link);
										while ($row = mysql_fetch_array($result)) {
											$selected = ($recivername == $row['recivername']) ? 'selected' : '';
											echo "<option value='" . htmlspecialchars($row['recivername']) . "' $selected>" . htmlspecialchars($row['recivername']) . "</option>";
										}
										?>
									</select>
								</div>
								<div class="col-md-4">
									<label for="startfrom_picker" class="form-label"><small class="text-muted">من تاريخ</small></label>
									<div class="input-group">
										<input type="text" class="form-control datepicker-input" name="startfrom_picker" id="startfrom_picker" value="<?= htmlspecialchars($startfrom_picker_value) ?>" placeholder="dd/mm/yyyy" autocomplete="off" onchange="recalculate();">
										<span class="input-group-text"><i class="bi bi-calendar3"></i></span>
									</div>
								</div>
								<div class="col-md-4">
									<label for="enddate_picker" class="form-label"><small class="text-muted">إلى تاريخ</small></label>
									<div class="input-group">
										<input type="text" class="form-control datepicker-input" name="enddate_picker" id="enddate_picker" value="<?= htmlspecialchars($enddate_picker_value) ?>" placeholder="dd/mm/yyyy" autocomplete="off" onchange="recalculate();">
										<span class="input-group-text"><i class="bi bi-calendar3"></i></span>
									</div>
								</div>
							</div>

							<div class="d-flex gap-2 flex-wrap justify-content-start">
								<button type="button" class="btn btn-primary" onclick="recalculate();">
									<i class="bi bi-search me-1"></i>
									بحث
								</button>
								<button type="button" class="btn btn-success"
									onclick="printReport();">
									<i class="bi bi-printer me-1"></i>
									عرض للطباعة
								</button>
								<button type="button" class="btn btn-secondary" onclick="window.location.href='reports.hnt';">
									<i class="bi bi-x-circle me-1"></i>
									إلغاء
								</button>
							</div>
						</form>
					<?php endif; ?>
				</div>
			</div>

			<script>
			$(document).ready(function() {
				var calendarType = 'gregorian';

				$('.datepicker-input').each(function() {
					var $input = $(this);
					$input.attr('data-calendartype', calendarType);
					$input.data('calendartype', calendarType);
					$input.datepicker({
						format: 'dd/mm/yyyy',
						language: 'ar',
						rtl: true,
						autoclose: true,
						todayHighlight: true,
						orientation: 'bottom auto',
						weekStart: 0,
						calendarType: calendarType
					});
				});

				$('.input-group-text').off('click.datepicker').on('click.datepicker', function() {
					var input = $(this).closest('.input-group').find('input.datepicker-input:first');
					if (input.length) {
						input.focus();
						try {
							input.datepicker('show');
						} catch (e) {}
					}
				});
			});

			function formatPickerDateForQuery(value) {
				value = (value || '').trim();
				if (!value) {
					return '';
				}

				var parts = value.split(/[\/-]/);
				if (parts.length !== 3) {
					return value;
				}

				var day = String(parseInt(parts[0], 10) || 0).padStart(2, '0');
				var month = String(parseInt(parts[1], 10) || 0).padStart(2, '0');
				var year = String(parseInt(parts[2], 10) || 0);

				return day + '-' + month + '-' + year;
			}

			function syncDateFilters() {
				$('#startfrom').val(formatPickerDateForQuery($('#startfrom_picker').val()));
				$('#enddate').val(formatPickerDateForQuery($('#enddate_picker').val()));
			}

			function buildFilterUrl(report) {
				var recivername = encodeURIComponent($('#recivername').val() || '');
				var startfrom = formatPickerDateForQuery($('#startfrom_picker').val());
				var enddate = formatPickerDateForQuery($('#enddate_picker').val());

				var url = 'mohasleen.hnt?';
				url += 'recivername=' + recivername;
				url += '&startfrom=' + encodeURIComponent(startfrom);
				url += '&enddate=' + encodeURIComponent(enddate);

				if (report) {
					url += '&report=1';
				}

				return url;
			}

			function navigateIfChanged(url) {
				var targetUrl = new URL(url, window.location.href);
				var currentUrl = new URL(window.location.href);

				if (targetUrl.pathname === currentUrl.pathname && targetUrl.search === currentUrl.search) {
					return;
				}

				window.location.href = targetUrl.toString();
			}

			function recalculate() {
				syncDateFilters();
				navigateIfChanged(buildFilterUrl(0));
			}

			function printReport() {
				syncDateFilters();
				navigateIfChanged(buildFilterUrl(1));
			}
			</script>

			<?php
			// Display specific period if dates are provided
			if ($startfromx) {
				echo '<div class="card shadow-sm mb-4">';
				echo '<div class="card-header bg-primary text-white">';
				echo '<h5 class="mb-0"><i class="bi bi-calendar-check me-2"></i>الفترة: ' . date("d/m/Y", $startfromx) . ' إلى ' . date("d/m/Y", $enddatex) . '</h5>';
				echo '</div>';
				echo '<div class="card-body">';

				$sql = "SELECT SUM(amount) as xp, recivername FROM eradat
            WHERE (paymentdate > " . intval($startfromx) . " AND paymentdate < " . intval($enddatex) . ")";

				if ($recivername) {
					$sql .= " AND recivername = '" . addslashes($recivername) . "'";
				}

				$sql .= " GROUP BY recivername ORDER BY xp DESC";
				$result = mysql_query($sql, $link);

				echo '<div class="table-responsive">';
				echo '<table class="table table-hover table-striped align-middle">';
				echo '<thead class="table-light">';
				echo '<tr class="text-center">';
				echo '<th><i class="bi bi-person me-1"></i>اسم المحصل</th>';
				echo '<th><i class="bi bi-currency-exchange me-1"></i>المبالغ المحصلة</th>';
				echo '</tr>';
				echo '</thead>';
				echo '<tbody>';

				$total = 0;
				while ($row = mysql_fetch_array($result)) {
					$collector_name = $row['recivername'] == "" ? "المكتب" : htmlspecialchars($row['recivername']);
					$amount = floatval($row['xp']);
					$total += $amount;

					echo '<tr class="text-center">';
					echo '<td><strong>' . $collector_name . '</strong></td>';
					echo '<td><strong class="text-success">' . number_format($amount, 2) . '</strong></td>';
					echo '</tr>';
				}

				echo '<tr class="table-primary fw-bold text-center">';
				echo '<td>الإجمالي</td>';
				echo '<td><h5 class="mb-0 text-success">' . number_format($total, 2) . '</h5></td>';
				echo '</tr>';

				echo '</tbody>';
				echo '</table>';
				echo '</div>';
				echo '</div>';
				echo '</div>';

				if ($report == 1) {
					require("../../../reportfooter.hnt");
				}
				echo '</div></div></div>';
				require('../../../foter.hnt');
				exit();
			}

			// Display monthly reports for the last 24 months
			for ($i = 0; $i < 24; $i++) {
				$current_year = date("Y");
				$current_month = date("n") - $i;
				$first_minute = mktime(0, 0, 0, $current_month, 1, $current_year);
				$last_minute = mktime(23, 59, 59, $current_month, date("t", $first_minute), $current_year);

				echo '<div class="card shadow-sm mb-4">';
				echo '<div class="card-header bg-info text-white">';
				echo '<h5 class="mb-0"><i class="bi bi-calendar-month me-2"></i>الفترة: ' . date("d/m/Y", $first_minute) . ' إلى ' . date("d/m/Y", $last_minute) . '</h5>';
				echo '</div>';
				echo '<div class="card-body">';

				$sql = "SELECT SUM(amount) as xp, recivername FROM eradat
            WHERE (paymentdate > " . intval($first_minute) . " AND paymentdate < " . intval($last_minute) . ")
            GROUP BY recivername
            ORDER BY xp DESC";
				$result = mysql_query($sql, $link);

				echo '<div class="table-responsive">';
				echo '<table class="table table-hover table-striped align-middle">';
				echo '<thead class="table-light">';
				echo '<tr class="text-center">';
				echo '<th><i class="bi bi-person me-1"></i>اسم المحصل</th>';
				echo '<th><i class="bi bi-currency-exchange me-1"></i>المبالغ المحصلة</th>';
				echo '</tr>';
				echo '</thead>';
				echo '<tbody>';

				$monthly_total = 0;
				$has_data = false;

				while ($row = mysql_fetch_array($result)) {
					$has_data = true;
					$collector_name = $row['recivername'] == "" ? "المكتب" : htmlspecialchars($row['recivername']);
					$amount = floatval($row['xp']);
					$monthly_total += $amount;

					echo '<tr class="text-center">';
					echo '<td><strong>' . $collector_name . '</strong></td>';
					echo '<td><strong class="text-success">' . number_format($amount, 2) . '</strong></td>';
					echo '</tr>';
				}

				if ($has_data) {
					echo '<tr class="table-secondary fw-bold text-center">';
					echo '<td>الإجمالي</td>';
					echo '<td><strong class="text-success">' . number_format($monthly_total, 2) . '</strong></td>';
					echo '</tr>';
				} else {
					echo '<tr><td colspan="2" class="text-center text-muted">لا توجد بيانات لهذه الفترة</td></tr>';
				}

				echo '</tbody>';
				echo '</table>';
				echo '</div>';
				echo '</div>';
				echo '</div>';
			}
			?>
		</div>
	</div>
</div>
