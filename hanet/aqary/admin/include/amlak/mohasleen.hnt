 * Modern refactored version with Bootstrap 5
 */

// Extract POST variables
extract($_REQUEST);

// Initialize variables
$recivername = isset($recivername) ? trim($recivername) : '';
$report = isset($report) ? intval($report) : 0;
$startfrom_request = isset($startfrom) ? trim($startfrom) : '';
$enddate_request = isset($enddate) ? trim($enddate) : '';
$dd = isset($dd) ? intval($dd) : 0;
$mm = isset($mm) ? intval($mm) : 0;
$yy = isset($yy) ? intval($yy) : 0;
$dd2 = isset($dd2) ? intval($dd2) : 0;
$mm2 = isset($mm2) ? intval($mm2) : 0;
$yy2 = isset($yy2) ? intval($yy2) : 0;

$sc_title = "تقرير نشاط المحصلين";
$sc_id = "59";

include_once "../../../nocash.hnt";
$canscroll = 1;

if ($report == 1) {
	include_once "../../../report_header.hnt";
} else {
	include_once "../../../header.hnt";
}

require '../arabicTools.class.hnt';
include_once "arabic_num.class.hnt";
include_once "amlakfunctions.hnt";
require '../uCal.class.hnt';
$dcal = new uCal;

// Calculate current date
$daxx = date("H/i/s/m/d/Y");
$daxx = explode("/", $daxx);
$h_date = mktime($daxx[0], $daxx[1], $daxx[2], $daxx[3], $daxx[4], $daxx[5]);
$h_date2 = arabicDate("ar:l d/F -Y h:iA", $h_date);
$h_date1 = arabicDate('hj:l d-F-Y هـ', $h_date);

// Set default date range (current month)
$startfrom = time();
$enddate = time() + (30 * 86400);

if (!isset($hnt_dll) || (!$hnt_dll && (!isset($hnt_supper_dll) || $hnt_supper_dll != 5))) {
	$dateo = $dcal->g2u(date("d", $startfrom), date("m", $startfrom), date("Y", $startfrom));
	$daxx[3] = $dateo['day'];
	$daxx[4] = $dateo['month'];
	$daxx[5] = $dateo['year'];
	$dateo = $dcal->g2u(date("d", $enddate), date("m", $enddate), date("Y", $enddate));
	$dax2[3] = $daxx[3];
	$dax2[4] = $dateo['month'];
	$dax2[5] = $dateo['year'];
} else {
	$daxx[3] = date("d", $startfrom);
	$daxx[4] = date("m", $startfrom);
	$daxx[5] = date("Y", $startfrom);
	$dax2[3] = $daxx[3];
	$dax2[4] = date("m", $enddate);
	$dax2[5] = date("Y", $enddate);
}

// Process date range if provided
$startfromx = 0;
$enddatex = 0;

if ($startfrom_request !== '' && strpos($startfrom_request, '-') !== false && $enddate_request !== '' && strpos($enddate_request, '-') !== false) {
	$start_parts = explode("-", "0-0-0-" . $startfrom_request);
	$end_parts = explode("-", "0-0-0-" . $enddate_request);

	if (isset($start_parts[5], $end_parts[5], $start_parts[4], $end_parts[4], $start_parts[3], $end_parts[3]) && ($start_parts[5] < 1900) && ($start_parts[5] > 1400)) {
		$dateo = $dcal->u2g($start_parts[3], $start_parts[4], $start_parts[5]);
		$start_parts[3] = $dateo['day'];
		$start_parts[4] = $dateo['month'];
		$start_parts[5] = $dateo['year'];
		$dateo = $dcal->u2g($end_parts[3], $end_parts[4], $end_parts[5]);
		$end_parts[3] = $dateo['day'];
		$end_parts[4] = $dateo['month'];
		$end_parts[5] = $dateo['year'];
	}

	if (isset($start_parts[3], $start_parts[4], $start_parts[5], $end_parts[3], $end_parts[4], $end_parts[5])) {
		$startfromx = mktime(0, 0, 0, $start_parts[4], $start_parts[3], $start_parts[5]);
		$enddatex = mktime(0, 0, 0, $end_parts[4], $end_parts[3], $end_parts[5]);
		$dd = intval($start_parts[3]);
		$mm = intval($start_parts[4]);
		$yy = intval($start_parts[5]);
		$dd2 = intval($end_parts[3]);
		$mm2 = intval($end_parts[4]);
		$yy2 = intval($end_parts[5]);
		$daxx[3] = $dd;
		$daxx[4] = $mm;
		$daxx[5] = $yy;
		$dax2[3] = $dd2;
		$dax2[4] = $mm2;
		$dax2[5] = $yy2;
	}
} elseif ($dd) {
	$daxx[3] = $dd;
	$daxx[4] = $mm;
	$daxx[5] = $yy;
	$dax2[3] = $dd2;
	$dax2[4] = $mm2;
	$dax2[5] = $yy2;

	if (($yy < 1900) && ($yy > 1400)) {
		$dateo = $dcal->u2g($dd, $mm, $yy);
		$dd = $dateo['day'];
		$mm = $dateo['month'];
		$yy = $dateo['year'];
		$dateo = $dcal->u2g($dd2, $mm2, $yy2);
		$dd2 = $dateo['day'];
		$mm2 = $dateo['month'];
		$yy2 = $dateo['year'];
	}

	$startfromx = mktime(0, 0, 0, $mm, $dd, $yy);
	$enddatex = mktime(0, 0, 0, $mm2, $dd2, $yy2);
}

$startfrom_picker_value = date("d/m/Y", intval($startfromx ? $startfromx : $startfrom));
$enddate_picker_value = date("d/m/Y", intval($enddatex ? $enddatex : $enddate));
?>

<!-- Main Content -->
<div class="container-fluid mt-4">
