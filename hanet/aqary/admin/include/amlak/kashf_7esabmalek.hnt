                            </div>
                        </div>
                    </div>
                </div>
            </div>
<?php endif; ?>
        </div>
    </div>
</div>

<script>
$(document).ready(function() {
    var calendarType = 'gregorian';
    var isHijri = false;

    $('.datepicker-input').each(function() {
        var $input = $(this);
        $input.attr('data-calendartype', calendarType);
        $input.data('calendartype', calendarType);
        $input.datepicker({
            format: 'dd/mm/yyyy',
            language: 'ar',
            rtl: true,
            autoclose: true,
            todayHighlight: true,
            orientation: 'bottom auto',
            weekStart: isHijri ? 6 : 0,
            calendarType: calendarType
        });

        var dpData = $input.data('datepicker');
        if (dpData) {
            if (dpData.o) {
                dpData.o.calendarType = calendarType;
            }
            if (dpData.calendarType !== undefined) {
                dpData.calendarType = calendarType;
            }
            try {
                if (dpData.fill) {
                    dpData.fill();
                }
                if (dpData.update) {
                    dpData.update();
                }
            } catch (e) {}
        }
    });

    $('.input-group-text').off('click.datepicker').on('click.datepicker', function() {
        var input = $(this).closest('.input-group').find('input.datepicker-input:first');
        if (input.length) {
            input.focus();
            try {
                input.datepicker('show');
            } catch (e) {}
        }
    });

    // Load bank accounts when property is selected via ajaxfilldiv
    // Monitor both idaqar (hidden) and aqarname (visible) fields
    $('#idaqar, #aqarname').on('change propertychange', function() {
        loadBankAccounts();
    });

    // Also trigger on DOMSubtreeModified for idaqar (catches ajaxfilldiv updates)
    $('#idaqar').on('DOMSubtreeModified', function() {
        loadBankAccounts();
    });

    // Load bank accounts on page load if property is selected
    <?php if ($idaqar > 0): ?>
    loadBankAccounts();
    <?php endif; ?>

    // Set interval to check for changes from ajaxfilldiv (it updates values programmatically)
    let lastIdaqar = $('#idaqar').val();
    let lastAqarname = $('#aqarname').val();
    setInterval(function() {
        const currentIdaqar = $('#idaqar').val();
        const currentAqarname = $('#aqarname').val();
        if (currentIdaqar !== lastIdaqar || currentAqarname !== lastAqarname) {
            lastIdaqar = currentIdaqar;
            lastAqarname = currentAqarname;
            loadBankAccounts();
            recalculate();
        }
    }, 500);

    function loadBankAccounts() {
        const idaqar = $('#idaqar').val();
        if (!idaqar || idaqar == 0) {
            $('#bank_account_filter').html('<option value="0">الكل</option>');
            return;
        }

        $.ajax({
            url: 'kashf_7esabmalek.hnt',
            type: 'POST',
            data: {
                ajax_action: 'get_property_bank_accounts',
                idaqar: idaqar
            },
            dataType: 'json',
            success: function(response) {
                if (response.success && response.accounts) {
                    const select = $('#bank_account_filter');
                    const currentBankId = <?= $bankid ?>;
                    select.html('<option value="0">الكل</option>');

                    response.accounts.forEach(function(acc) {
                        const label = acc.bankname + ' - ' + acc.acountholder + ' (' + acc.acountnumber + ')';
                        const selected = (acc.id == currentBankId) ? ' selected' : '';
                        select.append('<option value="' + acc.id + '"' + selected + '>' + label + '</option>');
                    });
                }
            },
            error: function(xhr, status, error) {
                console.error('Error loading bank accounts:', error);
            }
        });
    }

    // Update hidden bankid field when bank account selector changes
    $('#bank_account_filter').on('change', function() {
        $('#bankid').val($(this).val());
        recalculate();
    });

    $('#payment_type_filter').on('change', function() {
        recalculate();
    });

    $('.datepicker-input').on('changeDate change', function() {
        recalculate();
    });

    $('form[name="form"]').on('submit', function() {
        syncDateFilters();
    });
});

function formatPickerDateForQuery(value) {
    value = (value || '').trim();
    if (!value) {
        return '';
    }

    var parts = value.split(/[\/-]/);
    if (parts.length !== 3) {
        return value;
    }

    var day = String(parseInt(parts[0], 10) || 0).padStart(2, '0');
    var month = String(parseInt(parts[1], 10) || 0).padStart(2, '0');
    var year = String(parseInt(parts[2], 10) || 0);

    return day + '-' + month + '-' + year;
}

function syncDateFilters() {
    $('#startfrom').val(formatPickerDateForQuery($('#startfrom_picker').val()));
    $('#enddate').val(formatPickerDateForQuery($('#enddate_picker').val()));
}

function buildFilterUrl(showtasfia, report, hidecommision) {
    const idaqar = $('#idaqar').val() || 0;
    const aqarname = encodeURIComponent($('#aqarname').val() || '');
    const startfrom = formatPickerDateForQuery($('#startfrom_picker').val());
    const enddate = formatPickerDateForQuery($('#enddate_picker').val());
    const bankid = $('#bankid').val() || 0;
    const payment_type = $('#payment_type_filter').val() || 0;

    let url = 'kashf_7esabmalek.hnt?idaqar=' + idaqar + '&aqarname=' + aqarname;
    url += '&startfrom=' + encodeURIComponent(startfrom);
    url += '&enddate=' + encodeURIComponent(enddate);

    if (bankid > 0) {
        url += '&bankid=' + bankid;
    }

    if (payment_type > 0) {
        url += '&payment_type=' + payment_type;
    }

    if (showtasfia) {
        url += '&showtasfia=' + showtasfia;
    }

    if (report) {
        url += '&report=1';
    }

    if (hidecommision) {
        url += '&hidecommision=1';
    }

    return url;
}

function recalculate() {
    window.location.href = buildFilterUrl(<?= $showtasfia ?>, 0, 0);
}

function resetFilters() {
    const idaqar = $('#idaqar').val() || 0;
    const aqarname = encodeURIComponent($('#aqarname').val() || '');
    let url = 'kashf_7esabmalek.hnt';

    if (idaqar > 0 || aqarname) {
        url += '?idaqar=' + idaqar + '&aqarname=' + aqarname;
    }

    window.location.href = url;
}

function applyFilters(showtasfia) {
    window.location.href = buildFilterUrl(showtasfia, 0, 0);
}

function printReport(hidecommision) {
    window.location.href = buildFilterUrl(<?= $showtasfia ?>, 1, hidecommision);
}
</script>

<?php
if ($report == 1) {
    require("../../../reportfooter.hnt");
} else {
    require('../../../foter.hnt');
}
?>
