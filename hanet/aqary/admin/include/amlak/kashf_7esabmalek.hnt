<?php
    $counx = 0;
    $allsandrakam = array();

    while ($row = mysql_fetch_array($result)) {
        // Remove duplicated entries
        if (in_array($row['sanadrakam'], $allsandrakam)) {
            $rid = mysql_fetch_array(mysql_query("SELECT sanadrakam FROM eradat WHERE sanadrakam='" . addslashes($row['sanadrakam']) . "'"));
            if ($rid['sanadrakam']) {
                loginfo("critical", "delete", "تم حذف الايرد رقم سند: {$row['sanadrakam']} البيان", "", "eradat", $row['sanadrakam'], $link);
                mysql_query("DELETE FROM eradat WHERE sanadrakam='" . addslashes($row['sanadrakam']) . "'", $link);
            }
            continue;
        }
        $allsandrakam[] = $row['sanadrakam'];

        $counx++;

        // Format date
        if (isset($hnt_dll) && ($hnt_dll || (isset($hnt_supper_dll) && $hnt_supper_dll == 5))) {
            $payment_date = date("d/m/Y", $row['paymentdate']);
        } else {
            $payment_date = $arabicTools->arabicDate('hj:d/m/Y', $row['paymentdate']);
        }
?>
                                <tr class="text-center">
                                    <td><strong><?= htmlspecialchars($row['sanadrakam']) ?></strong></td>
                                    <td><?= htmlspecialchars(str_replace("+", " بدون ", $row['pymentdesription'])) ?></td>
