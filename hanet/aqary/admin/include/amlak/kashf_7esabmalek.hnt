<?php
/**
 * Owner Account Statement
 * Modern refactored version with Bootstrap 5
 */

// Extract POST variables
extract($_REQUEST);

// Initialize variables
$idaqar = isset($idaqar) ? intval($idaqar) : 0;
$aqarname = isset($aqarname) ? trim($aqarname) : '';
$report = isset($report) ? intval($report) : 0;
$startfrom = isset($startfrom) ? trim($startfrom) : '';
$enddate = isset($enddate) ? trim($enddate) : '';
$startfromx = isset($startfromx) ? intval($startfromx) : 0;
$enddatex = isset($enddatex) ? intval($enddatex) : 0;
$dd = isset($dd) ? intval($dd) : 0;
$mm = isset($mm) ? intval($mm) : 0;
$yy = isset($yy) ? intval($yy) : 0;
$dd2 = isset($dd2) ? intval($dd2) : 0;
$mm2 = isset($mm2) ? intval($mm2) : 0;
$yy2 = isset($yy2) ? intval($yy2) : 0;
$showtasfia = isset($showtasfia) ? intval($showtasfia) : 0;
$hidecommision = isset($hidecommision) ? intval($hidecommision) : 0;
$bankid = isset($bankid) ? intval($bankid) : 0;
$payment_type = isset($payment_type) ? intval($payment_type) : 0;

// AJAX handler to fetch bank accounts for selected property
if (isset($_POST['ajax_action']) && $_POST['ajax_action'] == 'get_property_bank_accounts') {
    include_once "../../../reqloginajax.hnt";
    header('Content-Type: application/json; charset=utf-8');
    $property_id = isset($_POST['idaqar']) ? intval($_POST['idaqar']) : 0;

    if ($property_id > 0) {
        // Fetch bank accounts: company accounts (ownerid2=0) OR property accounts (ownerid2=idaqar)
        $sql = "SELECT id, bankname, acountholder, acountnumber
                FROM bankacounts
                WHERE ownerid2 = 0 OR ownerid2 = '$property_id'
                ORDER BY ownerid2 DESC, id DESC";
        $result = mysql_query($sql, $link);

        $accounts = [];
        while ($row = mysql_fetch_assoc($result)) {
            $accounts[] = $row;
        }

        echo json_encode(['success' => true, 'accounts' => $accounts], JSON_UNESCAPED_UNICODE | JSON_INVALID_UTF8_SUBSTITUTE);
    } else {
        echo json_encode(['success' => false, 'message' => 'معرف العقار غير صحيح'], JSON_UNESCAPED_UNICODE);
    }
    exit;
}

$sc_title = "كشف حساب مالك";
$sc_id = "50";

include_once "../../../nocash.hnt";
require '../arabicTools.class.hnt';
include_once "arabic_num.class.hnt";
require '../uCal.class.hnt';
$dcal = new uCal;
$arabicTools = new ArabicTools();
include_once "amlakfunctions.hnt";
$local_hnt_dll_type = (isset($hnt_dll) && ($hnt_dll || (isset($hnt_supper_dll) && $hnt_supper_dll == 5))) ? 1 : 0;

// Export handler — runs before any HTML output
if (isset($_GET['export']) && in_array(trim($_GET['export']), ['csv', 'xls'], true) && $idaqar) {
    include_once  "../../../connectdb.hnt";
    $_exp_start = isset($_GET['startfromx']) && intval($_GET['startfromx']) ? intval($_GET['startfromx']) : 0;
    $_exp_end   = isset($_GET['enddatex'])   && intval($_GET['enddatex'])   ? intval($_GET['enddatex'])   : 0;
    if (!$_exp_start && isset($_GET['startfrom']) && $_GET['startfrom']) {
        $_d = explode("-", "0-0-0-" . $_GET['startfrom']);
        if (isset($_d[5])) $_exp_start = mktime(0, 0, 0, $_d[4], $_d[3], $_d[5]);
    }
    if (!$_exp_end && isset($_GET['enddate']) && $_GET['enddate']) {
        $_d = explode("-", "0-0-0-" . $_GET['enddate']);
        if (isset($_d[5])) $_exp_end = mktime(0, 0, 0, $_d[4], $_d[3], $_d[5]) + 86400;
    }
    if (!$_exp_start) $_exp_start = time() - 15768000;
    if (!$_exp_end)   $_exp_end   = time() + 86400;

    $_showtasfia   = isset($_GET['showtasfia'])   ? intval($_GET['showtasfia'])   : 0;
    $_bankid       = isset($_GET['bankid'])        ? intval($_GET['bankid'])        : 0;
    $_payment_type = isset($_GET['payment_type']) ? intval($_GET['payment_type']) : 0;

    $_tasfia_f = $_showtasfia ? " AND tasfia = '' " : "";
    $_bk_f     = $_bankid > 0       ? " AND sanadrakam IN (SELECT sanadrakam FROM sanad WHERE bankid = '" . $_bankid . "')" : "";
    $_pt_f     = $_payment_type > 0 ? " AND sanadrakam IN (SELECT sanadrakam FROM sanad WHERE payment_type = '" . $_payment_type . "')" : "";

    $exp_headers = ['النوع', 'البيان', 'التاريخ', 'دائن', 'مدين'];
    $exp_rows = [];

    // Income (eradat)
    $exp_res = mysql_query("SELECT pymentdesription, paymentdate, amount, mysa3ee, tamen, mywater, services
                            FROM eradat WHERE idaqar='" . intval($idaqar) . "'
                            AND paymentdate > '$_exp_start' AND paymentdate < '$_exp_end'
                            $_tasfia_f $_bk_f $_pt_f", $link);
    while ($r = mysql_fetch_array($exp_res)) {
        $net = floatval($r['amount']) - floatval($r['mysa3ee']) - floatval($r['services']);
        $exp_rows[] = ['إيراد', str_replace('+', ' بدون ', $r['pymentdesription']), date('d/m/Y', $r['paymentdate']), number_format($net, 2, '.', ''), ''];
    }

    // Expenses (masrofat)
    $exp_res = mysql_query("SELECT payeddue, payeddate, amount FROM masrofat
                            WHERE fund_source = 0 AND idaqar='" . intval($idaqar) . "'
                            AND payeddate > '$_exp_start' AND payeddate < '$_exp_end'
                            $_tasfia_f", $link);
    while ($r = mysql_fetch_array($exp_res)) {
        $exp_rows[] = ['مصروف', str_replace('+', ' بدون ', $r['payeddue']), date('d/m/Y', $r['payeddate']), '', number_format($r['amount'], 2, '.', '')];
    }

    // Vouchers delivered to owner (sanadsarf)
    $exp_res = mysql_query("SELECT bayan, sanadate, amount FROM sanadsarf
                            WHERE aqarid='" . intval($idaqar) . "'
                            AND sanadate > '$_exp_start' AND sanadate < '$_exp_end'
                            $_tasfia_f", $link);
    while ($r = mysql_fetch_array($exp_res)) {
        $exp_rows[] = ['تسليم للمالك', $r['bayan'], date('d/m/Y', $r['sanadate']), '', number_format($r['amount'], 2, '.', '')];
    }

    usort($exp_rows, function($a, $b) { return strcmp($a[2], $b[2]); });

    $_exp_type = trim($_GET['export']);
    $_fn = date('Ymd_His');
    if ($_exp_type === 'csv') {
        header('Content-Type: text/csv; charset=UTF-8');
        header('Content-Disposition: attachment; filename="kashf_malek_' . $_fn . '.csv"');
        $_out = fopen('php://output', 'w');
        fwrite($_out, "\xEF\xBB\xBF");
        fputcsv($_out, $exp_headers, ',', '"', '\\');
        foreach ($exp_rows as $_r) fputcsv($_out, $_r, ',', '"', '\\');
        fclose($_out);
        exit;
    }
    header('Content-Type: application/vnd.ms-excel; charset=UTF-8');
    header('Content-Disposition: attachment; filename="kashf_malek_' . $_fn . '.xls"');
    echo '<html lang="ar" dir="rtl"><head><meta charset="UTF-8"></head><body><table border="1"><tr>';
    foreach ($exp_headers as $_h) echo '<th>' . htmlspecialchars($_h) . '</th>';
    echo '</tr>';
    foreach ($exp_rows as $_r) { echo '<tr>'; foreach ($_r as $_c) echo '<td>' . htmlspecialchars($_c) . '</td>'; echo '</tr>'; }
    echo '</table></body></html>';
    exit;
}

$canscroll = 1;
if ($report == 1) {
    include_once "../../../report_header.hnt";
} else {
    include_once "../../../header.hnt";
}

if ($idaqar) {
    $sql = "SELECT * FROM amlak WHERE idaqar = '" . intval($idaqar) . "'";
    $aqinfo = mysql_fetch_array(mysql_query($sql, $link));
    $aqarname = isset($aqinfo['aqarname']) ? $aqinfo['aqarname'] : '';
}

// Calculate dates
$daxx = date("H/i/s/m/d/Y");
$daxx = explode("/", $daxx);
$h_date = mktime($daxx[0], $daxx[1], $daxx[2], $daxx[3], $daxx[4], $daxx[5]);
$h_date2 = arabicDate("ar:l d/F -Y h:iA", $h_date);
$h_date1 = arabicDate('hj:l d-F-Y هـ', $h_date);

// Set default date range
if (!isset($hnt_dll) || (!$hnt_dll && (!isset($hnt_supper_dll) || $hnt_supper_dll != 5))) {
    $ers = 15277248; // ~6 months
} else {
    $ers = 15768000; // ~6 months
}

if ($startfromx) {
    $startfrom = date("d-m-Y", $startfromx);
    $enddate = date("d-m-Y", $enddatex);
}

if ($startfrom) {
    $daxx = explode("-", "0-0-0-" . $startfrom);
    $dax2 = explode("-", "0-0-0-" . $enddate);

    if (($daxx[5] < 1900) && ($daxx[5] > 1400)) {
        $dateo = $dcal->u2g($daxx[3], $daxx[4], $daxx[5]);
        $startfrom = $dateo['day'] . "-" . $dateo['month'] . "-" . $dateo['year'];
        $dateo = $dcal->u2g($dax2[3], $dax2[4], $dax2[5]);
        $enddate = $dateo['day'] . "-" . $dateo['month'] . "-" . $dateo['year'];
    }

    $daxx = explode("-", "0-0-0-" . $startfrom);
    $startfrom = mktime(0, 0, 0, $daxx[4], $daxx[3], $daxx[5]);
    $dax2 = explode("-", "0-0-0-" . $enddate);
    $enddate = mktime(0, 0, 0, $dax2[4], $dax2[3], $dax2[5]);
} else {
    $startfrom = time() - $ers;
    $enddate = time() + 86400;
}

if (!isset($hnt_dll) || (!$hnt_dll && (!isset($hnt_supper_dll) || $hnt_supper_dll != 5))) {
    $dateo = $dcal->g2u(date("d", $startfrom), date("m", $startfrom), date("Y", $startfrom));
    $daxx[3] = $dateo['day'];
    $daxx[4] = $dateo['month'];
    $daxx[5] = $dateo['year'];
    $dateo = $dcal->g2u(date("d", $enddate), date("m", $enddate), date("Y", $enddate));
    $dax2[3] = $dateo['day'];
    $dax2[4] = $dateo['month'];
    $dax2[5] = $dateo['year'];
} else {
    $daxx[3] = date("d", $startfrom);
    $daxx[4] = date("m", $startfrom);
    $daxx[5] = date("Y", $startfrom);
    $dax2[3] = date("d", $enddate);
    $dax2[4] = date("m", $enddate);
    $dax2[5] = date("Y", $enddate);
}

if ($startfromx) {
    $startfrom = $startfromx;
    $enddate = $enddatex;
}

$startfrom_picker_value = date("d/m/Y", intval($startfrom));
$enddate_picker_value = date("d/m/Y", intval($enddate));

$checked1 = " checked ";
$checked2 = "";
if ($showtasfia == 1) {
    $checked1 = "";
    $checked2 = " checked ";
}

// Initialize totals
$totalincome = 0;
$totaloutcome = 0;
