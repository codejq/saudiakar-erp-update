.files-table th { background: transparent; color: white; font-weight: 600; text-align: center; padding: 0.75rem; border: none; }
.files-table td { text-align: center; padding: 0.75rem; vertical-align: middle; }
.files-table tbody tr:hover { background-color: #f8f9fa; }
.toast { min-width: 350px; backdrop-filter: blur(10px); }
.bg-success-subtle { background-color: #d1e7dd !important; border-left: 4px solid #198754; }
.bg-danger-subtle { background-color: #f8d7da !important; border-left: 4px solid #dc3545; }
.bg-info-subtle { background-color: #cff4fc !important; border-left: 4px solid #0dcaf0; }
</style>

