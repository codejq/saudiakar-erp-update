.tenant-image-preview { width: 120px; height: 150px; object-fit: cover; border-radius: 8px; border: 3px solid #e9ecef; cursor: pointer; transition: all 0.3s ease; }
.tenant-image-preview:hover { border-color: #189c2aff; transform: scale(1.05); }
