    <?php
    $sql = "SELECT * FROM upfiles WHERE category='amlak' AND ownerid='" . intval($mostagerid) . "'";
    $result = mysql_query($sql, $link);
    if (mysql_num_rows($result) > 0) {
    ?>
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover files-table mb-0">
                    <thead>
                        <tr>
                            <th>اسم الملف</th>
                            <th>فتح</th>
                            <th>حذف</th>
                        </tr>
                    </thead>
                    <tbody>
                        <?php while ($row = mysql_fetch_array($result)) { ?>
                        <tr>
                            <td>
                                <a href='data/<?= htmlspecialchars($row['filename'], ENT_QUOTES, 'UTF-8') ?>'
                                   class="text-decoration-none">
                                    <i class="bi bi-file-earmark me-1"></i>
                                    <?= htmlspecialchars($row['filedescription'], ENT_QUOTES, 'UTF-8') ?>
                                </a>
                            </td>
