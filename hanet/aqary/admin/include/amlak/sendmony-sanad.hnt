                                <tbody>
                                    <?php
                                    $sql = "SELECT * FROM masrofat WHERE fund_source = 0 AND tasfia = '' AND idaqar = '" . intval($idaqar) . "' ORDER BY payeddate DESC";
                                    $result_all_expenses = mysql_query($sql, $link);

                                    while ($row_exp = mysql_fetch_array($result_all_expenses)) {
                                        $checkedselected = in_array($row_exp['idmasrof'], $idmasrofcheck) ? ' checked' : '';

                                        if ($local_hnt_dll_type) {
                                            $exp_date = date("d/m/Y", $row_exp['payeddate']);
                                        } else {
                                            $dateo = $dcal->g2u(date("d", $row_exp['payeddate']), date("m", $row_exp['payeddate']), date("Y", $row_exp['payeddate']));
                                            $exp_date = $dateo['day'] . "/" . $dateo['month'] . "/" . $dateo['year'];
                                        }
                                    ?>
                                    <tr>
                                        <td><strong><?= number_format(floatval($row_exp['amount']), 2) ?></strong></td>
                                        <td><small><?= htmlspecialchars($row_exp['payeddue']) ?></small></td>
                                        <td style="direction: ltr;"><small><?= $exp_date ?></small></td>
                                        <td>
                                            <input type="checkbox" class="chkmasrofat checkbox-custom"
                                                   name="idmasrofcheck[]"
                                                   value="<?= $row_exp['idmasrof'] ?>"
                                                   id="idmasrofcheck<?= $row_exp['idmasrof'] ?>"
                                                   <?= $checkedselected ?>>
                                        </td>
                                    </tr>
                                    <?php } ?>
                                </tbody>
                            </table>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
$(document).ready(function() {
    var isHijri = <?= $local_hnt_dll_type ? 'false' : 'true' ?>;
    var calType = isHijri ? 'hijri' : 'gregorian';

    $('.datepicker-input').each(function() {
        var $input = $(this);
        $input.data('calendartype', calType);
        $input.datepicker({
            format: 'dd/mm/yyyy',
            language: 'ar',
            rtl: true,
            autoclose: true,
            todayHighlight: true,
            orientation: 'bottom auto',
            weekStart: isHijri ? 6 : 0,
            calendarType: calType
        });
    });

    $('.input-group-text').off('click.datepicker').on('click.datepicker', function() {
        var input = $(this).closest('.input-group').find('input.datepicker-input:first');
        if (input.length) {
            input.focus();
            try {
                input.datepicker('show');
            } catch (e) {}
        }
    });

    // Capture calculation breakdown for record keeping
    // Builds a compact calc-table from the live values instead of
    // copying verbose Bootstrap HTML (which exceeds the varchar(3500) limit).
    function updateCashText() {
        function val(id) {
            var el = document.getElementById(id);
            return el ? el.innerText || el.textContent || '' : '';
        }

        var rows = [
            ['المبلغ المحصل:',                          val('holeincome')],
            ['المبلغ المحصل للإيجار:',                  val('income')],
            ['العمولة:',                                 val('commession')],
            ['المياه:',                                  val('water')],
            ['خدمات:',                                   val('services')],
            ['التأمين:',                                 val('tameen')],
            ['النسبة المستحقة:',                         val('persentage')],
            ['المبلغ المستحق للمالك قبل خصم المصروفات:', val('netincome')],
            ['إجمالي المصروفات المخصومة:',               val('totalspends')],
            ['إجمالي المستحق للمالك:',                   val('finalamount')]
        ];

        var html = '<table class="calc-table">';
        for (var i = 0; i < rows.length; i++) {
            if (rows[i][1] !== '') {
                html += '<tr><td>' + rows[i][0] + '</td><td>' + rows[i][1] + '</td></tr>';
            }
        }

        // Payment method and money source
        var payLabels = {1:'نقداً', 2:'شيك', 3:'طريقة أخرى', 4:'تحويل بنكي', 5:'شبكة'};
        var selPayMethod = parseInt($('input[name="payment_type"]:checked').val() || '1');
        html += '<tr><td>طريقة الصرف:</td><td>' + (payLabels[selPayMethod] || 'نقداً') + '</td></tr>';

        var selMoneySource = $('input[name="money_source"]').val() || '0';
        html += '<tr><td>مصدر المبلغ:</td><td>' + (selMoneySource == '1' ? 'من حساب المالك (تحويل داخلي)' : 'من حساب المكتب') + '</td></tr>';

        // محرر و مبلغ مستحق from #userdata text
        var userText = $('#userdata').text().replace(/\s+/g, ' ').trim();
        html += '</table>' + userText;

        $("#cashtext").val(html);
    }

    updateCashText();

    // Load bank accounts for transfer payment
    function loadSarfBankAccounts() {
        var idaqar = <?= intval($idaqar) ?>;
        if (!idaqar) return;
        $.ajax({
            url: 'sendmony-sanad.hnt',
            type: 'POST',
            data: { ajax_submit: '1', action: 'get_bank_accounts_sarf', idaqar: idaqar },
            dataType: 'json',
            success: function(response) {
                if (response.success && response.accounts) {
                    var select = $('#sarf_bank_account_select');
                    select.empty().append('<option value="">-- اختر حساب --</option>');
                    $.each(response.accounts, function(i, acc) {
                        var label = acc.bankname + ' - ' + acc.acountholder + ' (' + acc.acountnumber + ')';
                        select.append($('<option></option>').val(acc.id)
                            .data('bankname', acc.bankname).data('holder', acc.acountholder)
                            .data('number', acc.acountnumber).data('iban', acc.iban || '')
                            .text(label));
                    });
                }
            }
        });
    }
    loadSarfBankAccounts();

    // Bank account auto-fill on transfer selection
    $('#sarf_bank_account_select').on('change', function() {
        var opt = $(this).find('option:selected');
        if (opt.val()) {
            $('#sarf_bankid').val(opt.val());
            $('#sarf_checkbank').val(opt.data('bankname') + ' - ' + opt.data('holder'));
            var note = 'تحويل الى حساب ' + opt.data('holder') + ' - بنك ' + opt.data('bankname') + ' - حساب ' + opt.data('number');
            if (opt.data('iban')) note += ' - آيبان ' + opt.data('iban');
            $('input[name="sanadnote"]').val(note);
        } else {
            $('#sarf_bankid').val('0');
        }
        updateCashText();
    });

    // Payment method card click
    $('.payment-method-card-sarf').on('click', function() {
        $('.payment-method-card-sarf').removeClass('active');
        $(this).addClass('active');
        $(this).find('input[type="radio"]').prop('checked', true);
        var method = parseInt($(this).data('method'));
        $('#sarf_checkrakam, #sarf_checkdate, #sarf_checkbank').val('');
        $('#sarf_bankid').val('0');
        $('#sarf_bank_account_select').val('');
        if (method === 1) {
            $('#sarfPaymentDetails').hide();
            $('#sarfBankAccountSelector').hide();
        } else {
            $('#sarfPaymentDetails').show();
            if (method === 4) {
                $('#sarfBankAccountSelector').show();
                $('#sarf_checkrakam').attr('placeholder', 'رقم الحوالة');
            } else {
                $('#sarfBankAccountSelector').hide();
                $('#sarf_checkrakam').attr('placeholder', method === 2 ? 'رقم الشيك' : method === 5 ? 'رقم العملية' : '');
            }
        }
        updateCashText();
    });


    // AJAX form submission for payment
    $('#paymentForm').on('submit', function(e) {
        e.preventDefault();

        // Update cashtext before submission
        updateCashText();

        const formData = new FormData(this);
        formData.append('ajax_submit', '1');

        const submitBtn = $(this).find('button[type="submit"]');
        const originalBtnText = submitBtn.html();
        submitBtn.prop('disabled', true)
                 .html('<i class="bi bi-hourglass-split me-2"></i>جاري الصرف...');

        $.ajax({
            url: 'sendmony-sanad.hnt',
            type: 'POST',
            data: formData,
            processData: false,
            contentType: false,
            dataType: 'json',
            success: function(response) {
                submitBtn.prop('disabled', false).html(originalBtnText);

                if (response.success) {
                    alert(response.message);
                    // Redirect back to property settlements
                    window.location.href = 'sendmony.hnt?idaqar=<?= $idaqar ?>';
                } else {
                    alert('خطأ: ' + (response.error || 'حدث خطأ غير متوقع'));
                }
            },
            error: function(xhr, status, error) {
                submitBtn.prop('disabled', false).html(originalBtnText);
                console.error('AJAX Error:', error);
                alert('حدث خطأ في الاتصال بالخادم');
            }
        });
    });

    // Auto-submit expenses form when checkboxes change
    $('.chkmasrofat').on('change', function() {
        // Optional: Auto-submit on change
        // $('#expensesForm').submit();
    });

    // Keyboard shortcuts
    $(document).on('keydown', function(e) {
        // Ctrl+S to submit payment
        if (e.ctrlKey && e.keyCode == 83) {
            e.preventDefault();
            $('#paymentForm').submit();
        }
    });
});
</script>

<?php
    require('../../../foter.hnt');
}
?>
