require '../uCal.class.hnt';
$dcal = new uCal;

function convertDisplayDateToTimestamp($date_value, $local_hnt_dll_type, $dcal) {
    $date_value = trim($date_value);
    if ($date_value === '') {
        return 0;
    }

    $parts = explode('/', $date_value);
    if (count($parts) !== 3) {
        return 0;
    }

    $day = intval($parts[0]);
    $month = intval($parts[1]);
    $year = intval($parts[2]);

    if ($local_hnt_dll_type) {
        return mktime(0, 0, 0, $month, $day, $year);
    }

    $gregorian_date = $dcal->u2g($day, $month, $year);
    return mktime(0, 0, 0, intval($gregorian_date['month']), intval($gregorian_date['day']), intval($gregorian_date['year']));
}

// Check for duplicate payment attempt
if (isset($_REQUEST['formuid']) && !empty($_REQUEST['formuid'])) {
    $sql = "SELECT COUNT(sanadid) as dd FROM sanadsarf WHERE formuid = '" . addslashes($_REQUEST['formuid']) . "'";
    $row_check = mysql_fetch_array(mysql_query($sql, $link));
    if ($row_check['dd'] > 0) {
        if ($is_ajax_request) {
            header('Content-Type: application/json; charset=utf-8');
            echo json_encode([
                'success' => false,
                'error' => 'خطأ: محاولة تكرار الدفع'
            ], JSON_UNESCAPED_UNICODE);
            exit;
        }
        echo "<div class='alert alert-danger text-center'><h5>حدث خطأ: محاولة تكرار الدفع</h5></div>";
        require('../../../foter.hnt');
        exit;
    }
}

// Schema updates for payment method and money source tracking
