}

require '../arabicTools.class.hnt';
require '../uCal.class.hnt';
$dcal = new uCal;
$arabicTools = new ArabicTools();
include_once "amlakfunctions.hnt";

// Get tenant date type
if ($mostagerid) {
    $row = mysql_fetch_array(mysql_query("SELECT hnt_dll_type FROM amlakdetails WHERE mostagerid='" . intval($mostagerid) . "'", $link));
    $row_dll_type = isset($row['hnt_dll_type']) ? $row['hnt_dll_type'] : null;
}

$hnt_dll_defult = isset($hnt_dll) ? $hnt_dll : 0;
if (isset($row_dll_type) && ($row_dll_type == 1 || $row_dll_type === "0")) {
    $hnt_dll = $row_dll_type;
} else {
    $hnt_dll = $hnt_dll_defult;
}
