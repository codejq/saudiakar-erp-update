// Get current date in Arabic
$daxx = date("H/i/s/m/d/Y");
$daxx = explode("/", $daxx);
$h_date = mktime($daxx[0], $daxx[1], $daxx[2], $daxx[3], $daxx[4], $daxx[5]);
$h_date2 = arabicDate("ar:l d/F -Y h:iA", $h_date);
$h_date1 = arabicDate('hj:l d-F-Y هـ', $h_date);
$display_date_gregorian = $h_date2;
$display_date_hijri = $h_date1;

// Get property list for dropdown
$properties_query = mysql_query("SELECT idaqar, aqarname FROM amlak ORDER BY aqarname", $link);
