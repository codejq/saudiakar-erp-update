<script>
function handlePropertySelectionChange(selectElement) {
    const selectedOption = selectElement.options[selectElement.selectedIndex];
    const aqarname = selectedOption.getAttribute('data-name') || '';
    document.getElementById('aqarname').value = aqarname;

    if (selectElement.value) {
        document.getElementById('propertyForm').submit();
    }
}
</script>

