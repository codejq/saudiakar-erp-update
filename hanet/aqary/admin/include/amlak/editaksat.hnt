		$result = mysql_query($sql, $link);
		while ($re = mysql_fetch_array($result)) {


			$id = $re['kastid'];

			// Skip if kastdate not provided for this installment
			if (!isset($kastdate[$id]) || empty($kastdate[$id])) {
				continue;
			}

			$dateParts = explode("/", $kastdate[$id]);
			if (count($dateParts) < 3) {
				continue; // Invalid date format
			}
			list($st_datet, $st_montht, $st_yeart) = $dateParts;
//echo $kastdate[$id] ."<br>";
			if ($st_yeart < 1900) {
//convert from hegery  to melady

				list($st_date, $st_month, $st_year) = $dateParts;

				$t1 = $arabicTools->dateHejri2Geo((intval($st_date) + 1) . "/" . ($st_month) . "/" . $st_year);
				$t1 = explode("-", $t1);

				$dateo = $dcal->u2g(intval($st_date), intval($st_month), intval($st_year));
				$kastdate[$id] = mktime(0, 0, 0, $dateo['month'], $dateo['day'], $dateo['year']);

			} else {
				$t1 = explode("/", $kastdate[$id]);
				$kastdate[$id] = mktime(0, 0, 0, intval($t1[1]), intval($t1[0]), intval($t1[2]));
//echo "$t1[1], $t1[0], $t1[2]<br>";
			}

			if($id < $maxKey){
				$iscomplete[$id] = 1;
			}

			$sql = "update aksat set
kastname='" . ($kastname[$id] ?? '') . "',
kastvalue='" . ($kastvalue[$id] ?? 0) . "',
dof3at='" . ($dof3at[$id] ?? 0) . "',
dof3at_tafsel='" . ($dof3at_tafsel[$id] ?? 0) . "',
kastdate='" . ($kastdate[$id] ?? 0) . "',
water='" . ($water[$id] ?? 0) . "',
sa3ee='" . ($sa3ee[$id] ?? 0) . "',
services='" . ($services[$id] ?? 0) . "',
iscomplete='" . ($iscomplete[$id] ?? 0) . "'
where kastid='" . $id . "'
";

			mysql_query($sql, $link);

		}

// add new field

		if ($kastname['rosa']) {

			list($st_datett, $st_monthtt, $st_yeartt) = explode("/", $kastdate['rosa']);

			if ($st_yeartt < 1900) {
//convert from hegery  to melady

				list($st_date, $st_month, $st_year) = explode("/", $kastdate['rosa']);
				$t1 = $arabicTools->dateHejri2Geo(($st_date + 1) . "/" . ($st_month) . "/" . $st_year);
				$t1 = explode("-", $t1);

				$dateo = $dcal->u2g($st_date, $st_month, $st_year);
				$kastdate['rosa'] = mktime(0, 0, 0, $dateo['month'], $dateo['day'], $dateo['year']);


