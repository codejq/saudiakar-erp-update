		$moda = mysql_query($sql, $link);
		while ($rowmoda = mysql_fetch_array($moda)) {

			$mymoda = $rowmoda['kastdate'] - $mymoda;

		}
		$mymoda = sqrt($mymoda * $mymoda);

		$mymoda = ceil(($mymoda) / (60 * 60 * 24 * 30));
		if ($mymoda > 12 or $mymoda < 1) {
			$mymoda = 12;
		}
		$row2['duration'] = $mymoda;
		$sql = "update egar set duration='" . $mymoda . "' where rakam3akdid='" . $re['rakam3akdid'] . "' ";
		mysql_query($sql, $link);


	}

