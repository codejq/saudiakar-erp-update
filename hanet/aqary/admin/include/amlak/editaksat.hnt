	// start save aksat
	if ($saveaksat) {
		$maxKey = 0;
		foreach ($iscomplete as $key => $value){
			if($iscomplete[$key] && $key > $maxKey ){
				$maxKey = $key;
			}
		}
		$sql = "update aksat set iscomplete=1 where kastid < " .$maxKey . " and idsubaqar='" . $idsubaqar . "'	";
		mysql_query($sql, $link);

		// not to break older custumer
