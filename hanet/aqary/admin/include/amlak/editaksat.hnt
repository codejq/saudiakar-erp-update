    <script langauge=javascript>

        $(function () {
            $("#vat_type").val("<?=$row2["vat_type"];?>").trigger('change');
            $("#water_duration").val("<?=$row2["water_duration"];?>").trigger('change');
            $("#services_duration").val("<?=$row2["services_duration"];?>").trigger('change');
            $("#secondsa3e_duration").val("<?=$row2["secondsa3e_duration"];?>").trigger('change');
        });

        // Function to calculate depositeamount based on annualprice and duration
        // Duration is the number of months between payments (e.g., 6 = pay every 6 months)
        function calculateDepositeAmount() {
            var annualprice = parseFloat($('input[name="annualprice"]').val()) || 0;
            var duration = parseFloat($('input[name="duration"]').val()) || 1;
            
            if (duration > 0) {
                // depositeamount = (annual price / 12 months) * duration months
                var depositeamount = ((annualprice / 12) * duration).toFixed(2);
                $('input[name="depositeamount"]').val(depositeamount);
                calculatePayedAmount();
            }
        }

        // Function to calculate payedamount based on depositeamount and fees
        function calculatePayedAmount() {
            var depositeamount = parseFloat($('input[name="depositeamount"]').val()) || 0;
            var tamen = parseFloat($('input[name="tamen"]').val()) || 0;
            var fristsa3e = parseFloat($('input[name="fristsa3e"]').val()) || 0;
            var secondsa3e = parseFloat($('input[name="secondsa3e"]').val()) || 0;
            var water = parseFloat($('input[name="water"]').val()) || 0;
            var services = parseFloat($('input[name="services"]').val()) || 0;
            
            // Get duration settings (0 = first installment only, 1 = every installment)
            var secondsa3e_duration = parseInt($('#secondsa3e_duration').val()) || 0;
            var water_duration = parseInt($('#water_duration').val()) || 0;
            var services_duration = parseInt($('#services_duration').val()) || 0;
            
            // Start with depositeamount and tamen (always included)
            var payedamount = depositeamount + tamen + fristsa3e;
            
            // Add fees based on their duration settings
            // If duration is 0, add with first installment only
            // If duration is 1, add with every installment (but we're calculating first payment here)
            if (secondsa3e_duration == 0 || secondsa3e_duration == 1) {
                payedamount += secondsa3e;
            }
            
            if (water_duration == 0 || water_duration == 1) {
                payedamount += water;
            }
            
            if (services_duration == 0 || services_duration == 1) {
                payedamount += services;
            }
            
            $('input[name="payedamount"]').val(payedamount.toFixed(2));
        }

        // Add onchange events to duration and annualprice
        $('input[name="duration"]').on('change keyup', function() {
            calculateDepositeAmount();
        });
        
        $('input[name="annualprice"]').on('change keyup', function() {
            calculateDepositeAmount();
        });

        // Add onchange events to all fee-related fields
        $('input[name="depositeamount"], input[name="tamen"], input[name="fristsa3e"], input[name="secondsa3e"], input[name="water"], input[name="services"]').on('change keyup', function() {
            calculatePayedAmount();
        });

        // Add onchange events to duration selectors
        $('#secondsa3e_duration, #water_duration, #services_duration').on('change', function() {
            calculatePayedAmount();
        });

    </script>

