<script>
// Date range recalculation
document.getElementById('recalculateBtn').addEventListener('click', function() {
    const dd = document.getElementById('dd').value;
    const mm = document.getElementById('mm').value;
    const yy = document.getElementById('yy').value;
    const dd2 = document.getElementById('dd2').value;
    const mm2 = document.getElementById('mm2').value;
    const yy2 = document.getElementById('yy2').value;

    const url = `masrofateglalyat.hnt?startfrom=${dd}-${mm}-${yy}&enddate=${dd2}-${mm2}-${yy2}`;
    window.location.href = url;
});

// Allow Enter key to trigger recalculation
const dateInputs = document.querySelectorAll('.date-input-group input');
dateInputs.forEach(input => {
    input.addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
            document.getElementById('recalculateBtn').click();
        }
    });
});
</script>

