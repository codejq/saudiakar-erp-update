<?php
// Set page variables
$sc_title = "تقرير نوعيات المصروفات وإجمالياتها";
$sc_id = "52";

// Extract request variables
extract($_REQUEST);

// Initialize variables
$startfrom = isset($startfrom) ? $startfrom : null;
$enddate = isset($enddate) ? $enddate : "";
$startfromx = isset($startfromx) ? $startfromx : null;
$enddatex = isset($enddatex) ? $enddatex : null;

// Check if this is a report view (print mode)
$report = isset($report) && $report == 1 ? 1 : 0;

include_once "../../../nocash.hnt";
require '../arabicTools.class.hnt';
include_once "arabic_num.class.hnt";
include_once "amlakfunctions.hnt";
$arabicTools = new ArabicTools();

// Export handler — runs before any HTML output
if (isset($_GET['export']) && in_array(trim($_GET['export']), ['csv', 'xls'], true)) {
    include_once "../../../connectdb.hnt";
    $_exp_start = isset($_GET['startfromx']) && intval($_GET['startfromx']) ? intval($_GET['startfromx']) : 0;
    $_exp_end   = isset($_GET['enddatex'])   && intval($_GET['enddatex'])   ? intval($_GET['enddatex'])   : 0;
    if (!$_exp_start && isset($_GET['startfrom']) && $_GET['startfrom']) {
        $_d = explode("-", "0-0-0-" . $_GET['startfrom']);
        if (isset($_d[5])) $_exp_start = mktime(0, 0, 0, $_d[4], $_d[3], $_d[5]);
    }
    if (!$_exp_end && isset($_GET['enddate']) && $_GET['enddate']) {
        $_d = explode("-", "0-0-0-" . $_GET['enddate']);
        if (isset($_d[5])) $_exp_end = mktime(0, 0, 0, $_d[4], $_d[3], $_d[5]) + 86400;
    }
    if (!$_exp_start) $_exp_start = time() - 15768000;
    if (!$_exp_end)   $_exp_end   = time() + 86400;

    $exp_sql = "SELECT m.idmasrofcod, SUM(m.amount) as xp, mt.masrofkind
                FROM masrofat m
                LEFT JOIN masrofattakweed mt ON m.idmasrofcod = mt.idmasrofcod
                WHERE m.payeddate > '" . intval($_exp_start) . "'
                AND m.payeddate < '" . intval($_exp_end) . "'
                GROUP BY m.idmasrofcod, mt.masrofkind
                ORDER BY xp DESC";
    $exp_res = mysql_query($exp_sql, $link);

    $exp_headers = ['م', 'نوع المصروف', 'إجمالي القيمة'];
    $exp_rows = [];
    $xx = 0;
    while ($r = mysql_fetch_array($exp_res)) {
        $xx++;
        $exp_rows[] = [$xx, $r['masrofkind'] ?: 'غير محدد', number_format($r['xp'], 2, '.', '')];
    }

    $_exp_type = trim($_GET['export']);
    $_fn = date('Ymd_His');
    if ($_exp_type === 'csv') {
        header('Content-Type: text/csv; charset=UTF-8');
        header('Content-Disposition: attachment; filename="masrofat_eglalyat_' . $_fn . '.csv"');
        $_out = fopen('php://output', 'w');
        fwrite($_out, "\xEF\xBB\xBF");
        fputcsv($_out, $exp_headers, ',', '"', '\\');
        foreach ($exp_rows as $_r) fputcsv($_out, $_r, ',', '"', '\\');
        fclose($_out);
        exit;
    }
    header('Content-Type: application/vnd.ms-excel; charset=UTF-8');
    header('Content-Disposition: attachment; filename="masrofat_eglalyat_' . $_fn . '.xls"');
    echo '<html lang="ar" dir="rtl"><head><meta charset="UTF-8"></head><body><table border="1"><tr>';
    foreach ($exp_headers as $_h) echo '<th>' . htmlspecialchars($_h) . '</th>';
    echo '</tr>';
    foreach ($exp_rows as $_r) { echo '<tr>'; foreach ($_r as $_c) echo '<td>' . htmlspecialchars($_c) . '</td>'; echo '</tr>'; }
    echo '</table></body></html>';
    exit;
}

if ($report == 1) {
    include_once "../../../report_header.hnt";
} else {
    include_once "../../../header.hnt";
}

// Get current date in Arabic
$daxx_now = date("H/i/s/m/d/Y");
$daxx_now = explode("/", $daxx_now);
$h_date = mktime($daxx_now[0], $daxx_now[1], $daxx_now[2], $daxx_now[3], $daxx_now[4], $daxx_now[5]);
$h_date2 = arabicDate("ar:l d/F -Y h:iA", $h_date);
$h_date1 = arabicDate('hj:l d-F-Y هـ', $h_date);
$display_date = ($hnt_dll || $hnt_supper_dll == 5) ? $h_date2 : $h_date1;

// Calculate default date range (6 months)
if (!$hnt_dll && $hnt_supper_dll != 5) {
    $ers = 15277248; // Hijri 6 months in seconds
} else {
    $ers = 15768000; // Gregorian 6 months in seconds
}

// Process date range
if ($startfrom) {
    $daxx = explode("-", "0-0-0-" . $startfrom);
    $dax2 = explode("-", "0-0-0-" . $enddate);

    // Check if Hijri date (year between 1400-1500)
    if (($daxx[5] < 1500) && ($daxx[5] > 1400)) {
        $startfrom = str_replace("-", "/", $startfrom);
        $startfrom = $arabicTools->dateHejri2Geo($startfrom);
        $enddate = str_replace("-", "/", $enddate);
        $enddate = $arabicTools->dateHejri2Geo($enddate);
    }

    $daxx = explode("-", "0-0-0-" . $startfrom);
    $startfrom = mktime(0, 0, 0, $daxx[4], $daxx[3], $daxx[5]);
    $dax2 = explode("-", "0-0-0-" . $enddate);
    $enddate = mktime(0, 0, 0, $dax2[4], $dax2[3], $dax2[5]);
} else {
    $startfrom = time() - $ers;
    $enddate = time();
}

// Format dates for display
if (!$hnt_dll && $hnt_supper_dll != 5) {
    $daxx = explode("-", arabicDate('hj:s-i-h-d-m-Y', $startfrom));
    $dax2 = explode("-", arabicDate('hj:s-i-h-d-m-Y', $enddate));
} else {
    $daxx = explode("-", arabicDate('ar:s-i-h-d-m-Y', $startfrom));
    $dax2 = explode("-", date('s-i-h-d-m-Y', $enddate));
}

if ($startfromx) {
    $startfrom = $startfromx;
    $enddate = $enddatex;
}

// Get expenses data grouped by type
$sqlaq = "SELECT SUM(amount) as xp, idmasrofcod FROM masrofat
          WHERE payeddate > '" . $startfrom . "'
          AND payeddate < '" . $enddate . "'
          GROUP BY idmasrofcod";
$resaq = mysql_query($sqlaq, $link);

// Calculate total expenses
$total_query = mysql_query("SELECT SUM(amount) as total FROM masrofat
                            WHERE payeddate > '" . $startfrom . "'
                            AND payeddate < '" . $enddate . "'", $link);
$total_result = mysql_fetch_array($total_query);
$total_expenses = isset($total_result['total']) ? $total_result['total'] : 0;

// Count expense types
$expense_count = mysql_num_rows($resaq);

// Only render HTML if NOT in report mode
if ($report != 1) {
?>

