<script>
// Modern ES6+ JavaScript

// Toggle property section based on movement type
const togglePropertySection = () => {
    const movement = document.getElementById('movement').value;
    const propertySection = document.getElementById('propertySection');

    if (movement == '3' || movement == '4') {
        propertySection.style.display = 'block';
    } else {
        propertySection.style.display = 'none';
    }
};

// Toggle check details based on payment method
const toggleCheckDetails = () => {
    const checkDetails = document.getElementById('checkDetails');
    const isCash = document.getElementById('nakdan').checked;

    checkDetails.style.display = isCash ? 'none' : 'block';
};

// Calculate totals
const calculateTotal = () => {
    const allcollectedmony = floatval(document.getElementById('allcollectedmony').value);
    const alldeleverdmony = floatval(document.getElementById('alldeleverdmony').value);
    let alltameenmony = floatval(document.getElementById('alltameenmony').value);
    let allwaterdmony = floatval(document.getElementById('allwaterdmony').value);
    const alnesbamonytotal = floatval(document.getElementById('alnesbamonytotal').value);
    const alnesbamony = floatval(document.getElementById('alnesbamony').value);
    const allexpensesdmony = floatval(document.getElementById('allexpensesdmony').value);

    const addtameento = document.getElementById('addtameento').value;
    const addwaterto = document.getElementById('addwaterto').value;

    // Adjust insurance if not for owner
    if (addtameento !== 'المالك') {
        document.getElementById('alltameenmony').value = -Math.abs(alltameenmony);
        alltameenmony = 0;
    }

    // Adjust water if not for owner
    if (addwaterto !== 'المالك') {
        document.getElementById('allwaterdmony').value = -Math.abs(allwaterdmony);
        allwaterdmony = 0;
    }

    // Calculate reminder
    let remindermony = allcollectedmony - alldeleverdmony;
    remindermony = remindermony + alltameenmony + allwaterdmony;

    // Calculate percentage
    document.getElementById('alnesbamonytotal').value =
        ((alnesbamony * (allcollectedmony + alltameenmony + allwaterdmony)) / 100).toFixed(2);

    remindermony = remindermony - floatval(document.getElementById('alnesbamonytotal').value);
    remindermony = remindermony - allexpensesdmony;

    document.getElementById('allnotdeleverdmony').value = remindermony.toFixed(2);
    document.getElementById('nonedeleverttomalek').value = remindermony.toFixed(2);
};

// Load property data
const loadPropertyData = async (pageNum = 1) => {
    const idaqar = document.getElementById('idaqar').value;

    if (!idaqar) {
        return;
    }

    // Build SQL for revenues
    let sql = `SELECT iderad as 'رقم',
               pymentdesription as 'بيـــــان الإيــراد',
               (amount - mysa3ee) as 'المبلغ',
               FROM_UNIXTIME(paymentdate,'%Y-%m-%d') as 'التاريخ',
               tasfia as 'تصفية'
               FROM eradat
               WHERE tasfia='' AND idaqar='${idaqar}'`;

    // Load insurance destination
    const sqlAddTameen = `SELECT IF(addtameento='malek','المالك','المكتب') FROM amlak WHERE idaqar='${idaqar}'`;
    ajaxmysqlrow(sqlAddTameen, 'addtameento');

    // Load water destination
    const sqlAddWater = `SELECT IF(addwaterto='malek','المالك','المكتب') FROM amlak WHERE idaqar='${idaqar}'`;
    ajaxmysqlrow(sqlAddWater, 'addwaterto');

    // Load collected money
    const sqlCollected = `SELECT SUM(amount - mysa3ee - tamen - mywater) FROM eradat WHERE tasfia='' AND idaqar='${idaqar}'`;
    ajaxmysqlrow(sqlCollected, 'allcollectedmony');

    // Load delivered money
    const sqlDelivered = `SELECT SUM(amount) FROM sanadsarf WHERE tasfia='' AND aqarid='${idaqar}'`;
    ajaxmysqlrow(sqlDelivered, 'alldeleverdmony');

    // Load expenses
    const sqlExpenses = `SELECT SUM(amount) FROM masrofat WHERE  fund_source = 0 AND tasfia='' AND idaqar='${idaqar}'`;
    ajaxmysqlrow(sqlExpenses, 'allexpensesdmony');

    // Load insurance
    const sqlTameen = `SELECT SUM(tamen) FROM eradat WHERE tasfia='' AND idaqar='${idaqar}'`;
    ajaxmysqlrow(sqlTameen, 'alltameenmony');

    // Load water
    const sqlWater = `SELECT SUM(mywater) FROM eradat WHERE tasfia='' AND idaqar='${idaqar}'`;
    ajaxmysqlrow(sqlWater, 'allwaterdmony');

    // Load percentage
    const sqlNesba = `SELECT IF(persentage < 3000, persentage/100, 0) FROM amlak WHERE idaqar='${idaqar}'`;
    ajaxmysqlrow(sqlNesba, 'alnesbamony');

    // Fill revenue grid
    ajaxfillgrid(sql, 'containerid', true, pageNum);

    // Build SQL for expenses
    let sqlExpense = `SELECT idmasrof as 'رقم',
                      (SELECT masrofkind FROM masrofattakweed WHERE masrofattakweed.idmasrofcod=masrofat.idmasrofcod) as 'النوع',
                      payeddue as 'بيــــان المصــروف',
                      amount as 'القيمة',
                      FROM_UNIXTIME(payeddate,'%Y-%m-%d') as 'التاريخ'
                      FROM masrofat
                      WHERE tasfia='' AND idaqar='${idaqar}'`;

    ajaxfillgrid(sqlExpense, 'containerid2', true, pageNum);

    // Calculate totals after a delay
    setTimeout(calculateTotal, 1000);
};

// Form submission handler
document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('formsandsarf');
    const movement = document.getElementById('movement');
    const idaqar = document.getElementById('idaqar');
    const nakdan = document.getElementById('nakdan');
    const checkan = document.getElementById('checkan');
    const showConfirmBtn = document.getElementById('showConfirmBtn');
    const cancelConfirmBtn = document.getElementById('cancelConfirmBtn');
    const initialButtons = document.getElementById('initialButtons');
    const confirmButtons = document.getElementById('confirmButtons');
    const prevPage = document.getElementById('prevPage');
    const nextPage = document.getElementById('nextPage');
    const tajpagenum = document.getElementById('tajpagenum');
    const viewSystemPoints = document.getElementById('viewSystemPoints');

    // Movement change handler - Use jQuery for Select2
    $('#movement').on('change', togglePropertySection);

    // Property change handler - Use jQuery for Select2
    $('#idaqar').on('change', function() {
        loadPropertyData();
    });

    // Payment method change handlers
    nakdan.addEventListener('change', toggleCheckDetails);
    checkan.addEventListener('change', toggleCheckDetails);

    // Show confirmation buttons
    showConfirmBtn.addEventListener('click', () => {
        initialButtons.style.display = 'none';
        confirmButtons.style.display = 'flex';
    });

    // Cancel confirmation
    cancelConfirmBtn.addEventListener('click', () => {
        confirmButtons.style.display = 'none';
        initialButtons.style.display = 'flex';
    });

    // Pagination handlers
    prevPage.addEventListener('click', () => {
        let page = intval(tajpagenum.value) - 1;
        if (page < 1) return;
        tajpagenum.value = page;
        loadPropertyData(page);
    });

    nextPage.addEventListener('click', () => {
        const containerid = document.getElementById('containerid');
        if (!containerid.innerHTML) return;

        let page = intval(tajpagenum.value) + 1;
        tajpagenum.value = page;
        loadPropertyData(page);
    });

    tajpagenum.addEventListener('keyup', (e) => {
        if (e.key === 'Enter') {
            loadPropertyData(intval(tajpagenum.value));
        }
    });

    // View system points handler
    viewSystemPoints.addEventListener('click', (e) => {
        e.preventDefault();
        const aqarId = idaqar.value;
        const aqarName = idaqar.options[idaqar.selectedIndex].text;

        if (aqarId) {
            window.location.href = `stat_point.hnt?idaqar=${aqarId}&aqarname=${encodeURIComponent(aqarName)}`;
        } else {
            alert('الرجاء اختيار عقار أولاً');
        }
    });

    // Form submission
    form.addEventListener('submit', async (e) => {
        e.preventDefault();

        // Validation
        const amount = floatval(document.getElementById('amount').value);
        if (amount < 1) {
            alert('لم تقم بإدخال مبلغ');
            return;
        }

        const movementVal = intval(movement.value);
        if (movementVal == 3 || movementVal == 4) {
            const allnotdeleverdmony = floatval(document.getElementById('allnotdeleverdmony').value);
            if (amount > allnotdeleverdmony) {
                alert('المبلغ المدخل أكبر من المبلغ المتاح في حساب العميل');
                return;
            }
        }

        // Submit via AJAX
        const formData = new FormData(form);

        try {
            const response = await fetch(window.location.href, {
                method: 'POST',
                body: formData
            });

            const result = await response.json();

            if (result.success) {
                // Redirect to success page
                let redirectUrl = `sanad_sarf.hnt?shwome=${result.sanad_id}`;
                if (result.reminder) {
                    redirectUrl += `&reminder=${result.reminder}`;
                }
                if (result.nethampoint) {
                    redirectUrl += `&nethampoint=${result.nethampoint}`;
                }
                window.location.href = redirectUrl;
            } else {
                alert(result.message || 'حدث خطأ أثناء الحفظ');
            }
        } catch (error) {
            console.error('Error:', error);
            alert('حدث خطأ أثناء الحفظ');
        }
    });

    // Auto-calculate totals every 2 seconds
    setInterval(calculateTotal, 2000);

    // Initialize
    togglePropertySection();
    toggleCheckDetails();
});
</script>


<?php require('../../../foter.hnt'); ?>
