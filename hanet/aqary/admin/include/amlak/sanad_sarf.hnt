<?php
// Set page variables
$sc_title = "إصدار سند صرف";
$sc_id = "54";
$ajax_request = isset($_REQUEST['ajax']) ? intval($_REQUEST['ajax']) : 0;

 if($ajax_request == 1) {
     include_once "../../../reqloginajax.hnt";
 }
else{
$_SERVER['HTTP_REFERER'] = "reports.hnt";
include_once "../../../header.hnt";


}


// Include required files
require '../uCal.class.hnt';
require '../arabicTools.class.hnt';
$dcal = new uCal();


// Initialize variables
$amount = isset($_REQUEST['amount']) ? $_REQUEST['amount'] : '';
$sanadate_input = isset($_REQUEST['sanadate']) ? $_REQUEST['sanadate'] : '';
$bayansanad = isset($_REQUEST['bayansanad']) ? addslashes($_REQUEST['bayansanad']) : '';
$note = isset($_REQUEST['note']) ? addslashes($_REQUEST['note']) : '';
$mostafeed = isset($_REQUEST['mostafeed']) ? addslashes($_REQUEST['mostafeed']) : '';
$movement = isset($_REQUEST['movement']) ? intval($_REQUEST['movement']) : 0;
$mowazaf = isset($_REQUEST['mowazaf']) ? addslashes($_REQUEST['mowazaf']) : '';
$aqarid = isset($_REQUEST['aqarid']) ? intval($_REQUEST['aqarid']) : 0;
$checkrakam = isset($_REQUEST['checkrakam']) ? addslashes($_REQUEST['checkrakam']) : '';
$checkdate = isset($_REQUEST['checkdate']) ? addslashes($_REQUEST['checkdate']) : '';
$checkbank = isset($_REQUEST['checkbank']) ? addslashes($_REQUEST['checkbank']) : '';
$nonedeleverttomalek = isset($_REQUEST['nonedeleverttomalek']) ? floatval($_REQUEST['nonedeleverttomalek']) : 0;


// Handle AJAX form submission
if ($amount && $ajax_request == 1) {
    // Process date
    $payeddate = explode("/", $sanadate_input);
    if (count($payeddate) == 3 && $payeddate[2] < 1700) {
        $dateo = $dcal->u2g($payeddate[0], $payeddate[1], $payeddate[2]);
        $payeddate[0] = $dateo['day'];
        $payeddate[1] = $dateo['month'];
        $payeddate[2] = $dateo['year'];
    }

    $sanadate = mktime(0, 0, 0, $payeddate[1], $payeddate[0], $payeddate[2]);

    // Insert payment voucher
    $sql = "INSERT INTO sanadsarf SET
            sanadate = '" . addslashes($sanadate) . "',
            amount = '" . addslashes($amount) . "',
            bayan = '" . $bayansanad . "',
            note = '" . $note . "',
            mostafeed = '" . $mostafeed . "',
            qayedtype = '" . $movement . "',
            mowazaf = '" . $mowazaf . "',
            aqarid = '" . $aqarid . "',
            checkrakam = '" . $checkrakam . "',
            checkdate = '" . $checkdate . "',
            checkbank = '" . $checkbank . "'";

    mysql_query($sql, $link);
    $sanadsarfrakam = mysql_insert_id();

    // Lock tables for transaction
    mysql_query("LOCK TABLES eradat WRITE, sanadsarf WRITE, masrofat WRITE", $link);

    $reminder = $nonedeleverttomalek - floatval($amount);
    $nethampoint = 0;

    // Check if we need to create a system checkpoint
    if ($reminder < 2 && ($movement == 3 || $movement == 4) && $aqarid > 0) {
        $mytime = time();
        mysql_query("UPDATE eradat SET tasfia = '" . $mytime . "' WHERE tasfia = '' AND idaqar = '" . $aqarid . "'", $link);
        mysql_query("UPDATE sanadsarf SET tasfia = '" . $mytime . "' WHERE tasfia = '' AND aqarid = '" . $aqarid . "'", $link);
        mysql_query("UPDATE masrofat SET tasfia = '" . $mytime . "' WHERE tasfia = '' AND idaqar = '" . $aqarid . "'", $link);
        $nethampoint = 1;
    }

    mysql_query("UNLOCK TABLES", $link);

    // Return JSON response
    $response = array(
        'success' => true,
        'message' => 'تم إدراج السند بنجاح',
        'sanad_id' => $sanadsarfrakam,
        'reminder' => $reminder,
        'nethampoint' => $nethampoint
    );

    echo json_encode($response, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES);
    exit();
}

// Handle success messages
$nethampoint = isset($_REQUEST['nethampoint']) ? intval($_REQUEST['nethampoint']) : 0;
$reminder = isset($_REQUEST['reminder']) ? floatval($_REQUEST['reminder']) : 0;
$shwome = isset($_REQUEST['shwome']) ? intval($_REQUEST['shwome']) : 0;

if ($nethampoint) {
    echo '<div class="alert alert-success text-center mb-3" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>
            <strong>تم إنشاء نقطة نظام بتاريخ اليوم</strong> - لن تظهر الإيرادات والمصروفات السابقة في سند القبض
          </div>';
}

if ($reminder) {
    echo '<div class="alert alert-warning text-center mb-3" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <strong>تنبيه:</strong> تم إنشاء نقطة نظام وعليك أن تصرف مبلغ ' . number_format($reminder, 2) . ' وذلك لضبط الحسابات
          </div>';
}

if ($shwome) {
    echo '<div class="alert alert-success text-center mb-3" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>
            <h5>تم إدراج السند بنجاح</h5>
            <div class="mt-3">
                <a href="selectprintform.hnt?formtype=paymentvaoucher&id=' . $shwome . '" class="btn btn-primary me-2">
                    <i class="bi bi-printer me-1"></i>
                    عرض نسخة للطباعة
                </a>
                <a href="reports.hnt" class="btn btn-secondary">
                    <i class="bi bi-x-circle me-1"></i>
                    إلغاء الأمر
                </a>
            </div>
          </div>';
    require('../../../foter.hnt');
    exit();
}

// Get current date
if ($hnt_dll || $hnt_supper_dll == 5) {
    $today = date("d/m/Y", time());
} else {
    $today_arr = $dcal->g2u(date("d", time()), date("m", time()), date("Y", time()));
    $today = $today_arr['day'] . '/' . $today_arr['month'] . '/' . $today_arr['year'];
}
?>

