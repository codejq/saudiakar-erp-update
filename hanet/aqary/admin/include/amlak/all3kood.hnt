                if (($xi > ($page - 4) && $xi < ($page + 4)) || $xi == 1 || $xi == $pagenum || $xi < 4 || $xi > ($pagenum - 4)) {
                  echo "<li class='page-item {$active}'>";
                  echo "<a class='page-link' href='?search=" . urlencode($search) . "&page={$xi}&searchold={$searchold}&status_filter=" . urlencode($currentStatusFilter) . "' {$bgStyle}>{$xi}</a>";
                  echo "</li>";
                } elseif ($xi == ($page - 4) || $xi == ($page + 4)) {
                  echo "<li class='page-item disabled'><span class='page-link'>...</span></li>";
                }
              }
              ?>
