                <th>وورد</th>
                <th>الحالة</th>
                <th>إنهاء</th>
              </tr>
            </thead>
            <tbody>
              <?php
              $sql = "SELECT e.*,
                      CASE
                        WHEN e.status IS NULL OR e.status = '' THEN
                          CASE WHEN e.txt3akd = '' THEN 'active' ELSE 'expired' END
                        ELSE e.status
                      END as current_status
                      FROM egar e
                      {$where}
                      ORDER BY e.rakam3akdid DESC
                      LIMIT {$limit}";
              $result = mysql_query($sql, $link);

              if (!$result || mysql_num_rows($result) == 0) {
                echo "<tr><td colspan='14' class='text-center py-4'>";
                echo "<i class='bi bi-inbox fs-1 text-muted'></i><br>";
                echo "<span class='text-muted'>لا توجد عقود مطابقة للبحث</span>";
                echo "</td></tr>";
              }

              while ($row = mysql_fetch_array($result)) {
                // Get tenant name - use elect field for terminated contracts
                $tenantId = intval($row['mostagerid']);
                
                // If contract is terminated/expired and mostagerid is 0, try to get tenant from elect field
                if ($tenantId == 0 && !empty($row['elect'])) {
                    $tenantId = intval($row['elect']);
                }
                
                $sql2 = "SELECT mostagername FROM mostagereen WHERE mostagerid='" . $tenantId . "'";
                $rowmos = mysql_fetch_array(mysql_query($sql2, $link));

                // Format dates
                if ($hnt_dll || $hnt_supper_dll == 5) {
                  $dhd1 = date("d/m/Y", $row['startegar']);
                  $dhd2 = date("d/m/Y", $row['end3aqd']);
                } else {
                  $dateo = $dcal->g2u(date("d", $row['startegar']), date("m", $row['startegar']), date("Y", $row['startegar']));
                  $dhd1 = $dateo['day'] . "/" . $dateo['month'] . "/" . $dateo['year'];

                  $dateo = $dcal->g2u(date("d", $row['end3aqd']), date("m", $row['end3aqd']), date("Y", $row['end3aqd']));
                  $dhd2 = $dateo['day'] . "/" . $dateo['month'] . "/" . $dateo['year'];
                }

                // Attachment link
                if ($row['attachedimages']) {
                  $attachedimagelink = "<a href='/aqary/admin/include/uploadcenter.hnt?ids=" . htmlspecialchars($row['attachedimages'], ENT_QUOTES, 'UTF-8') .
                    "&table=egar&tableid=rakam3akdid&tableidvalue=" . intval($row['rakam3akdid']) . "'
                                                    class='text-primary' target='_blank' title='عرض الملفات المرفقة'>
                                                    <i class='bi bi-paperclip fs-5'></i>
                                                    </a>";
                } else {
                  $attachedimagelink = "<a href='/aqary/admin/include/uploadcenter.hnt?ids=0,0&table=egar&tableid=rakam3akdid&tableidvalue=" . intval($row['rakam3akdid']) . "'
                                                    class='text-secondary' target='_blank' title='لا يوجد مرفقات - انقر لإضافة'>
                                                    <i class='bi bi-link fs-5'></i>
                                                    </a>";
                }

                // Contract status - use new status system
                $statusBadge = renderContractStatus($row);
              ?>
                <tr>
                  <td>
                    <a href='show3akd.hnt?rakam3akdid=<?= intval($row['rakam3akdid']) ?>'
                      class="text-decoration-none fw-bold">
                      <?= intval($row['rakam3akdid']) ?>
                    </a>
                  </td>
                  <td><?= htmlspecialchars($row['aqaraddress'], ENT_QUOTES, 'UTF-8') ?></td>
                  <td>
                    <a href='editmostager.hnt?small=small&mostagerid=<?= $tenantId ?>'
                      onclick="return hs.htmlExpand(this, {
                                       contentId: 'my-content',
                                       objectType: 'iframe',
                                       objectWidth: 950,
                                       width: 950,
                                       objectHeight: 900
                                   });"
                      class="text-decoration-none">
                      <?= htmlspecialchars($rowmos['mostagername'] ?? '', ENT_QUOTES, 'UTF-8') ?>
                    </a>
                  </td>
                  <td><?= htmlspecialchars($row['depositeamount'], ENT_QUOTES, 'UTF-8') ?></td>
                  <td><?= $dhd1 ?></td>
                  <td><?= $dhd2 ?></td>
                  <td><?= htmlspecialchars($row['tamen'], ENT_QUOTES, 'UTF-8') ?></td>
                  <td><?= htmlspecialchars($row['fristsa3e'], ENT_QUOTES, 'UTF-8') ?></td>
                  <td><?= htmlspecialchars($row['water'], ENT_QUOTES, 'UTF-8') ?></td>
                  <td><?= $attachedimagelink ?></td>
                  <td>
                    <a href='selectprintform.hnt?formtype=rentcontract&id=<?= intval($row['rakam3akdid']) ?>'
                      class='btn btn-sm btn-outline-primary' target='_blank'>
                      <i class="bi bi-eye me-1"></i>عرض
                    </a>
                  </td>
                  <td>
                    <button type="button" class='btn btn-sm btn-outline-info'
                      onclick="openWordDocument('<?= $server ?>/aqary/admin/include/amlak/show3akdvb.hnt?rakam3akdid=<?= intval($row['rakam3akdid']) ?>');">
                      <i class="bi bi-file-word me-1"></i>وورد
                    </button>
                  </td>
                  <td><?= $statusBadge ?></td>
                  <td>
                    <?php if ($row['current_status'] != 'renewed' && $row['current_status'] != 'expired' && $row['current_status'] != 'terminated' && $row['current_status'] != 'cancelled') { ?>
                      <button type="button" class='btn btn-sm btn-danger <?= "policy_" . $sc_id . "_deleetes" ?>'
                        onclick="confirmTermination(<?= intval($row['rakam3akdid']) ?>);">
                        <i class="bi bi-x-circle me-1"></i>إنهاء
                      </button>
                    <?php } else { ?>
                      <span class="text-muted">-</span>
                    <?php } ?>
                  </td>
                </tr>
