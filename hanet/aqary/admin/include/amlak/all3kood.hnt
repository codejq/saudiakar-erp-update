// Set page variables
$sc_title = "إستعراض عقود الإيجار";
$sc_id = "45";

// Extract request variables
extract($_REQUEST);

// Check if this is an AJAX request
$is_ajax_request = isset($_POST['ajax_submit']) && $_POST['ajax_submit'] == '1';

// Only include headers if NOT an AJAX request
if (!$is_ajax_request) {
  include_once "../../../nocash.hnt";
  include_once "../../../header.hnt";
} else {
  include_once "../../../reqloginajax.hnt";
}

// Include required classes
require '../arabicTools.class.hnt';
require '../uCal.class.hnt';
$dcal = new uCal;
require_once 'contract_status_indicator.hnt';

// Database schema updates
@mysql_query("ALTER TABLE egar ADD attachedimages VARCHAR(500) NOT NULL", $link);

// Initialize variables
$search = isset($_REQUEST['search']) ? trim($_REQUEST['search']) : '';
$searchold = isset($_REQUEST['searchold']) ? intval($_REQUEST['searchold']) : 0;
$page = isset($_REQUEST['page']) ? intval($_REQUEST['page']) : 1;
$rowperpage = 20;

// Build WHERE clause
$where = "WHERE txt3akd=''";
if ($searchold) {
  $where = "WHERE txt3akd!=''";
}

if ($search) {
  if (is_numeric($search)) {
    $where = "WHERE txt3akd='' AND rakam3akdid='" . addslashes($search) . "'";
    if ($searchold) {
      $where = "WHERE txt3akd!='' AND rakam3akdid='" . addslashes($search) . "'";
    }
  } else {
    $where = "WHERE txt3akd='' AND txtcash LIKE BINARY '%" . addslashes($search) . "%'";
    if ($searchold) {
      $where = "WHERE txt3akd!='' AND txtcash LIKE BINARY '%" . addslashes($search) . "%'";
    }
  }
}

// Status filter
if (isset($_REQUEST['status_filter']) && $_REQUEST['status_filter'] !== '') {
  $statusFilter = mysql_real_escape_string($_REQUEST['status_filter']);
  $where .= " AND status = '" . $statusFilter . "'";
}

// Calculate pagination
$sql = "SELECT COUNT(rakam3akdid) as dd FROM egar {$where}";
$rownum = mysql_fetch_array(mysql_query($sql, $link));
$rownum = isset($rownum['dd']) ? $rownum['dd'] : 0;

if (!$rowperpage) {
  $rowperpage = 20;
}
$pagenum = ceil($rownum / $rowperpage);

if (!isset($page) || $page == '' || $page < 1) {
  $page = 1;
}

$limit = (($page - 1) * $rowperpage) . "," . $rowperpage;
if ($page == 1 || $page == '') {
  $limit = $rowperpage;
}

// Only render HTML if NOT AJAX request
if (!$is_ajax_request) {
?>

  <!-- Bootstrap 5.3 Toast Container -->
  <div id="toast-container" class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 9999;"></div>

  <style>
    .section-header {
      background: linear-gradient(135deg, #0891b2 0%, #0e7490 100%);
