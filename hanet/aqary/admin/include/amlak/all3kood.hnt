    <!-- Contracts Table -->
    <div class="card shadow-sm border-0">
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover contract-table mb-0">
            <thead>
              <tr>
                <th>رقم العقد</th>
