    <?php
    // Get property data
    $sql = "SELECT aqarname, persentage FROM amlak WHERE idaqar='" . intval($idaqar) . "'";
    $property_result = mysql_query($sql, $link);
    $property_data = mysql_fetch_array($property_result);
    $property_name = $property_data['aqarname'] ?? 'غير محدد';
    $persentage = $property_data['persentage'] ?? 0;

    // Calculate date range
    if (!$hnt_dll && $hnt_supper_dll != 5) {
        $ers = 15277248; // Hijri year in seconds
    } else {
        $ers = 15768000; // Gregorian year in seconds
    }

    if ($startfrom) {
        $daxx = explode("-", "0-0-0-" . $startfrom);
        if (($daxx[5] < 1500) && ($daxx[5] > 1400)) {
            $startfrom = str_replace("-", "/", $startfrom);
            $startfrom = $arabicTools->dateHejri2Geo($startfrom);
            $enddate = str_replace("-", "/", $enddate);
            $enddate = $arabicTools->dateHejri2Geo($enddate);
        }
        $daxx = explode("-", "0-0-0-" . $startfrom);
        $startfrom = mktime(0, 0, 0, $daxx[4], $daxx[3], $daxx[5]);
        $dax2 = explode("-", "0-0-0-" . $enddate);
        $enddate = mktime(0, 0, 0, $dax2[4], $dax2[3], $dax2[5]);
    } else {
        $startfrom = time() - $ers;
        $enddate = time();
    }

    if (!$hnt_dll && $hnt_supper_dll != 5) {
        $daxx = explode("-", $arabicTools->arabicDate('hj:s-i-h-d-m-Y', $startfrom));
        $dax2 = explode("-", $arabicTools->arabicDate('hj:s-i-h-d-m-Y', $enddate));
    } else {
        $daxx = explode("-", date('s-i-h-d-m-Y', $startfrom));
        $dax2 = explode("-", date('s-i-h-d-m-Y', $enddate));
    }

    if ($startfromx) {
        $startfrom = $startfromx;
        $enddate = $enddatex;
    }

    // Get current date for report header
    $current_time = time();
    if (!$hnt_dll && $hnt_supper_dll != 5) {
        $current_date_hijri = $arabicTools->arabicDate('hj:l d-F-Y هـ', $current_time);
        $current_date_gregorian = date('d/m/Y', $current_time);
    } else {
        $current_date_gregorian = date('d/m/Y', $current_time);
        $current_date_hijri = $arabicTools->arabicDate('hj:l d-F-Y هـ', $current_time);
    }
    ?>

    <!-- Report Header -->
    <div class="report-card">
