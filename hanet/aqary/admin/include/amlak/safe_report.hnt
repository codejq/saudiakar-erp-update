            <h4 class="mb-3"><?= htmlspecialchars($property_name, ENT_QUOTES, 'UTF-8') ?></h4>
            <p class="mb-1">بتاريخ : <?= $current_date_gregorian ?></p>
            <p class="mb-0">الموافق: <?= $current_date_hijri ?></p>
