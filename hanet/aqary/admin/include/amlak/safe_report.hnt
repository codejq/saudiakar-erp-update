                        <span class="input-group-text">/</span>
                        <input type="text" class="form-control text-center" id="mm" value="<?= $daxx[4] ?>" placeholder="شهر" style="width: 60px;">
                        <span class="input-group-text">/</span>
                        <input type="text" class="form-control text-center" id="yy" value="<?= $daxx[5] ?>" placeholder="سنة" style="width: 80px;">
                    </div>
                </div>
                <div class="col-auto">
                    <label class="form-label mb-1">إلى تاريخ</label>
                    <div class="input-group input-group-sm">
                        <input type="text" class="form-control text-center" id="dd2" value="<?= $dax2[3] ?>" placeholder="يوم" style="width: 60px;">
                        <span class="input-group-text">/</span>
                        <input type="text" class="form-control text-center" id="mm2" value="<?= $dax2[4] ?>" placeholder="شهر" style="width: 60px;">
                        <span class="input-group-text">/</span>
                        <input type="text" class="form-control text-center" id="yy2" value="<?= $dax2[5] ?>" placeholder="سنة" style="width: 80px;">
                    </div>
                </div>
                <div class="col-auto">
                    <button type="button" class="btn btn-info btn-sm" onclick="recalculateReport();">
                        <i class="bi bi-arrow-clockwise me-1"></i>
                        إعادة الحساب
                    </button>
                </div>
            </div>
        </div>
    </div>
    <?php } ?>


    <?php
    // Calculate revenues
    $sql = "SELECT SUM(amount) as total_amount, SUM(mysa3ee) as total_sa3ee, SUM(mywater) as total_water
            FROM eradat
            WHERE idaqar='" . intval($idaqar) . "'
            AND paymentdate > '" . intval($startfrom) . "'
            AND paymentdate < '" . intval($enddate) . "'";
    $revenue_result = mysql_query($sql, $link);
    $revenue_data = mysql_fetch_array($revenue_result);
    $erad = $revenue_data['total_amount'] ?? 0;
    $sa3ee = $revenue_data['total_sa3ee'] ?? 0;
    $water = $revenue_data['total_water'] ?? 0;

    // Calculate expenses
    $sql = "SELECT SUM(amount) as total_expenses
            FROM masrofat
            WHERE idaqar='" . intval($idaqar) . "'
            AND payeddate > '" . intval($startfrom) . "'
            AND payeddate < '" . intval($enddate) . "'";
    $expense_result = mysql_query($sql, $link);
    $expense_data = mysql_fetch_array($expense_result);
    $masrof = $expense_data['total_expenses'] ?? 0;

    // Calculate commission
    $per = $persentage / 100;
    if ($per < 100) {
        if ($per < 1) {
            $per = $per * 100;
        }
        $myper = $per * $erad / 100;
        $commission_formula = "($per% × " . number_format($erad) . ")/100 = ";
    } else {
        $myper = $per;
        $commission_formula = "";
    }

    // Calculate net income
    $net_income = $erad - $masrof - $myper;
    ?>

    <!-- Financial Report -->
    <div class="report-card">
        <div class="report-row">
            <div class="report-label">
