<?php
// Set page variables
$sc_title = "بيان صافي الإيراد";
$sc_id = "103";

// Extract request variables
extract($_REQUEST);

// Initialize variables
$idaqar = isset($idaqar) ? intval($idaqar) : 0;
$report = isset($report) ? intval($report) : 0;
$tasfia = isset($tasfia) ? intval($tasfia) : 0;
$startfrom = isset($startfrom) ? trim($startfrom) : '';
$enddate = isset($enddate) ? trim($enddate) : '';
$startfromx = isset($startfromx) ? intval($startfromx) : 0;
$enddatex = isset($enddatex) ? intval($enddatex) : 0;

// Check if this is an AJAX request
$is_ajax_request = isset($_POST['ajax_submit']) && $_POST['ajax_submit'] == '1';

// Include authentication and database
if ($is_ajax_request) {
    include_once "../../../reqloginajax.hnt";
} else {
    include_once "../../../nocash.hnt";
    $_SERVER['HTTP_REFERER'] = "showeditaqar.hnt?idaqar=$idaqar";
    $canscroll = 1;

    if ($report == 1) {
        include_once "../../../report_header.hnt";
    } else {
        include_once "../../../header.hnt";
    }
}

// Include required classes
require_once '../arabicTools.class.hnt';
include_once "arabic_num.class.hnt";

// Instantiate classes
$arabicTools = new ArabicTools();
$arabicNum = new Arabic_num();

// Handle liquidation request
if ($tasfia == 1 && $idaqar > 0) {
    $sql = "UPDATE eradat SET idaqar='-" . intval($idaqar) . "' WHERE idaqar='" . intval($idaqar) . "'";
    mysql_query($sql, $link);
    $sql = "UPDATE masrofat SET idaqar='-" . intval($idaqar) . "' WHERE idaqar='" . intval($idaqar) . "'";
    mysql_query($sql, $link);

    if ($is_ajax_request) {
        header('Content-Type: application/json; charset=utf-8');
        echo json_encode([
            'success' => true,
            'message' => 'تم تصفية الموقف المالي للعقار بنجاح'
        ], JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES);
        exit;
    }
}

// Only render HTML if NOT an AJAX request
if (!$is_ajax_request) {
?>

