                                    <th>خدمات</th>
                                    <th><i class="bi bi-cash-stack me-1"></i>صافي الإيراد</th>
                                </tr>
                            </thead>
                            <tbody>
<?php
    $grand_total_amount = 0;
    $grand_total_tamen = 0;
    $grand_total_water = 0;
    $grand_total_commission = 0;
    $grand_total_services = 0;
    $grand_total_net = 0;

    while ($row = mysql_fetch_array($result)) {
        // Calculate net income based on property settings
        $water_deduction = 0;
        $tamen_deduction = 0;

        if (!($row['addwaterto'] == "" || $row['addwaterto'] == "malek")) {
            $water_deduction = $row['total_water'];
        }

        if (!($row['addtameento'] == "" || $row['addtameento'] == "malek")) {
            $tamen_deduction = $row['total_tamen'];
        }

        $net_income = $row['total_amount'] - $row['total_commission'] - $row['total_services'] - $water_deduction - $tamen_deduction;

        $grand_total_amount += $row['total_amount'];
        $grand_total_tamen += $row['total_tamen'];
        $grand_total_water += $row['total_water'];
        $grand_total_commission += $row['total_commission'];
        $grand_total_services += $row['total_services'];
        $grand_total_net += $net_income;
?>
                                <tr class="text-center">
                                    <td class="text-start"><strong><?= htmlspecialchars($row['aqarname']) ?></strong></td>
                                    <td><?= number_format($row['transaction_count']) ?></td>
                                    <td><?= number_format($row['total_amount'], 2) ?></td>
                                    <td><?= number_format($row['total_tamen'], 2) ?></td>
                                    <td><?= number_format($row['total_water'], 2) ?></td>
                                    <td class="hidecommision"><?= number_format($row['total_commission'], 2) ?></td>
                                    <td><?= number_format($row['total_services'], 2) ?></td>
                                    <td><strong class="text-success"><?= number_format($net_income, 2) ?></strong></td>
                                </tr>
<?php
    }
?>
                                <tr class="table-secondary fw-bold text-center">
