                                    <td><strong><?= number_format($grand_total_amount, 2) ?></strong></td>
                                    <td><?= number_format($grand_total_tamen, 2) ?></td>
                                    <td><?= number_format($grand_total_water, 2) ?></td>
                                    <td class="hidecommision"><?= number_format($grand_total_commission, 2) ?></td>
                                    <td><?= number_format($grand_total_services, 2) ?></td>
                                    <td><strong class="text-success"><?= number_format($grand_total_net, 2) ?></strong></td>
