<script>
$(document).ready(function() {
    var calendarType = 'gregorian';
    var suppressAutoRecalculate = true;

    $('.datepicker-input').each(function() {
        var $input = $(this);
        $input.attr('data-calendartype', calendarType);
        $input.data('calendartype', calendarType);
        $input.datepicker({
            format: 'dd/mm/yyyy',
            language: 'ar',
            rtl: true,
            autoclose: true,
            todayHighlight: true,
            orientation: 'bottom auto',
            weekStart: 0,
            calendarType: calendarType
        });

        var dpData = $input.data('datepicker');
        if (dpData) {
            if (dpData.o) {
                dpData.o.calendarType = calendarType;
            }
            if (dpData.calendarType !== undefined) {
                dpData.calendarType = calendarType;
            }
            try {
                if (dpData.fill) {
                    dpData.fill();
                }
                if (dpData.update) {
                    dpData.update();
                }
            } catch (e) {}
        }
    });

    $('.input-group-text').off('click.datepicker').on('click.datepicker', function() {
        var input = $(this).closest('.input-group').find('input.datepicker-input:first');
        if (input.length) {
            input.focus();
            try {
                input.datepicker('show');
            } catch (e) {}
        }
    });

    // Load all bank accounts on page load
    loadAllBankAccounts();

    function loadAllBankAccounts() {
        $.ajax({
            url: 'incomm_repoert.hnt',
            type: 'POST',
            data: {
                ajax_action: 'get_all_bank_accounts'
            },
            dataType: 'json',
            success: function(response) {
                if (response.success && response.accounts) {
                    const select = $('#bank_account_filter');
                    const currentBankId = <?= $bankid ?>;
                    select.html('<option value="0">الكل</option>');

                    response.accounts.forEach(function(acc) {
                        const label = acc.bankname + ' - ' + acc.acountholder + ' (' + acc.acountnumber + ')';
                        const selected = (acc.id == currentBankId) ? ' selected' : '';
                        select.append('<option value="' + acc.id + '"' + selected + '>' + label + '</option>');
                    });
                }
            }
        });
    }

    // Update hidden bankid field when bank account selector changes
    $('#bank_account_filter').on('change', function() {
        if (suppressAutoRecalculate) {
            return;
        }
        $('#bankid').val($(this).val());
        recalculate();
    });

    $('#payment_type_filter').on('change', function() {
        if (suppressAutoRecalculate) {
            return;
        }
        recalculate();
    });

    $('.datepicker-input').on('changeDate change', function() {
        if (suppressAutoRecalculate) {
            return;
        }
        recalculate();
    });

    $('form[name="form"]').on('submit', function() {
        syncDateFilters();
    });

    setTimeout(function() {
        suppressAutoRecalculate = false;
    }, 300);
});

function formatPickerDateForQuery(value) {
    value = (value || '').trim();
    if (!value) {
        return '';
    }

    var parts = value.split(/[\/-]/);
    if (parts.length !== 3) {
        return value;
    }

    var day = String(parseInt(parts[0], 10) || 0).padStart(2, '0');
    var month = String(parseInt(parts[1], 10) || 0).padStart(2, '0');
    var year = String(parseInt(parts[2], 10) || 0);

    return day + '-' + month + '-' + year;
}

function syncDateFilters() {
    $('#startfrom').val(formatPickerDateForQuery($('#startfrom_picker').val()));
    $('#enddate').val(formatPickerDateForQuery($('#enddate_picker').val()));
}

function buildFilterUrl(showtasfia, report, hidecommision) {
    const startfrom = formatPickerDateForQuery($('#startfrom_picker').val());
    const enddate = formatPickerDateForQuery($('#enddate_picker').val());
    const bankid = $('#bankid').val() || 0;
    const payment_type = $('#payment_type_filter').val() || 0;

    let url = 'incomm_repoert.hnt?';
    url += 'startfrom=' + encodeURIComponent(startfrom);
    url += '&enddate=' + encodeURIComponent(enddate);

    if (bankid > 0) {
        url += '&bankid=' + bankid;
    }

    if (payment_type > 0) {
        url += '&payment_type=' + payment_type;
    }

    if (showtasfia) {
        url += '&showtasfia=' + showtasfia;
    }

    if (report) {
        url += '&report=1';
    }

    if (hidecommision) {
        url += '&hidecommision=1';
    }

    return url;
}

function navigateIfChanged(url) {
    var targetUrl = new URL(url, window.location.href);
    var currentUrl = new URL(window.location.href);

    if (targetUrl.pathname === currentUrl.pathname && targetUrl.search === currentUrl.search) {
        return;
    }

    window.location.href = targetUrl.toString();
}

function recalculate() {
    syncDateFilters();
    navigateIfChanged(buildFilterUrl(<?= $showtasfia ?>, 0, 0));
}

function applyFilters(showtasfia) {
    syncDateFilters();
    navigateIfChanged(buildFilterUrl(showtasfia, 0, 0));
}

function printReport(hidecommision) {
    syncDateFilters();
    navigateIfChanged(buildFilterUrl(<?= $showtasfia ?>, 1, hidecommision));
}
</script>

<?php
if ($report == 1) {
    require("../../../reportfooter.hnt");
} else {
    require('../../../foter.hnt');
}
?>
