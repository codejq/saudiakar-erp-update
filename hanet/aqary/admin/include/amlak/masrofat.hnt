<?php
$sc_title = "إدخال مصروفات الصيانة";
$sc_id = "40";

// Check if this is an AJAX form submission
$is_ajax_request = isset($_POST['ajax_submit']) && $_POST['ajax_submit'] == '1';

if ($is_ajax_request) {
    include_once "../../../reqloginajax.hnt";
} else {
    include_once "../../../nocash.hnt";
    $_SERVER['HTTP_REFERER'] = "index.hnt";
    include_once "../../../header.hnt";
    mysql_query("alter table masrofat add fund_source int(11) default 0 ", $link);
}

require '../arabicTools.class.hnt';
require '../uCal.class.hnt';
$dcal = new uCal;

// Handle adding new expense category
if (isset($_REQUEST['masrofkind']) && $_REQUEST['masrofkind']) {
    $masrofkind = mysql_real_escape_string($_REQUEST['masrofkind'], $link);
    $row = mysql_fetch_array(mysql_query("SELECT * FROM masrofattakweed WHERE masrofkind='$masrofkind'", $link));

    if ($is_ajax_request) {
        header('Content-Type: application/json; charset=utf-8');
        if ($row) {
            echo json_encode(['success' => false, 'message' => 'هذه النوعية من المصروفات موجودة بالبرنامج مسبقاً'], JSON_UNESCAPED_UNICODE);
        } else {
            $sql = "INSERT INTO masrofattakweed SET masrofkind='$masrofkind'";
            mysql_query($sql, $link);
            echo json_encode(['success' => true, 'message' => 'تم إضافة التكويد بنجاح'], JSON_UNESCAPED_UNICODE);
        }
        exit;
    } else {
        if ($row) {
            echo "<center>هذه النوعية من المصروفات موجودة بالبرنامج مسبقاً</center>";
        } else {
            $sql = "INSERT INTO masrofattakweed SET masrofkind='$masrofkind'";
            mysql_query($sql, $link);
            echo "<center><br>تم إضافة التكويد بنجاح<br></center>";
        }
    }
}

// Handle form submission for expense entry/update
if (isset($_POST['idaqar']) && isset($_POST['amount']) && $_POST['idaqar'] && $_POST['amount']) {
    $idaqar = mysql_real_escape_string($_POST['idaqar'], $link);
    $idsubaqar = isset($_POST['idsubaqar']) ? mysql_real_escape_string($_POST['idsubaqar'], $link) : '';
    $idmasrofcod = isset($_POST['idmasrofcod']) ? mysql_real_escape_string($_POST['idmasrofcod'], $link) : '';
    $fund_source = isset($_POST['fund_source']) ? intval($_POST['fund_source']) : 0;
    $amount = mysql_real_escape_string($_POST['amount'], $link);
    $payedby = isset($_POST['payedby']) ? mysql_real_escape_string($_POST['payedby'], $link) : '';
    $payeddue = isset($_POST['payeddue']) ? mysql_real_escape_string($_POST['payeddue'], $link) : '';

    // Process date — handle both d/m/Y (Arabic slash) and Y-m-d (ISO from grid)
    $payeddate = isset($_POST['payeddate']) ? trim($_POST['payeddate']) : date('d/m/Y');
    if (strpos($payeddate, '-') !== false) {
        // ISO format Y-m-d → split into [day, month, year]
        $iso = explode('-', $payeddate);
        $payeddate_parts = [(int)($iso[2] ?? 1), (int)($iso[1] ?? 1), (int)($iso[0] ?? date('Y'))];
    } else {
        $tmp = explode('/', $payeddate);
        $payeddate_parts = [(int)($tmp[0] ?? 1), (int)($tmp[1] ?? 1), (int)($tmp[2] ?? date('Y'))];
    }
    if ($payeddate_parts[2] < 1700) {
        $dateo = $dcal->u2g($payeddate_parts[0], $payeddate_parts[1], $payeddate_parts[2]);
        $payeddate_parts[0] = (int)$dateo['day'];
        $payeddate_parts[1] = (int)$dateo['month'];
        $payeddate_parts[2] = (int)$dateo['year'];
    }
    $payeddate_unix = mktime(0, 0, 0, $payeddate_parts[1], $payeddate_parts[0], $payeddate_parts[2]);

    if (isset($_POST['idmasrof']) && $_POST['idmasrof']) {
        // Update existing expense
        $idmasrof = mysql_real_escape_string($_POST['idmasrof'], $link);
        $sql = "UPDATE masrofat SET
            idmasrofcod='$idmasrofcod',
            amount='$amount',
            payeddate='$payeddate_unix',
            payedby='$payedby',
            payeddue='$payeddue',
            fund_source='$fund_source'
            WHERE idmasrof='$idmasrof' LIMIT 1";
    } else {
        // Insert new expense
        $sql = "INSERT INTO masrofat SET
            idaqar='$idaqar',
            idsubaqar='$idsubaqar',
            idmasrofcod='$idmasrofcod',
            amount='$amount',
            payeddate='$payeddate_unix',
            payedby='$payedby',
            payeddue='$payeddue',
            fund_source='$fund_source'";
    }

    mysql_query($sql, $link);

    if ($is_ajax_request) {
        header('Content-Type: application/json; charset=utf-8');
        if (mysql_error()) {
            echo json_encode(['success' => false, 'message' => 'حدث خطأ: ' . mysql_error()], JSON_UNESCAPED_UNICODE);
        } else {
            $message = isset($_POST['idmasrof']) && $_POST['idmasrof'] ? 'تم تحديث المصروف بنجاح' : 'تم إضافة المصروف بنجاح';
            echo json_encode(['success' => true, 'message' => $message], JSON_UNESCAPED_UNICODE);
        }
        exit;
    } else {
        ?>
        <script>
        if (typeof parent.parent.parent.fillmasrofat === 'function') {
            parent.parent.parent.fillmasrofat();
        }
        if (parent.parent.document.getElementById('payedby')) {
            parent.parent.document.getElementById('payedby').value = '';
            parent.parent.document.getElementById('payeddue').value = '';
            parent.parent.document.getElementById('amount').value = '';
            parent.parent.document.getElementById('mafrofatsubmit').disabled = false;
        }
        </script>
        <?php
        exit();
    }
}

// Get current date
$currentdate = date('d/m/Y');
if (!isset($hnt_dll)) $hnt_dll = 0;
if (!isset($hnt_supper_dll)) $hnt_supper_dll = 0;

if (!$hnt_dll && $hnt_supper_dll != 5) {
    $dateo = $dcal->g2u(date('d'), date('m'), date('Y'));
    $currentdate = "{$dateo['day']}/{$dateo['month']}/{$dateo['year']}";
}

// Only render HTML if not AJAX request
if ($is_ajax_request) {
    exit;
}
?>

