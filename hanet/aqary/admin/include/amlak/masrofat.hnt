<script>
$(document).ready(function() {
    // Initialize tooltips
    const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
    tooltipTriggerList.map(function(tooltipTriggerEl) {
        return new bootstrap.Tooltip(tooltipTriggerEl);
    });

    // Date picker — same setup as egar.hnt
    var isHijri = <?= (isset($hnt_dll) && $hnt_dll == 0) ? 'true' : 'false' ?>;
    var calType  = isHijri ? 'hijri' : 'gregorian';
    $('#payeddate').data('calendartype', calType).datepicker({
        format: 'dd/mm/yyyy',
        language: 'ar',
        rtl: true,
        autoclose: true,
        todayHighlight: true,
        calendarType: calType,
        orientation: 'bottom auto',
        weekStart: isHijri ? 6 : 0
    });
    $('#payeddate').next('.input-group-text').on('click', function () {
        $('#payeddate').focus();
        $('#payeddate').datepicker('show');
    });

    // Property selection change handler
    $('#idaqar').on('change', function() {
        const idaqar = $(this).val();
        toggleFormControls();

        if (idaqar) {
            fillmasrofat();
            // Load units for selected property
            const sql = "SELECT amlakdetails.idsubaqar, CONCAT(aqarsubtype.aqarsubtypename, ' - ', amlakdetails.rakam) AS unitname FROM amlakdetails, aqarsubtype WHERE amlakdetails.aqarsubtype = aqarsubtype.aqarsubtype AND amlakdetails.idaqar = '" + idaqar + "'";
            ajaxfillcombox(document.getElementById('idsubaqar'), sql);
        }
    });

    // Toggle form controls based on property selection
    function toggleFormControls() {
        const hasProperty = $('#idaqar').val() !== '';
        $('#payeddue, #payedby, #amount, #mafrofatsubmit').prop('disabled', !hasProperty);
    }

    // Add new expense category
    $('#addCategoryBtn').on('click', function() {
        const masrofkind = $('#masrofkind').val().trim();
        if (!masrofkind) {
            if (typeof showBootstrapNotification === 'function') {
                showBootstrapNotification('warning', 'الرجاء إدخال نوع المصروف');
            } else {
                alert('الرجاء إدخال نوع المصروف');
            }
            return;
        }

        $.ajax({
            url: 'masrofat.hnt',
            type: 'POST',
            data: {
                masrofkind: masrofkind,
                ajax_submit: '1'
            },
            dataType: 'json',
            success: function(response) {
                if (response.success) {
                    if (typeof showBootstrapNotification === 'function') {
                        showBootstrapNotification('success', response.message);
                    } else {
                        alert(response.message);
                    }
                    // Reload category dropdown
                    setTimeout(function() {
                        const sql = "SELECT * FROM masrofattakweed ORDER BY idmasrofcod DESC";
                        ajaxfillcombox(document.getElementById('idmasrofcod'), sql);
                        setTimeout(function() {
                            $('#idmasrofcod option:eq(1)').prop('selected', true);
                            $('#masrofkind').val('');
                        }, 100);
                    }, 500);
                } else {
                    if (typeof showBootstrapNotification === 'function') {
                        showBootstrapNotification('danger', response.message);
                    } else {
                        alert(response.message);
                    }
                }
            },
            error: function() {
                if (typeof showBootstrapNotification === 'function') {
                    showBootstrapNotification('danger', 'حدث خطأ أثناء إضافة النوع');
                } else {
                    alert('حدث خطأ أثناء إضافة النوع');
                }
            }
        });
    });

    // Form submission
    $('#masrofatForm').on('submit', function(e) {
        e.preventDefault();

        const formData = new FormData(this);
        formData.append('ajax_submit', '1');

        $('#mafrofatsubmit').prop('disabled', true);

        $.ajax({
            url: 'masrofat.hnt',
            type: 'POST',
            data: formData,
            processData: false,
            contentType: false,
            dataType: 'json',
            success: function(response) {
                if (response.success) {
                    if (typeof showBootstrapNotification === 'function') {
                        showBootstrapNotification('success', response.message);
                    } else {
                        alert(response.message);
                    }
                    // Clear form and reset button
                    $('#payedby, #payeddue, #amount').val('');
                    $('#idmasrof').val('');
                    $('#mafrofatsubmit').html('<i class="bi bi-check-circle me-2"></i>إدخال إلى المصروفات');
                    fillmasrofat();
                } else {
                    if (typeof showBootstrapNotification === 'function') {
                        showBootstrapNotification('danger', response.message);
                    } else {
                        alert(response.message);
                    }
                }
                $('#mafrofatsubmit').prop('disabled', false);
            },
            error: function() {
                if (typeof showBootstrapNotification === 'function') {
                    showBootstrapNotification('danger', 'حدث خطأ أثناء حفظ المصروف');
                } else {
                    alert('حدث خطأ أثناء حفظ المصروف');
                }
                $('#mafrofatsubmit').prop('disabled', false);
            }
        });
    });

    // Pagination handlers
    $('#prevPage').on('click', function() {
        let currentPage = parseInt($('#tajpagenum').val());
        if (currentPage > 1) {
            $('#tajpagenum').val(currentPage - 1);
            fillmasrofat($('#tajpagenum').val());
        }
    });

    $('#nextPage').on('click', function() {
        if ($('#containerid').html() !== '') {
            let currentPage = parseInt($('#tajpagenum').val());
            $('#tajpagenum').val(currentPage + 1);
            fillmasrofat($('#tajpagenum').val());
        }
    });

    $('#tajpagenum').on('change', function() {
        fillmasrofat($(this).val());
    });

    // Fill expenses grid
    window.fillmasrofat = function(pagenm) {
        if (typeof pagenm === 'undefined') pagenm = 1;

        const idaqar = $('#idaqar').val();
        if (!idaqar) return;

        let sql = "SELECT idmasrof AS 'رقم', ";
        sql += "(SELECT masrofkind FROM masrofattakweed WHERE masrofattakweed.idmasrofcod = masrofat.idmasrofcod) AS 'النوع', ";
        sql += "payeddue AS 'بيــــان المصــروف', ";
        sql += "amount AS 'القيمة', ";
        sql += "FROM_UNIXTIME(payeddate, '%Y-%m-%d') AS 'التاريخ', ";
        sql += "IF(fund_source=1,'المالك','المكتب') AS 'مصدر الصرف' ";
        sql += "FROM masrofat ";
        sql += "WHERE tasfia = '' AND idaqar = '" + idaqar + "' ";
        sql += "ORDER BY idmasrof DESC";

        ajaxfillgrid(sql, 'containerid', true, pagenm);
    };

    // Context menu for row actions
    let contextMenuTimer;
    let selectedRowId = null;

    window.showcontextlayer = function(objtr, idtr) {
        $('#contextlayer').css({
            display: 'block',
            top: currentMousePos.y + 'px',
            left: currentMousePos.x + 'px'
        });
        $(objtr).css('background-color', '#bedadc');
        selectedRowId = idtr;
        return false;
    };

    function hideContextLayer() {
        contextMenuTimer = setTimeout(function() {
            $('#contextlayer').hide();
        }, 1000);
    }

    $('#contextlayer').on('mouseover', function() {
        clearTimeout(contextMenuTimer);
        $(this).show();
    }).on('mouseout', function() {
        hideContextLayer();
    });

    // ── Shared edit/delete logic ──────────────────────────────
    function doEditRow(rowId) {
        const row = $('#mtr' + rowId);
        let html = row.html();
        html = html.replace('><', '> <').replace('\n', '');

        const re = /<td.*?>(.*?)<\/td>/gi;
        const result = [];
        let match;
        while ((match = re.exec(html)) !== null) {
            result.push(match[1]);
        }

        if (result.length >= 5) {
            $('#idmasrof').val(result[0]);
            $('#idmasrofcod option').filter(function() {
                return $.trim($(this).text()) === $.trim(result[1]);
            }).prop('selected', true);
            $('#payeddue').val(result[2]);
            $('#amount').val(result[3]);
            $('#payeddate').val(result[4]);
            // fund_source: result[5] is 'المالك' or 'المكتب'
            $('#fund_source').val(result[5] === 'المالك' ? '1' : '0');
            $('#mafrofatsubmit').prop('disabled', false)
                .html('<i class="bi bi-floppy me-2"></i>حفظ المصروف');
        }

        $('html, body').animate({ scrollTop: $('#masrofatForm').offset().top - 20 }, 300);
        $('#contextlayer').hide();
    }

    function doDeleteRow(rowId) {
        confirm('هل ترغب في حذف هذا الحقل؟', 'تحذير', function() {
            ajaxmysql("DELETE FROM masrofat WHERE idmasrof = '" + rowId + "'");
            const rowElement = document.getElementById('mtr' + rowId);
            if (rowElement && typeof deleteRow === 'function') {
                deleteRow(rowElement);
            }
            fillmasrofat();
        });
        $('#contextlayer').hide();
    }

    // Context menu buttons delegate to shared functions
    $('#editExpense').on('click', function(e) {
        e.preventDefault();
        doEditRow(selectedRowId);
        return false;
    });

    $('#deleteExpense').on('click', function(e) {
        e.preventDefault();
        doDeleteRow(selectedRowId);
        return false;
    });

    // ── Inline action buttons injected after grid renders ─────
    function injectActionButtons() {
        const $table = $('#containerid table');
        if (!$table.length) return;

        // Add header column once
        if (!$table.find('th.actions-col').length) {
            $table.find('thead tr').append('<th class="actions-col text-center" style="width:80px;">إجراءات</th>');
        }

        // Inject buttons into each data row that doesn't have them yet
        $table.find('tbody tr[id^="mtr"]').each(function() {
            if ($(this).find('.inline-actions').length) return;
            const rowId = this.id.replace('mtr', '');
            $(this).append(
                '<td class="text-center inline-actions" style="white-space:nowrap;">' +
                  '<button type="button" class="btn btn-sm btn-outline-primary border-0 me-1 btn-inline-edit" data-id="' + rowId + '" title="تعديل">' +
                    '<i class="bi bi-pencil-fill"></i>' +
                  '</button>' +
                  '<button type="button" class="btn btn-sm btn-outline-danger border-0 btn-inline-delete" data-id="' + rowId + '" title="حذف">' +
                    '<i class="bi bi-trash3-fill"></i>' +
                  '</button>' +
                '</td>'
            );
        });
    }

    // Delegated click handlers for inline buttons
    $(document).on('click', '.btn-inline-edit', function(e) {
        e.stopPropagation();
        doEditRow($(this).data('id'));
    });

    $(document).on('click', '.btn-inline-delete', function(e) {
        e.stopPropagation();
        doDeleteRow($(this).data('id'));
    });

    // Watch #containerid for grid re-renders
    const observer = new MutationObserver(function() {
        injectActionButtons();
    });
    observer.observe(document.getElementById('containerid'), { childList: true, subtree: true });

    // Initialize form state
    toggleFormControls();
});
</script>

<!-- Context Menu -->
<div id="contextlayer" class="dropdown-menu" style="display: none; position: absolute;" dir="rtl">
    <a href="#" id="editExpense" class="dropdown-item <?= 'policy_' . $sc_id . '_edits' ?>">
        <i class="bi bi-pencil me-2"></i>تعديل البيانات
    </a>
    <a href="#" id="deleteExpense" class="dropdown-item <?= 'policy_' . $sc_id . '_deleetes' ?>">
        <i class="bi bi-trash me-2"></i>حذف
    </a>
</div>

