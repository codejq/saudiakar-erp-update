// Build WHERE clause
$conditions = [];

if ($sanadid) {
    $conditions[] = "sanadid='" . intval($sanadid) . "'";
} else {
    if ($search) {
        $conditions[] = "(sanadid='" . addslashes($search) . "' OR amount='" . addslashes($search) . "' OR bayan LIKE '%" . addslashes($search) . "%' OR note LIKE '%" . addslashes($search) . "%' OR mostafeed LIKE '%" . addslashes($search) . "%')";
    }
    if ($idaqar > 0) {
        $conditions[] = "aqarid='" . intval($idaqar) . "'";
    }
    if ($startfrom_ts > 0) {
        $conditions[] = "sanadate >= '" . $startfrom_ts . "'";
    }
    if ($enddate_ts > 0) {
        $conditions[] = "sanadate <= '" . $enddate_ts . "'";
    }
    if ($payment_type_f > 0) {
        $conditions[] = "payment_type='" . intval($payment_type_f) . "'";
    }
    if ($money_source_filter >= 0) {
        $conditions[] = "money_source='" . intval($money_source_filter) . "'";
    }
    if ($bankid > 0) {
        $conditions[] = "bankid='" . intval($bankid) . "'";
    }
}

$where = count($conditions) ? ' WHERE ' . implode(' AND ', $conditions) : '';

// Pagination
$sql = "SELECT COUNT(sanadid) as dd FROM sanadsarf $where";
$rownum = mysql_fetch_array(mysql_query($sql, $link));
$rownum = $rownum['dd'];
$rowperpage = isset($rowperpage) ? intval($rowperpage) : 40;
$pagenum = ceil($rownum / $rowperpage);

// Display count
echo '<div class="alert alert-info mb-3">';
echo '<i class="bi bi-info-circle me-2"></i>';
echo 'عدد السندات: <strong class="text-danger">' . $rownum . '</strong> سند';
echo '</div>';

// Pagination
if ($pagenum > 1) {
    echo '<nav aria-label="Page navigation"><ul class="pagination justify-content-center">';
    for ($xi = 1; $xi <= $pagenum; $xi++) {
        $active = ($page == $xi) ? 'active' : '';
        if (($xi > ($page - 4) && $xi < ($page + 4)) || $xi == 1 || $xi == $pagenum || $xi < 4 || $xi > ($pagenum - 4)) {
            echo '<li class="page-item ' . $active . '"><a class="page-link" href="allsarfsanad.hnt?page=' . $xi . $filter_params . '">' . $xi . '</a></li>';
        } elseif ($xi == ($page - 4) || $xi == ($page + 4)) {
            echo '<li class="page-item disabled"><span class="page-link">...</span></li>';
        }
    }
    echo '</ul></nav>';
}

// Calculate limit
$limit = ($page - 1) * $rowperpage;
$limit = $limit . "," . $rowperpage;
if ($page == 1 || $page == '') {
    $limit = $rowperpage;
}

// Get vouchers
$sql = "SELECT * FROM sanadsarf $where ORDER BY sanadate DESC LIMIT $limit";
$result = mysql_query($sql, $link);
$total_amount = 0;
