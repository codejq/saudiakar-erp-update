<script>
    // Modern ES6+ JavaScript

let editVoucherModalInstance = null;

// Open Word voucher
const openWordVoucher = (sanadid) => {
    const server = '<?= $server ?>';
    const url = `${server}/aqary/admin/include/amlak/read_word_voucher.hnt?sanadid=${sanadid}`;
    const iframe = document.getElementById('wordd');
    iframe.src = url;
};

// Delete voucher with confirmation
const deleteVoucher = async (sanadid) => {
    if (!confirm('هل أنت متأكد من حذف هذا السند؟\n\nهذا الإجراء لا يمكن التراجع عنه.')) {
        return;
    }

    try {
        const formData = new FormData();
        formData.append('deltesanadid', sanadid);
        formData.append('ajax', '1');

        const response = await fetch(window.location.href, {
            method: 'POST',
            body: formData
        });

        const result = await response.json();

        if (result.success) {
            // Show success message
            const alertDiv = document.createElement('div');
            alertDiv.className = 'alert alert-success alert-dismissible fade show position-fixed top-0 start-50 translate-middle-x mt-3';
            alertDiv.style.zIndex = '9999';
            alertDiv.innerHTML = `
                <i class="bi bi-check-circle-fill me-2"></i>
                <strong>${result.message}</strong>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            `;

            document.body.appendChild(alertDiv);

            // Reload page after 1 second
            setTimeout(() => {
                window.location.reload();
            }, 1000);
        } else {
            alert(result.message || 'حدث خطأ أثناء حذف السند');
        }
    } catch (error) {
        console.error('Error:', error);
        alert('حدث خطأ أثناء حذف السند');
    }
};

function openEditVoucherModal(button) {
    const data = button.dataset;
    $('#edit_sanadid').val(data.sanadid || '');
    $('#edit_readonly_sanadid').val(data.sanadid || '');
    $('#edit_readonly_mostafeed').val(data.mostafeed || '');
    $('#edit_readonly_amount').val(data.amount || '');
    $('#edit_readonly_bayan').val(data.bayan || '');
    $('#edit_readonly_aqarname').val(data.aqarname || '');
    $('#edit_readonly_mowazaf').val(data.mowazaf || '');
    $('#edit_sanadate').val(data.editDate || '');
    $('#edit_payment_type').val(data.paymentType || '1').trigger('change');
    $('#edit_money_source').val(data.moneySource || '0').trigger('change');

    if (!editVoucherModalInstance) {
        editVoucherModalInstance = new bootstrap.Modal(document.getElementById('editVoucherModal'));
    }

    editVoucherModalInstance.show();
}

function loadBankAccounts() {
    const idaqar = $('#idaqar').val();
    $.ajax({
        url: 'allsarfsanad.hnt',
        type: 'POST',
        data: { ajax_action: 'get_property_bank_accounts', idaqar: idaqar || 0 },
        dataType: 'json',
        success: function(response) {
            if (response.success && response.accounts) {
                const select = $('#bank_account_filter');
                const currentBankId = parseInt($('#bankid').val()) || 0;
                select.html('<option value="0">الكل</option>');
                response.accounts.forEach(function(acc) {
                    const label = acc.bankname + ' - ' + acc.acountholder + ' (' + acc.acountnumber + ')';
                    const selected = (acc.id == currentBankId) ? ' selected' : '';
                    select.append('<option value="' + acc.id + '"' + selected + '>' + label + '</option>');
                });
            }
        }
    });
}

function formatPickerDateForQuery(value) {
    value = (value || '').trim();
    if (!value) {
        return '';
    }

    const parts = value.split(/[\/-]/);
    if (parts.length !== 3) {
        return value;
    }

    const day = String(parseInt(parts[0], 10) || 0).padStart(2, '0');
    const month = String(parseInt(parts[1], 10) || 0).padStart(2, '0');
    const year = String(parseInt(parts[2], 10) || 0);

    return day + '-' + month + '-' + year;
}

function syncDateFilters() {
    $('#startfrom').val(formatPickerDateForQuery($('#startfrom_picker').val()));
    $('#enddate').val(formatPickerDateForQuery($('#enddate_picker').val()));
}

function buildFilterUrl() {
    const search    = encodeURIComponent($('#search').val() || '');
    const idaqar    = $('#idaqar').val() || 0;
    const aqarname  = encodeURIComponent($('#aqarname').val() || '');
    const startfrom = formatPickerDateForQuery($('#startfrom_picker').val());
    const enddate = formatPickerDateForQuery($('#enddate_picker').val());
    const bankid              = $('#bankid').val() || 0;
    const payment_type_f      = $('#payment_type_f_select').val() || 0;
    const money_source_filter = $('#money_source_filter').val();

    let url = 'allsarfsanad.hnt?';
    if (search)    url += '&search='   + search;
    if (idaqar > 0) url += '&idaqar=' + idaqar + '&aqarname=' + aqarname;
    if (startfrom) url += '&startfrom=' + encodeURIComponent(startfrom);
    if (enddate) url += '&enddate='  + encodeURIComponent(enddate);
    if (bankid > 0) url += '&bankid=' + bankid;
    if (payment_type_f > 0) url += '&payment_type_f=' + payment_type_f;
    if (money_source_filter !== '' && money_source_filter !== '-1') url += '&money_source_filter=' + money_source_filter;
    return url;
}

function navigateIfChanged(url) {
    const targetUrl = new URL(url, window.location.href);
    const currentUrl = new URL(window.location.href);

    if (targetUrl.pathname === currentUrl.pathname && targetUrl.search === currentUrl.search) {
        return;
    }

    window.location.href = targetUrl.toString();
}

function recalculate() {
    syncDateFilters();
    navigateIfChanged(buildFilterUrl());
}

// Initialize on page load
$(document).ready(function() {
    const calendarType = 'gregorian';
    let suppressAutoRecalculate = true;

    $('.datepicker-input').each(function() {
        const $input = $(this);
        $input.attr('data-calendartype', calendarType);
        $input.data('calendartype', calendarType);
        $input.datepicker({
            format: 'dd/mm/yyyy',
            language: 'ar',
            rtl: true,
            autoclose: true,
            todayHighlight: true,
            orientation: 'bottom auto',
            weekStart: 0,
            calendarType: calendarType
        });
    });

    $('.input-group-text').off('click.datepicker').on('click.datepicker', function() {
        const input = $(this).closest('.input-group').find('input.datepicker-input:first');
        if (input.length) {
            input.focus();
            try {
                input.datepicker('show');
            } catch (e) {}
        }
    });

    $('.datepicker-input').on('changeDate change', function() {
        if (suppressAutoRecalculate) {
            return;
        }
        recalculate();
    });

    $('.voucher-edit-datepicker').each(function() {
        const $input = $(this);
        $input.attr('data-calendartype', calendarType);
        $input.data('calendartype', calendarType);
        $input.datepicker({
            format: 'dd/mm/yyyy',
            language: 'ar',
            rtl: true,
            autoclose: true,
            todayHighlight: true,
            orientation: 'bottom auto',
            weekStart: 0,
            calendarType: calendarType
        });
    });

    $('.voucher-edit-datepicker-trigger').off('click.datepicker').on('click.datepicker', function() {
        const input = $(this).closest('.input-group').find('input.voucher-edit-datepicker:first');
        if (input.length) {
            input.focus();
            try {
                input.datepicker('show');
            } catch (e) {}
        }
    });

    // Sync Select2 display with PHP-rendered selected value
    $('#money_source_filter').val('<?= $money_source_filter ?>').trigger('change.select2');

    // Auto-recalculate on dropdown changes
    $('#payment_type_f_select, #money_source_filter').on('change', function() {
        if (suppressAutoRecalculate) {
            return;
        }
        recalculate();
    });

    // Bank account filter: update hidden field and recalculate on change
    $('#bank_account_filter').on('change', function() {
        $('#bankid').val($(this).val());
        if (suppressAutoRecalculate) {
            return;
        }
        recalculate();
    });

    // Reload bank list when property changes (ajaxfilldiv polling)
    loadBankAccounts();
    let lastIdaqar = $('#idaqar').val();
    let lastAqarname = $('#aqarname').val();
    setInterval(function() {
        const cur = $('#idaqar').val();
        const curName = $('#aqarname').val();
        if (cur !== lastIdaqar || curName !== lastAqarname) {
            lastIdaqar = cur;
            lastAqarname = curName;
            loadBankAccounts();
            if (!suppressAutoRecalculate) {
                recalculate();
            }
        }
    }, 500);

    const searchInput = document.getElementById('search');
    if (searchInput && !searchInput.value) {
        searchInput.focus();
    }

    $('#editVoucherForm').on('submit', async function(e) {
        e.preventDefault();
        const saveButton = $('#saveVoucherChangesBtn');
        saveButton.prop('disabled', true);

        try {
            const formData = new FormData(this);

            const response = await fetch('allsarfsanad.hnt', {
                method: 'POST',
                body: formData
            });

            const result = await response.json();
            if (result.success) {
                if (editVoucherModalInstance) {
                    editVoucherModalInstance.hide();
                }
                setTimeout(function() {
                    window.location.reload();
                }, 300);
                return;
            }

            alert(result.message || 'تعذر تحديث بيانات السند');
        } catch (error) {
            alert('حدث خطأ أثناء تحديث بيانات السند');
        } finally {
            saveButton.prop('disabled', false);
        }
    });

    setTimeout(function() {
        suppressAutoRecalculate = false;
        syncDateFilters();
        lastIdaqar = $('#idaqar').val();
        lastAqarname = $('#aqarname').val();
    }, 0);
});
</script>

