function convertGregorianDisplayDateToTimestamp($date_value) {
    $date_value = trim($date_value);
    if ($date_value === '') {
        return 0;
    }

    $parts = explode('/', $date_value);
    if (count($parts) !== 3) {
        return 0;
    }

    $day = intval($parts[0]);
    $month = intval($parts[1]);
    $year = intval($parts[2]);
    if ($day < 1 || $month < 1 || $year < 1) {
        return 0;
    }

    return mktime(0, 0, 0, $month, $day, $year);
}

// Export handler — runs before any HTML output
if (isset($_GET['export']) && in_array(trim($_GET['export']), ['csv', 'xls'], true)) {
    include_once "../../../connectdb.hnt";
    $_search    = isset($_GET['search'])    ? trim($_GET['search'])    : '';
    $_idaqar    = isset($_GET['idaqar'])    ? intval($_GET['idaqar'])  : 0;
    $_sf        = isset($_GET['startfrom']) ? trim($_GET['startfrom']) : '';
    $_ed        = isset($_GET['enddate'])   ? trim($_GET['enddate'])   : '';
    $_pt        = isset($_GET['payment_type_f'])    ? intval($_GET['payment_type_f'])    : 0;
    $_ms        = isset($_GET['money_source_filter']) && $_GET['money_source_filter'] !== '' ? intval($_GET['money_source_filter']) : -1;
    $_bankid    = isset($_GET['bankid'])             ? intval($_GET['bankid'])             : 0;

    $_sf_ts = 0; $_ed_ts = 0;
    if ($_sf) {
        $_d = explode("-", "0-0-0-" . $_sf);
        if (isset($_d[5]) && $_d[5] < 1900 && $_d[5] > 1400) {
            $_dateo = $dcal->u2g($_d[3], $_d[4], $_d[5]); $_d[3] = $_dateo['day']; $_d[4] = $_dateo['month']; $_d[5] = $_dateo['year'];
        }
        if (isset($_d[5])) $_sf_ts = mktime(0, 0, 0, $_d[4], $_d[3], $_d[5]);
    }
    if ($_ed) {
        $_d2 = explode("-", "0-0-0-" . $_ed);
        if (isset($_d2[5]) && $_d2[5] < 1900 && $_d2[5] > 1400) {
            $_dateo = $dcal->u2g($_d2[3], $_d2[4], $_d2[5]); $_d2[3] = $_dateo['day']; $_d2[4] = $_dateo['month']; $_d2[5] = $_dateo['year'];
        }
        if (isset($_d2[5])) $_ed_ts = mktime(0, 0, 0, $_d2[4], $_d2[3], $_d2[5]) + 86399;
    }

    $_conds = [];
    if ($_search) $_conds[] = "(sanadid='" . addslashes($_search) . "' OR amount='" . addslashes($_search) . "' OR bayan LIKE '%" . addslashes($_search) . "%' OR mostafeed LIKE '%" . addslashes($_search) . "%')";
    if ($_idaqar > 0) $_conds[] = "sd.aqarid='" . $_idaqar . "'";
    if ($_sf_ts > 0)  $_conds[] = "sd.sanadate >= '" . $_sf_ts . "'";
    if ($_ed_ts > 0)  $_conds[] = "sd.sanadate <= '" . $_ed_ts . "'";
    if ($_pt > 0)      $_conds[] = "sd.payment_type='" . $_pt . "'";
    if ($_ms >= 0)     $_conds[] = "sd.money_source='" . $_ms . "'";
    if ($_bankid > 0)  $_conds[] = "sd.bankid='" . $_bankid . "'";
    $_where = count($_conds) ? 'WHERE ' . implode(' AND ', $_conds) : '';

    $_ptLabels = [1 => 'نقداً', 2 => 'شيك', 3 => 'طريقة أخرى', 4 => 'تحويل بنكي', 5 => 'شبكة'];
    $exp_sql = "SELECT sd.sanadid, sd.mostafeed, sd.amount, sd.bayan, sd.sanadate, sd.payment_type, sd.money_source, a.aqarname
                FROM sanadsarf sd LEFT JOIN amlak a ON sd.aqarid = a.idaqar
                $_where ORDER BY sd.sanadate DESC";
    $exp_res = mysql_query($exp_sql, $link);
    $exp_headers = ['رقم السند', 'المستفيد', 'المبلغ', 'البيان', 'العقار', 'التاريخ', 'طريقة الصرف', 'مصدر المبلغ'];
    $exp_rows = [];
    while ($r = mysql_fetch_array($exp_res)) {
        $_pt2 = intval($r['payment_type']); if ($_pt2 < 1) $_pt2 = 1;
        $exp_rows[] = [
            intval($r['sanadid']), $r['mostafeed'], number_format($r['amount'], 2, '.', ''), $r['bayan'],
            $r['aqarname'] ?: '', date('d/m/Y', $r['sanadate']),
            isset($_ptLabels[$_pt2]) ? $_ptLabels[$_pt2] : 'نقداً',
            intval($r['money_source']) == 1 ? 'حساب المالك' : 'المكتب',
        ];
    }

    $_exp_type = trim($_GET['export']); $_fn = date('Ymd_His');
    if ($_exp_type === 'csv') {
        header('Content-Type: text/csv; charset=UTF-8');
        header('Content-Disposition: attachment; filename="allsarfsanad_' . $_fn . '.csv"');
        $_out = fopen('php://output', 'w'); fwrite($_out, "\xEF\xBB\xBF");
        fputcsv($_out, $exp_headers, ',', '"', '\\');
        foreach ($exp_rows as $_r) fputcsv($_out, $_r, ',', '"', '\\');
        fclose($_out); exit;
    }
    header('Content-Type: application/vnd.ms-excel; charset=UTF-8');
    header('Content-Disposition: attachment; filename="allsarfsanad_' . $_fn . '.xls"');
    echo '<html lang="ar" dir="rtl"><head><meta charset="UTF-8"></head><body><table border="1"><tr>';
    foreach ($exp_headers as $_h) echo '<th>' . htmlspecialchars($_h) . '</th>';
    echo '</tr>';
    foreach ($exp_rows as $_r) { echo '<tr>'; foreach ($_r as $_c) echo '<td>' . htmlspecialchars($_c) . '</td>'; echo '</tr>'; }
    echo '</table></body></html>'; exit;
}

