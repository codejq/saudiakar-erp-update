// Process date filters → unix timestamps (support Hijri and Gregorian)
$startfrom_ts = 0;
$enddate_ts   = 0;
$dd = $mm = $yy = $dd2 = $mm2 = $yy2 = '';

if ($startfrom) {
    $daxx = explode("-", "0-0-0-" . $startfrom);
    if (isset($daxx[5]) && ($daxx[5] < 1900) && ($daxx[5] > 1400)) {
        $dateo = $dcal->u2g($daxx[3], $daxx[4], $daxx[5]);
        $daxx[3] = $dateo['day']; $daxx[4] = $dateo['month']; $daxx[5] = $dateo['year'];
    }
    $startfrom_ts = mktime(0, 0, 0, $daxx[4], $daxx[3], $daxx[5]);
    $dd = $daxx[3]; $mm = $daxx[4]; $yy = $daxx[5];
}

if ($enddate) {
    $dax2 = explode("-", "0-0-0-" . $enddate);
    if (isset($dax2[5]) && ($dax2[5] < 1900) && ($dax2[5] > 1400)) {
        $dateo = $dcal->u2g($dax2[3], $dax2[4], $dax2[5]);
        $dax2[3] = $dateo['day']; $dax2[4] = $dateo['month']; $dax2[5] = $dateo['year'];
    }
    $enddate_ts = mktime(0, 0, 0, $dax2[4], $dax2[3], $dax2[5]) + 86399;
    $dd2 = $dax2[3]; $mm2 = $dax2[4]; $yy2 = $dax2[5];
}

if (!$startfrom_ts) {
    $startfrom_ts = time();
}

if (!$enddate_ts) {
    $enddate_ts = (time() + (30 * 86400)) + 86399;
}

$startfrom_picker_value = date("d/m/Y", $startfrom_ts);
$enddate_picker_value = date("d/m/Y", $enddate_ts);

// Build shared filter params string for pagination links
$filter_params  = $search   ? '&search='        . urlencode($search)   : '';
$filter_params .= $idaqar   ? '&idaqar='         . $idaqar . '&aqarname=' . urlencode($aqarname) : '';
$filter_params .= $startfrom ? '&startfrom='     . urlencode($startfrom) : '';
$filter_params .= $enddate   ? '&enddate='        . urlencode($enddate)   : '';
$filter_params .= $payment_type_f   > 0  ? '&payment_type_f='   . $payment_type_f   : '';
$filter_params .= $money_source_filter >= 0 ? '&money_source_filter=' . $money_source_filter : '';
$filter_params .= $bankid > 0 ? '&bankid=' . $bankid : '';

// Ensure table structure is up to date
mysql_query("ALTER TABLE sanadsarf ADD attachedimages varchar(500) NOT NULL", $link);

if (isset($_POST['ajax_action']) && $_POST['ajax_action'] == 'update_limited_voucher') {
    header('Content-Type: application/json; charset=utf-8');

    $edit_sanadid = isset($_POST['edit_sanadid']) ? intval($_POST['edit_sanadid']) : 0;
    $edit_sanadate = convertGregorianDisplayDateToTimestamp(isset($_POST['edit_sanadate']) ? $_POST['edit_sanadate'] : '');
    $edit_payment_type = isset($_POST['edit_payment_type']) ? intval($_POST['edit_payment_type']) : 0;
    $edit_money_source = isset($_POST['edit_money_source']) ? intval($_POST['edit_money_source']) : -1;

    if ($edit_sanadid < 1) {
        echo json_encode(['success' => false, 'message' => 'رقم السند غير صحيح'], JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES);
        exit();
    }

    if (!$edit_sanadate) {
        echo json_encode(['success' => false, 'message' => 'تاريخ السند غير صحيح'], JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES);
        exit();
    }

    if (!in_array($edit_payment_type, [1, 2, 3, 4, 5], true)) {
        echo json_encode(['success' => false, 'message' => 'طريقة الصرف غير صحيحة'], JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES);
        exit();
    }

    if (!in_array($edit_money_source, [0, 1], true)) {
        echo json_encode(['success' => false, 'message' => 'مصدر المبلغ غير صحيح'], JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES);
        exit();
    }

    $existing_voucher = mysql_fetch_array(mysql_query("SELECT sanadid FROM sanadsarf WHERE sanadid='" . $edit_sanadid . "' LIMIT 1", $link));
    if (!isset($existing_voucher['sanadid']) || !$existing_voucher['sanadid']) {
        echo json_encode(['success' => false, 'message' => 'السند غير موجود'], JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES);
        exit();
    }

    $update_sql = "UPDATE sanadsarf SET sanadate='" . $edit_sanadate . "', payment_type='" . $edit_payment_type . "', money_source='" . $edit_money_source . "' WHERE sanadid='" . $edit_sanadid . "' LIMIT 1";
    $updated = mysql_query($update_sql, $link);

    if ($updated) {
        echo json_encode(['success' => true, 'message' => 'تم تحديث بيانات السند بنجاح'], JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES);
        exit();
    }

    echo json_encode(['success' => false, 'message' => 'تعذر تحديث بيانات السند'], JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES);
    exit();
}

// Handle AJAX delete request
if ($deltesanadid && $ajax_request == 1) {
    $rid = mysql_fetch_array(mysql_query("SELECT sanadid FROM sanadsarf WHERE sanadid='" . intval($deltesanadid) . "' LIMIT 1", $link));

    if ($rid['sanadid']) {
        loginfo("critical", "delete", "تم حذف سند الصرف رقم {$deltesanadid}", "", "sanadsarf", $deltesanadid, $link);
        mysql_query("DELETE FROM sanadsarf WHERE sanadid='" . intval($deltesanadid) . "' LIMIT 1", $link);

        $response = array(
            'success' => true,
            'message' => 'تم حذف السند بنجاح'
        );
    } else {
        $response = array(
            'success' => false,
            'message' => 'السند غير موجود'
        );
    }

    echo json_encode($response, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES);
    exit();
}
