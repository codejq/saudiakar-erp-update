    <!-- Installment Summary Statistics -->
    <?php
    // Calculate installment statistics for this specific property
    // Uses new database schema with status and amount tracking
    $currentTime = time();
    $statsSql = "SELECT
                    COUNT(*) as total_installments,
                    SUM(CASE 
                        WHEN iscomplete = 1 THEN 1
                        WHEN IFNULL(amount_paid, IFNULL(dof3at, 0)) >= (kastvalue + IFNULL(water, 0) + IFNULL(sa3ee, 0) + IFNULL(services, 0)) THEN 1
                        ELSE 0 
                    END) as paid_count,
                    SUM(CASE 
                        WHEN iscomplete = 0 
                        AND IFNULL(amount_paid, IFNULL(dof3at, 0)) > 0 
                        AND IFNULL(amount_paid, IFNULL(dof3at, 0)) < (kastvalue + IFNULL(water, 0) + IFNULL(sa3ee, 0) + IFNULL(services, 0)) 
                        THEN 1 
                        ELSE 0 
                    END) as partial_count,
                    SUM(CASE 
                        WHEN kastdate < $currentTime 
                        AND iscomplete = 0 
                        AND IFNULL(amount_paid, IFNULL(dof3at, 0)) < (kastvalue + IFNULL(water, 0) + IFNULL(sa3ee, 0) + IFNULL(services, 0))
                        AND status != 'cancelled'
                        AND status != 'waived'
                        THEN 1 
                        ELSE 0 
                    END) as overdue_count,
                    SUM(kastvalue + IFNULL(water, 0) + IFNULL(sa3ee, 0) + IFNULL(services, 0)) as total_amount,
                    SUM(IFNULL(amount_paid, IFNULL(dof3at, 0))) as total_paid,
                    SUM(GREATEST(0, (kastvalue + IFNULL(water, 0) + IFNULL(sa3ee, 0) + IFNULL(services, 0)) - IFNULL(amount_paid, IFNULL(dof3at, 0)))) as total_remaining,
                    SUM(IFNULL(late_fee, 0)) as total_late_fees
                 FROM aksat
                 WHERE idsubaqar = '$idsubaqar'
                 AND egar_id = '$contractId'
                 AND status != 'cancelled'";
    $statsResult = mysql_query($statsSql, $link);
    $stats = mysql_fetch_assoc($statsResult);

    // Provide defaults if query fails or returns no results
    if (!$stats) {
        $stats = [
            'total_installments' => 0,
            'paid_count' => 0,
            'partial_count' => 0,
            'overdue_count' => 0,
            'total_amount' => 0,
            'total_paid' => 0,
            'total_remaining' => 0,
            'total_late_fees' => 0
        ];
    }

    // Ensure numeric values
    $stats['total_installments'] = intval($stats['total_installments']);
    $stats['paid_count'] = intval($stats['paid_count']);
    $stats['partial_count'] = intval($stats['partial_count']);
    $stats['overdue_count'] = intval($stats['overdue_count']);
    $stats['total_amount'] = floatval($stats['total_amount']);
    $stats['total_paid'] = floatval($stats['total_paid']);
    $stats['total_remaining'] = floatval($stats['total_remaining']);
    $stats['total_late_fees'] = floatval($stats['total_late_fees']);
    
    // If total_remaining is 0 but we have unpaid installments, calculate it
    if ($stats['total_remaining'] == 0 && ($stats['paid_count'] + $stats['partial_count']) < $stats['total_installments']) {
        $stats['total_remaining'] = $stats['total_amount'] - $stats['total_paid'];
    }
    ?>

    <div class="installment-summary">
        <h5 class="mb-3">
