    <!-- Installments List -->
    <div class="row" id="installmentsList">
        <?php
        // Get installments with VAT info for this specific property's current contract
        $sql = "SELECT a.*, e.vat_type
                FROM aksat a
                LEFT JOIN amlakdetails ad ON a.idsubaqar = ad.idsubaqar
                LEFT JOIN egar e ON ad.rakam3akdid = e.rakam3akdid
                WHERE a.idsubaqar = '$idsubaqar'
                AND a.egar_id = '$contractId'
                ORDER BY a.kastdate ASC";
                
        $result = mysql_query($sql, $link);

        $installmentNumber = 1;
        while ($installment = mysql_fetch_assoc($result)):
            // DEBUG: Show raw values from database
            $debug_amount_paid = $installment['amount_paid'] ?? 'NULL';
            $debug_dof3at = $installment['dof3at'] ?? 'NULL';
            
            // Initialize fields - use dof3at (old system) as fallback for amount_paid
            $installment['amount_paid'] = !empty($installment['amount_paid']) ? $installment['amount_paid'] : floatval($installment['dof3at'] ?? 0);
            $installment['late_fee'] = $installment['late_fee'] ?? 0;
            $installment['status'] = $installment['status'] ?? '';

            // Calculate VAT based on contract type
            $commesion_vat = 0;
            $depositeamount_vat = 0;
            $vat_type = $installment['vat_type'] ?? 0;
            
            if ($vat_type > 0) {
                $rentValue = $installment['kastvalue'] - $installment['water'] - $installment['sa3ee'] - $installment['services'];
                $commesion_vat = $installment['sa3ee'] * 0.15;
                
                if ($vat_type == 2) {
                    $depositeamount_vat = $rentValue * 0.15;
                }
            }

            // Calculate total amount including VAT
            $totalAmount = $installment['kastvalue'] + $commesion_vat + $depositeamount_vat;

            // Calculate remaining amount
            $installment['amount_remaining'] = $totalAmount - $installment['amount_paid'];
            if ($installment['amount_remaining'] < 0) $installment['amount_remaining'] = 0;

            // Get status
            $status = $installment['status'];
            if (empty($status) || $status == 'pending') {
                if ($installment['iscomplete'] == 1 || $installment['amount_paid'] >= $totalAmount) {
                    $status = 'paid';
                } elseif ($installment['amount_paid'] > 0 && $installment['amount_paid'] < $totalAmount) {
                    $status = 'partial';
                }
            }

            // Calculate payment percentage
            $paymentPercentage = 0;
            if ($totalAmount > 0) {
                $paymentPercentage = ($installment['amount_paid'] / $totalAmount) * 100;
            }

            // Status badge configuration
            $statusConfig = [
                'paid' => ['color' => 'success', 'icon' => 'check-circle', 'label' => 'مدفوع'],
                'partial' => ['color' => 'warning', 'icon' => 'exclamation-circle', 'label' => 'مدفوع جزئياً'],
                'overdue' => ['color' => 'danger', 'icon' => 'x-circle', 'label' => 'متأخر'],
                'due' => ['color' => 'info', 'icon' => 'clock', 'label' => 'مستحق'],
                'pending' => ['color' => 'secondary', 'icon' => 'hourglass', 'label' => 'قادم'],
                'cancelled' => ['color' => 'dark', 'icon' => 'slash-circle', 'label' => 'ملغي'],
                'waived' => ['color' => 'muted', 'icon' => 'dash-circle', 'label' => 'معفى']
            ];

            $statusInfo = $statusConfig[$status] ?? $statusConfig['pending'];
            $statusClass = 'status-' . $status;
        ?>

            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card installment-card <?= $statusClass ?> h-100">
                    <div class="card-body">
                        <!-- Header -->
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <h5 class="card-title mb-1">
                                    قسط رقم <?= $installment['kastname'] ?>
                                </h5>
                                <small class="text-muted">
                                    <i class="bi bi-calendar3 me-1"></i>
                                    <?= $calendar->formatDateForDisplay($installment['kastdate'], $calendarType) ?>
                                </small>
                            </div>
                            <span class="badge bg-<?= $statusInfo['color'] ?> status-badge-lg">
                                <i class="bi bi-<?= $statusInfo['icon'] ?> me-1"></i>
                                <?= $statusInfo['label'] ?>
                            </span>
                        </div>

                        <!-- Amount Details -->
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-2">
                                <span>قيمة الإيجار:</span>
                                <strong><?= number_format(($installment['kastvalue']-$installment['water'] - $installment['sa3ee'] - $installment['services']), 2) ?></strong>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">المياه:</span>
                                <span><?= number_format($installment['water'], 2) ?></span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">السعي:</span>
                                <span><?= number_format($installment['sa3ee'], 2) ?></span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">الخدمات:</span>
                                <span><?= number_format($installment['services'], 2) ?></span>
                            </div>
                            <?php if ($vat_type > 0): ?>
                                <?php if ($commesion_vat > 0): ?>
                                    <div class="d-flex justify-content-between mb-2">
                                        <span class="text-info">ضريبة السعي (15%):</span>
                                        <span><?= number_format($commesion_vat, 2) ?></span>
                                    </div>
                                <?php endif; ?>
                                <?php if ($depositeamount_vat > 0): ?>
                                    <div class="d-flex justify-content-between mb-2">
                                        <span class="text-info">ضريبة الإيجار (15%):</span>
                                        <span><?= number_format($depositeamount_vat, 2) ?></span>
                                    </div>
                                <?php endif; ?>
                            <?php endif; ?>
                            <?php if ($installment['late_fee'] > 0): ?>
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="text-danger">غرامة التأخير:</span>
                                    <span class="late-fee-badge"><?= number_format($installment['late_fee'], 2) ?></span>
                                </div>
                            <?php endif; ?>
                            <hr>
                            <div class="d-flex justify-content-between mb-2">
                                <strong>المجموع:</strong>
                                <strong class="text-primary"><?= number_format($totalAmount + $installment['late_fee'], 2) ?> ريال</strong>
                            </div>
                            <div class="d-flex justify-content-between mb-2" style="background: #e8f5e9; padding: 5px; border-radius: 4px;">
                                <strong class="text-success">المدفوع:</strong>
                                <strong class="text-success"><?= number_format($installment['amount_paid'], 2) ?> ريال</strong>
                            </div>
                            <!-- DEBUG INFO -->
                            <div style="font-size: 10px; color: #666; padding: 3px; background: #f0f0f0; border-radius: 3px;display:none">
                                DEBUG: amount_paid=<?= $debug_amount_paid ?> | dof3at=<?= $debug_dof3at ?> | final=<?= $installment['amount_paid'] ?>
                            </div>
                            <div class="d-flex justify-content-between" style="background: #fff3e0; padding: 5px; border-radius: 4px;">
                                <strong class="text-warning">المتبقي:</strong>
                                <strong class="text-warning"><?= number_format($installment['amount_remaining'], 2) ?> ريال</strong>
                            </div>
                        </div>

                        <!-- Payment Progress Bar -->
                        <?php if ($installment['amount_paid'] > 0 && $installment['amount_remaining'] > 0): ?>
                            <div class="mb-3">
                                <div class="partial-payment-bar">
                                    <div class="partial-payment-fill" style="width: <?= $paymentPercentage ?>%"></div>
                                </div>
                                <small class="text-muted text-center d-block mt-1"><?= number_format($paymentPercentage, 1) ?>% مدفوع</small>
                            </div>
                        <?php endif; ?>

                        <!-- Actions -->
                        <div class="d-grid gap-2">
                            <?php if ($status != 'paid' && $status != 'cancelled'): ?>
                                <button type="button" class="btn btn-sm btn-success"
                                        onclick="showPaymentModal(<?= $installment['kastid'] ?>)">
                                    <i class="bi bi-cash me-1"></i>
                                    تسجيل دفعة
                                </button>
                            <?php endif; ?>
                            <div class="btn-group btn-group-sm" role="group">
                                <button type="button" class="btn btn-outline-primary"
                                        onclick="showEditModal(<?= $installment['kastid'] ?>)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button type="button" class="btn btn-outline-info"
                                        onclick="showPaymentHistory(<?= $installment['kastid'] ?>)">
                                    <i class="bi bi-clock-history"></i>
                                </button>
                                <?php if ($status != 'paid' && $status != 'cancelled'): ?>
                                    <button type="button" class="btn btn-outline-danger"
                                            onclick="cancelInstallment(<?= $installment['kastid'] ?>)">
                                        <i class="bi bi-x-circle"></i>
                                    </button>
                                <?php endif; ?>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        <?php
            $installmentNumber++;
        endwhile;
        ?>
    </div>
</div>

