<?php
// Set page variables
$sc_title = "تقرير بجميع الشواغر المتوفرة";
$sc_id = "51";

// Extract request variables
extract($_REQUEST);

// Check if this is a report view (print mode)
$report = isset($report) && $report == 1 ? 1 : 0;

// Include required files early (needed by export handler)
require '../arabicTools.class.hnt';
include_once "arabic_num.class.hnt";
include_once "amlakfunctions.hnt";

// Export handler — runs before any HTML output
if (isset($_GET['export']) && in_array(trim($_GET['export']), ['csv', 'xls'], true)) {
    include_once "../../../nocash.hnt";
    include_once  "../../../connectdb.hnt";

    $exp_sql = "SELECT ad.idsubaqar, ad.rakam, ad.price, a.aqarname,
                       COALESCE(st.aqarsubtypename, '') as aqarsubtypename
                FROM amlakdetails ad
                LEFT JOIN amlak a ON ad.idaqar = a.idaqar
                LEFT JOIN aqarsubtype st ON ad.aqarsubtype = st.aqarsubtype
                WHERE ad.mostagerid = 0
                ORDER BY ad.aqarsubtype";
    $exp_res = mysql_query($exp_sql, $link);

    $exp_headers = ['م', 'نوع الوحدة', 'رقم', 'العقار', 'الإيجار السنوي'];
    $exp_rows = [];
    $xx = 0;
    while ($r = mysql_fetch_array($exp_res)) {
        $xx++;
        $exp_rows[] = [$xx, $r['aqarsubtypename'], $r['rakam'], $r['aqarname'], number_format($r['price'], 2, '.', '')];
    }

    $_exp_type = trim($_GET['export']);
    $_fn = date('Ymd_His');
    if ($_exp_type === 'csv') {
        header('Content-Type: text/csv; charset=UTF-8');
        header('Content-Disposition: attachment; filename="allshawagher_' . $_fn . '.csv"');
        $_out = fopen('php://output', 'w');
        fwrite($_out, "\xEF\xBB\xBF");
        fputcsv($_out, $exp_headers, ',', '"', '\\');
        foreach ($exp_rows as $_r) fputcsv($_out, $_r, ',', '"', '\\');
        fclose($_out);
        exit;
    }
    header('Content-Type: application/vnd.ms-excel; charset=UTF-8');
    header('Content-Disposition: attachment; filename="allshawagher_' . $_fn . '.xls"');
    echo '<html lang="ar" dir="rtl"><head><meta charset="UTF-8"></head><body><table border="1"><tr>';
    foreach ($exp_headers as $_h) echo '<th>' . htmlspecialchars($_h) . '</th>';
    echo '</tr>';
    foreach ($exp_rows as $_r) { echo '<tr>'; foreach ($_r as $_c) echo '<td>' . htmlspecialchars($_c) . '</td>'; echo '</tr>'; }
    echo '</table></body></html>';
    exit;
}

// Include authentication and database
if ($report == 1) {
    include_once "../../../nocash.hnt";
    include_once "../../../report_header.hnt";
} else {
    include_once "../../../nocash.hnt";
    include_once "../../../header.hnt";
}

// Get current date in Arabic
$daxx = date("H/i/s/m/d/Y");
$daxx = explode("/", $daxx);
$h_date = mktime($daxx[0], $daxx[1], $daxx[2], $daxx[3], $daxx[4], $daxx[5]);
$h_date2 = arabicDate("ar:l d/F -Y h:iA", $h_date);
$h_date1 = arabicDate('hj:l d-F-Y هـ', $h_date);
$display_date = ($hnt_dll || $hnt_supper_dll == 5) ? $h_date2 : $h_date1;

// Get vacant properties data
$sqlaq = "SELECT idsubaqar, rakam, idaqar, aqarsubtype, price FROM amlakdetails WHERE mostagerid = 0 ORDER BY aqarsubtype";
$resaq = mysql_query($sqlaq, $link);

// Calculate total
$sumation = mysql_fetch_array(mysql_query("SELECT SUM(price) as dd FROM amlakdetails WHERE mostagerid = 0", $link));
$total_price = isset($sumation['dd']) ? $sumation['dd'] : 0;

// Count vacant properties
$vacant_count = mysql_num_rows($resaq);

// Only render HTML if NOT in report mode, otherwise use report layout
if ($report != 1) {
?>

