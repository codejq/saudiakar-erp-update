            <!-- Properties Table -->
            <?php if ($vacant_count > 0) { ?>
            <div class="table-responsive">
                <table class="table property-table mb-0">
                    <thead>
                        <tr>
                            <th style="width: 80px;">م</th>
                            <th>العقار</th>
                            <th style="width: 150px;">الإيجار السنوي</th>
                        </tr>
                    </thead>
                    <tbody>
                        <?php
                        $xx = 0;
                        mysql_data_seek($resaq, 0); // Reset pointer
                        while ($rowaq = mysql_fetch_array($resaq)) {
                            $xx++;
                            $property_type = displaysubtype($rowaq['aqarsubtype']);
                            $property_name = displayaqarname($rowaq['idaqar']);
                            $price_formatted = number_format($rowaq['price'], 2);
                        ?>
                        <tr>
                            <td><strong><?= $xx ?></strong></td>
                            <td class="text-start">
