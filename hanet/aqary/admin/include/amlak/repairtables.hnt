<style>
.repair-progress {
	background: linear-gradient(135deg, #0891b2 0%, #0e7490 100%);
	color: white;
	padding: 1rem;
	border-radius: 6px;
	margin-bottom: 1rem;
	font-weight: 600;
}
.repair-status {
	background: #f8f9fa;
	padding: 0.75rem;
	border-radius: 4px;
	margin-bottom: 0.5rem;
	border-left: 4px solid #0891b2;
	font-size: 0.9rem;
}
#repairLog {
	max-height: 400px;
	overflow-y: auto;
}
</style>

<div class="container-fluid py-3">
	<div class="card shadow-sm border-0">
		<div class="card-header text-white" style="background: linear-gradient(135deg, #189c2aff 0%, #066d96ff 100%);">
			<h4 class="mb-0">
				<i class="bi bi-tools me-2"></i>
				ضبط وإصلاح قاعدة البيانات
			</h4>
		</div>
		<div class="card-body p-4" dir="rtl">
			<div class="alert alert-info mb-4" role="alert">
				<i class="bi bi-info-circle me-2"></i>
				جاري فحص وإصلاح جداول قاعدة البيانات... الرجاء الانتظار.
			</div>

			<div id="repairProgress" class="mb-3">
				<div class="progress" style="height: 25px;">
					<div class="progress-bar progress-bar-striped progress-bar-animated bg-success" role="progressbar" style="width: 0%" id="progressBar">
						<span id="progressText">0%</span>
					</div>
				</div>
			</div>

			<div id="repairLog">
				<!-- Repair operations will be logged here -->
			</div>
		</div>
	</div>
</div>

<script>
function updateProgress(percent, message) {
	const progressBar = document.getElementById('progressBar');
	const progressText = document.getElementById('progressText');
	const repairLog = document.getElementById('repairLog');

	if (progressBar && progressText) {
		progressBar.style.width = percent + '%';
		progressText.textContent = Math.round(percent) + '%';
	}

	if (message && repairLog) {
		const logEntry = document.createElement('div');
		logEntry.className = 'repair-status';
		logEntry.innerHTML = '<i class="bi bi-check-circle text-success me-2"></i>' + message;
		repairLog.appendChild(logEntry);
		repairLog.scrollTop = repairLog.scrollHeight;
	}
}

function completeRepair() {
	updateProgress(100, 'اكتملت عملية الإصلاح بنجاح');
	const progressBar = document.getElementById('progressBar');
	if (progressBar) {
		progressBar.classList.remove('progress-bar-animated');
	}
	setTimeout(function() {
		if (typeof showBootstrapNotification === 'function') {
			showBootstrapNotification('success', 'تم ترقية وإصلاح قاعدة البيانات بنجاح');
		} else {
			alert('تم ترقية وإصلاح قاعدة البيانات بنجاح');
		}
	}, 500);
}

updateProgress(5, 'بدء عملية الإصلاح...');
</script>

