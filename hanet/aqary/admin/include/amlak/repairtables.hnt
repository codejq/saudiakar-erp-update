function addscreenifnotexists($sc_idD , $sc_titleD ,$screenParent,$link ){
	$sql="select count(screenid) as dd  from  screens where screenid = '{$sc_idD}'  ";
	$row=mysql_fetch_array(mysql_query($sql,$link));
	if($row['dd'] < 1){
		mysql_query("INSERT INTO screens VALUES ($sc_idD, '{$sc_idD}', '{$sc_titleD}', '1', $screenParent,'') " ,$link);
		echo mysql_error();
	}
}

