// Build WHERE clause
$where = "";
if ($search) {
    $where = " WHERE
        idsanad='" . addslashes($search) . "' OR
        mostagername LIKE '%" . addslashes($search) . "%' OR
        depositeamount LIKE '%" . addslashes($search) . "%' OR
        recivername LIKE '%" . addslashes($search) . "%' OR
        mybyan LIKE '%" . addslashes($search) . "%' OR
        cheqnumber LIKE '%" . addslashes($search) . "%' OR
        cheqon LIKE '%" . addslashes($search) . "%'";
}

if ($idsanad) {
    $where = " WHERE idsanad='" . intval($idsanad) . "'";
}

if ($idaqar && isset($startfromx) && isset($enddatex)) {
    $where = " WHERE idaqar='" . intval($idaqar) . "' AND sanaddate > $startfromx AND sanaddate < $enddatex";
}

if ($dd && !$idaqar && isset($startfromx) && isset($enddatex)) {
    $where = " WHERE sanaddate > $startfromx AND sanaddate < $enddatex";
}

// Pagination
$sql = "SELECT COUNT(idsanad) as dd FROM sanad $where";
$rownum = mysql_fetch_array(mysql_query($sql, $link));
$rownum = $rownum['dd'];
$rowperpage = isset($rowperpage) ? intval($rowperpage) : 40;
$pagenum = ceil($rownum / $rowperpage);

// Display count
echo '<div class="alert alert-info mb-3">';
echo '<i class="bi bi-info-circle me-2"></i>';
echo 'عدد السندات: <strong class="text-danger">' . $rownum . '</strong> سند';
echo '</div>';

// Pagination
if ($pagenum > 1) {
    echo '<nav aria-label="Page navigation"><ul class="pagination justify-content-center">';
    for ($xi = 1; $xi <= $pagenum; $xi++) {
        $active = ($page == $xi) ? 'active' : '';
        if (($xi > ($page - 4) && $xi < ($page + 4)) || $xi == 1 || $xi == $pagenum || $xi < 4 || $xi > ($pagenum - 4)) {
            echo '<li class="page-item ' . $active . '"><a class="page-link" href="allsanad.hnt?page=' . $xi . '&where=' . urlencode($where) . '">' . $xi . '</a></li>';
        } elseif ($xi == ($page - 4) || $xi == ($page + 4)) {
            echo '<li class="page-item disabled"><span class="page-link">...</span></li>';
        }
    }
    echo '</ul></nav>';
}

// Calculate limit
$limit = ($page - 1) * $rowperpage;
$limit = $limit . "," . $rowperpage;
if ($page == 1 || $page == '') {
    $limit = $rowperpage;
}

// Get vouchers
$sql = "SELECT * FROM sanad $where ORDER BY idsanad DESC LIMIT $limit";
$result = mysql_query($sql, $link);
?>

