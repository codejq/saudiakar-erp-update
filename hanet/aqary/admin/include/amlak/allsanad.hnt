$enddate_request = isset($enddate) ? trim($enddate) : '';
$dd = isset($dd) ? intval($dd) : 0;
$mm = isset($mm) ? intval($mm) : 0;
$yy = isset($yy) ? intval($yy) : 0;
$dd2 = isset($dd2) ? intval($dd2) : 0;
$mm2 = isset($mm2) ? intval($mm2) : 0;
$yy2 = isset($yy2) ? intval($yy2) : 0;

$sc_title = "عرض جميع سندات القبض";
$sc_id = "56";

include_once "../../../nocash.hnt";
require '../arabicTools.class.hnt';
require '../uCal.class.hnt';
$dcal = new uCal;

// Export handler — runs before any HTML output
if (isset($_GET['export']) && in_array(trim($_GET['export']), ['csv', 'xls'], true)) {
    include_once "../../../connectdb.hnt";
    $_search  = isset($_GET['search'])  ? trim($_GET['search'])  : '';
    $_idsanad = isset($_GET['idsanad']) ? intval($_GET['idsanad']) : 0;
    $_idaqar  = isset($_GET['idaqar'])  ? intval($_GET['idaqar']) : 0;
    $_startfrom = isset($_GET['startfrom']) ? trim($_GET['startfrom']) : '';
    $_enddate = isset($_GET['enddate']) ? trim($_GET['enddate']) : '';
    $_dd  = isset($_GET['dd'])  ? intval($_GET['dd'])  : 0;
    $_mm  = isset($_GET['mm'])  ? intval($_GET['mm'])  : 0;
    $_yy  = isset($_GET['yy'])  ? intval($_GET['yy'])  : 0;
    $_dd2 = isset($_GET['dd2']) ? intval($_GET['dd2']) : 0;
    $_mm2 = isset($_GET['mm2']) ? intval($_GET['mm2']) : 0;
    $_yy2 = isset($_GET['yy2']) ? intval($_GET['yy2']) : 0;

    $_sfx = 0; $_edx = 0;
    if ($_startfrom !== '' && strpos($_startfrom, '-') !== false && $_enddate !== '' && strpos($_enddate, '-') !== false) {
        $_d = explode("-", "0-0-0-" . $_startfrom);
        $_d2 = explode("-", "0-0-0-" . $_enddate);
        if (isset($_d[5], $_d2[5], $_d[4], $_d2[4], $_d[3], $_d2[3]) && $_d[5] < 1900 && $_d[5] > 1400) {
            $_dateo = $dcal->u2g($_d[3], $_d[4], $_d[5]); $_d[3] = $_dateo['day']; $_d[4] = $_dateo['month']; $_d[5] = $_dateo['year'];
            $_dateo = $dcal->u2g($_d2[3], $_d2[4], $_d2[5]); $_d2[3] = $_dateo['day']; $_d2[4] = $_dateo['month']; $_d2[5] = $_dateo['year'];
        }
        if (isset($_d[5], $_d[4], $_d[3], $_d2[5], $_d2[4], $_d2[3])) {
            $_sfx = mktime(0, 0, 0, $_d[4], $_d[3], $_d[5]);
            $_edx = mktime(0, 0, 0, $_d2[4], $_d2[3], $_d2[5]);
        }
    } elseif ($_dd) {
        if ($_yy < 1900 && $_yy > 1400) {
            $_dateo = $dcal->u2g($_dd, $_mm, $_yy);  $_dd = $_dateo['day'];  $_mm = $_dateo['month'];  $_yy = $_dateo['year'];
            $_dateo = $dcal->u2g($_dd2, $_mm2, $_yy2); $_dd2 = $_dateo['day']; $_mm2 = $_dateo['month']; $_yy2 = $_dateo['year'];
        }
        $_sfx = mktime(0, 0, 0, $_mm, $_dd, $_yy);
        $_edx = mktime(0, 0, 0, $_mm2, $_dd2, $_yy2);
    }

    $_where = '';
    if ($_search) {
        $_where = " WHERE idsanad='" . addslashes($_search) . "' OR mostagername LIKE '%" . addslashes($_search) . "%' OR depositeamount LIKE '%" . addslashes($_search) . "%' OR mybyan LIKE '%" . addslashes($_search) . "%'";
    } elseif ($_idsanad) {
        $_where = " WHERE idsanad='" . intval($_idsanad) . "'";
    } elseif ($_idaqar && $_sfx && $_edx) {
        $_where = " WHERE idaqar='" . intval($_idaqar) . "' AND sanaddate > $_sfx AND sanaddate < $_edx";
    } elseif ($_dd && $_sfx && $_edx) {
        $_where = " WHERE sanaddate > $_sfx AND sanaddate < $_edx";
    }

    $exp_sql = "SELECT s.idsanad, s.mostagername, s.depositeamount, s.mybyan, s.sanaddate, a.aqarname
                FROM sanad s LEFT JOIN amlak a ON s.idaqar = a.idaqar
                $_where ORDER BY s.idsanad DESC";
    $exp_res = mysql_query($exp_sql, $link);
    $exp_headers = ['رقم السند', 'اسم المستأجر', 'المبلغ', 'البيان', 'العقار', 'التاريخ'];
    $exp_rows = [];
    while ($r = mysql_fetch_array($exp_res)) {
        $exp_rows[] = [intval($r['idsanad']), $r['mostagername'], number_format($r['depositeamount'], 2, '.', ''), $r['mybyan'], $r['aqarname'] ?: '', date('d/m/Y', $r['sanaddate'])];
    }

    $_exp_type = trim($_GET['export']); $_fn = date('Ymd_His');
    if ($_exp_type === 'csv') {
        header('Content-Type: text/csv; charset=UTF-8');
        header('Content-Disposition: attachment; filename="allsanad_' . $_fn . '.csv"');
        $_out = fopen('php://output', 'w'); fwrite($_out, "\xEF\xBB\xBF");
        fputcsv($_out, $exp_headers, ',', '"', '\\');
        foreach ($exp_rows as $_r) fputcsv($_out, $_r, ',', '"', '\\');
        fclose($_out); exit;
    }
    header('Content-Type: application/vnd.ms-excel; charset=UTF-8');
    header('Content-Disposition: attachment; filename="allsanad_' . $_fn . '.xls"');
    echo '<html lang="ar" dir="rtl"><head><meta charset="UTF-8"></head><body><table border="1"><tr>';
    foreach ($exp_headers as $_h) echo '<th>' . htmlspecialchars($_h) . '</th>';
    echo '</tr>';
    foreach ($exp_rows as $_r) { echo '<tr>'; foreach ($_r as $_c) echo '<td>' . htmlspecialchars($_c) . '</td>'; echo '</tr>'; }
    echo '</table></body></html>'; exit;
}

include_once "../../../header.hnt";
