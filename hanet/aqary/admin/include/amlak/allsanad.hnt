// Calculate default dates
$startfrom = time();
$enddate = time() + (30 * 86400);

if (!isset($hnt_dll) || (!$hnt_dll && (!isset($hnt_supper_dll) || $hnt_supper_dll != 5))) {
    $dateo = $dcal->g2u(date("d", $startfrom), date("m", $startfrom), date("Y", $startfrom));
    $daxx[3] = $dateo['day'];
    $daxx[4] = $dateo['month'];
    $daxx[5] = $dateo['year'];
    $dateo = $dcal->g2u(date("d", $enddate), date("m", $enddate), date("Y", $enddate));
    $dax2[3] = $daxx[3];
    $dax2[4] = $dateo['month'];
    $dax2[5] = $dateo['year'];
} else {
    $daxx[3] = date("d", $startfrom);
    $daxx[4] = date("m", $startfrom);
    $daxx[5] = date("Y", $startfrom);
    $dax2[3] = $daxx[3];
    $dax2[4] = date("m", $enddate);
    $dax2[5] = date("Y", $enddate);
}

// Override with request values if provided
if ($dd) {
    $daxx[3] = $dd;
    $daxx[4] = $mm;
    $daxx[5] = $yy;
    $dax2[3] = $dd2;
    $dax2[4] = $mm2;
    $dax2[5] = $yy2;

    if (($yy < 1900) && ($yy > 1400)) {
        $dateo = $dcal->u2g($dd, $mm, $yy);
        $dd = $dateo['day'];
        $mm = $dateo['month'];
        $yy = $dateo['year'];
        $dateo = $dcal->u2g($dd2, $mm2, $yy2);
        $dd2 = $dateo['day'];
        $mm2 = $dateo['month'];
        $yy2 = $dateo['year'];
    }

    $startfromx = mktime(0, 0, 0, $mm, $dd, $yy);
    $enddatex = mktime(0, 0, 0, $mm2, $dd2, $yy2);
}
