while ($row = mysql_fetch_array($result)) {
    // Prepare attachments link
    if ($row['attachedimages']) {
        $attachedimagelink = "<a href='/aqary/admin/include/uploadcenter.hnt?ids=" . $row['attachedimages'] . "&table=sanad&tableid=idsanad&tableidvalue=" . $row['idsanad'] . "' class='btn btn-sm btn-outline-primary' target='_blank' title='عرض المرفقات'><i class='bi bi-paperclip'></i></a>";
    } else {
        $attachedimagelink = "<a href='/aqary/admin/include/uploadcenter.hnt?ids=0,0&table=sanad&tableid=idsanad&tableidvalue=" . $row['idsanad'] . "' class='btn btn-sm btn-outline-secondary' target='_blank' title='إضافة مرفقات'><i class='bi bi-link-45deg'></i></a>";
    }

    // Get property name
    $sql2 = "SELECT aqarname FROM amlak WHERE idaqar='" . intval($row['idaqar']) . "'";
    $rowaq = mysql_fetch_array(mysql_query($sql2, $link));

    // Format date
    if (isset($hnt_dll) && ($hnt_dll || (isset($hnt_supper_dll) && $hnt_supper_dll == 5))) {
        $dhd = date("d/m/Y", $row['sanaddate']);
    } else {
        $dhd = ArabicTools::arabicDate('hj:d/m/Y', $row['sanaddate']);
    }

    $voucer_type = "";
    if (!isset($rowaq['aqarname']) || !$rowaq['aqarname']) {
        $dhd = $row['period'];
        $voucer_type = "free2";
    }
