        $mm2 = $dateo['month'];
        $yy2 = $dateo['year'];
    }

    $startfromx = mktime(0, 0, 0, $mm, $dd, $yy);
    $enddatex = mktime(0, 0, 0, $mm2, $dd2, $yy2);
}

if (!$startfromx || !$enddatex) {
    $startfromx = $default_startfrom;
    $enddatex = $default_enddate;
}

