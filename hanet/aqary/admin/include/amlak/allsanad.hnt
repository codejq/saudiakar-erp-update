$startfromx = 0;
$enddatex = 0;
$default_startfrom = time();
$default_enddate = time() + (30 * 86400);

if ($startfrom_request !== '' && strpos($startfrom_request, '-') !== false && $enddate_request !== '' && strpos($enddate_request, '-') !== false) {
    $start_parts = explode("-", "0-0-0-" . $startfrom_request);
    $end_parts = explode("-", "0-0-0-" . $enddate_request);

    if (isset($start_parts[5], $end_parts[5], $start_parts[4], $end_parts[4], $start_parts[3], $end_parts[3]) && ($start_parts[5] < 1900) && ($start_parts[5] > 1400)) {
        $dateo = $dcal->u2g($start_parts[3], $start_parts[4], $start_parts[5]);
        $start_parts[3] = $dateo['day'];
        $start_parts[4] = $dateo['month'];
        $start_parts[5] = $dateo['year'];
        $dateo = $dcal->u2g($end_parts[3], $end_parts[4], $end_parts[5]);
        $end_parts[3] = $dateo['day'];
        $end_parts[4] = $dateo['month'];
        $end_parts[5] = $dateo['year'];
    }

    if (isset($start_parts[5], $start_parts[4], $start_parts[3], $end_parts[5], $end_parts[4], $end_parts[3])) {
        $startfromx = mktime(0, 0, 0, $start_parts[4], $start_parts[3], $start_parts[5]);
        $enddatex = mktime(0, 0, 0, $end_parts[4], $end_parts[3], $end_parts[5]);
    }
} elseif ($dd) {
    if (($yy < 1900) && ($yy > 1400)) {
        $dateo = $dcal->u2g($dd, $mm, $yy);
        $dd = $dateo['day'];
        $mm = $dateo['month'];
        $yy = $dateo['year'];
