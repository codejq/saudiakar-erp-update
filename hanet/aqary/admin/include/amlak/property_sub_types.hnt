<?php
$sc_title = "إدارة أنواع الوحدات الفرعية";
$sc_id = "41";

// Check if this is an AJAX form submission
$is_ajax_request = isset($_POST['ajax_submit']) && $_POST['ajax_submit'] == '1';

if ($is_ajax_request) {
    include_once "../../../reqloginajax.hnt";
} else {
    include_once "../../../nocash.hnt";
    $_SERVER['HTTP_REFERER'] = "reports.hnt";
    include_once "../../../header.hnt";
}

// Handle AJAX requests
if ($is_ajax_request) {
    $action = isset($_POST['action']) ? $_POST['action'] : '';
    header('Content-Type: application/json; charset=utf-8');

    // Get sub type
    if ($action == 'get') {
        $aqarsubtype = intval($_POST['aqarsubtype']);
        $sql = "SELECT * FROM aqarsubtype WHERE aqarsubtype='" . $aqarsubtype . "'";
        $result = mysql_query($sql, $link);
        
        if ($result && mysql_num_rows($result) > 0) {
            $row = mysql_fetch_array($result, MYSQL_ASSOC);
            echo json_encode(['success' => true, 'data' => $row], JSON_UNESCAPED_UNICODE | JSON_INVALID_UTF8_SUBSTITUTE);
        } else {
            echo json_encode(['success' => false, 'error' => 'نوع الوحدة غير موجود'], JSON_UNESCAPED_UNICODE | JSON_INVALID_UTF8_SUBSTITUTE);
        }
        exit;
    }

    // Add sub type
    if ($action == 'add') {
        $aqarsubtypename = trim($_POST['aqarsubtypename']);

        if (empty($aqarsubtypename)) {
            echo json_encode(['success' => false, 'error' => 'الرجاء إدخال اسم نوع الوحدة'], JSON_UNESCAPED_UNICODE | JSON_INVALID_UTF8_SUBSTITUTE);
            exit;
        }

        // Check if already exists
        $check_sql = "SELECT aqarsubtype FROM aqarsubtype WHERE aqarsubtypename='" . addslashes($aqarsubtypename) . "'";
        $check_result = mysql_query($check_sql, $link);
        
        if ($check_result && mysql_num_rows($check_result) > 0) {
            echo json_encode(['success' => false, 'error' => 'هذا النوع موجود بالفعل'], JSON_UNESCAPED_UNICODE | JSON_INVALID_UTF8_SUBSTITUTE);
            exit;
        }

        $sql = "INSERT INTO aqarsubtype SET 
                aqarsubtypename='" . addslashes($aqarsubtypename) . "',
                formuid='" . md5(time() . rand()) . "'";
        
        if (mysql_query($sql, $link)) {
            echo json_encode(['success' => true, 'message' => 'تم إضافة نوع الوحدة بنجاح'], JSON_UNESCAPED_UNICODE | JSON_INVALID_UTF8_SUBSTITUTE);
        } else {
            echo json_encode(['success' => false, 'error' => 'حدث خطأ أثناء الإضافة'], JSON_UNESCAPED_UNICODE | JSON_INVALID_UTF8_SUBSTITUTE);
        }
        exit;
    }

    // Update sub type
    if ($action == 'update') {
        $aqarsubtype = intval($_POST['aqarsubtype']);
        $aqarsubtypename = trim($_POST['aqarsubtypename']);

        if (empty($aqarsubtypename)) {
            echo json_encode(['success' => false, 'error' => 'الرجاء إدخال اسم نوع الوحدة'], JSON_UNESCAPED_UNICODE | JSON_INVALID_UTF8_SUBSTITUTE);
            exit;
        }

        // Check if name already exists for different ID
        $check_sql = "SELECT aqarsubtype FROM aqarsubtype WHERE aqarsubtypename='" . addslashes($aqarsubtypename) . "' AND aqarsubtype!=" . $aqarsubtype;
        $check_result = mysql_query($check_sql, $link);
        
        if ($check_result && mysql_num_rows($check_result) > 0) {
            echo json_encode(['success' => false, 'error' => 'هذا الاسم مستخدم بالفعل'], JSON_UNESCAPED_UNICODE | JSON_INVALID_UTF8_SUBSTITUTE);
            exit;
        }

        $sql = "UPDATE aqarsubtype SET 
                aqarsubtypename='" . addslashes($aqarsubtypename) . "'
                WHERE aqarsubtype=" . $aqarsubtype;
        
        if (mysql_query($sql, $link)) {
            echo json_encode(['success' => true, 'message' => 'تم تحديث نوع الوحدة بنجاح'], JSON_UNESCAPED_UNICODE | JSON_INVALID_UTF8_SUBSTITUTE);
        } else {
            echo json_encode(['success' => false, 'error' => 'حدث خطأ أثناء التحديث'], JSON_UNESCAPED_UNICODE | JSON_INVALID_UTF8_SUBSTITUTE);
        }
        exit;
    }

    // Delete sub type
    if ($action == 'delete') {
        $aqarsubtype = intval($_POST['aqarsubtype']);

        // Check if type is used in amlakdetails table
        $check_sql = "SELECT COUNT(*) as count FROM amlakdetails WHERE aqarsubtype='" . $aqarsubtype . "'";
        $check_result = mysql_query($check_sql, $link);
        $check_row = mysql_fetch_array($check_result);

        if ($check_row['count'] > 0) {
            echo json_encode([
                'success' => false, 
                'error' => 'لا يمكن حذف هذا النوع لأنه مستخدم في ' . $check_row['count'] . ' وحدة. الرجاء تغيير نوع هذه الوحدات أولاً'
            ], JSON_UNESCAPED_UNICODE | JSON_INVALID_UTF8_SUBSTITUTE);
            exit;
        }

        $sql = "DELETE FROM aqarsubtype WHERE aqarsubtype=" . $aqarsubtype;
        
        if (mysql_query($sql, $link)) {
            echo json_encode(['success' => true, 'message' => 'تم حذف نوع الوحدة بنجاح'], JSON_UNESCAPED_UNICODE | JSON_INVALID_UTF8_SUBSTITUTE);
        } else {
            echo json_encode(['success' => false, 'error' => 'حدث خطأ أثناء الحذف'], JSON_UNESCAPED_UNICODE | JSON_INVALID_UTF8_SUBSTITUTE);
        }
        exit;
    }

    // List all sub types
    if ($action == 'list') {
        $sql = "SELECT * FROM aqarsubtype ORDER BY aqarsubtypename";
        $result = mysql_query($sql, $link);
        $types = [];
        
        while ($row = mysql_fetch_array($result, MYSQL_ASSOC)) {
            $types[] = $row;
        }
        
        echo json_encode(['success' => true, 'data' => $types], JSON_UNESCAPED_UNICODE | JSON_INVALID_UTF8_SUBSTITUTE);
        exit;
    }

    // Get count of units using this sub type
    if ($action == 'get_count') {
        $aqarsubtype = intval($_POST['aqarsubtype']);
        $sql = "SELECT COUNT(*) as count FROM amlakdetails WHERE aqarsubtype='" . $aqarsubtype . "'";
        $result = mysql_query($sql, $link);
        $row = mysql_fetch_array($result);
        
        echo json_encode(['success' => true, 'count' => $row['count']], JSON_UNESCAPED_UNICODE | JSON_INVALID_UTF8_SUBSTITUTE);
        exit;
    }
}

// Only render HTML if not AJAX
if (!$is_ajax_request) {
?>

