                            </tbody>
                        </table>
                    </div>
                </div>

                <div id="emptyState" class="empty-state" style="display: none;">
                    <i class="fas fa-door-open"></i>
                    <h5>لا توجد أنواع وحدات</h5>
                    <p>ابدأ بإضافة نوع وحدة جديد</p>
                    <button class="btn btn-success" onclick="showAddModal()">
                        <i class="bi bi-plus-lg me-2"></i>
                        إضافة نوع جديد
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add/Edit Modal -->
<div class="modal fade" id="typeModal" tabindex="-1" dir="rtl">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">
                    <i class="bi bi-plus-circle me-2"></i>
                    إضافة نوع وحدة جديد
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="typeForm">
                    <input type="hidden" id="aqarsubtype" name="aqarsubtype">
                    <input type="hidden" id="formAction" value="add">
                    
                    <div class="mb-3">
                        <label for="aqarsubtypename" class="form-label">
                            <i class="bi bi-tag-fill text-success me-1"></i>
                            اسم نوع الوحدة <span class="text-danger">*</span>
                        </label>
                        <input type="text" class="form-control" id="aqarsubtypename" name="aqarsubtypename" required placeholder="مثال: شقة عزاب، محل تجاري، مكتب">
                        <small class="text-muted">أدخل اسم واضح ومحدد لنوع الوحدة</small>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle me-1"></i>
                    إلغاء
                </button>
                <button type="button" class="btn btn-success" onclick="saveType()">
                    <i class="bi bi-check-circle me-1"></i>
                    حفظ
                </button>
            </div>
        </div>
    </div>
</div>

<script>
let typesData = [];
let modal = null;

$(document).ready(function() {
    modal = new bootstrap.Modal(document.getElementById('typeModal'));
    loadTypes();
});

function loadTypes() {
    $('#loadingSpinner').show();
    $('#typesTableContainer').hide();
    $('#emptyState').hide();

    $.ajax({
        url: 'property_sub_types.hnt',
        type: 'POST',
        data: {
            ajax_submit: '1',
            action: 'list'
        },
        dataType: 'json',
        success: function(response) {
            $('#loadingSpinner').hide();
            
            if (response.success) {
                typesData = response.data;
                
                if (typesData.length === 0) {
                    $('#emptyState').show();
                } else {
                    renderTable();
                    $('#typesTableContainer').show();
                }
            } else {
                showAlert('حدث خطأ أثناء تحميل البيانات', 'danger');
            }
        },
        error: function() {
            $('#loadingSpinner').hide();
            showAlert('حدث خطأ في الاتصال', 'danger');
        }
    });
}

function renderTable() {
    let html = '';
    
    typesData.forEach((type, index) => {
        let countBadge = '<span class="badge-count" id="count_' + type.aqarsubtype + '">...</span>';
        
        html += `
            <tr>
                <td><strong>${index + 1}</strong></td>
                <td><strong>${type.aqarsubtypename}</strong></td>
                <td>${countBadge}</td>
                <td>
                    <button class="btn btn-sm btn-primary btn-action me-1" onclick="editType(${type.aqarsubtype})" title="تعديل">
                        <i class="bi bi-pencil"></i>
                    </button>
                    <button class="btn btn-sm btn-danger btn-action" onclick="deleteType(${type.aqarsubtype}, '${type.aqarsubtypename.replace(/'/g, "\\'")}')"
 title="حذف">
                        <i class="bi bi-trash"></i>
                    </button>
                </td>
            </tr>
        `;
    });
    
    $('#typesTableBody').html(html);
    
    // Load counts for each type
    typesData.forEach(type => {
        loadTypeCount(type.aqarsubtype);
    });
}

function loadTypeCount(aqarsubtype) {
    $.ajax({
        url: 'property_sub_types.hnt',
        type: 'POST',
        data: {
            ajax_submit: '1',
            action: 'get_count',
            aqarsubtype: aqarsubtype
        },
        dataType: 'json',
        success: function(response) {
            if (response && response.success) {
                $('#count_' + aqarsubtype).text(response.count);
            }
        }
    });
}

function showAddModal() {
    $('#modalTitle').html('<i class="bi bi-plus-circle me-2"></i>إضافة نوع وحدة جديد');
    $('#formAction').val('add');
    $('#typeForm')[0].reset();
    $('#aqarsubtype').val('');
    modal.show();
}

function editType(aqarsubtype) {
    $.ajax({
        url: 'property_sub_types.hnt',
        type: 'POST',
        data: {
            ajax_submit: '1',
            action: 'get',
            aqarsubtype: aqarsubtype
        },
        dataType: 'json',
        success: function(response) {
            if (response.success) {
                $('#modalTitle').html('<i class="bi bi-pencil me-2"></i>تعديل نوع الوحدة');
                $('#formAction').val('update');
                $('#aqarsubtype').val(response.data.aqarsubtype);
                $('#aqarsubtypename').val(response.data.aqarsubtypename);
                modal.show();
            } else {
                showAlert(response.error, 'danger');
            }
        },
        error: function() {
            showAlert('حدث خطأ في الاتصال', 'danger');
        }
    });
}

function saveType() {
    const form = $('#typeForm')[0];
    if (!form.checkValidity()) {
        form.reportValidity();
        return;
    }

    const action = $('#formAction').val();
    const data = {
        ajax_submit: '1',
        action: action,
        aqarsubtypename: $('#aqarsubtypename').val().trim()
    };

    if (action === 'update') {
        data.aqarsubtype = $('#aqarsubtype').val();
    }

    $.ajax({
        url: 'property_sub_types.hnt',
        type: 'POST',
        data: data,
        dataType: 'json',
        success: function(response) {
            if (response.success) {
                modal.hide();
                showAlert(response.message, 'success');
                loadTypes();
            } else {
                showAlert(response.error, 'danger');
            }
        },
        error: function() {
            showAlert('حدث خطأ في الاتصال', 'danger');
        }
    });
}

function deleteType(aqarsubtype, typename) {
    confirm(
        'هل أنت متأكد من حذف نوع الوحدة "' + typename + '"؟',
        'تأكيد الحذف',
        function() {
            $.ajax({
                url: 'property_sub_types.hnt',
                type: 'POST',
                data: {
                    ajax_submit: '1',
                    action: 'delete',
                    aqarsubtype: aqarsubtype
                },
                dataType: 'json',
                success: function(response) {
                    if (response.success) {
                        showAlert(response.message, 'success');
                        loadTypes();
                    } else {
                        showAlert(response.error, 'danger');
                    }
                },
                error: function() {
                    showAlert('حدث خطأ في الاتصال', 'danger');
                }
            });
        }
    );
}

function showAlert(message, type) {
    const alertHtml = `
        <div class="alert alert-${type} alert-dismissible fade show" role="alert" style="position: fixed; top: 20px; left: 50%; transform: translateX(-50%); z-index: 9999; min-width: 300px;">
            ${message}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    `;
    
    $('body').append(alertHtml);
    
    setTimeout(function() {
        $('.alert').fadeOut(300, function() {
            $(this).remove();
        });
    }, 3000);
}
</script>

<?php
    require('../../../foter.hnt');
}
?>
