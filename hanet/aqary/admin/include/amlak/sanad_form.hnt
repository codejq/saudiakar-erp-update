                    $rentValue = $rowk['kastvalue'] - $rowk['water'] - $rowk['sa3ee'] - $rowk['services'];

                    // Get next receipt number
                    $sql = "SELECT MAX(idsanad) AS dd FROM sanad";
                    $rows = mysql_fetch_array(mysql_query($sql, $link));
                    $sanadrakam = $rows['dd'] + 1;

                    // Calculate period
                    if ($hnt_dll || $hnt_supper_dll == 5) {
                        $startingkast = mktime(0, 0, 0, (date("m", $rowk['kastdate']) + $rowegar['duration']), date("d", $rowk['kastdate']), date("Y", $rowk['kastdate']));
                        $period = date("d/m/Y", $rowk['kastdate']) . " - " . date("d/m/Y", $startingkast);
                        $today = date("d/m/Y", time());
                    } else {
                        $dateo = $dcal->g2u(date("d", $rowk['kastdate']), date("m", $rowk['kastdate']), date("Y", $rowk['kastdate']));
                        $dateo = $dcal->u2g($dateo['day'], ($dateo['month'] + ($rowegar['duration'])), $dateo['year']);
                        $dateo = $dcal->g2u($dateo['day'], $dateo['month'], $dateo['year']);
                        $period_end = "{$dateo['day']}/{$dateo['month']}/{$dateo['year']}";

                        $dateo = $dcal->g2u(date("d", $rowk['kastdate']), date("m", $rowk['kastdate']), date("Y", $rowk['kastdate']));
                        $period = "{$dateo['day']}/{$dateo['month']}/{$dateo['year']} - $period_end";

                        $today = $dcal->g2u(date("d", time()), date("m", time()), date("Y", time()));
                        $today = "{$today['day']}/{$today['month']}/{$today['year']}";
                    }

                    // Calculate required amount
                    $required_amound = $rentValue - $rowk['dof3at'] + $rowk["water"] + $rowk["sa3ee"] + $rowk["services"];
                    if ($rowegar["vat_type"] == 1) {
                        $required_amound += ($rowk['sa3ee'] * 0.15);
                    }
                    if ($rowegar["vat_type"] == 2) {
                        $required_amound += ($rowk['sa3ee'] * 0.15) + ($rentValue * 0.15);
                    }
