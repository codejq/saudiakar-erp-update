<script>
$(document).ready(function() {
    // Initialize tooltips
    const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
    tooltipTriggerList.map(function(tooltipTriggerEl) {
        return new bootstrap.Tooltip(tooltipTriggerEl);
    });

    // Calculate VAT and required amount
    function calcVat() {
        const total_vat = floatval($('#amount1').text());
        $('#total_vat').val(total_vat);

        const requiredAmount = floatval($('#amount0').text()) +
                              floatval($('#amount1').text()) +
                              floatval($('#amount2').text()) +
                              floatval($('#amount3').text()) +
                              floatval($('#amount4').text()) +
                              floatval($('#amount5').text());
        $('#requiredamound').text(requiredAmount.toFixed(2));
    }

    calcVat();

    // Update VAT when amount changes
    $('#depositeamount').on('keyup change', function() {
        calcVat();
    });

    // Property selection change
    $('#idaqar').on('change', function() {
        const idaqar = $(this).val();
        if (idaqar) {
            const sql = "SELECT amlakdetails.idsubaqar, CONCAT(aqarsubtype.aqarsubtypename, ' - ', amlakdetails.rakam) AS unitname FROM amlakdetails, aqarsubtype WHERE amlakdetails.aqarsubtype = aqarsubtype.aqarsubtype AND amlakdetails.rakam3akdid > 0 AND amlakdetails.idaqar = '" + idaqar + "'";
            ajaxfillcombox(document.getElementById('idsubaqar'), sql);
        }
    });

    // Unit selection change
    $('#idsubaqar').on('change', function() {
        const idsubaqar = $(this).val();
        if (idsubaqar) {
            window.location.href = 'sanad.hnt?idsubaqar=' + idsubaqar;
        }
    });

    // Load bank accounts for the current property
    function loadBankAccounts() {
        const idsubaqar = $('#idsubaqar').val();
        if (!idsubaqar) return;

        $.ajax({
            url: 'sanad.hnt',
            type: 'POST',
            data: {
                ajax_submit: '1',
                action: 'get_bank_accounts',
                idsubaqar: idsubaqar
            },
            dataType: 'json',
            success: function(response) {
                if (response.success && response.accounts) {
                    const select = $('#bank_account_select');
                    select.empty();
                    select.append('<option value="">-- اختر حساب بنكي --</option>');
                    
                    response.accounts.forEach(function(acc) {
                        const label = acc.bankname + ' - ' + acc.acountholder + ' (' + acc.acountnumber + ')';
                        select.append($('<option></option>')
                            .attr('value', acc.id)
                            .attr('data-bankname', acc.bankname)
                            .attr('data-holder', acc.acountholder)
                            .attr('data-number', acc.acountnumber)
                            .attr('data-iban', acc.iban || '')
                            .text(label));
                    });
                }
            }
        });
    }

    // Load bank accounts on page load
    loadBankAccounts();

    // Bank account selection handler
    $('#bank_account_select').on('change', function() {
        const selected = $(this).find('option:selected');
        if (selected.val()) {
            const bankname = selected.data('bankname') || '';
            const holder = selected.data('holder') || '';
            const acountnumber = selected.data('number') || '';
            const iban = selected.data('iban') || '';
            const fillText = bankname + ' - ' + holder;
            
            $('#cheqon').val(fillText);
            $('#bankid').val(selected.val());
            
            // Auto-fill notes with detailed bank account information
            let notesText = 'تحويل الى حساب ' + holder;
            notesText += ' - بنك ' + bankname;
            notesText += '-  حساب ' + acountnumber;
            if (iban) {
                notesText += ' - آيبان ' + iban;
            }
            $('#notes').val(notesText);
        } else {
            $('#cheqon').val('');
            $('#bankid').val('0');
            $('#notes').val('');
        }
    });

    // Payment method selection
    $('.payment-method-card').on('click', function() {
        $('.payment-method-card').removeClass('active');
        $(this).addClass('active');
        $(this).find('input[type="radio"]').prop('checked', true);

        const method = $(this).data('method');
        
        // Clear cheqon, bankid, and notes when changing payment method
        $('#cheqon').val('');
        $('#bankid').val('0');
        $('#bank_account_select').val('');
        $('#notes').val('');
        
        if (method === 1) {
            $('#paymentDetails').hide();
            $('#bankAccountSelector').hide();
            $('#cheqnumber').val('');
        } else {
            $('#paymentDetails').show();
            
            if (method === 4) {
                // Transfer - show bank account selector
                $('#bankAccountSelector').show();
                $('#cheqnumber').attr('placeholder', 'رقم الحوالة');
                $('#cheqon').attr('placeholder', 'البنك');
            } else {
                $('#bankAccountSelector').hide();
                
                if (method === 2) {
                    $('#cheqnumber').attr('placeholder', 'اكتب رقم الشيك');
                    $('#cheqon').attr('placeholder', 'مسحوب على');
                } else if (method === 5) {
                    $('#cheqnumber').attr('placeholder', 'رقم العملية');
                    $('#cheqon').attr('placeholder', 'البنك');
                } else {
                    $('#cheqnumber').attr('placeholder', '');
                    $('#cheqon').attr('placeholder', '');
                }
            }
        }
    });

    // Form submission
    $('#sanadForm').on('submit', function(e) {
        e.preventDefault();

        // Validate amount
        const depositeamount = floatval($('#depositeamount').val());
        const requiredamound = floatval($('#requiredamound').text());

        if (depositeamount > requiredamound) {
            if (typeof showBootstrapNotification === 'function') {
                showBootstrapNotification('warning', 'المبلغ المدخل أكبر من قيمة القسط - لا يمكن دفع أكثر من قيمة القسط');
            } else {
                alert('المبلغ المدخل أكبر من قيمة القسط - لا يمكن دفع أكثر من قيمة القسط');
            }
            return false;
        }

        const formData = new FormData(this);
        formData.append('ajax_submit', '1');

        $('#submitBtn').prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2"></span>جاري المعالجة...');

        $.ajax({
            url: 'sanad.hnt',
            type: 'POST',
            data: formData,
            processData: false,
            contentType: false,
            dataType: 'json',
            success: function(response) {
                if (response.success) {
                    if (response.html) {
                        $('.card-body').html(response.html);
                    } else {
                        if (typeof showBootstrapNotification === 'function') {
                            showBootstrapNotification('success', response.message);
                        } else {
                            alert(response.message);
                        }
                        setTimeout(function() {
                            window.location.href = 'selectprintform.hnt?formtype=recivevoucher&id=' + response.idsanad;
                        }, 1500);
                    }
                } else {
                    if (typeof showBootstrapNotification === 'function') {
                        showBootstrapNotification('danger', response.message);
                    } else {
                        alert(response.message);
                    }
                    $('#submitBtn').prop('disabled', false).html('<i class="bi bi-check-circle me-2"></i>نعم قم بعمل السند');
                }
            },
            error: function() {
                if (typeof showBootstrapNotification === 'function') {
                    showBootstrapNotification('danger', 'حدث خطأ أثناء حفظ السند');
                } else {
                    alert('حدث خطأ أثناء حفظ السند');
                }
                $('#submitBtn').prop('disabled', false).html('<i class="bi bi-check-circle me-2"></i>نعم قم بعمل السند');
            }
        });
    });
});
</script>

<?php include("../uploadmodule.hnt"); ?>
<?php require("../../../foter.hnt"); ?>
