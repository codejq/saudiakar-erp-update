            <i class="bi bi-plus-circle me-2"></i>جدول جديد
        </a>
    </div>

    <!-- Sheets Grid -->
    <?php if (empty($sheets)): ?>
    <div class="empty-state">
        <i class="bi bi-file-earmark-spreadsheet" style="font-size:5rem;"></i>
        <h4 class="mt-3">لا توجد جداول بعد</h4>
        <p>أنشئ جدولك الأول الآن واحفظ بياناتك وصيغك الحسابية</p>
        <a href="edit.hnt" class="btn btn-success btn-lg">
            <i class="bi bi-plus-circle me-2"></i>إنشاء جدول جديد
        </a>
    </div>
    <?php else: ?>
    <div class="row g-3">
        <?php foreach ($sheets as $sheet): ?>
        <div class="col-sm-6 col-lg-4 col-xl-3" id="card-<?= $sheet['id'] ?>">
            <div class="sheet-card d-flex flex-column">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="sheet-icon">
                        <i class="bi bi-table"></i>
                    </div>
                    <div class="flex-grow-1 overflow-hidden">
                        <h6 class="mb-0 text-truncate fw-semibold"
                            title="<?= htmlspecialchars($sheet['title'], ENT_QUOTES, 'UTF-8') ?>">
                            <?= htmlspecialchars($sheet['title'], ENT_QUOTES, 'UTF-8') ?>
                        </h6>
                        <small class="text-muted">
                            <i class="bi bi-clock me-1"></i>
                            <?= date('Y/m/d H:i', strtotime($sheet['updated_at'])) ?>
                        </small>
                    </div>
                </div>
                <div class="d-flex gap-2 mt-auto">
                    <a href="edit.hnt?id=<?= $sheet['id'] ?>" class="btn btn-success btn-sm flex-grow-1">
                        <i class="bi bi-pencil me-1"></i>فتح وتعديل
                    </a>
                    <button class="btn btn-outline-danger btn-sm"
                        onclick="confirmDelete(<?= $sheet['id'] ?>, '<?= addslashes(htmlspecialchars($sheet['title'], ENT_QUOTES, 'UTF-8')) ?>')"
                        title="حذف">
                        <i class="bi bi-trash"></i>
                    </button>
                </div>
            </div>
        </div>
        <?php endforeach; ?>
    </div>
    <?php endif; ?>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:15px;border:none;">
            <div class="modal-header"
                 style="background:linear-gradient(135deg,#dc3545,#c82333);border-radius:15px 15px 0 0;border:none;">
                <h5 class="modal-title text-white">
                    <i class="bi bi-exclamation-triangle me-2"></i>تأكيد الحذف
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <p class="mb-1">هل أنت متأكد من حذف الجدول:</p>
                <p class="fw-bold mb-0" id="deleteSheetTitle"></p>
                <p class="text-danger mb-0 mt-2"><small>لا يمكن التراجع عن هذا الإجراء.</small></p>
            </div>
            <div class="modal-footer border-0 pb-3">
                <button class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle me-1"></i>إلغاء
                </button>
                <button class="btn btn-danger" id="confirmDeleteBtn">
                    <i class="bi bi-trash me-1"></i>حذف
                </button>
            </div>
        </div>
    </div>
</div>

<script>
var deleteId   = null;
var deleteModal = null;

function confirmDelete(id, title) {
    deleteId = id;
    document.getElementById('deleteSheetTitle').textContent = title;
    deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'));
    deleteModal.show();
}

document.getElementById('confirmDeleteBtn').addEventListener('click', function () {
    if (!deleteId) return;
    var btn = this;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>جاري الحذف...';

    var fd = new FormData();
    fd.append('action', 'delete');
    fd.append('id', deleteId);

    fetch('ajax.hnt', { method: 'POST', body: fd })
        .then(function (r) { return r.json(); })
        .then(function (data) {
            if (data.success) {
                var card = document.getElementById('card-' + deleteId);
                if (card) card.remove();
                deleteModal.hide();
                deleteId = null;
                // reload if no cards left so empty state appears
                if (!document.querySelector('[id^="card-"]')) {
                    location.reload();
                }
            } else {
                alert('خطأ: ' + data.error);
            }
        })
        .catch(function () { alert('تعذر الاتصال بالخادم'); })
        .finally(function () {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-trash me-1"></i>حذف';
        });
});
</script>

<?php require("../../foter.hnt"); ?>
