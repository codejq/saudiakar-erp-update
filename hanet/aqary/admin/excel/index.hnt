}
</style>

<div class="container-fluid p-4">

    <!-- Header -->
    <div class="excel-header d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <h1 class="mb-1 fw-bold">
                <i class="bi bi-file-earmark-spreadsheet me-2"></i>الجداول الإلكترونية
            </h1>
            <p class="mb-0 opacity-75">
                إنشاء وإدارة جداول البيانات مع دعم الصيغ الحسابية
                <span class="badge bg-light text-dark ms-2"><?= count($sheets) ?> جدول</span>
            </p>
