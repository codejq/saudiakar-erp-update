<script>
    function printQR() {
        window.print();
    }

    function copyToClipboard() {
        const url = window.location.href;
        navigator.clipboard.writeText(url).then(() => {
            alert('تم نسخ الرابط بنجاح');
        });
    }

    function copyShareLink() {
        const input = document.getElementById('shareLink');
        input.select();
        document.execCommand('copy');
        alert('تم نسخ الرابط بنجاح');
    }

    // Print styles
    const style = document.createElement('style');
    style.textContent = `
        @media print {
            /* Hide navigation, buttons, and non-essential elements */
            nav, .btn-group, .breadcrumb, .modal, footer, header,
            .card-header, button, a[class*="btn"] {
                display: none !important;
            }
            
            /* Show main content */
            body, .container-fluid, .row, .col-lg-8, .card, .card-body {
                visibility: visible !important;
                display: block !important;
            }
            
            /* Center the QR code */
            .col-lg-8 {
                width: 100% !important;
                max-width: 100% !important;
            }
            
            /* Make QR code larger for print */
            .col-lg-8 > .card:first-child img {
                max-width: 600px !important;
            }
            
            /* Hide sidebar on print */
            .col-lg-4 {
                display: none !important;
            }
            
            /* Page breaks */
            .card {
                page-break-inside: avoid;
                margin-bottom: 20px;
            }
            
            /* Remove shadows and backgrounds for cleaner print */
            .card {
                box-shadow: none !important;
                border: 1px solid #ddd !important;
            }
        }
    `;
    document.head.appendChild(style);
</script>

