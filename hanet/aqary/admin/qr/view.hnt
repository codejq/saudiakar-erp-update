$pageTitle = 'عرض رمز QR';
$sc_title = 'عرض التفاصيل';
$sc_id = "84";
include_once "../../nocash.hnt";

$canscroll = 0;
$showdhmltazkeer = 0;
include_once "../../header.hnt";

require_once('./qr_init.hnt');

// Get QR ID
if (!isset($_GET['id'])) {
    header('Location: index.hnt');
    exit;
}

$qrId = intval($_GET['id']);
$qr = $qrGenerator->getQR($qrId);

if (!$qr) {
    header('Location: index.hnt');
    exit;
}

// Increment scan count if from external source
if (isset($_GET['scan']) && $_GET['scan'] == '1') {
    $qrGenerator->incrementScan($qrId);
}

// Get attachments
$attachments = $qrGenerator->getAttachments($qrId);
?>

