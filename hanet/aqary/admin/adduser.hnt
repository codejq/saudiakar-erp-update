<script>
console.log('=== SCRIPT TAG STARTED ===');

// Load users table via AJAX
function loadUsers() {
	console.log('loadUsers() called');
	document.getElementById('containerid').innerHTML = '<div class="text-center py-4"><div class="spinner-border text-primary" role="status"><span class="visually-hidden">جاري التحميل...</span></div></div>';

	$.ajax({
		url: 'user_list.hnt',
		type: 'GET',
		dataType: 'json',
		success: function(response) {
			console.log('Response received:', response);
			if(response.success && response.users.length > 0) {
				var tableHtml = '<table class="table table-hover table-striped align-middle">';
				tableHtml += '<thead class="table-dark">';
				tableHtml += '<tr>';
				tableHtml += '<th width="60">#</th>';
				tableHtml += '<th>الاسم</th>';
				tableHtml += '<th>اسم الدخول</th>';
				tableHtml += '<th>المجموعة</th>';
				tableHtml += '<th width="200" class="text-center">الإجراءات</th>';
				tableHtml += '</tr>';
				tableHtml += '</thead>';
				tableHtml += '<tbody>';

				response.users.forEach(function(user, index) {
					tableHtml += '<tr>';
					tableHtml += '<td>' + user.userid + '</td>';
					tableHtml += '<td><strong>' + user.name + '</strong></td>';
					tableHtml += '<td>' + user.username + '</td>';
					tableHtml += '<td><span class="badge bg-info">' + user.groupname + '</span></td>';
					tableHtml += '<td class="text-center">';
					tableHtml += '<div class="btn-group btn-group-sm gap-1" role="group">';
					tableHtml += '<button class="btn btn-primary <?='policy_'.$sc_id.'_edits'?>" onclick="editUser(' + user.userid + ')" title="تعديل">';
					tableHtml += '<i class="bi bi-pencil"></i> تعديل';
					tableHtml += '</button>';
					if(user.username !== 'admin') {
						tableHtml += '<button class="btn btn-danger ms-1 <?="policy_".$sc_id."_deleetes"?>" onclick="confirm(\'هل ترغب في حذف المستخدم &quot;' + user.name.replace(/'/g, "\\'") + '&quot;؟\', \'حذف مستخدم\', () => deleteUser(' + user.userid + '))" title="حذف">';
						tableHtml += '<i class="bi bi-trash"></i> حذف';
						tableHtml += '</button>';
					}
					tableHtml += '</div>';
					tableHtml += '</td>';
					tableHtml += '</tr>';
				});

				tableHtml += '</tbody>';
				tableHtml += '</table>';

				document.getElementById('containerid').innerHTML = tableHtml;
			} else {
				document.getElementById('containerid').innerHTML = '<div class="alert alert-warning text-center"><i class="bi bi-exclamation-triangle"></i> لا توجد مستخدمين</div>';
			}
		},
		error: function(xhr, status, error) {
			console.error('AJAX Error:', status, error);
			console.error('Response:', xhr.responseText);
			document.getElementById('containerid').innerHTML = '<div class="alert alert-danger text-center"><i class="bi bi-x-circle"></i> حدث خطأ في تحميل البيانات<br><small>' + error + '</small></div>';
		}
	});
}

// Edit user function
function editUser(userid) {
	$.ajax({
		url: 'user_list.hnt',
		type: 'GET',
		data: { userid: userid },
		dataType: 'json',
		success: function(response) {
			if(response.success && response.user) {
				var user = response.user;
				$('#updateuserid').val(user.userid);
				$('#name').val(user.name);
				$('#username').val(user.username);
				$('#password').val(user.password);
				$('#groupid').val(user.groupid).trigger('change');
				$('#btnText').text('تحديث المستخدم');
				$('#submitBtn').removeClass('btn-success').addClass('btn-warning');

				if(user.username === 'admin') {
					$('#username').prop('readonly', true);
				} else {
					$('#username').prop('readonly', false);
				}

				$('html, body').animate({
					scrollTop: $('#userForm').offset().top - 100
				}, 500);
			}
		}
	});
}

// Delete user function
function deleteUser(userid, name) {
	$.ajax({
		url: 'adduser.hnt',
		type: 'POST',
		data: { action: 'delete', userid: userid },
		dataType: 'json',
		success: function(response) {
			if(response.success) {
				$('#maintitlebox').html(
					'<div class="alert alert-success alert-dismissible fade show">' +
					'<strong>نجح!</strong> ' + response.message +
					'<button type="button" class="btn-close" data-bs-dismiss="alert"></button>' +
					'</div>'
				);
				loadUsers();
				setTimeout(function() {
					$('#maintitlebox .alert').fadeOut();
				}, 3000);
			} else {
				alert('خطأ: ' + response.message);
			}
		},
		error: function() {
			alert('حدث خطأ في الاتصال بالخادم');
		}
	});
}

// Reset form function
function resetForm() {
	$('#userForm')[0].reset();
	$('#updateuserid').val('');
	$('#username').prop('readonly', false);
	$('#btnText').text('إضافة المستخدم');
	$('#submitBtn').removeClass('btn-warning').addClass('btn-success');
	$('#name').focus();
}

// Initialize
console.log('Script loaded, jQuery available:', typeof $ !== 'undefined');

// Fallback if jQuery is not loaded
if (typeof $ === 'undefined') {
	console.error('jQuery is NOT loaded! Cannot initialize page.');
	document.getElementById('containerid').innerHTML = '<div class="alert alert-danger text-center"><i class="bi bi-x-circle"></i> خطأ: jQuery غير محمل</div>';
} else {
	$(document).ready(function() {
		console.log('Document ready, calling loadUsers()');
		$('#userForm').on('submit', function(e) {
		e.preventDefault();

		var formData = $(this).serialize();
		var submitBtn = $('#submitBtn');
		var originalBtnText = $('#btnText').html();

		submitBtn.prop('disabled', true);
		$('#btnText').html('<span class="spinner-border spinner-border-sm" role="status"></span> جاري الحفظ...');

		$.ajax({
			url: 'adduser.hnt',
			type: 'POST',
			data: formData,
			dataType: 'json',
			success: function(response) {
				if(response.success) {
					$('#maintitlebox').html(
						'<div class="alert alert-success alert-dismissible fade show" role="alert">' +
						'<strong>نجح!</strong> ' + response.message +
						'<button type="button" class="btn-close" data-bs-dismiss="alert"></button>' +
						'</div>'
					);

					resetForm();
					loadUsers();

					setTimeout(function() {
						$('#maintitlebox .alert').fadeOut();
					}, 5000);

				} else {
					$('#maintitlebox').html(
						'<div class="alert alert-danger alert-dismissible fade show" role="alert">' +
						'<strong>خطأ!</strong> ' + response.message +
						'<button type="button" class="btn-close" data-bs-dismiss="alert"></button>' +
						'</div>'
					);
				}
			},
			error: function(xhr, status, error) {
				$('#maintitlebox').html(
					'<div class="alert alert-danger alert-dismissible fade show" role="alert">' +
					'<strong>خطأ!</strong> حدث خطأ في الاتصال بالخادم' +
					'<button type="button" class="btn-close" data-bs-dismiss="alert"></button>' +
					'</div>'
				);
				console.error('AJAX Error:', status, error);
			},
			complete: function() {
				submitBtn.prop('disabled', false).html(originalBtnText);
			}
		});
	});

	// Load users on page load
	loadUsers();
	});
}
</script>

