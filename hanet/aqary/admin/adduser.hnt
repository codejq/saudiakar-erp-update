<?php
$sc_title="اضافة مستخدم";
$sc_id="92";
include_once"../nocash.hnt";

// Handle delete action BEFORE any HTML output
if (isset($_POST['action']) && $_POST['action'] == 'delete') {
	include_once"../connectdb.hnt";
	$userid = isset($_POST['userid']) ? intval($_POST['userid']) : 0;

	if($userid <= 0) {
		header('Content-Type: application/json; charset=utf-8');
		echo json_encode(['success' => false, 'message' => 'معرف المستخدم غير صحيح']);
		exit();
	}

	$check_sql = "SELECT username FROM user WHERE userid={$userid}";
	$check_result = mysql_query($check_sql, $link);
	$user_data = mysql_fetch_array($check_result);

	if($user_data['username'] == 'admin') {
		header('Content-Type: application/json; charset=utf-8');
		echo json_encode(['success' => false, 'message' => 'لا يمكن حذف مستخدم admin']);
		exit();
	}

	$delete_sql = "DELETE FROM user WHERE userid={$userid} AND username <> 'admin'";
	$result = mysql_query($delete_sql, $link);

	if($result) {
		header('Content-Type: application/json; charset=utf-8');
		echo json_encode(['success' => true, 'message' => 'تم حذف المستخدم بنجاح']);
	} else {
		header('Content-Type: application/json; charset=utf-8');
		echo json_encode(['success' => false, 'message' => 'فشل في حذف المستخدم: ' . mysql_error($link)]);
	}
	exit();
}

// Handle insert/update action
if (isset($_POST['action']) && $_POST['action'] == 'insert' && isset($_POST['username']) && isset($_POST['groupid'])) {
	include_once"../connectdb.hnt";

	$username = mysql_real_escape_string(trim($_POST['username']));
	$password = mysql_real_escape_string(trim($_POST['password']));
	$name = mysql_real_escape_string(trim($_POST['name']));
	$groupid = intval($_POST['groupid']);
	$updateuserid = isset($_POST['updateuserid']) ? intval($_POST['updateuserid']) : 0;

	if(empty($username)) {
		header('Content-Type: application/json; charset=utf-8');
		echo json_encode(['success' => false, 'message' => 'برجاء كتابة اسم الدخول']);
		exit();
	}

	if($groupid <= 0) {
		header('Content-Type: application/json; charset=utf-8');
		echo json_encode(['success' => false, 'message' => 'برجاء اختيار المجموعة']);
		exit();
	}

	if($updateuserid > 0) {
		$sql = "UPDATE user SET password='{$password}', name='{$name}', groupid={$groupid} WHERE userid={$updateuserid}";
		$message = "تم تحديث المستخدم '{$name}' بنجاح";
	} else {
		$check_sql = "SELECT COUNT(*) as count FROM user WHERE username='{$username}'";
		$check_result = mysql_query($check_sql, $link);
		$row = mysql_fetch_array($check_result);

		if ($row['count'] > 0) {
			header('Content-Type: application/json; charset=utf-8');
			echo json_encode(['success' => false, 'message' => "اسم المستخدم '{$username}' موجود بالفعل"]);
			exit();
		}

		$sql = "INSERT INTO user SET username='{$username}', password='{$password}', name='{$name}', groupid={$groupid}";
		$message = "تم إضافة المستخدم '{$name}' بنجاح";
	}

	$result = mysql_query($sql, $link);

	if(!$result) {
		header('Content-Type: application/json; charset=utf-8');
		echo json_encode(['success' => false, 'message' => 'فشل في حفظ المستخدم: ' . mysql_error($link)]);
		exit();
	}

	header('Content-Type: application/json; charset=utf-8');
	echo json_encode(['success' => true, 'message' => $message, 'userid' => $updateuserid > 0 ? $updateuserid : mysql_insert_id()]);
	exit();
}

// Now include header for normal page display
include_once"../header.hnt";

